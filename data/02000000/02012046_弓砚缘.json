{
  "script_id": "02012046",
  "title": "弓砚缘",
  "alias": [
    "及第花"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "何玉凤",
      "hangdang": "旦"
    },
    {
      "name": "安骥",
      "hangdang": "小生"
    },
    {
      "name": "纪多文",
      "hangdang": "武生"
    },
    {
      "name": "安学海",
      "hangdang": "老生"
    },
    {
      "name": "邓九公",
      "hangdang": "净"
    },
    {
      "name": "佟夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "安骥应试得中探花，举家欢幸。旋又被派为山东学政，正拟上任，忽闻纪多文勾结关外番王，为其父报仇，\n业已攻近关口。何玉凤得知，遂请安骥代为呈请皇帝、派令带兵迎剿，以报父仇。皇帝允准后，何玉凤乃求\n邓九公一同前往。又海马周三等改邪归正，投效官军，迭奏功勋，累升至川陝五路总兵官，奉命迎战纪多文，\n均未成功。何玉凤到后，遂将纪多文生擒。何玉凤之杀父冤仇，终得报复云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四下手、中军、纪多文同上。〖点绛唇〗。"
        },
        {
          "character": "纪多文",
          "type": "念",
          "text": "我父功臣不到头，今与天子结冤仇。招兵聚将来关口，要夺天朝九龙楼。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "俺，纪多文。我父纪献唐，命丧京都，飞虎亲军，俱已死故亡逃。是俺单身逃 至这沙漠地面，招聚我父部下将士，已经数载，如今又有数十万人马。意欲勾 动边外众家王子，一同兴兵，侵犯天朝。也曾修书前去，未见到来。"
        },
        {
          "character": "四王子",
          "type": "内同白",
          "text": "众家王子到。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众家王子到。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四王子同上，纪多文、四王子同坐。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "不知众家王子驾到，少迎恕罪。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "岂敢。我等来得卤莽，公子恕罪。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "公子修书，邀动我等，所为何事？"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "只因我父呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "公子敢有报仇之意？"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "一来要报父仇，二来闻听天朝，要夺众位王子封地，为此相邀商议。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "我等不信。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "我有一好友，在朝为官。与我密书一封，众位王子请看。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "可恼吓，可恼！"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "恼恨也是枉然。我们一同兴兵，夺取天朝，平分疆土，岂不是好？"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "既然如此，我等各归封地，起兵前来，会合一处，再议进兵之策。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "如此甚好。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "告辞了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四王子同下。"
        },
        {
          "character": "纪多文",
          "type": "笑",
          "text": "哈哈哈哈！"
        },
        {
          "character": "纪多文",
          "type": "念",
          "text": "一封假书信，邀动四路兵。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "众将！ 中国京剧戏考 《弓砚缘》【十本】 2"
        },
        {
          "character": "四大铠、四下手",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "每日操练士卒，听候调遣。掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安学海上。"
        },
        {
          "character": "安学海",
          "type": "念",
          "text": "居住山庄似画图，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佟夫人上。"
        },
        {
          "character": "佟夫人",
          "type": "念",
          "text": "我儿赶考进皇都。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "安人。"
        },
        {
          "character": "佟夫人",
          "type": "白",
          "text": "老爷。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "想我安学海，自遭风波，告职归里。如今又得玉凤、金凤两个儿媳，替你我料 理家务。丰衣足食，居守田园，也算得人生极乐也！"
        },
        {
          "character": "佟夫人",
          "type": "白",
          "text": "话虽如此，常言道："
        },
        {
          "character": "佟夫人",
          "type": "念",
          "text": "不必身富贵，只要子成名。"
        },
        {
          "character": "佟夫人",
          "type": "白",
          "text": "你我那安骥孩儿，自从秋榜得中，如今又赴试春闱。如果联捷登科，方为全美。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报录人上。"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "这里可是安大老爷的山庄？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "少老爷中了第六名进士，特来报喜。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "可有报条？"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "有报条。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报录人递。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "启老爷、夫人：少爷中了第六名进士。报喜人在外。这有报单呈上。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "呈上来。 第六名进士安骥。 谢天谢地！"
        },
        {
          "character": "佟夫人",
          "type": "白",
          "text": "当谢天地！"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "赏报喜人纹银十两。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "报喜人过来。老爷赏纹银十两。"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "谢老爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报录人下。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "请你二位少夫人。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请二位少夫人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤、张金凤同上。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同念",
          "text": "昨夜灯花结蕊红，今朝喜鹊噪当空。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "参见公婆！"
        },
        {
          "character": "安学海、佟夫人",
          "type": "同白",
          "text": "罢了。适才报喜人到来，你丈夫中了第六名进士。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "此乃公婆教训，请上待儿媳叩贺。"
        },
        {
          "character": "安学海、佟夫人",
          "type": "同白",
          "text": "且慢。候你丈夫殿试归来，一同再贺。且服侍我二老后堂晚膳。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佟夫人、何玉凤、张金凤同。"
        },
        {
          "character": "安学海",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《弓砚缘》【十本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报录人上。"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "俺，报喜人是也。今有安少老爷钦点一甲第三名探花及第。急急前去报喜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报录人走。"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "来此已是。 有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "我乃报喜人是也。少老爷钦点一甲第三名探花及第。特来报喜。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "报条有么？"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "见了你家老爷，当面叩呈。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "请老爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海上。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "少老爷钦点一甲第三名探花及第。报喜人门外求见。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "唤他进来。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "唤你进来。"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "报喜人叩头。报条呈上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海看。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "一甲第三名安骥。"
        },
        {
          "character": "安学海",
          "type": "笑",
          "text": "吓，哈哈哈！"
        },
        {
          "character": "安学海",
          "type": "唱",
          "text": "我的儿连登科正在年少， 到如今也不枉教子勤劳。 看纹银二十两作为赏号，"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "吓，谢过老爷。"
        },
        {
          "character": "报录人",
          "type": "白",
          "text": "谢老爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报录人下。"
        },
        {
          "character": "安学海",
          "type": "唱",
          "text": "从今后做封君快乐逍遥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佟夫人上。"
        },
        {
          "character": "佟夫人",
          "type": "唱",
          "text": "猛听得前堂上喧哗喜笑，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤、张金凤同上。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同唱",
          "text": "姐妹们奉婆母细问根苗。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "吓，安人，你我的儿子，点了一甲第三名探花及第，从今你要做太夫人了吓！"
        },
        {
          "character": "安学海",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "佟夫人",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "佟夫人",
          "type": "唱",
          "text": "听说是探花郎被儿占了， 不由人畅心怀喜上眉稍。"
        },
        {
          "character": "何玉凤",
          "type": "唱",
          "text": "这都是祖阴功父母训教，"
        },
        {
          "character": "张金凤",
          "type": "唱",
          "text": "姐妹们跪堂前叩贺年高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众鼓手、众吹打、众执事同上，安骥插花披红上。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "爹娘请上，受孩儿一拜！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥拜。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "我儿同到后面，拜谢天地祖先吓！"
        },
        {
          "character": "安学海",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四大铠、四下手、纪多文同上。"
        },
        {
          "character": "纪多文",
          "type": "念",
          "text": "杀父冤仇恨，常挂一片心。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "俺，纪多文。操兵练将，要与我父报仇。也曾邀请众家王子合兵一处，怎么还 不见前来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小番、四番将、四王子同上。"
        },
        {
          "character": "纪多文",
          "type": "stage",
          "text": "中国京剧戏考 《弓砚缘》【十本】 4"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "众位王子请了！"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "纪公子请了！"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "众位王子，大兵已到，就此杀往边关。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "且慢。此事须要立一主帅，方可进兵。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "但不知立何人为帅？"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "我等久受老将军之恩，愿推公子为主帅。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "纪某不敢。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "不必推辞，就请传令。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "如此斗胆了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同取碗。纪多文、四王子同歃血涂面，同唱二句。〖吹打〗。纪多文上坐。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "参见元帅！"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "众位王子少礼。此番夺取天朝，得了疆土，大家均分。就此杀往边关。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "得令！ 众将官！"
        },
        {
          "character": "四小番、四番将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "四王子",
          "type": "同白",
          "text": "杀往边关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手、将官同上。"
        },
        {
          "character": "将官",
          "type": "念",
          "text": "镇守西北边关，儿郎闻我胆寒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
