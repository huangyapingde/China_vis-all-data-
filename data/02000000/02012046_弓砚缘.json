        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、安骥同上。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "打道回府。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。安骥下轿。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "有请爹娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海、佟夫人同上。"
        },
        {
          "character": "安学海、佟夫人",
          "type": "同白",
          "text": "我儿回来了？ 中国京剧戏考 《弓砚缘》【十本】 5"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "儿回来了。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "今日上朝受职，圣上怎样传旨？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "哎呀，爹娘吓！圣上封孩儿平西参赞大臣，不日就要赴任。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海惊。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "吓！儿虽然探花及第，是新进士，怎么就放为平西参赞大臣？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "只因圣上偶得一梦，驾巡沙漠地面。贼寇前来劫驾，忽见一匹骏马，上带鞍鞯。 半空中又有一只玉色凤凰。马凤齐鸣，将贼寇唬退。故见了孩儿名字叫做安 骥，就有此旨。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "那沙漠地面，八月飞霜，千里无草，乃西北边外寒苦之地。儿此番不得不去， 叫我二老怎舍！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥、安学海、佟夫人同哭。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "话虽如此，又道吃王爵禄，当报君恩。儿正在青年，到彼历练数载，定然调回。 不必啼哭，听为父一言。"
        },
        {
          "character": "安学海",
          "type": "唱",
          "text": "圣天子待儿恩似海， 沙漠重地显英才。 此番去到边疆外， 除暴安良理应该。 地苦天寒儿忍耐， 小心疾病防祸灾。 报效三年并五载， 必然宣儿回朝来。"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "爹爹讲话儿悲慨， 远离膝下苦哀哉。 将双亲请至后堂界，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海、佟夫人同掩泪下。"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "洞房告知二裙钗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤、张金凤同上。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同唱",
          "text": "夫荣妻贵花放彩， 姐妹双双伴妆台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥上。"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "霎时叫人愁眉黛， 见了贤妻说开怀。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "夫君回来了？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "今日上朝受职，为何闷闷不乐？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "哎呀，妻呀！圣上封我平西参赞大臣，不日就要赴任。"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "吓，夫君。虽然探花及第，乃是新进士，怎么就放了平西参赞大臣？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "只因圣上偶得一梦，驾巡沙漠地面，贼寇前来劫驾。忽见一匹骏马，上带鞍鞯。 半空中又有一只玉色凤凰，马凤齐鸣，唬退贼寇。故见为丈夫名叫安骥，就 有此旨。"
        },
        {
          "character": "张金凤",
          "type": "哭",
          "text": "哎呀，哎呀！"
        },
        {
          "character": "张金凤",
          "type": "唱",
          "text": "听说儿夫到边外， 一家骨肉要丢开。 实指望为官多自在，"
        },
        {
          "character": "张金凤",
          "type": "哭头",
          "text": "夫吓！ 中国京剧戏考 《弓砚缘》【十本】 6"
        },
        {
          "character": "张金凤",
          "type": "唱",
          "text": "地苦天寒几时回来？"
        },
        {
          "character": "何玉凤",
          "type": "唱",
          "text": "贤妹休要愁眉黛， 万里封侯展大才。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "听二卿之言，一个恩义重，一个志量高。但愿圣上收回成命才好。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童上。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "启大人：送来密书一封，等候回信。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "呈上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥看。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "“愚兄乌明隅，报与安贤弟知晓：适才边关有告急本章到来，反了众家王子。 圣上恐贤弟年幼，难当重任。另差他人前去，将贤弟改放山东学政了”。"
        },
        {
          "character": "安骥",
          "type": "笑",
          "text": "吓，哈哈哈哈！"
        },
        {
          "character": "何玉凤、张金凤",
          "type": "同白",
          "text": "果然天从人愿，谢天谢地！"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "吩咐来人，书已收到。明日朝房面会。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童下。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "到后堂禀告爹娘知道。"
        },
        {
          "character": "安骥",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥、何玉凤、张金凤同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周德胜、李茂、吕芳、韩永、郝武同上。"
        },
        {
          "character": "周德胜、李茂、吕芳、韩永、郝武",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "周德胜。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "李茂。"
        },
        {
          "character": "韩永",
          "type": "白",
          "text": "韩永。"
        },
        {
          "character": "吕芳",
          "type": "白",
          "text": "吕芳。"
        },
        {
          "character": "郝武",
          "type": "白",
          "text": "郝武。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "我等投效官军，累累拿强获盗，圣上见喜，封为川陝五路总兵官。昨日圣旨到 来，因纪多文勾引边外众家王子，反过边关，调我弟兄前去征剿。众位贤弟！"
        },
        {
          "character": "李茂、吕芳、韩永、郝武",
          "type": "同白",
          "text": "三哥。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "今乃黄道吉日，那位贤弟请发兵。"
        },
        {
          "character": "李茂、吕芳、韩永、郝武",
          "type": "同白",
          "text": "三哥请发兵。"
        },
        {
          "character": "周德胜",
