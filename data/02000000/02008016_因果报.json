          "text": "暗藏毒意人不识，"
        },
        {
          "character": "李成",
          "type": "念",
          "text": "未知她心似我心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成、陈桂香同下。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "只要毒死孟庆云，何愁江山不归我侄儿也！"
