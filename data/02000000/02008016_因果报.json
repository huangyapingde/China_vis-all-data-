          "character": null,
          "type": "stage",
          "text": "城隍、判官同上。〖牌子〗。李成上。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "李成鬼魂当面。"
        },
        {
          "character": "城隍",
          "type": "白",
          "text": "查看李成阳寿可终？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "判官应。〖牌子〗。"
        },
        {
          "character": "判官",
          "type": "白",
          "text": "命尽禄绝。"
        },
        {
          "character": "城隍",
          "type": "白",
          "text": "李成，看你忠直含冤，奈你阳寿已绝，且入冥府，待吾奏过天庭，再入轮回。 看文房四宝伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。李成下。四功曹同上，同跳击鼓。许真君上，接帖。"
        },
        {
          "character": "许真君",
          "type": "白",
          "text": "依巡天界去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四功曹同下。"
        },
        {
          "character": "许真君",
          "type": "白",
          "text": "直入灵霄。 二郎真君何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨戬上。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "来也！ 有何法旨？"
        },
        {
          "character": "许真君",
          "type": "白",
          "text": "玉帝有牒文一道，命你到西天雷音寺投递，不得有误。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "领玉旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "许真君、杨戬同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。毘那、达摩同上。"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "佛祖殿前传妙音，九曲难悟问至尊。两镜光含千古意，珠玑泻出显家门。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "吾乃毘那尊者是也。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "吾乃达摩祖师是也。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "吾奉佛旨，直巡雷音，献七宝香花，供养承事。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "看来天紫云冲，必有玉牒临西也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨戬上。"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "二位世尊稽首。"
        },
        {
          "character": "毘那、达摩",
          "type": "同白",
          "text": "妙道真君，手捧玉牒，有何宣示？"
        },
        {
          "character": "杨戬",
          "type": "白",
          "text": "下界梁武帝君妃一段因果，特来佛前投递。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "我佛未登宝座，请留牒文，我佛自然遵牒发遣。"
        },
        {
          "character": "杨戬",
          "type": "念",
          "text": "孽由心造心犹谁，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨戬下。"
        },
        {
          "character": "毘那、达摩",
          "type": "同念",
          "text": "心罪当知谁所为。"
        },
        {
          "character": "毘那、达摩",
          "type": "同白",
          "text": "看五百罗汉绕殿。我佛登莲台来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众罗汉同上，同排班。如来佛上。"
        },
        {
          "character": "如来佛",
          "type": "念",
          "text": "眼望东土一片沙，西方普地种莲花。万劫方登极乐界，可称三藐三菩提。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "吾乃如来佛是也。掌大千世界，护十方万灵，须菩提汝意云何。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "玉帝有牒，请我佛劫还因果。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "如来佛看。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "呵，原来如此。那梁武帝乃打柴的樵子，因他善果无量，脱生大梁之主，享帝 王之福，喜他一念不忘敬佛斋僧，玉帝欶旨，武帝添增一代，后朝帝王。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "我佛慈悲，遣一尊罗汉前去临凡，以为武帝后嗣。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "维摩尊者。"
        },
        {
          "character": "维摩",
          "type": "白",
          "text": "佛祖。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "命你去东土，脱生梁武帝后嗣，不负他敬佛之心，享帝王之洪福，但不可忘却 本来面目，功满原复本位。"
        },
        {
          "character": "维摩",
          "type": "白",
          "text": "我佛法旨，敢不谨遵，但尘凡疫瘴重重，怎掌一统山河？还求佛祖大发慈悲。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "你既前往，自有功臣勇将，按上方列宿扶助于你。"
        },
        {
          "character": "维摩",
          "type": "白",
          "text": "谨遵佛旨。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "郗氏乃上界天绞星，一念思凡，玉帝不从。毘伽！"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "佛祖！"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "谁料她忘却根本，嫉妒嗔痴，毁佛谤僧，造下无边罪孽，坠落红尘，你可下凡 点化与她，若能回头，准复本位。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "启上佛祖：那梁武帝生前有些因果疫瘴，维摩罗汉，难以支持，我佛慈悲，发 下几尊罗汉，以为护应。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "降龙罗汉，命你下凡，到湖广襄阳脱生陈刚，扶维摩江山，不得有违。"
        },
        {
          "character": "降龙罗汉",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "伏虎罗汉，命你下凡，到西蜀渝州，脱生黄茂，扶维摩创业，不得有违。"
        },
        {
          "character": "伏虎罗汉",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "阿兰哪尊者，命你下凡到西蜀，脱生吕珍，再将天巧星谪下，脱生你妹仙琼， 后为昭阳。"
        },
        {
          "character": "阿兰哪尊者",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "紫金罗汉，命你下凡脱生冲天广，在少林寺出家，后为护国军师。"
        },
        {
          "character": "紫金罗汉",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "达摩尊者，所有梁帝因果，你已尽知，如今维摩下凡，你可紧随护应，施展法 力，成全此段因果，方显释教佛法无边。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "弟子等愚昧，恐凡尘迷性，望佛指点一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毘那、维摩、降龙罗汉、伏虎罗汉、阿兰哪尊者、紫金罗汉同应。"
        },
        {
          "character": "如来佛",
          "type": "白",
          "text": "听吾解空大众者。"
        },
        {
          "character": "毘那、达摩、维摩、降龙罗汉、伏虎罗汉、阿兰哪尊者、紫金罗汉",
          "type": "同白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "如来佛",
          "type": "唱",
          "text": "毘伽世者下凡间， 南无观音菩萨， 消灾延寿佛菩萨也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "锣鼓。"
        },
        {
          "character": "如来佛",
          "type": "唱",
          "text": "劝善郗氏到长干， 嫉妒嗔痴，洗心悔过， 依然复位镇三天。 南无释迦牟尼佛， 南无金翅明王佛， 维摩世者下凡尘， 南无文殊菩萨， 无量功德佛菩萨也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "锣鼓。"
        },
        {
          "character": "如来佛",
          "type": "唱",
          "text": "三灾八难有护应， 一番疫瘴一番冤。 虔心智慧菩提愿， 一统山河乐无边。 南无庄严燃灯佛， 南无长耳定光佛。 降龙、伏虎二世尊， 南无普贤菩萨， 释迦弥勒佛菩萨也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "锣鼓。"
        },
        {
          "character": "如来佛",
          "type": "唱",
          "text": "紫金脱生冲天广， 吕珍脱生是阿兰。 维摩走国你护救， 功德圆满回西天。 南无孔雀明王佛， 南无华严极乐佛。 达摩世者下雷音， 南无地藏菩萨接引准提佛菩萨也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "锣鼓。"
        },
        {
          "character": "如来佛",
          "type": "唱",
          "text": "梁王因果你透彻， 维摩担儿你承担。 你到东土兴佛教， 功德圆满回雷音。 南无普照照光明佛， 南无八万四千弥陀佛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众罗汉分班下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "猴子跳魂上。"
        },
        {
          "character": "猴子",
          "type": "念",
          "text": "凤凰山下苦修真，千载未曾脱人形。梁武闭洞绝吾命，飘飘渺渺到如今。"
        },
        {
          "character": "猴子",
          "type": "白",
          "text": "吾乃凤凰山石硖洞黑猴鬼魂是也。修炼千载，欲成正果，却被梁武闭洞饿死， 渺渺一气，不能脱转轮回。他善果无穷，脱生一朝天子，我无可奈何。如今达 摩老祖掌东土佛教，不免去往西川驻云岭求示因果，再渡轮回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猴子下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "松形、柏形同跳魂上。"
        },
        {
          "character": "柏形",
          "type": "念",
          "text": "受尽精华瑞云笼，千载不改老苍松。梁武砍枝掘根断，劫还因果再相逢。"
        },
        {
          "character": "柏形",
          "type": "白",
          "text": "我乃古柏形是也。我等千年老树，看看为神，却被梁武砍枝掘根，呜呼一命。 如来佛命达摩掌东土佛教，劫还因果，你我同去拜求老祖有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "松形、柏形同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。达摩上。"
        },
        {
          "character": "达摩",
          "type": "念",
          "text": "望东土，赡部州，佛旨谁参透。松柏树，黑石猴，莫来由，解结完愿两罢休。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "吾奉佛旨，扶维摩承袭天下，解梁武帝因果。看正东来了一股黑气，两道清风， 这些孽畜，也要讨债了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猴子、松形、柏形同上。"
        },
        {
          "character": "猴子、松形、柏形",
          "type": "同白",
          "text": "老祖慈悲吓！"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "吾奉佛旨结因果，你等见吾何事？"
        },
        {
          "character": "猴子",
          "type": "白",
          "text": "老祖听禀。"
        },
        {
          "character": "猴子",
          "type": "唱",
          "text": "古佛寺中把香焚， 梁武闭洞丧残生。"
        },
        {
          "character": "松形、柏形",
          "type": "同唱",
          "text": "千载何曾漏行影， 朝砍暮伐掘了根。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "便将你等脱转轮回，认母投胎。那梁武帝只有十数载寿元，却也来不及了。"
        },
        {
          "character": "猴子、松形、柏形",
          "type": "同白",
          "text": "求老祖大发慈悲。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "就将你等认尸扑窍，可还果报。 黑石猴，你可速往北淮魏王驾下，有一个臣名曰侯景，认尸扑窍，增寿一纪， 将梁武帝围困台城，断绝粮草，活活饿死，以全果报。"
        },
        {
          "character": "猴子",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猴子下。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "老松树，你可去河南影扑柴松，后来磨折维摩太子，拐卖银两，可也了你赎愿 也。"
        },
        {
          "character": "松形",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "松形下。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "古柏树，你到西蜀巴州扑柏氏之窍，为良善之妻，后来买太子为儿，磨折一番， 了你之愿也。"
        },
        {
          "character": "柏形",
          "type": "白",
          "text": "领佛旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柏形下。"
        },
        {
          "character": "达摩",
          "type": "白",
          "text": "我且到西蜀驻云岭安插，且到临期，再展佛力。正是："
        },
        {
          "character": "达摩",
          "type": "念",
          "text": "大千沙界原非有，念念救人万事休。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "达摩下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "和尚上。"
        },
        {
          "character": "和尚",
          "type": "念",
          "text": "圣凡同聚给孤园，似月如星共一天。持钵着衣弘圣化，人人尽是火中莲。"
        },
        {
          "character": "和尚",
          "type": "白",
          "text": "贫僧，长干寺方丈悟性是也。梁王万岁在此建中，启建水陆道场七七四十九日， 五百上堂僧奉经礼忏，今已二七。昨日来了一位圣僧，口诵真经，与众不同， 说今日要见万岁，有一番指悟。 看銮驾拥拥，圣驾临坛也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众御林军、大太监、小太监引梁武帝同上。〖牌子〗。"
        },
        {
          "character": "和尚",
          "type": "白",
          "text": "悟性接驾。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "众僧可曾用斋？"
        },
        {
          "character": "和尚",
          "type": "白",
          "text": "早已用过，俟驾临坛。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "吩咐起鼓参禅。"
        },
        {
          "character": "毘那",
          "type": "内白",
          "text": "阿弥陀佛！"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "长老，何人念佛声如雷震耳？"
        },
        {
          "character": "和尚",
          "type": "白",
          "text": "昨夜忽来一僧，颠言狂语，甚是不解，说今日见驾，还有禅机奏主。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "不可轻慢与他，快请。"
        },
        {
          "character": "和尚",
          "type": "白",
          "text": "万岁有旨，请圣僧入坛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毘那上。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "打开自己光明藏，尽在毛端一孔中。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "万岁稽首。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "佛堂不便赐坐。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "果然敬佛。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "方丈说你颠言狂语，到底是一个颠，还是一位仙？"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "颠也是个仙，仙也是个颠，有人识得颠仙破，不成佛来也成仙。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "果然是一位圣僧，可曾用过斋。"
        },
        {
          "character": "和尚",
          "type": "白",
          "text": "昨夜到寺观斋，不用。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "方丈，现斋不用，岂可不饿。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "不饿，不饿。"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "这机关谁人识得破，识破我也饿得过。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "看斋伺候。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "无量功德佛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毘那吃斋。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "一桶斋俱已吃完。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "一桶斋俱已吃完，岂可不饱。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "不饱，不饱。"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "臭皮囊生得小，小小我也装得了。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "这是与朕有缘，得遇这等高僧。"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "你有缘，我有缘，仙机莫与外人传。只要你的缘分满，贫僧送你到——"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "到哪里？"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "到西天。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "请问圣僧上下？"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "志公。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "志公长老，朕征伐天下，伤害生灵太过，故建水陆道场，欲求法师讲说一堂经 礼，一堂戒放，一堂焰口。若肯慈悲，自当酬谢。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "阿弥陀佛。讲经说法焰口赦，乃出家人本等，怎提酬谢二字，贫僧讲经说法， 不在方丈禅堂，要在荒郊野外高埠之处，讲说几句，叫那老少军民男妇人等听 一听，叫他们好开心见性，醒悟迷途。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "不知哪里宽阔？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "宴春门外，有座晏春台宽阔。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "传旨：不论老少军民人等，愿听经者，一概不准拦阻。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "请驾先行，贫僧随后就到。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "吩咐摆驾晏春台去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "御林军同应。〖牌子〗。众人同下。"
        }
      ]
    },
    {
