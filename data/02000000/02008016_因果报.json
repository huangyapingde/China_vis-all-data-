{
  "script_id": "02008016",
  "title": "因果报",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "梁武帝",
      "hangdang": "老生"
    },
    {
      "name": "郗娘娘",
      "hangdang": "正旦"
    },
    {
      "name": "孟庆云",
      "hangdang": "旦"
    },
    {
      "name": "日游神",
      "hangdang": "净"
    }
  ],
  "plot": "梁武帝时，招讨大元帅柳庆远，征讨寿阳，镇南王孟拔逃亡。柳庆远觅得孟女庆云，美艳无双。乃带回献给\n梁武帝为妃。梁武帝封为东宫，十分宠爱。正宫郗后，用婢女陈桂香计，藉梁武帝礼佛设斋期间，伪称供品，\n令内监李成，送蜜食毒死东宫。因东宫有孕，监察日游神等暗中保佑。当李成、陈桂香等送蜜食至东宫处\n时，将盒打落，被狗吞食而死，事乃大洩。郗后大怒，将李成打死。城隍查知李成阳寿虽终，但念其为人忠\n耿，特奏明玉帝，另投轮回。后乃转报如来佛，将梁武帝前因后果，一一查明云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、中军同上，同站门。柳庆远上。"
        },
        {
          "character": "柳庆远",
          "type": "引子",
          "text": "佐辅大梁，东鲁魏齐自灭亡，七雄五霸兴业创，定效闻仲扶商汤。"
        },
        {
          "character": "柳庆远",
          "type": "念",
          "text": "亲承王命伐北魏，将卒奋勇抖神威。各郡献降马前跪，方得英名万古垂。"
        },
        {
          "character": "柳庆远",
          "type": "白",
          "text": "本帅，柳庆远。在梁武帝驾下为臣，官居兵部大司马，招讨大元帅，拜护国军 师。吾主初接大位，命本帅招讨天下，虽有叛贼，尽皆鼠窜而逃。昨剿寿阳， 镇南王孟拔弃城而逃，只存爱女孟庆云，年方一十八岁，生得美丽端庄，温柔 俊雅，可称一朝贵人。吾主登基以来，未纳六宫嫔妃，为此不行杀害，带回朝 中，献与当今。今乃黄道吉日，不免班师回朝。 中军，将孟小姐车辇缓缓而行，就此班师回朝。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "将孟小姐车辇缓缓而行，班师回朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "朱异上。"
        },
        {
          "character": "朱异",
          "type": "念",
          "text": "金鸡三唱报晓筹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张绾上。"
        },
        {
          "character": "张绾",
          "type": "念",
          "text": "至尊天子坐龙楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苗秀上。"
        },
        {
          "character": "苗秀",
          "type": "念",
          "text": "静鞭三响齐整肃，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙安上。"
        },
        {
          "character": "孙安",
          "type": "念",
          "text": "文武百官拜冕旒。"
        },
        {
          "character": "朱异",
          "type": "白",
          "text": "老夫大丞相朱异。"
        },
        {
          "character": "张绾",
          "type": "白",
          "text": "老夫右丞相张绾。"
        },
        {
          "character": "苗秀",
          "type": "白",
          "text": "下官，兵部司马苗秀。"
        },
        {
          "character": "孙安",
          "type": "白",
          "text": "下官，皇门侍郎孙安。"
        },
        {
          "character": "朱异",
          "type": "白",
          "text": "列位大人请了！"
        },
        {
          "character": "张绾、苗秀、孙安",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "朱异",
          "type": "白",
          "text": "昨日火牌到来，军师柳元帅今日回朝复命。"
        },
        {
          "character": "张绾、苗秀、孙安",
          "type": "同白",
          "text": "天子临殿，一同启奏。你我两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四小太监、大太监同上，同站门。梁武帝上。"
        },
        {
          "character": "梁武帝",
          "type": "引子",
          "text": "舜德尧仁，掌社稷，物阜民丰。"
        },
        {
          "character": "梁武帝",
          "type": "念",
          "text": "五帝传流夏商周，战国治世秦汉刘。倚仗群雄安天下，一统山河乐无忧。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "朕大梁天子萧衍武帝在位。只因齐和帝软弱无能，让位与孤，托龙天之佑，赖 群臣之威，四方宁静。只有北魏不服，欲争疆土，已命军师柳庆远前去征剿， 未知胜负若何。 内侍，开放龙门。"
        },
        {
          "character": "朱异",
          "type": "白",
          "text": "臣启万岁：军师得胜回朝，午门候旨。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "卿家替朕传旨：宣柳卿上殿。"
        },
        {
          "character": "朱异",
          "type": "白",
          "text": "领旨。 圣上有旨：宣军师柳庆远上殿。"
        },
        {
          "character": "柳庆远",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳庆远上。"
        },
        {
          "character": "柳庆远",
          "type": "念",
          "text": "腹内包罗锦綉，胸中贯透珠玑。"
        },
        {
          "character": "柳庆远",
          "type": "白",
          "text": "臣，柳庆远见驾，吾皇万岁！"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "柳庆远",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "命卿征伐北魏，奏与朕知。"
        },
        {
          "character": "柳庆远",
          "type": "白",
          "text": "臣奉命征剿北魏，各郡献降，容臣细奏！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "好。卿家雄才大略，四海清宁，封卿为楚国公，光禄寺摆宴，与卿家贺功。"
        },
        {
          "character": "柳庆远",
          "type": "白",
          "text": "启奏万岁：臣打破寿阳城，孟拔逃窜，只存一女，名曰孟庆云，生得有沉鱼落 雁之容，闭月羞花之貌，可称国色天香，献与万岁纳为嫔妃，以助国政，望主 降旨。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "朕登基以来，未选六宫嫔妃，奈天下方定，军民初安，未得宣秀纳宠，军师今 进美女，甚合朕意。 司礼监孙庆与孤传旨：传宫娥彩女扶孟贵人上殿，待朕御览。"
        },
        {
          "character": "孙庆",
          "type": "白",
          "text": "领旨！ 万岁有旨：宣孟贵人冠带上殿。"
        },
        {
          "character": "孟庆云",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟庆云上。"
        },
        {
          "character": "孟庆云",
          "type": "白",
          "text": "罪臣之女孟庆云见驾，吾皇万岁。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "见朕未何不抬起头来？"
        },
        {
          "character": "孟庆云",
          "type": "白",
          "text": "有罪不敢抬头。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "孟庆云",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "孟庆云果然美貌出众。朕封为东宫，钦赐玉簪一枝，与朕同掌山河。"
        },
        {
          "character": "孟庆云",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟庆云下。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "朕自接大位，刀兵方息，军民始安，残害万千生灵。 皇门侍郎，与朕传旨，长干寺延请高僧，设下水陆道场，二月十九日菩萨圣诞 日起，至四月初八日佛祖圣诞日止，七七四十九日，延请四百九十九众僧人， 广储司发银三万，朕亲往长干寺礼拜，四十九日超度亡魂。"
        },
        {
          "character": "柳庆远",
          "type": "白",
          "text": "万岁驾幸长干寺，超度生灵，朝事何人掌管？"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "命正宫郗娘娘料理内事，外事军师掌管。"
        },
        {
          "character": "柳庆远、朱异、张绾、苗秀、孙安",
          "type": "同白",
          "text": "臣等备宴，庆贺万岁。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "一应文武，免朝三日，朕幸东宫去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈桂香上。"
        },
        {
          "character": "陈桂香",
          "type": "念",
          "text": "每日巡宫披星塞，精灵机巧凭舌尖。常伴贵妃得恩宠，内侍宫人皆偃然。"
        },
        {
          "character": "陈桂香",
          "type": "白",
          "text": "奴家，陈桂香。自王新纳东宫，数月未进昭阳，国母十分不悦，如今万岁要到 长干寺斋僧招佛，今早娘娘传旨，备宴与万岁封斋，只得在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫娥同上，郗娘娘上。"
        },
        {
          "character": "郗娘娘",
          "type": "引子",
          "text": "轻移玉门，掌昭阳，治国殷勤。"
        },
        {
          "character": "郗娘娘",
          "type": "念",
          "text": "珠帘高卷乐声喧，贵如天子福绵绵。一朝国母谁不羡，妇随夫唱总由天。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "哀家，郗氏，执掌昭阳正院。万岁自纳孟妃，不理朝事，迷恋东宫，数月不出， 忘了结发糟糠，君妃鬓白，未有后嗣守阙真龙，使我日夜忧虑。为此令总督 苗芳，将我侄儿郗宠迎接到来，认为螟蛉，立为东宫殿下，以便江山有托。 陈桂香宣苗芳进宫。"
        },
        {
          "character": "陈桂香",
          "type": "白",
          "text": "领旨。 娘娘有旨：宣苗总监进宫。"
        },
        {
          "character": "苗芳",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苗芳上。"
        },
        {
          "character": "苗芳",
          "type": "念",
          "text": "禄高君恩重，报国哪得闲。"
        },
        {
          "character": "苗芳",
          "type": "白",
          "text": "奴婢，苗芳见驾，娘娘千岁！"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "苗芳",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "命你教习殿下习礼，少刻驾至昭阳，不得错乱。"
        },
        {
          "character": "苗芳",
          "type": "白",
          "text": "奴婢怎敢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内吹打。四太监同上，梁武帝上。"
        },
        {
          "character": "梁武帝",
          "type": "念",
          "text": "头顶玉殿金瓦，足踏龙凤门开。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "妾妃郗氏见驾，吾皇万岁！"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "谢坐。妾妃见文武奏章，万岁迷恋东宫，不理朝政，望陛下善保龙体，江山为 重。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "御妻此言差矣，你我结发三十馀年，未立后嗣。今纳东宫，若生殿下，山河有 靠，不枉朕创业一番。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "万岁请自宽心，妾有侄儿郗宠，一十二岁，体貌端方，龙眉凤眼，真正帝王之 相，莫若认为螟蛉，后来江山有靠。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "御妻既有侄儿，宣来见朕。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "领旨。 苗芳扶殿下见驾。"
        },
        {
          "character": "苗芳",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苗芳下。〖吹打〗。苗芳引郗宠同上。"
        },
        {
          "character": "郗宠",
          "type": "白",
          "text": "皇姑父！"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "万岁。"
        },
        {
          "character": "郗宠",
          "type": "白",
          "text": "不吗。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "今多大年纪？"
        },
        {
          "character": "郗宠",
          "type": "白",
          "text": "十一个生日十二岁。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "可曾攻书？"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "七岁读书。"
        },
        {
          "character": "郗宠",
          "type": "白",
          "text": "我不念书。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "苗芳将郗宠暂送入书馆，选翰林院官一员，教他读书学礼。"
        },
        {
          "character": "郗宠",
          "type": "白",
          "text": "我不爱读书。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "扶他下去。"
        },
        {
          "character": "苗芳",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苗芳、郗宠同下。"
        },
        {
          "character": "梁武帝",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "万岁看此子如何？"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "好！"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "趁今黄道吉日，立为东宫，后来也好受命江山。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "御妻何必这等性急？"
        },
        {
          "character": "梁武帝",
          "type": "唱",
          "text": "受当今东宫， 勅命承袭孤山河万岭。 你看他顽皮不敏， 哪分君共臣。 结发糟糠何理论， 不是骨肉也是亲。"
        },
        {
          "character": "郗娘娘",
          "type": "白",
          "text": "万岁明日驾幸长干寺，妾备宴封斋。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "不用。朕已斋戒三日了。"
