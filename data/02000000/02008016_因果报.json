      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（摆经台。众僧人自两边分上。梁武帝排驾上。〖牌子〗，〖吹打〗。梁武帝换衣。毘那上，参毕，上台中"
        },
        {
          "character": null,
          "type": "text",
          "text": "座。梁武帝下跪。）"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "念赞。"
        },
        {
          "character": "毘那",
          "type": "念",
          "text": "大乘境界尽含容，凡圣原来事一同。扫尽微尘生死念，依然回复旧家风。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "佛曰大乘金刚经。善哉，善哉。须菩提如汝所说。如来善护，念诸菩萨善付嘱 诸菩萨。汝今谛听，当为汝说，善男子，善女人，发耨多罗三藐三菩提，提心 如是住，如是降服其心，唯然世尊，愿乐欲闻。"
        },
        {
          "character": "众僧人",
          "type": "同白",
          "text": "阿弥陀佛。无量功德佛，讲经指迷途，一切诸佛，大千世界，七宝池边，看作 如五百罗汉金刚杵，如来相非何以故。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "出彩天花。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "阿弥陀佛。列位，听圣僧讲经，只说天花乱坠，异香扑鼻，千古罕闻，真是天 子有道，你我朝天叩谢！"
        },
        {
          "character": "众百姓",
          "type": "同合彩",
          "text": "谢天花，见活佛，普天士卒， 仰沾福，万邦宁，建洪乐，军民同乐齐庆祝。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "今后这晏春台，改名雨花台。"
        },
        {
          "character": "众百姓",
          "type": "同白",
          "text": "有道明君。"
        },
        {
          "character": "梁武帝",
          "type": "白",
          "text": "请长老回禅堂，朕亲自献斋。"
        },
        {
          "character": "毘那",
          "type": "白",
          "text": "万万岁！"
        },
        {
