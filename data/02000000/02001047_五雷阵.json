{
  "script_id": "02001047",
  "title": "五雷阵",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "海潮",
      "hangdang": "外"
    },
    {
      "name": "毛蕡",
      "hangdang": "净"
    },
    {
      "name": "王翦",
      "hangdang": "净"
    },
    {
      "name": "清风",
      "hangdang": "童"
    },
    {
      "name": "明月",
      "hangdang": "童"
    }
  ],
  "plot": "此剧系出列国，秦始皇遣王翦并吞六国之时，从妖道毛蕡助王翦攻齐起，其大概为孙膑侄为毛蕡所败，孙膑\n亲自出阵杀退毛蕡，不意被毛蕡败回作法，设下五雷阵，将孙膑魂摄入，将殛死之。幸孙膑道数高，真元不\n动，卒破毛蕡阵，用鬼谷师所遗太极图击死毛蕡云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王翦、四卒子同上。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "可恼啊，可恼。本帅王翦。奉了师父之命，下山扶助秦始皇，兵吞六国。一路 之上，迎风扫灭数国，只有燕、齐二国未平。本帅兴兵伐燕，瑞陵君孙操他父 子，俱丧本帅钢鞭之下。谁知瘸夫孙膑，私下天台高山，与他父兄报仇。本帅 被他杀得大败，免战高悬。当初下山之时，师父赐我信香一支：倘有急难之事， 焚香叩求，必遣师兄下山。也罢，就此焚香叩拜。 众将！"
        },
        {
          "character": "四卒子",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "看香案伺候。"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "一柱信香叩天仙， 过往力士听我言。 香烟捧过垂花洞， 等候师兄下高山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王翦、四卒子同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "海潮、清风、明月同上。"
        },
        {
          "character": "海潮",
          "type": "引子",
          "text": "养性参禅，修成大罗神仙。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "山人海朝。圣旨因秦始皇登基，他本是黄龙下界，玉帝牒文，兵吞六国。山人 打发二徒弟王翦下山，投在秦国。始皇封为天宝元帅，起动大兵，征讨六国， 不知何日已完劫数？山人今日，心神不定，不知所为何故？ 清风、明月童儿，"
        },
        {
          "character": "清风、明月",
          "type": "同白",
          "text": "伺候师父。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "闪开洞门，外面看来。"
        },
        {
          "character": "清风、明月",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "力士暗上，走，下。"
        },
        {
          "character": "清风、明月",
          "type": "同白",
          "text": "启禀师父：香烟吹到洞前。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "我山人出洞看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "力士上，走，下。"
        },
        {
          "character": "海潮",
          "type": "stage",
          "text": "中国京剧戏考 《五雷阵》【头本】 2"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "海潮",
          "type": "唱",
          "text": "睁慧眼在洞前仔细来观， 却原来小王翦叩焚香烟。 兵行至燕国中身临大难， 孙伯龄杀得他免战高悬。 叩求我遣能人将他扶助， 方能够秦始皇一统江山。 观罢了信香烟进洞打坐， 叫一声众弟子细听我言。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "众徒儿，"
        },
        {
          "character": "清风、明月",
          "type": "同白",
          "text": "师父。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "为师方才观看，香烟过去，却是你师兄王翦，兵至燕国，被天台山孙膑，杀得 他免战高悬，叩求山人，遣能人下山，破却孙膑，方能进兵。也罢，唤你师兄 上殿。"
        },
        {
          "character": "清风、明月",
          "type": "同白",
          "text": "有请师兄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡上。"
        },
        {
          "character": "毛蕡",
          "type": "念",
          "text": "弃凡学道在深山，八卦炉中看仙丹。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "参拜师父。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "谢座。师父唤弟子上殿，有何法旨？"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "方才山人，心血来潮，掐指一算，却原来是你师弟王翦，兵至燕国，被孙膑杀 得大败，因此唤你出来，命你下山，扶助秦国，大战孙膑。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "师父，那孙膑法理高强，徒儿非是瘸夫的对手。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "为师赐你镇洞法宝，带下山去。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "但不知是何法宝？"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "混元紫金锤、聚魂盒，外有五雷阴兵宝册，何愁不胜孙膑？"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "有此法宝，弟子即刻下山。"
        },
        {
          "character": "海潮",
          "type": "白",
          "text": "如此，听山人法旨："
        },
        {
          "character": "海潮",
          "type": "唱",
          "text": "秦国君他本是黄龙下凡， 应天命扫六国一统江山。 那孙膑不该把天台山下， 杀得你二师弟免战高悬。 此一去带法宝将他扶助， 劝孙膑弃红尘去归高山。 小孙燕本是那青龙一转， 交阵时休将他性命伤残。 你若是破孙膑早早回转， 休得要贪荣华不回高山。"
        },
        {
          "character": "毛蕡",
          "type": "唱",
          "text": "谨遵定我师命身下高山， 带定了这法宝去到阵前。 此一去但愿得功劳成定， 愚弟子不染尘急转高山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡下。"
        },
        {
          "character": "海潮",
          "type": "唱",
          "text": "毛蕡一去到阵前， 扶助始皇定江山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "海潮下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}