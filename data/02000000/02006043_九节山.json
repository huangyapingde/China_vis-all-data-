{
  "script_id": "02006043",
  "title": "九节山",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "九灵元圣",
      "hangdang": "净"
    },
    {
      "name": "孙悟空",
      "hangdang": "武生"
    }
  ],
  "plot": "太乙天尊座下九头狮子，乘太乙天尊朝斗之期，偷下尘凡。在九节山聚集子孙，自称九灵元圣仙翁，兴妖作\n怪。一日心神恍惚不定，乃命其部下黄云，往邻邦打听有无新奇之事。黄云行至玉华国，见下界祥云缭绕，\n系三件佛门之宝，乃偷去献与九灵元圣。惟三件宝物系孙悟空、猪八戒与沙僧之三件兵器。因玉华国国王三\n位世子，拜孙悟空等三人为师，特借取孙悟空等兵器，拟照模样造。不意被黄云偷去，极为焦灼。孙悟空乃\n告世子不必介意，由渠与猪八戒等自行寻找。乃至九节山长生洞，变作黄云部下刁钻、古怪，混入洞中，将\n兵器取出。行至途中，黄云赶来。孙悟空将黄云击退。当黄云将三件宝物呈献九灵元圣时，九灵元圣大喜，\n决定开钉耙大会庆祝。现在钉耙均被孙悟空等取回，黄云又被打败，九灵元圣大怒，乃亲往玉华国，将国王、\n唐三藏及三位世子均用妖术擒来。孙悟空见师父失踪，除令猪八戒等寻找师父等去向外，乃亲往妙岩宫谒\n太乙天尊，太乙天尊不得已，亲往下界，收回九头狮子，将唐三藏及国王救出。",
  "notes": "按此即《西游记》第八十八回“禅到玉华施法会，心猿木土采门人”与第八十九回“黄狮精虚设钉耙会，金\n木土计闹豹头山”等故事，惟稍微简化。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小妖引黄云、狻猊、搏象、伏狸、白泽、金猱、银雪、黑风同上。"
        },
        {
          "character": "黄云、狻猊、搏象、伏狸、白泽、金猱、银雪、黑风",
          "type": "同点绛唇",
          "text": "庆乐唐尧，神威拥耀，称祥瑞，万国来朝，同居九节岛。"
        },
        {
          "character": "黄云",
          "type": "白",
          "text": "俺，黄云大王是也。"
        },
        {
          "character": "白泽",
          "type": "白",
          "text": "俺，白泽大王是也。"
        },
        {
          "character": "搏象",
          "type": "白",
          "text": "俺，搏象大王是也。"
        },
        {
          "character": "狻猊",
          "type": "白",
          "text": "俺，狻猊大王是也。"
        },
        {
          "character": "伏狸",
          "type": "白",
          "text": "俺，伏狸大王是也。"
        },
        {
          "character": "金猱",
          "type": "白",
          "text": "俺，金猱大王是也。"
        },
        {
          "character": "银雪",
          "type": "白",
          "text": "俺，银雪大王是也。"
        },
        {
          "character": "黑风",
          "type": "白",
          "text": "俺，黑风大王是也。"
        },
        {
          "character": "黄云",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "狻猊、搏象、伏狸、白泽、金猱、银雪、黑风",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "黄云",
          "type": "白",
          "text": "众位贤弟，今日老仙翁升座，你我两厢伺候。"
        },
        {
          "character": "狻猊、搏象、伏狸、白泽、金猱、银雪、黑风",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小童执片幡引九灵元圣同上。"
        },
        {
          "character": "九灵元圣",
          "type": "逍遥乐",
          "text": "绿毛分派， 九节山中，居然化外。 鱼肉狼豺， 莽威风元圣官阶。 曾侍仙翁岂俗胎， 更喜得九灵封拜，潜修山界。 邻国空虚， 漫与分腮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。九灵元圣上高台。莲花生。"
        },
        {
          "character": "九灵元圣",
          "type": "念",
          "text": "天成杰异秉全精，执掌毛群做主盟。好把俘囚生肉啖，触邪獬豸岂空名。"
        },
        {
          "character": "九灵元圣",
          "type": "白",
          "text": "吾乃九灵元圣仙翁是也。自从昄依太乙，潜行定性，悟道修身。忽然静中思动， 正值天尊朝斗之期，是俺偷下凡尘，来在九节山长生洞，收聚许多子孙，占 据此山，十分潇洒。只是这几日心神恍惚，五内俱焚，不知是何缘故？"
        },
        {
          "character": "黄云",
          "type": "白",
          "text": "知是仙翁私下仙洞，惟恐天尊知觉，此乃仙翁私心惧罪之过，何必介意。"
        },
        {
          "character": "九灵元圣",
          "type": "白",
          "text": "话虽如此，怎奈我心乱如麻。也罢，就命你去到邻邦打探，若有奇异之事，速 报我知。"
        },
        {
          "character": "黄云",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "黄云",
          "type": "念",
          "text": "全凭胸中多仙术，变化人间谁能知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄云下。"
        },
        {
          "character": "九灵元圣",
          "type": "白",
          "text": "你看黄云一去，我且到后洞打坐一回。尔等好生看守洞府。"
        },
        {
          "character": "狻猊、搏象、伏狸、白泽、金猱、银雪、黑风",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同翻下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四内侍引玉华国王同上。"
        },
        {
          "character": "玉华国王",
          "type": "引子",
          "text": "天竺宗派玉华支，惟晓那纲常礼仪。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "我乃玉华国王是也。天竺分支，修斋奉佛。昨日闻报，有那大唐三藏，西天求 经，由我国经过。已命人送至馆驿安歇。今日已吩咐光禄寺，特备素斋，请来 少叙。改换关文，即早西行。 内侍，素筵可曾齐备？"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "素筵已齐。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "就请大唐圣僧上殿。"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "领旨。 国王有旨：请大唐圣僧上殿。"
        },
        {
          "character": "唐僧",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "唐僧上。"
        },
        {
          "character": "唐僧",
          "type": "念",
          "text": "普同一切恒沙乐，尽归如来法慧门。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "东土大唐和尚参见国王千岁。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "圣僧少礼。请坐。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "圣僧自从东土到此，不知行了多少路程？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "约有千万余里。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "哎呀，既有千万余里，不知经过多少春秋了？"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "千岁听禀。"
        },
        {
          "character": "唐僧",
          "type": "画眉序好姐姐",
          "text": "回首路途长， 十数年来说非谎。 这花香鸟语，水色山光， 何曾有一处相同。 也不知人间天上，哎，增惆怅。 幸喜贤王怜飘荡， 不放瞿昙困异乡。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "原来经过十数余载，暑往寒来，可谓久矣。 来，吩咐摆筵。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "且慢。启禀国王：贫僧还有三位徒弟，俱在朝外等候起行，不及领斋。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "既然如此，何不请进，一同用斋。 内侍，快请圣僧三位高徒上殿。"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "领旨。 国王有旨：宣东土圣僧三位上殿。"
        },
        {
          "character": "孙悟空、猪八戒、沙僧",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空、猪八戒、沙僧同上。"
        },
        {
          "character": "孙悟空、猪八戒、沙僧",
          "type": "同念",
          "text": "自离中华地，行路不记年。"
        },
        {
          "character": "孙悟空、猪八戒、沙僧",
          "type": "同白",
          "text": "国王在上，我等参见。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "免礼。 哎呀，吓杀我也。"
        },
        {
          "character": "玉华国王",
          "type": "啄木鹂",
          "text": "真奇怪， 须忖量兽面人心太古上。 他恃着豹眼獠牙， 不怕我剑戟刀枪。 全然不像僧模样。 斯文皆无，甚鲁莽，性强梁。 知机当避，筵席慢铺张。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "哎呀，吓死我也。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "既是国王害怕，悟空你等退下。"
        },
        {
          "character": "孙悟空、猪八戒、沙僧",
          "type": "同白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空、猪八戒、沙僧同下。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "圣僧，我见你一表人才，为何收下这样徒弟，使我吃惊，不能奉陪。 内侍，引圣僧一同三位高徒去到暴纱亭用斋去吧。"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "多谢国王。"
        },
        {
          "character": "唐僧",
          "type": "念",
          "text": "愚徒惊王驾，负罪本非轻。"
        },
        {
          "character": "内侍甲",
          "type": "白",
          "text": "啊，圣僧这里来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内侍甲、唐僧同下。二内侍引三世子同上。"
        },
        {
          "character": "三世子",
          "type": "同念",
          "text": "宫闱何喧闹，急忙道殿前。不知因何事，须得问根源。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "儿臣等参见父王千岁。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "吾儿平身。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "千千岁。请问父王，适才殿前喧哗，不知所为何事？"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "只因东土圣僧求经到此，改换关文，不想他三个徒弟，相貌凶恶，使我心惊， 为此喧哗。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "父王不必心惊，待儿臣三人去至暴纱亭看个分明。若是妖怪，将他擒来，与父 王压惊。"
        },
        {
          "character": "玉华国王",
          "type": "白",
          "text": "尔等前去，须要小心便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉华国王下。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "遵命。 内侍们！"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "看我们的兵器过来。前往暴纱亭前去便了。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "已到暴纱亭。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "三个丑鬼哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空执棒、猪八戒执钉耙、沙僧执铲同上。"
        },
        {
          "character": "孙悟空、猪八戒、沙僧",
          "type": "同念",
          "text": "人无害虎心，虎有伤人意。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你这三个孩童，手执器械，为着何来？"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "呔！丑鬼听着，适才父王言道，你等三人，面貌丑陋，定是妖怪。是你三位小 殿下，特来捉拿你等。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "哈哈，你等三人，慢说捉拿我等，就是俺这小小棍儿，你们若拿得动，再来捉 拿我等不迟。"
        },
        {
          "character": "世子甲",
          "type": "白",
          "text": "且慢！慢说一条棍棒，就是泰山也要撼它一撼。二位贤弟后退，待我拿来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "世子甲拿不动。"
        },
        {
          "character": "世子甲",
          "type": "白",
          "text": "二位贤弟一起拿来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "世子乙、世子丙同拿不动。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "哈哈，本来是三个小孩子，如何混充勇。慢说是那棍子，就是老猪这钯子，也 够你扛一伙儿的。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "三个孩童，休要逞强，我弟兄这兵器啊！"
        },
        {
          "character": "孙悟空",
          "type": "滴流神杖",
          "text": "冲霄汉，冲霄汉， 罩来电光。 惊人的，惊人的， 十分明晃。 有谁人敢阻挡。 你负隅休逞强着无状。 双臂挺是螳螂， 双臂挺是螳螂。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "妙啊。三位师父果然是武艺出奇，我等三人，情愿拜你等为师，望乞收留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三世子同拜。"
        },
        {
          "character": "三世子",
          "type": "同滴金楼",
          "text": "尊师重傅非虚诳， 敢把英雄还自奖， 逞奢豪误了年方壮。 悔前时空孟浪。 忖度思量，恕吾都魍魉， 愿吃当头一棒。 胜别人无数刚强。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你三人既已悦服我等，自当传授。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "多谢师父。请问师父们，这兵器可有多重？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "仙家至宝，何问轻重。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "求师父借与我们，做个式样，连夜命人造成，再送还师父。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "如今既是师徒，这有何妨。急速命人打造，不可耽误我师徒西行路程便了。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "请三位师父后面一叙。 来，尔等好生看守。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二内侍同应。"
        },
        {
          "character": "三世子",
          "type": "同白",
          "text": "三位师父请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空、猪八戒、沙僧、三世子同下。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "你看三位师父，同了世子前去叙谈，命你我在此看守兵器，且到亭上歇息便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二内侍同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小妖引黄云同上。"
