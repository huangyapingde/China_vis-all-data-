{
  "script_id": "02005002",
  "title": "观容",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "金氏",
      "hangdang": "正旦"
    },
    {
      "name": "邓伯道",
      "hangdang": "外"
    },
    {
      "name": "李氏",
      "hangdang": "老旦"
    }
  ],
  "plot": "晋时邓伯道之弟邓伯俭早亡，其妻思慕哀悼。特追思其生前形容，画相一幅，悬于堂上，藉供祭祀。并邀其\n兄嫂邓伯道夫妇，共同瞻仰哀悼，恳请邓伯道教养其子寿山（即邓方），以留后代根苗云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金氏上。"
        },
        {
          "character": "金氏",
          "type": "引子",
          "text": "寂寞香闺，为夫君，终朝泪垂。"
        },
        {
          "character": "金氏",
          "type": "念",
          "text": "自叹奴命蹇，夫君丧黄泉。遗容无处觅，托赖笔毫端。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "奴家金氏，伯伯邓伯道，姆姆李氏，丈夫邓伯俭。遗下一子，名唤寿山。且喜 伯伯、姆姆，十分爱惜。奴家自幼略晓丹青，不免将丈夫遗容，描画出来，早 晚供奉，以尽夫妇之情。"
        },
        {
          "character": "金氏",
          "type": "念",
          "text": "度日如年漫沉吟，终日思君不见君，描画丹青借笔力，叫奴辗转暗伤情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金氏描。"
        },
        {
          "character": "金氏",
          "type": "四朝元",
          "text": "伤情举笔，未描泪先垂。 画得他，温柔体态，儒雅风姿。 全凭着，全凭着纸共笔， 慢寻思就里就里。 画得他，锦绣襟怀，气质聪慧。 再画他衣冠威仪，堂堂貌美堂堂貌美。 我的夫，也只是少口气。 喳，再画他俊庞儿庞儿，秋水凝眸，春山秀丽。 吾画他，骨格清奇， 语句儿语句儿多伶俐。 只落得闲居静室，静室幽幽雅雅，好比作在生之日之日。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "遗容画完，不免供奉中堂，取些凉浆水饭，祭奠便了。 啊，我那夫哇！只说不得与你重相见，谁知纸上又重逢。不免请伯伯、姆姆出 来观看。 伯伯、姆姆有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道、李氏同上。"
        },
        {
          "character": "邓伯道、李氏",
          "type": "同薄幸引",
          "text": "奈何奈何为兄弟， 终朝泪落终朝泪落。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "伯伯、姆姆万福。"
        },
        {
          "character": "邓伯道、金氏",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "弟媳妇，请我二人出来，有何话讲？"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "自从丈夫丧后，朝思暮想。方才描画出来，请伯伯、姆姆观看！"
        },
        {
          "character": "邓伯道、李氏",
          "type": "同白",
          "text": "在哪里？"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "在中堂。"
        },
        {
          "character": "邓伯道、李氏",
          "type": "同白",
          "text": "大家前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金氏、邓伯道、李氏同走圆场。"
        },
        {
          "character": "邓伯道、李氏",
          "type": "同白",
          "text": "在哪里？"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "在上面。"
        },
        {
          "character": "邓伯道、李氏",
          "type": "同白",
          "text": "啊，我那（兄弟）（叔叔）哇！"
        },
        {
          "character": "邓伯道",
          "type": "念",
          "text": "一见图画始惊讶，老眼端详恰是他。指望兄弟常厮守，"
        },
        {
          "character": "李氏",
          "type": "念",
          "text": "谁知一命染黄沙。"
        },
        {
          "character": "邓伯道",
          "type": "念",
          "text": "画得好，果无差。"
        },
        {
          "character": "金氏",
          "type": "念",
          "text": "姣妻幼子靠谁家？"
        },
        {
          "character": "邓伯道",
          "type": "念",
          "text": "早知落在丹青手，觑定遗容泪如麻。"
        },
        {
          "character": "邓伯道",
          "type": "新水令",
          "text": "觑真容，恰便似共同胞。 觑着他模样儿，一般容貌。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "画便画得好，只是太丑陋了些。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "丈夫在日遗容，一时追想不来。"
        },
        {
          "character": "金氏",
          "type": "新水令",
          "text": "曾记得，临危遗容呵， 因此上，画得他病恹恹，这般黄瘦焦。"
        },
        {
          "character": "邓伯道",
          "type": "新水令",
          "text": "若是他，临危遗容呵， 全不差半分毫，分毫。 兄弟呵，你死后为神道，"
        },
        {
          "character": "邓伯道",
          "type": "驻马听",
          "text": "闪得她母子，母子单抛。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "哼。"
        },
        {
          "character": "金氏",
          "type": "驻马听",
          "text": "夫，想奴家，幼年丧父，中年丧夫。 此乃是大不幸了么？ 夫，你若是阴灵有感，有感阴灵， 保佑我母子们灾祸自然消！ 不由人哭嚎啕， 夫你今闪，闪得我也无归落。"
        },
        {
          "character": "李氏",
          "type": "步步娇",
          "text": "劝婶婶不必仍恁心焦， 少带些烦恼。 不幸叔叔归阴早， 从今后叔伯姆，只当作姐妹相交。 把侄儿爱惜他，如珍似宝， 我丈夫的衣衫鞋帽，任侄儿随意穿着，他随意儿穿着。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哼。"
        },
        {
          "character": "邓伯道",
          "type": "步步娇",
          "text": "老妻你讲便是这等讲。 自古道，男儿无妻家无倚， 妇人无夫身无主。 我那兄弟，生前不愧于天， 死后瞑目于地了么？ 老妻，你叫她，不必焦，少待烦恼， 休哭损她两眼秋波，免耽搁她玉体，玉体千姣。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "请伯伯、姆姆上香！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓伯道、李氏同上香。"
        },
        {
          "character": "邓伯道、李氏",
          "type": "同沉醉东风",
          "text": "手捧着金凤瓯， 设灵魂，在中堂供着，望灵魂容哀告。"
        },
        {
          "character": "邓伯道",
          "type": "沉醉东风",
          "text": "觑着他幽雅俊容貌， 飘飘冉冉丰姿好； 伴清风，也无消耗，"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "我邓伯道好生命苦。"
        },
        {
          "character": "邓伯道",
          "type": "沉醉东风",
          "text": "若留得我兄弟在日， 他有满腹经纶，盖世奇才。 指望与你，共乐余年， 又谁知，留你不住了。 兄弟，实指望，枝长梅花归故郊， 又谁知七弦琴，被风吹别调。 衰草秋，可怜姣花老。 实指望，兄弟相守到白头，白头， 又谁知你死，你死先抛。"
        },
        {
          "character": "金氏",
          "type": "白",
          "text": "哼。"
        },
        {
          "character": "金氏",
          "type": "沉醉东风",
          "text": "夫，再不来领姣儿， 携妻子，与你同偕到老。"
        },
        {
          "character": "邓伯道",
          "type": "沉醉东风",
          "text": "他那里说着，俺这里泪落，这里泪落。 猛然间，想起我那兄弟情，不由人默腹中，如刀似搅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内叫“哇哇哇”。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "什么叫？"
        },
        {
          "character": "金氏、李氏",
          "type": "同白",
          "text": "杜鹃。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "哪里是杜鹃，分明是我兄弟灵魂，见我一家，在此设祭，故托此鸟来叫。 杜鹃哪杜鹃，你若是我兄弟灵魂，大叫三声。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内叫“哇哇哇”。"
        },
        {
          "character": "邓伯道",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "邓伯道",
          "type": "雁儿落",
          "text": "你虽一死丧幽冥，幽冥， 幽冥难舍姣妻幼子情。 见我一家人来设祭， 你的阴灵化作杜鹃声。 又听得，杜鹃枝头声声叫， 他叫他子幼妻姣，我又年老。 若还保佑我一家坚牢， 多多照管你的根苗，我多多照管你的根苗。"
        },
        {
          "character": "金氏",
          "type": "雁儿落",
          "text": "伯伯、姆姆容哀告， 不幸丈夫归阴早。 看承寿山儿，长大成人， 母子们，衔环结草。"
        },
        {
          "character": "邓伯道",
          "type": "清江引",
          "text": "言三语四絮叨叨，叨叨， 家园家计我自承着。 杖神保佑，有我身体牢， 好扶养寿山你的儿曹，好扶养寿山你的儿曹。"
        },
        {
          "character": "邓伯道",
          "type": "尾声",
          "text": "弃子留侄孤儿保， 都只为所系宗祧。"
        },
        {
          "character": "金氏",
          "type": "尾声",
          "text": "教子成名， 你的恩不小。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}