{
  "script_id": "02003021",
  "title": "骂曹饯行",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "祢衡",
      "hangdang": "老生"
    },
    {
      "name": "荀彧",
      "hangdang": "末"
    },
    {
      "name": "荀攸",
      "hangdang": "小生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    }
  ],
  "plot": "祢衡击鼓骂曹操后，曹操乃用借刀杀人之计，将祢衡荐往刘表处。临行之时，并令张辽备酒长亭，荀彧、荀\n攸、郭嘉及程昱等，分别敬酒，借机侮辱。祢衡亦不肯示弱，一一反骂后，扬鞭而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "祢衡更衣，上。"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "丞相宽限岂宁坐， 披星戴月渡江河。 招安降事若不妥， 死在他乡做鬼魔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡下。"
        },
        {
          "character": "曹操",
          "type": "唱",
          "text": "祢衡说话真可恶， 舌尖犹如刺人戈。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "丞相，祢衡放肆，反命荆州为吏何故？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "若将他斩首，天下人道老夫不能容物。命他荆州为吏，借刘表杀之，岂不为美 哉？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "丞相高见不差。告辞。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恕不远送。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "不敢当了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。〖尾声〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "张将军长亭备宴，命府下众谋士，与祢衡饯行。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "祢衡，管叫你有路去，无路回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。曹操下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "荀彧上。"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "下官荀彧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "荀攸上。"
        },
        {
          "character": "荀攸",
          "type": "白",
          "text": "下官荀攸。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱上。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "下官程昱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭嘉上。"
        },
        {
          "character": "郭嘉",
          "type": "白",
          "text": "下官郭嘉。"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "我等领了丞相之命，备酒与祢衡饯行。来，打道。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "列位大人，祢衡到此，你我都不用起身，看他如何便是。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "远远望见祢衡来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡上。"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "祢衡马上自嗟叹， 古今事来颠倒颠。 高祖去赴鸿门宴， 西汉相争四百年。 曹操中原虚扶汉， 一心想谋汉江山。 孔融无谋将我荐， 曹瞒肉眼不识贤。 催马来在长亭看， 里面坐定文武官。 荀彧、荀攸智谋浅， 郭嘉程昱亦等闲。 必是与我把行饯， 停鞭忙下马雕鞍。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "来此长亭之上，里面坐的尽都是曹操谋士，须要以礼相待。 列位先生请了。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "我等不得远迎。"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "少待。 俺日前进府，与曹操深施一礼，他昂然不动。今日长亭，连他众谋士也是这等 大模大样。他们轻慢于我，但取笑一番。他有来言，我有去语。吓。"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "四海相逢初见面， 人生须得礼为先。 长亭假装把泪展， 问我一声回一言。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "祢衡见了我等，为何啼哭？"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "非是祢衡泪不干， 我今有言听心间： 指望来在古阳关， 谁知来在灵棺前。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "胆大狂徒。我等死尸，你乃无头狂鬼。尚不知耻！"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "俺本大丈夫，汉朝之臣，不做曹操之党。某怎得无头？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "俺丞相福大量大，不与你计较。荆州刘表，性如烈火。你若出言不逊，将你一 刀分为两段，岂不是无头狂鬼？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "俺祢衡宁做他乡之鬼，不做贼佞之臣！岂你等趋炎附势，只图眼前富贵，那知 臭名万载。无耻之辈，不足与吾谈论。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "你乃无耻之辈。胸中有什么策议，出此狂言？"
        },
        {
          "character": "祢衡",
          "type": "白",
          "text": "要问我胸中策论，展开你们驴耳，听俺道来。"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "你道俺胸中无策论， 战国、春秋日夜精。 上能治国如尧舜， 下能安邦保黎民。 安排摆兵和布阵， 可比韩信赛陈平。 有日大展经纶手， 要把贼子一笔倾。"
        },
        {
          "character": "荀彧",
          "type": "唱",
          "text": "胆大狂徒乱舌根， 自负才高夸己能。 三军满斟葡萄酒， 丞相之命敢不遵？ 你今领吾一杯酒， 好去他乡做鬼魂。"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "用手接过酒一樽， 将杯不饮奠埃尘。 非是祢衡酒不饮， 先奠荀彧死尸灵。"
        },
        {
          "character": "荀攸",
          "type": "唱",
          "text": "手捧葡萄酒一樽， 我与祢衡来饯行。 你今饮吾一杯酒， 但愿此去早归阴！"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "荀攸须为汉朝臣， 今做曹操帐下宾。 将酒奠在尘埃地， 管叫你千年万载落骂名。"
        },
        {
          "character": "程昱",
          "type": "唱",
          "text": "阳关饯行酒一樽， 一腔恶气往上喷。 若不奉了丞相命， 岂肯敬酒与狂生？"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "臣报君恩子奉亲， 你本不忠不孝人。 将酒奠在尘埃地， 天雷霹死儿当身。"
        },
        {
          "character": "郭嘉",
          "type": "唱",
          "text": "郭嘉奉酒泪淋淋， 手捧葡萄吊亡魂。 你今饮干吾的酒， 但愿早死早脱身。"
        },
        {
          "character": "祢衡",
          "type": "唱",
          "text": "郭嘉不必两泪淋， 短命年少小姣生。 吾去荆州有不幸， 儿是披麻戴孝人。 将酒奠在尘埃地， 有事关心少留停。 手扳雕鞍足踏蹬， 还有一事少叮咛。 回头我对群臣论， 贼子狗党仔细听： 我本天上东斗星， 亦非凡间等闲人。 只因有事犯了罪， 将俺谪贬下凡尘； 赐我一口青龙剑， 杀却朝中狗谗臣。 你等回复曹奸佞： 宽心稳坐听信音。 若得刘表来归顺， 祢衡当朝做公卿； 我今去后无音信， 却是孝子与贤孙。 在此不与你谈论， 跨马扬鞭走一程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "祢衡笑，下。"
        },
        {
          "character": "众人",
          "type": "同唱",
          "text": "长亭去了祢正平， 去时有路回无门。"
        },
        {
          "character": "荀彧",
          "type": "白",
          "text": "列位先生，祢衡言语狂妄，荆州吉凶难料。你我回复丞相。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "左右，带马回府交令去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "众人",
          "type": "stage",
          "text": "—————————— ⑴本场接《打鼓骂曹》最后一场。"
        }
      ]
    }
  ]
}