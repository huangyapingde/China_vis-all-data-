{
  "script_id": "02001030",
  "title": "连环阵",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "楚庄王",
      "hangdang": "老生"
    },
    {
      "name": "养由基",
      "hangdang": "武生"
    }
  ],
  "plot": "楚庄王伐晋，被晋国大司马魏奇射中左臂，乃调养由基前来应战。魏奇、养由基交战后，养由基一箭将魏奇\n射死。晋成公向蔡、宋、陈、郑四国借兵，摆下连环阵，与楚国对敌，幸养由基认识此阵，卒将五国联兵击\n败。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠同上，同站门，公子侧、潘望、楚庄王同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "昨日阵前失了机， 孤王险些命归西。 可叹乡老丧险地， 回朝加封把名题。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "孤，楚庄王熊羽。昨日与魏奇交战，不曾提防那贼暗射一箭，伤孤王左膀，险 些伤了性命，多亏众将救回关来。可叹乡老保楚多年，一旦丧命甚是可伤。那 魏奇十分骁勇，孤王要报一箭之仇，怎奈无有良将出马，好烦闷人也。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "大王难道忘怀了神箭手养由基不成？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "是吓，不是卿家提起，孤倒忘怀了。就命卿家星夜回朝，诏养由基前来助阵。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王败阵乱心意， 忘记小将养由基。 卿家速速回朝去， 调取小将赴戎机。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王下。"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "黄罗宝帐领旨意， 披星戴月转回归。 跨马离了荣阳地， 宣调神箭养由基。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、二大将、魏奇同上。"
        },
        {
          "character": "魏奇",
          "type": "唱",
          "text": "两军阵前兵对垒， 庄王焉敢逞雄威。 马仰人翻把兵退， 某一箭将他魂魄追。 将身且坐室帐内， 不灭庄王誓不回。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "某，晋国大司马魏奇。昨日与楚庄王交战，被某射了一箭，败进关去，不知他 生死存亡，累次詈阵，他只闭门不出来。 众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同允。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "尔等俱要抖擞精神，夺取荣阳关，方显我国威风也。"
        },
        {
          "character": "魏奇",
          "type": "唱",
          "text": "各个争先莫后退， 鞍前马后紧相随。 任他兵将如潮水， 本帅独骑闯重围。 交锋对阵勇为贵， 落个美名万古垂。 众将退帐归营队，"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "庄王！"
        },
        {
          "character": "魏奇",
          "type": "唱",
          "text": "某家箭法饶过谁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "养由基上。"
        },
        {
          "character": "养由基",
          "type": "引子",
          "text": "少小英雄，擅韬略，武艺精通。"
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "百步穿杨箭法精，万马军中显奇能。忠心赤胆扶王室，青史长标汗马勋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "俺，养由基，乃宛阳人士。熟读战策，颇晓兵机，效命于庄王，为车左将军之 职。只因斗越椒父子谋反，是俺一箭射死越椒，列国闻名。只今大王亲征晋国， 命俺与苏从护理国政。正是："
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "常将军务练，自有用兵时。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧上。"
        },
        {
          "character": "公子侧",
          "type": "念",
          "text": "今奉九重命，诏宣将才人。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "金牌下！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "“朕在荣阳关身有大难，命养由基星夜去至荣阳，不得迟误。谢恩。”"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "请过金牌。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "香案供奉。 将军保主征战晋国，受尽勤劳，不知大王因何被难？"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "大王与魏奇交战，不料左膀受了一箭，特命将军前去解危。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "既是大王有难，必须急速行起来。 旗牌，"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "禀知苏大人，说我前去救驾解围，着副将按期操演，不可懈怠。带马！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "将军请把雕鞍跨，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌带马。养由基、公子侧同上马。"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "食王爵禄保皇家。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "扬鞭催动跨下马，"
        },
        {
          "character": "公子侧",
          "type": "唱",
          "text": "哪怕山向路径斜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基、公子侧同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、楚庄王、潘望同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "寡人已把旨意下， 朝得孤王两眼花。 但愿由基来救驾， 灭却魏奇保邦家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子侧上。"
        },
        {
          "character": "公子侧",
          "type": "念",
          "text": "兼程离郢地，星夜到军前。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "养由基可曾宣到？"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "现在营外。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "快快宣他进帐。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "领旨。 大王有旨：宣养由基进帐。"
        },
        {
          "character": "养由基",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基上。"
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "君王多宵旰，为臣敢辞劳。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "臣，养由基见驾，大王千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "二卿坐下。"
        },
        {
          "character": "养由基、公子侧",
          "type": "同白",
          "text": "谢大王。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿与苏从等护理国政，别国不敢侵犯，皆卿等之功劳也。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "臣闻主公带伤，恨不得插翅而来。未知箭伤轻重？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "幸喜此箭无毒，只是其深及寸，痛疼难忍。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "臣自幼习学箭法，得来仙方丹药，现带身旁，请主公吃下，即刻痊愈。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "原来有此仙丹，卿家真忠臣也。 来，将此药调和，待孤即刻服下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王服药。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "妙哉呀，妙哉！真仙丹也。 啊，养卿。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "魏奇射孤一箭，定要报却此仇。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "臣与魏奇未曾会面，请主公观阵指与为臣，管叫此贼难逃性命。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "二卿听令。"
        },
        {
          "character": "潘望、公子侧",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "前去讨战。"
        },
        {
          "character": "潘望、公子侧",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘望、公子侧同下。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿家饱餐战饭，与孤观阵者。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "为王忙把旨传下， 大小三军听根芽： 免战牌休得高杆挂， 准备战场动杀法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、二大将、魏奇同上。"
        },
        {
          "character": "魏奇",
          "type": "唱",
          "text": "闭城不战害了怕， 为何今日把兵发？"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "二位将军，庄王闭城不战，为何今日又来叫阵？"
        },
        {
          "character": "二大将",
          "type": "同白",
          "text": "想是他国救兵到了。想司马如此英雄，今日一战定要杀他个片甲不归。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "好，杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘望、公子侧同上。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "潘望、公子侧",
          "type": "同白",
          "text": "听者！"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "俺乃公子侧。"
        },
        {
          "character": "潘望",
          "type": "白",
          "text": "俺乃潘望。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "原来是某手中败将，逃命去罢！"
        },
        {
          "character": "潘望、公子侧",
          "type": "同白",
          "text": "一派胡言，放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘望、公子侧、魏奇同起打，众人同下。四红文堂、四红大铠、楚庄王、养由基同上。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "战鼓不住连声打， 漫天蔽日起黄沙。 勒住丝疆把马下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "楚庄王、养由基同上城楼。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "看是输赢属谁家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘望、公子侧、魏奇同上，同起打，同下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "这是魏奇武艺大， 暗射孤王就是他。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "尊声大王休害怕， 急忙传旨把贼拿。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "赐你雕弓是鹊桦， 雕翎羽箭嵌狼牙。 你与魏奇比箭法， 就说孤王酬谢他。"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "由基领旨把马跨， 只要一箭打发他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基出城，会阵。四文堂、四大铠、二大将、魏奇同上。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "来将通名！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "俺乃庄王驾前车左将军养由基是也！"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "魏奇",
          "type": "唱",
          "text": "庄王兴兵有奸诈， 提兵调将果不差。 列国久闻名姓大， 百步穿杨第一家。 看来性命难保下， 狭路相逢遇冤家。 翻鞍离蹬下战马，"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "魏奇",
          "type": "唱",
          "text": "反被他人取笑咱。 大丈夫生在三光下， 生死二字何怕他。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "娃娃！"
        },
        {
          "character": "魏奇",
          "type": "唱",
          "text": "小小娃娃胆多大， 怎敢前来会某家！"
        },
        {
          "character": "养由基",
          "type": "唱",
          "text": "劝尔将头来割下， 不必与爷动杀法。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基、魏奇同起打，养由基下，魏奇退下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "武艺高强反回马， 孤王心中自嗟呀。 将军不把箭来发， 莫非有些惧怕他？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏奇、养由基同上。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "呔，尔敢是怯战！"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "住了，养老爷焉能怯战，闻你箭法高强，今日要与你比斗雌雄。"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "身为大将，只可阵前交锋，不许暗算。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "既不许暗算伤人，吾主左膀可是尔射的？"
        },
        {
          "character": "魏奇",
          "type": "白",
          "text": "庄王呀，可惜吓可惜！"
        },
        {
          "character": "养由基",
          "type": "白",
