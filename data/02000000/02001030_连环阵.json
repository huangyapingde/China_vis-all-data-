        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "郑、陈理应相助，蔡、宋二邦与晋国有仇，为何一同发兵？ 宣养由基进帐。"
        },
        {
          "character": "公子侧",
          "type": "白",
          "text": "领旨。 大王有旨：宣养由基进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "养由基上。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "养由基",
          "type": "念",
          "text": "若图英名传千古，须建血海汗马功。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "参见大王"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "平身赐坐。"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "谢坐。宣臣进帐，有何军情？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "今有晋邦搬来郑、陈、蔡、宋四国人马，合为五国之众，与孤决一死战。卿家 有何妙计？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "大王去往城楼观阵，再作准备。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "好，带马。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "孤王兴兵靠天命， 何惧五国动刀兵。 出得辕门踏金镫， （楚庄王上马。养由基、四龙套、四大铠同走圆场。楚庄王、养由基同上城。荀林甫、四龙套、公子坚、四 上手、公子都、四大铠、曹良臣、四下手、魏子敬同上，同摆阵势。）"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "兵如潮涌好惊人。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "这厮摆的什么阵势？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "此乃连环阵。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "荀林甫、四龙套、公子坚、四上手、公子都、四大铠、曹良臣、四下手、魏子敬同下。"
        },
        {
          "character": "楚庄王",
          "type": "唱",
          "text": "这贼摆的连环阵， 兵山将海势如云。 旗旙绕地天昏暗， 五路诸侯会用兵。 君臣且把大营进， 倒叫为王好胆惊。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "卿家既然知道，连环阵势是怎样的破法呢？"
        },
        {
          "character": "养由基",
          "type": "白",
          "text": "此阵按五路设定，阵阵相连，兵将连绵不断，叫我君臣不能料他有多少人马。 大王可命数员大将，相助为臣，管教五路人马片甲不回。"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "好。卿家后帐披挂，孤遣大将助你成功。 来，传众将进帐。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "众将进帐。"
        },
        {
          "character": "四将",
          "type": "内同白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "大王有何将令？"
        },
        {
          "character": "楚庄王",
          "type": "白",
          "text": "今有晋邦搬来四国兵将与孤对敌，尔等帮助养将军成功。"
        },
        {
          "character": "四将、养由基",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "四将、养由基",
          "type": "念",
          "text": "斩将如瓜滚，杀人似虎吞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将、养由基同下。"
        },
