{
  "script_id": "02012033",
  "title": "五里碑",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "霍炳",
      "hangdang": "净"
    },
    {
      "name": "黄天霸",
      "hangdang": "武生"
    },
    {
      "name": "丑老道",
      "hangdang": "丑"
    }
  ],
  "plot": "五里碑九天宫道士霍炳，因黄天霸杀死其两个徒弟，心中不平。除另派两个徒弟王洪、于治，前往行刺外，\n并邀请金鸡岭三位寨主雷燕喜、潘明业及谢美成共同商议刺杀施世纶。王洪、于治归后，谓施公防备甚周，\n无机可乘。又听到王有义控告霍炳，官兵即将前来剿拿。施世纶接王有义控状后，乃派徐茂私下调查。徐茂\n装作行商，至九天宫借宿，藉资查访，不意被霍炳看破，将徐茂捆绑预备晚间斩首。黄天霸等闻信，乃率人\n前往搭救，并将霍炳生擒。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。八喽啰同上，同站门。雷燕喜上。"
        },
        {
          "character": "雷燕喜",
          "type": "点绛唇",
          "text": "雄心胆壮，武艺高强，威名望，志气昂昂，杀人如草扬。"
        },
        {
          "character": "雷燕喜",
          "type": "念",
          "text": "英雄生来血气刚，虎背熊腰逞豪强。霸占金鸡无人挡，谁人不知雷大王！"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "某，雷燕喜。幼习绿林，创走江湖。每逢绿林作了买卖，是我平分一半。如若 不然，管叫他死无葬身之地。这且不言。可恨赃官施不全，屡次伤害绿林。有 心灭却，怎奈无有机会。正是："
        },
        {
          "character": "雷燕喜",
          "type": "念",
          "text": "苍天若是随人愿，定然灭却狗赃官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑老道上。"
        },
        {
          "character": "丑老道",
          "type": "念",
          "text": "奉了师父命，特来下书文。"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "来此已是金鸡岛。 里面有人么？"
        },
        {
          "character": "喽啰甲",
          "type": "白",
          "text": "作什么的？"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "奉了九天宫霍师父之命，前来与雷寨主下书。"
        },
        {
          "character": "喽啰甲",
          "type": "白",
          "text": "启寨主：今有九天宫霍师父，命人前来下书。"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "命来人进来。"
        },
        {
          "character": "喽啰甲",
          "type": "白",
          "text": "来人呢，寨主传你，要小心了。"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "是。 寨主在上，小人叩头！"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "谢寨主！霍师父有书信前来，寨主讲看。"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "呈上来。待某家一观。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "哦，原来霍师父相请，有大事相商。 来，拜上霍师父，修书不及，随后就到。"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "是，遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑老道下。"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "来，有请二位寨主。"
        },
        {
          "character": "喽啰甲",
          "type": "白",
          "text": "有请二位寨主！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘明业上。"
        },
        {
          "character": "潘明业",
          "type": "念",
          "text": "弟兄霸占金鸡岛，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谢美成上。"
        },
        {
          "character": "谢美成",
          "type": "念",
          "text": "不杀赃官恨怎消！"
        },
        {
          "character": "潘明业、谢美成",
          "type": "同白",
          "text": "参见大哥！"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "二位贤弟少礼。请坐。"
        },
        {
          "character": "潘明业、谢美成",
          "type": "同白",
          "text": "谢坐。唤小弟出来，有何金言？"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "二位贤弟，九天宫霍师父有书前来，请你我弟兄，有大事相商。"
        },
        {
          "character": "潘明业、谢美成",
          "type": "同白",
          "text": "大哥，但不知几时时程？"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "即刻起程。"
        },
        {
          "character": "潘明业、谢美成",
          "type": "同白",
          "text": "好。 喽啰带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八喽啰自两边分下。雷燕喜、潘明业、谢美成同骑马下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王洪、于治同上。"
        },
        {
          "character": "王洪",
          "type": "唱",
          "text": "只望行刺威名显，"
        },
        {
          "character": "于治",
          "type": "唱",
          "text": "灭却天霸杀赃官。"
        },
        {
          "character": "王洪、于治",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "王洪。"
        },
        {
          "character": "于治",
          "type": "白",
          "text": "于治。"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "师弟请了！"
        },
        {
          "character": "于治",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "王洪",
          "type": "白",
          "text": "你我奉了师父之命，行刺赃官施不全，是他等预备灯光，照如白昼。早有准备， 难以下手。你我不免回庙，报与师父知道便了。"
        },
        {
          "character": "于治",
          "type": "白",
          "text": "请哪！"
        },
        {
          "character": "王洪",
          "type": "唱",
          "text": "弟兄二人往前趱，"
        },
        {
          "character": "于治",
          "type": "唱",
          "text": "见了师父说一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王洪、于治同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸上。"
        },
        {
          "character": "黄天霸",
          "type": "引子",
          "text": "幼习武艺，论韬略，盖世无比。"
        },
        {
          "character": "黄天霸",
          "type": "念",
          "text": "侠义英雄弃绿林，增光耀祖换门庭。拿强捕盗归正路，铜心铁胆腹内存。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "俺、黄天霸。乃江南绍兴府金华县人氏。弃却绿林，归顺施公。每逢拿强捕盗， 也非容易。今日闲暇无事，不免到衙门中走遭也。"
        },
        {
          "character": "黄天霸",
          "type": "唱",
          "text": "结交绿林江湖上， 归顺施公保朝堂。 但愿后来功名望， 愿效犬马保忠良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "霍炳上。四大老道、四小老道自两边分上。"
        },
        {
          "character": "霍炳",
          "type": "引子",
          "text": "身入玄门，归三宝，压服绿林。"
        },
        {
          "character": "霍炳",
          "type": "念",
          "text": "四面八方俺为尊，江湖豪杰入玄门。杀人放火如谈笑，好酒贪花快乐心。"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "某，姓霍名炳，江湖人称银面瘟神，乃江都县人氏。身在绿林。只因伤害人命 甚多，官兵拿俺甚紧。来在五里碑九天宫，带发出家，身入玄门。可恨赃官施 不全，收下天霸等，灭却绿林。将我两个徒弟，拿去斩首在江都县。是俺命王 洪、于治，前到公馆行刺，又恐不能成功。我也曾命人前往金鸡岛，去请雷、 潘、谢三位贤弟，这般时候，还未见到来。 来，伺候了！"
        },
        {
          "character": "四大老道、四小老道",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "丑老道上。"
        },
        {
          "character": "丑老道",
          "type": "念",
          "text": "忙将寨主事，回报师父知。"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "启老师：雷、潘、谢三位寨主到。"
        },
        {
          "character": "雷燕喜",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": "丑老道",
          "type": "白",
          "text": "吓，有请三位寨主！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷燕喜、潘明业、谢美成同上。"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "吓，霍师父！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "吓，三位贤弟！"
        },
        {
          "character": "霍炳、雷燕喜、潘明业、谢美成",
          "type": "同笑",
          "text": "吓，哈哈哈！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "不知三位贤弟驾到，未曾远迎，面前恕罪。"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "我等来得卤莽，霍师父海涵！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "霍师兄相邀，有何见谕？"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "三位贤弟，你我绿林之中，什么为先？"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "义气为先。"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "可恨赃官施不全，屡与绿林英雄作对。是俺请三位贤弟到来，定下一计，灭却 赃官，以去绿林后患！"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "霍师父之言，正合我等之意。怎奈无有机会，难以下手，也是枉然。"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "俺曾命王洪、于治，前去行刺。去了数日，未见音信。是俺放心不下，请三位 贤弟到来，以作计较。"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "有我弟兄三人，料无妨碍。若是不回，待等明日，我三人前去探听信息便了。"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "全仗三位贤弟了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王洪、于治同上。"
        },
        {
          "character": "王洪、于治",
          "type": "同白",
          "text": "走吓！ 参见师父！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "罢了。见过三位寨主。"
        },
        {
          "character": "王洪、于治",
          "type": "同白",
          "text": "吓，参见三位寨主！"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "王洪、于治",
          "type": "同白",
          "text": "谢坐。"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "命你二人公馆行刺，为何今日才回，大功可成？"
        },
        {
          "character": "王洪、于治",
          "type": "同白",
          "text": "是我二人前去，指望成功，不想灯光照如白昼，难以下手。又打听得王有义在 江都县喊冤告定，特来回禀知道。"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "吓，前番王有义夫妇，在此经过。偶遇暴雨，天色已晚，在此借宿。是俺见那 妇人生得有几分美色，用银钱打动，谁想他执意不从。是俺怒恼心头，一时火 起，就要乱棍将他打死。好一个伶俐的妇人，再三哀求，饶他不死。赏他纹银 十两，写下文约一张，放他还乡。谁想他大胆，竟敢在江都县将俺告定！"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "霍师兄但放宽心，那赃官不差人前来便罢。若是差人前来，我弟兄三人，定然 与他一死相拼！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "全仗三位贤弟了。"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "太谦了吓！"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "徒弟们，将酒宴摆在禅堂，与众位英雄畅饮一番。"
        },
        {
          "character": "雷燕喜、潘明业、谢美成",
          "type": "同白",
          "text": "请哪！"
        },
        {
          "character": "霍炳",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐茂上。"
        },
        {
          "character": "徐茂",
          "type": "唱",
          "text": "适才领了施公命， 寻找无名少姓人。"
        },
        {
          "character": "徐茂",
          "type": "白",
          "text": "俺，徐茂。施太爷命俺私访狂徒恶霸，无名少姓之人。咳，可恨王有义，这厮 告下这样不明不白状词，叫我哪里去寻，哪里去访？咳，好不闷坏人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "咳，这不是徐头儿吗？在这一个人，什么事情自言自语的？"
        },
        {
          "character": "徐茂",
          "type": "白",
          "text": "俺有心事在怀吓！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "有什么事情？到我这酒铺吃杯酒，我与你解劝解劝心事。"
        },
        {
          "character": "徐茂",
          "type": "白",
          "text": "改日再去吃酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "往常吃酒，不来总来三两趟。走罢，走罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保拉徐茂同走小圆场。"
        },
        {
          "character": "徐茂",
          "type": "白",
          "text": "吃几杯就吃几杯。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "请进来罢，徐头儿。"
        },
        {
          "character": "徐茂",
          "type": "白",
          "text": "荡酒去。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "伙计们，荡上两壶白干。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伙计内应。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "酒到，我给你斟上。"
        },
        {
          "character": "徐茂",
          "type": "白",
          "text": "咳，有劳了。"
        },
        {
          "character": null,
          "type": "stage",
