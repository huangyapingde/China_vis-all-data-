    },
    {
      "name": "蔡瑁",
      "hangdang": "净"
    },
    {
      "name": "张允",
      "hangdang": "净"
    }
  ],
  "plot": "曹操因为刘备得到诸葛亮用为军师，非常畏忌，知道对于自己必定不利，所以特命徐庶来招降。哪知徐庶深\n恨曹操赚他脱离刘备，一方又很感刘备待遇之恩；所以身虽在曹誓不为曹操设一谋，定一策。此次前来招降，\n反代刘备谋划逃走之法；既然会见诸葛亮，告知曹操声势浩大，不可抵敌，只有避让方妥。于是先叫关公\n到江夏刘琦处借兵，再叫张飞、赵云保护百姓和刘备的家眷逃避。及至到了荆州，刘琮听信了蔡瑁的谗言，\n不让刘备进城。这时魏延在荆州，有心归降刘备，所以私自开放城门，反被文聘打败，逃到长沙韩玄处。徐\n庶回见曹操，告知刘备不肯投诚，现已逃去。曹操一听大怒，当时率领大兵追赶。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "执掌乾坤，破孙刘，豹略龙韬。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "我本盖世一英雄，曾破黄巾立奇功。赏罚不能由献帝，汉室已在掌握中。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操。汉室为臣。自扫灭吕布，献帝甚喜，封我丞相之职。可恨桃园弟兄， 居住汉阳，实乃心腹大患。今又得诸葛辅助，如困龙得水，恐一日得志，不 可制也。我意欲填塞白河，今大军分作八路，一齐来取樊城。不免唤刘晔进帐 商议。 来。"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传刘晔进帐。"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "是。 传刘晔进帐。"
        },
        {
          "character": "刘晔",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘晔上。"
        },
        {
          "character": "刘晔",
          "type": "念",
          "text": "满腹藏经纶，逢识已为明。"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "免礼。"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "唤某进帐，有何军情议论？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "我想刘备是我心腹大患，意欲分兵去取樊城，你看如何？"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "我想丞相初至襄阳，必须先买民心。今刘备尽迁新野百姓入樊城。若我兵径进， 变为齑粉矣。不如先使人招降刘备，备既不降，亦可见吾爱民之心；若其来 降，则荆州之地可不战而定也。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此计甚善。谁人可以为使？"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "徐庶与刘备甚厚，现在军中，何不命他一往？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "他去恐不复来。"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "他若不来，贻笑于人。丞相勿疑。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "既如此，命他前往。速传徐庶进帐。"
        },
        {
          "character": "刘晔",
          "type": "白",
          "text": "是。 丞相有命：传徐庶进帐。"
        },
        {
          "character": "徐庶",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "老母虽然丧泉下，心中难忘刘主恩。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生免礼。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢丞相。唤庶进帐，有何差遣？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "可恨刘备，火烧新野，将百姓移入樊城。我本欲分兵八路，踏破樊城，奈众百 姓之命，公可往说刘备。若肯来降，吾免罪赐爵；若更执迷，军民共戮，玉石 俱焚。我知公忠义，故使公一往。愿勿相负。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "丞相吩咐，敢不遵命。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有劳先生。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "就此去也。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "正好借此将刘报， 暗透消息放他逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "今遣说客汉阳到， 静候回音再作计较。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、刘晔同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "心儿里恨曹操做事有错， 欺天子压诸侯行事太恶。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "山人姓徐名庶字元直。昔日在刘皇叔驾前为臣。辞别皇叔，归降曹操。曹操乃 奸诈之徒，设下调虎离山之计，要害桃园弟兄。想刘皇叔待我情同骨肉，尚未 报答。今奉曹操之命，一来下书，二来走漏风声，放他君臣逃走，脱离此难便 了。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "设下了牢笼套瞒哄诸葛， 汉阳院走风声叫他逃脱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、糜竺、糜芳、简雍、诸葛亮、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "心中悲痛汉刘表， 劣子无谋降于曹。 我兵微薄将又少， 不能擒逆扶汉朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙乾上。"
        },
        {
          "character": "孙乾",
          "type": "西皮摇板",
          "text": "适才军士来禀报， 元直到此甚蹊跷。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "启禀主公：徐先生到。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哪个徐先生？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "必是徐元直到了。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，孤可相见于他？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他前在主公帐下，焉有不见之理？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "如此快快有请。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且慢。他今到此不是下书，定是说降，待山人且退屏风后面，听他说些什么， 也好作燃眉之计。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生且退。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人告退。正是："
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "千丈黄河探到底，惟有人心最难评。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有请徐先生。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "皇叔有请徐先生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "念",
          "text": "明来下书信，暗是漏真情。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣徐庶见驾，主公千岁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生请起。请坐。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "伯母康安？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣母不幸，故世曹营。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "山遥路远未曾吊祭伯母，实为抱歉。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣未来报丧，恕臣之罪。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "岂敢。先生驾临，有何见谕？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "奉曹丞相之命，特来下书。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "下的何书？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "书信在此，主公请看。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤王看书，无人奉陪先生。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "臣独坐一时，又待何妨。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤王有罪了。"
        },
        {
          "character": "刘备",
          "type": "西皮导板",
          "text": "与卿家分别有数载，"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "今日相逢天降来。 孤王看书你休怪， 一封书信亲手开。 上写曹操顿首拜， 皇叔台前问安泰： 东吴孙权，"
        },
        {
          "character": "刘备",
          "type": "西皮流水板",
          "text": "争地界， 约定赤壁把兵排。 曹、刘二家合一快， 得了东吴四六开。 看罢书信忙揣怀， 有劳先生远路来。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公，信内什么情由？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "曹、刘二家兵士合在一处，得了东吴，地界平分。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公意下如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮内嗽。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "何人痰嗽？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "乃是诸葛先生。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "请来相见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请先生进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "徐先生在此，上前相见。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊，师兄！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "恭喜主公，今得卧龙先生扶保，如鱼得水，指日汉室可兴，真乃天下之幸也。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吾得卧龙扶助，皆赖先生举荐之力也。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "此乃主公洪福。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "师兄不在曹营，到此有何见教？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "启主公：那曹操使某前来招降使君，实乃假买人心，请君裁处。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生既肯降临，有何良策，何妨教我，定当听从。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊，师兄，不要忘了旧日之情，须当替主公筹划良策，使我君臣转祸为福。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "那曹操本欲踏平樊城，奈怜百姓之命，因此命庶前来说降。使君如肯来降，免 罪赐爵；若更执迷，军民被戮，玉石俱焚。今曹操分兵八路填白河而进，樊城 恐不可守。宜速作计较，不可久停矣。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "啊，师兄言曹操分兵八路，填白河而进。我军虽寡，既有关、张、赵云勇冠三 军，万夫难当。前弟略施小计，火烧新野，杀得曹操望风丧胆，何惧他八路分 兵！"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "你知曹操现有多少人马？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "八十三万。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "约荆襄九郡有多少人马？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "二十八万。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "共在一处，有多少人马？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "一百一十一万。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "好啊。你保刘主，兵不满千人，将不足十员；那曹操人马遮天盖日而来，关、 张英雄，也难御敌也！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "人生祸福实难料， 可叹奔返枉徒劳。 安居未稳曹兵到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备哭。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "怎能弃民自奔逃。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公啊。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "既爱百姓寻安巢，"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "仁德之心如唐尧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人亦算定，我君臣有一大难，不料应在目前。有了，待我将计就计，在他面 前领教便了。 小弟有礼。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟施礼为何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "听兄之言，我君臣大难将临，望兄指弟一条明路。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟，你上知天文，胸藏谋机，难道还没有计策吗？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "岂不知忙中无计？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "我这里有锦囊一封，你去看来。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "呵呀，未来之事，他早已算透。有了。 师兄，这锦囊上面情由，皆打参不透，还要在师兄台前领教。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "师弟听了。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "弟兄们同坐汉阳营， 细看锦囊上面情： 汉业至今四百零，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我保刘主，尚未得地，怎么就知四百有零？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "非也。自汉高祖斩蛇以来，相传至献帝，可有四百余载？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "不错，有四百余载。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "却又来。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "建安登基出三雄。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哪三雄？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "奸雄曹操，英雄孙权，枭雄刘……"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "噤声！"
        },
        {
          "character": "徐庶、诸葛亮",
          "type": "同笑",
          "text": "哈哈哈……"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "三国不和刀兵动， 荆襄王有子与无同。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "荆襄王现有二子，长子刘琦，次子刘琮，怎说无有？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "只因蔡君不贤，废长立幼，文武不服，百姓皆怨，他将荆襄九郡献与曹操，曹 操不仁，将他母子贬于青州，又差于禁在途中将母子谋害。有子不能承父业， 岂不是无子么？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "看起来，尽是丧家之犬也。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "走虎飞去又逃龙，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这“走虎逃龙”是什么人？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "就是关公。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "他乃有名之将，倘若败阵岂不失了将军一世威名？还要避过此阵才好。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "江夏刘琦那里有二十五万铁甲雄兵，遣他前去借兵，可以避过此难。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "这“逃龙”是谁？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "附耳上来，记下了："
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "长坂坡前救真龙。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "真龙敢是皇叔？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "非也。玄德不过创业之主，后出阿斗，有四十二年天下，那才是你的真主。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我定要保皇叔一统天下。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "贤弟不可逆天行事。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "师兄啊。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "皇叔三顾把我请， 知遇之恩常在心。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "自古天数早造定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备上。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "刀兵滚滚何日宁？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，军务之事，可曾说明？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "一一听从。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "主公还是弃了百姓，速去为妙。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "数万百姓，从新野相随至此，不忍弃之。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "庶去回复，曹操刀兵即至。若不速行，悔之晚矣。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "师兄放心，吾主必然听从。师兄回至曹营，须要暗护我主，以表旧日之情。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "我若得机会，必然暗助。庶今告辞去也。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "依我之见，先生不要回去，就在此同诸葛扶助孤刘，必然稳如磐石矣。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "本当效犬马之劳，今当不回，惹人笑我。今老母已丧，抱恨终天。身虽在彼， 誓不为设一谋。公有卧龙扶助，何愁大事不成？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生执意要去，亦不敢强留。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你我弟兄日后哪里相逢？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "在南屏山相逢便了。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "主公速行方为妙， 曹兵到来恐难逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "徐庶不忘旧日好， 先生从速作计较。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "启主公：江夏大公子刘琦那里，还有二十五万铁甲雄兵，不免命二千岁前去搬 兵。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "家眷何人保护？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "家眷付与四将军保护，料无遗失。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "来，请二将军进帐。"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "是。 主公请二将军进帐。"
        },
        {
          "character": "关羽",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "山崩地裂乾坤乱， 扰动山河社稷川。 丹心一点重扶汉， 未知何日太平年。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "参见大哥。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "贤弟免礼。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "唤弟进帐，有何军情议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生有差。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "先生有何差遣？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今曹操统领大兵八十三万，分八路而进，前来攻取我军。我军单薄，孤城难守。 命二将军去至江夏公子刘琦那里搬兵，不得有误。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某前去搬兵，何人保护大哥的家眷？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "有三将军、四将军把守，料然无事。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某在何处接驾？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "在汉津接驾。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "好，某就此前往。"
        },
        {
          "character": "关羽",
          "type": "西皮摇板",
          "text": "辞别大哥跨走战， 我去到江夏把兵搬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "来，请三将军、四将军进帐。"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "是。 先生有请三将军、四将军进帐。"
        },
        {
          "character": "张飞、赵云",
          "type": "内同白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "人如金刚马如龙，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "文要精来武要通。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "同破黄巾威名重，"
        },
        {
          "character": "赵云",
          "type": "念",
          "text": "忠心保主炎汉兴。"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "参见主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "免礼。"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "唤进帐来，有何议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生有差。"
        },
        {
          "character": "张飞、赵云",
          "type": "同白",
          "text": "先生有何差遣？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今有曹操统领八十三万人马而来，此处孤城难守，欲命四将军保护主公家眷， 须要小心。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "末将受主公知遇之恩，保护家眷，万死不辞。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "赵云，你保护敢说无虑么？"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "三将军，你好小量人也！"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "常言忠义能尽命， 何惧曹操百万兵。"
        },
        {
          "character": "张飞",
          "type": "西皮摇板",
          "text": "你保家眷难凭信， 怕你能说不能行。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "翼德且莫要争论， 赵云岂是说空言人？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "启主公：可速弃城而走。先取江陵为家，不可迟误。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，奈百姓相随已久，安忍弃之而走。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公既然难舍百姓，何不遍告他们：愿者跟随前去，不愿者留下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好，正合我意。 简雍速晓谕百姓：曹兵将至，孤城不能久守，众百姓愿者同走，不愿者听其自 便。"
        },
        {
          "character": "简雍",
          "type": "白",
          "text": "遵命。 众百姓听者：今曹兵将至，孤城难守，主公有命，原随者便前往，不愿者听其 自便。"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "我等虽死，愿随使君前往。"
        },
        {
          "character": "简雍",
          "type": "白",
          "text": "好，待我与你们回禀。 启主公：众百姓情愿相随。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "好，叫他们各自收拾齐备，听候起行。"
        },
        {
          "character": "众百姓",
          "type": "内同白",
          "text": "哦。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣启主公：二将军去江夏搬兵，仍恐大公子刘琦不能从速救应，必须山人亲身 一往，复催兵将，方不误事。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "刘琦感念先生昔日之教，就烦先生亲走一遭。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人就此告辞。"
        },
        {
          "character": "诸葛亮",
          "type": "西皮摇板",
          "text": "主公速行莫迟延， 亮到江夏催救援。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请二位主母。"
        },
        {
          "character": "龙套",
          "type": "同白",
          "text": "请二位主母。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同上。"
        },
        {
          "character": "甘夫人",
          "type": "西皮摇板",
          "text": "日夜忧思心不定，"
        },
        {
          "character": "糜夫人",
          "type": "西皮摇板",
          "text": "曹操累害我夫君。"
        },
        {
          "character": "甘夫人",
          "type": "西皮摇板",
          "text": "一县之主身未稳，"
        },
        {
          "character": "糜夫人",
          "type": "西皮摇板",
          "text": "奔走何日得安宁。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "夫君，唤妾等出来何事？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "今有曹操兴兵前来，此城不能久守，故唤你们出来，一同逃走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "甘夫人、糜夫人同哭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不必啼哭。看衣更换。 三弟，你催百姓，一同赶行。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！众百姓听者：愿随俺大哥者，一同赶路。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "曹操人马要临境， 孤城岂能久存身。 急速江夏去逃奔，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下，众人同下。"
        },
        {
          "character": "赵云",
          "type": "西皮摇板",
          "text": "保家责任在我身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云下。"
        }
      ]
    },
    {
