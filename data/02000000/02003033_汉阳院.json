          "text": "四船夫引孙乾同上。"
        },
        {
          "character": "孙乾",
          "type": "白",
          "text": "俺，孙乾。奉了主公之命，预备船只，渡民过江，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、众百姓、糜芳、简雍、张飞、赵云、甘夫人、糜夫人、刘备同上船。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "船已载满百姓，后来者不能渡也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众百姓同哭。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "咳！我一人使百姓遭此大难，我何生哉！不如投江一死，以报百姓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备欲投江。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公若寻短见，岂不使百姓失望？保重身体，亦不失主公爱民之心。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同白",
          "text": "是吓。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吩咐速速渡百姓过江。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
