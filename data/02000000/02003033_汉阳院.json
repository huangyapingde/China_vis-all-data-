      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "刘备实乃心腹患， 困龙不擒必升天。 徐庶顺说未回转， 恐他不肯归降咱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶上。"
        },
        {
          "character": "徐庶",
          "type": "西皮摇板",
          "text": "顺说无成徒往返， 回报丞相托谎言。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "刘备降意如何？"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "刘备却还有意，怎奈孔明阻扰，不肯归降。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生后面歇息。"
        },
        {
          "character": "徐庶",
          "type": "白",
          "text": "谢丞相。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐庶下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "刘备既不肯归降，必弃城而走。待我传令点动大军，四路捉拿桃园弟兄便了。 正是："
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "点动大军阻去道，谅他插翅亦难逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下，四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
