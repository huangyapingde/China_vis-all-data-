        {
          "character": "众人",
          "type": "同白",
          "text": "花轿已去，老英雄怎样行事？"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "将腰牌带好，收拾一同前去便了。正是："
        },
        {
          "character": "鲍自安",
          "type": "念",
          "text": "安排打虎牢笼套，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "虎穴龙潭走这遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
