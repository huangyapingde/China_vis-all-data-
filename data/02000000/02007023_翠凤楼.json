          "type": "stage",
          "text": "张用上。"
        },
        {
          "character": "张用",
          "type": "白",
          "text": "老人家哪里，老人家哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲍自安上。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "来了，何事？"
        },
        {
          "character": "张用",
