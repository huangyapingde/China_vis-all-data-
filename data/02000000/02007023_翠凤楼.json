        {
          "character": "鲍自安",
          "type": "白",
          "text": "腰牌有了，轿搭中堂，新人要上轿。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "将轿抬上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "栾守礼下，轿子上，众人同吹打，同下。众人同看。"
