        {
          "character": "鲍自安",
          "type": "白",
          "text": "女儿不肯上轿，你不回去，你要怎么样？"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "老人家，你家人也不少，不拘谁送亲就是。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "我们去得？"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "男子去不得，有妇人就去得的。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "无有妇人，就有一丫鬟。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "丫鬟姐，就送过去的。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "去得的？还有一件，黑夜娶去，不知门户。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "哎呀哎呀，城内张府，谁人不知，一问就找着了。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "无有腰牌，谁能城中行走？"
        },
        {
          "character": "栾守礼",
