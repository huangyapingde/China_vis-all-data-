      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四文官同上，贺喜，过场，同下。四大铠、曹林、曹风、武忠、武勇同上，贺喜，过场，同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "冯洪、余千、骆宏勋、濮天鹏、花振芳、鲍自安同上，同起霸。"
        },
        {
          "character": "众人",
          "type": "同粉蝶儿",
          "text": "巧改扮夤夜私行， 为国家削除奸佞。 奋雄心抖起精神， 哪怕他龙潭虎穴轻身同奔。"
        },
        {
          "character": "众人",
          "type": "白",
          "text": "俺——"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "鲍自安。"
        },
        {
          "character": "花振芳",
          "type": "白",
          "text": "花振芳。"
        },
        {
          "character": "花碧莲",
          "type": "白",
          "text": "花碧莲。"
        },
        {
          "character": "鲍金花",
          "type": "白",
          "text": "鲍金花。"
        },
        {
          "character": "骆宏勋",
          "type": "白",
          "text": "骆宏勋。"
        },
        {
          "character": "濮天鹏",
          "type": "白",
          "text": "濮天鹏。"
        },
        {
          "character": "余千",
          "type": "白",
          "text": "余千。"
        },
        {
          "character": "冯洪",
          "type": "白",
          "text": "冯洪。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "贤弟此番前去若将奸人斩尽。其功非小。"
        },
        {
          "character": "花振芳",
          "type": "白",
          "text": "仁兄杀尽奸人，逃出都城，狄千岁不能见面，也是大事难成。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "不妨，无有奸人，狄千岁必能见面。太子一定还朝。"
        },
        {
          "character": "濮天鹏",
          "type": "白",
          "text": "二位老人家，如此忠心，必定成功也。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "花轿去远急急前去便了。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "众人",
          "type": "同粉蝶儿",
          "text": "全凭着狮虎心除恶安良， 管他魂胆丧，奸雄废命。 还须是秉忠心扶保乾坤， 方显得美英雄，声名远振。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（栾守礼、四青袍、院子、四鼓手、轿子同上，过场，〖吹打〗，同下。冯洪、余千、骆宏勋、濮天鹏、花"
        },
        {
          "character": null,
          "type": "text",
          "text": "振芳、鲍自安同上。）"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "呀！"
        },
        {
          "character": "众人",
          "type": "同石榴花",
          "text": "俺只见灯光缭绕，月色莹明， 鼓声震动，梦中人悄低声影。 步暗地私行， 全凭侠义志， 扫灭虎狼群。 哪怕他百万官兵， 哪怕他百万官兵。 轻身入穴伤贼命， 此前行探取奸人。 暗地里安排阴兵阵， 管叫他亡魂丧胆赴幽冥。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "来此已是。"
        },
        {
          "character": "花振芳",
          "type": "白",
          "text": "大家飞身上去。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "且慢，候碧莲儿前来一同上去，且随俺来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张天佐上。"
        },
        {
          "character": "张天佐",
          "type": "引子",
          "text": "喜耀门庭，来恭贺，百辆迎门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "众位大人到。"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、四文官、四武官、四青袍、栾守礼同上。"
        },
        {
          "character": "栾守礼",
          "type": "念",
          "text": "奉命娶新人，喜庆降豪门。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "启太爷：花轿到。"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "轿搭中堂，交拜天地。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "太师吩咐：轿搭中堂，交拜天地。 （张用、四青袍、院子、四鼓手、轿子同上，同下。冯洪、余千、骆宏勋、濮天鹏、花振芳、鲍自安同上， 鲍金花上，众人同下。张胜忠上。）"
        },
        {
          "character": "张胜忠",
          "type": "白",
          "text": "且住，花轿到来，怎不见武家有人，前来送亲，莫非有变？也罢，待俺去至洞 房观看，若不是武家之女，我就是这一刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张胜忠下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鲍金花、花碧莲同上。张用上。"
        },
        {
          "character": "张用",
          "type": "白",
          "text": "姐姐，姐姐，别叫新人哭了，大爷有气了，哭不出好来，轻者是打，重者就不 得了。"
        },
        {
          "character": "花碧莲",
          "type": "白",
          "text": "怎么样？"
        },
        {
          "character": "张用",
          "type": "白",
          "text": "我是个大好人。"
        },
        {
          "character": "花碧莲",
          "type": "白",
          "text": "你是个好人。"
        },
        {
          "character": "张用",
          "type": "白",
          "text": "我是好人。"
        },
        {
          "character": "花碧莲",
          "type": "白",
          "text": "杀你狗日的。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "花碧莲杀死张用，下。张天佐、栾守礼同上。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "吓，公子，太师请你来吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张胜忠上，怒。"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "儿吓，事到如今，还与父生气么。"
        },
        {
          "character": "张胜忠",
          "type": "白",
          "text": "爹爹，洞房之女，她是何人？"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "她是武家之女。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "既是武家之女，缘何不见武家有人前来送亲？"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "这个……哎呀，儿吓，娶进门来，就是儿的亲事，若是不好，将她赶出府去， 谁敢拦阻。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "着哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯洪、余千、骆宏勋、濮天鹏、花振芳、鲍自安同上，同亮相。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "吓，太师之言说的极是，公子请到前堂去吧。"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "儿吓，随为父的饮酒来呀。"
        },
        {
          "character": "张天佐",
          "type": "笑",
          "text": "吓哈哈哈哈！"
        },
        {
          "character": "张天佐",
          "type": "白",
          "text": "来呀。 （张天佐、张胜忠、栾守礼同下，同上，众人杀死张天佐、栾守礼，张胜忠败下，众人同放火烧。四红龙套、 会阵，起打。众人同败下，凹门同上。）"
        },
        {
          "character": "四红大铠、四上手、四下手、曹林、曹凤、武忠、武勇同上，同站门。张胜忠上，众人过场，同下，同上、花振芳",
          "type": "白",
          "text": "老英雄，你看官兵甚众，如何是好？"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "腰牌在身旁，大家诈出城门，再作道理。"
        },
        {
          "character": "花振芳",
          "type": "白",
          "text": "好哇，大家前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走小圆场。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "呔开城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二城军同上。"
        },
        {
          "character": "二城军",
          "type": "同白",
          "text": "可有腰牌取来？"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "有腰牌在此。"
        },
        {
          "character": "二城军",
          "type": "同白",
          "text": "果有腰牌，开城。 （冯洪、余千、骆宏勋、濮天鹏、鲍金花、花碧莲、花振芳、鲍自安同出城，同下。张胜忠、四红龙套、四 红大铠、四上手、四下手、曹林、曹凤、武忠、武勇同追上。）"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "贼人不见。"
        },
        {
          "character": "总兵",
          "type": "白",
          "text": "收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
