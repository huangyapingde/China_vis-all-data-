          "text": "吓，老人家，吉时已到，请新人上轿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲍自安上。"
        },
        {
          "character": "鲍自安",
          "type": "白",
          "text": "新人不曾收拾，少待一时。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "来，再吹打吹打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。张用上。"
        },
        {
          "character": "张用",
          "type": "白",
          "text": "吓，大人腰牌有了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张用下。"
        },
        {
          "character": "栾守礼",
          "type": "白",
          "text": "腰牌有了。 吓，老人家，腰牌来了。"
