        {
          "character": "韩彦直",
          "type": "白",
          "text": "唤孩儿出见，有何吩咐？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "圣上命孙浩督兵，前来征剿金人，那贼从飞龙岭迎敌金兵去了。命尔带领人马， 暗地保护，倘有差池，提头来见。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩彦直下。"
        },
        {
          "character": "韩彦直",
          "type": "白",
          "text": "众将官，催动人马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四宋兵、四将、中军、韩世忠同下。"
        }
