{
  "script_id": "02010018",
  "title": "雄州关",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "韩世忠",
      "hangdang": "老生"
    },
    {
      "name": "韩彦直",
      "hangdang": "武生"
    },
    {
      "name": "孙浩",
      "hangdang": "净"
    },
    {
      "name": "金兀术",
      "hangdang": "净"
    }
  ],
  "plot": "金兀术南犯攻下潞安州后，继续南下，进攻雄州关。时镇守雄州关者为韩世忠，因为兵力单薄请求救兵。蔡\n京与宦官童贯狼狈为奸，派孙浩领兵救援。惟孙浩曾隶韩世忠部下，因犯军令被韩世忠责打四十大板。后乃\n逃奔京师，在童贯府中当差，此刻竟充任总兵。复因韩世忠不亲自出迎，竟不与韩世忠联络，直接与金兀术\n交锋。韩世忠明知孙浩非金兀术对手，深恐有失，被朝廷责斥，乃令其子韩彦直暗中前往保护。不意孙浩与\n金兀术交锋后，被金兀术打落马下。韩彦直冲入金营，虽得小胜，但未能将孙浩救出。韩世忠闻知后，责其\n子未能贯彻任务，欲将其斩首，经诸将求情始罢。韩世忠与金兀术亲自交战，始将金击退。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "呼呔狄上，起霸。"
        },
        {
          "character": "呼呔狄",
          "type": "念",
          "text": "百万貔貅犯中原，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷洪切上，起霸。"
        },
        {
          "character": "雷洪切",
          "type": "念",
          "text": "搅乱宋室不安然；"
        },
        {
          "character": null,
          "type": "stage",
          "text": "达林呈上，起霸。"
        },
        {
          "character": "达林呈",
          "type": "念",
          "text": "渴时常饮刀头血，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "季乐芬上，起霸。"
        },
        {
          "character": "季乐芬",
          "type": "念",
          "text": "饥馁人肉当饭餐。"
        },
        {
          "character": "呼呔狄、雷洪切、达林呈、季乐芬",
          "type": "同白",
          "text": "俺——"
        },
        {
          "character": "呼呔狄",
          "type": "白",
          "text": "金邦大将呼呔狄。"
        },
        {
          "character": "雷洪切",
          "type": "白",
          "text": "金邦副将雷洪切。"
        },
        {
          "character": "达林呈",
          "type": "白",
          "text": "左先锋达林呈。"
        },
        {
          "character": "季乐芬",
          "type": "白",
          "text": "右先锋季乐芬。"
        },
        {
          "character": "呼呔狄",
          "type": "白",
          "text": "众位将军请了。"
        },
        {
          "character": "雷洪切、达林呈、季乐芬",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "呼呔狄",
          "type": "白",
          "text": "你我奉狼主之命，跟随四太子领兵夺取宋室江山，兵到即克。也当徽宗气数当 尽，咳，这些蛮子怎能苦争恶战，这是我狼主洪福齐天也！"
        },
        {
          "character": "呼呔狄、雷洪切、达林呈、季乐芬",
          "type": "同白",
          "text": "号角声响，太子升帐也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金兀术上。"
        },
        {
          "character": "金兀术",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，军威浩，地动山摇，要把宋室扫！"
        },
        {
          "character": "金兀术",
          "type": "念",
          "text": "杀气腾腾满乾坤，哀声处处震天庭。徽宗失政宠奸佞，锦绣江山一旦顷。"
        },
        {
          "character": "金兀术",
          "type": "白",
          "text": "孤，金邦四太子兀术是也。宋室徽宗无道，宠信奸臣。内奸童贯封为广杨之职。 前有密书到孤父王处，约定期内兴兵，夺取社稷。童贯以为内应，这江山岂 不是唾手而得。自兴兵以来，战无不胜，攻无不取。前者破了潞安州，守将陆 登自刎身亡，甚为悲惨。前面乃是雄州关，守将韩世忠。此人亦是忠勇之士， 不忍逼之过甚。意欲招他归顺，助孤一臂之力，何愁大事不成。 众番儿，兴兵已至雄州关，不可擅杀百姓，违令者斩。催动人马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "探马上。"
        },
        {
          "character": "探马",
          "type": "引子",
          "text": "短甲随身，衲襖齐肩上。横担令字旗，年年岁岁，领皇赏。一马冲到军队里。"
        },
        {
          "character": "探马",
          "type": "白",
          "text": "俺乃韩元帅麾下能行探子是也。奉了元帅将令，着俺四路哨探。今圣上差孙浩 督兵，前来剿灭金邦，已到三山口。不免飞骑报与元帅知道便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探马下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "韩世忠",
          "type": "内西皮导板",
          "text": "为金兵急得我神魂不定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩世忠上。"
        },
        {
          "character": "韩世忠",
          "type": "西皮三眼",
          "text": "盼救兵望眼穿昼夜不宁。 陆元帅尽忠心自刎丧命， 只一子失陷在万马军营。 好叫我忍不住腮边泪滚，"
        },
        {
          "character": "韩世忠",
          "type": "西皮二六板",
          "text": "可叹他夫妻们饮恨幽冥。 急公文求圣上遣将助阵， 因何故十数日渺无信音。 在二堂心无计心中忧闷， 我父子只恐怕难敌雄兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "报马如飞急，叩禀元帅知。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "启元帅：探马求见。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "吩咐升帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩世忠下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "升帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵自两边分上，韩世忠上。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "传探马。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "传探马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探马上。"
        },
        {
          "character": "探马",
          "type": "白",
          "text": "探马告进。 帅爷在上，探子叩头。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "哪路军情，起来讲。"
        },
        {
          "character": "探马",
          "type": "白",
          "text": "帅爷容禀："
        },
        {
          "character": "探马",
          "type": "念",
          "text": "一马哨探如流星，朝中差来孙总兵；十万人马到疆界，禀报元帅得知情。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "朝中没有什么姓孙的呀！"
        },
        {
          "character": "探马",
          "type": "白",
          "text": "在元帅麾下当过副将的。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "敢是孙浩？"
        },
        {
          "character": "探马",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "探马",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探马下。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "且住！想那孙浩，在某麾下曾当过副将。只因犯我军令，捆打四十，逃至京中 广杨府中，做一名随侍。今番奉旨前来，焉有不接之理。 传众将进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将进帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "四将",
          "type": "同念",
          "text": "虎将传军令，将士共趋迎。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "少礼！"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "元帅传末将等进帐，有何军情？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "圣上命孙浩督兵前来，征剿金人，现已到三山口。命你等前去接应。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "元帅，那孙浩缘何得授此职？倘若问及元帅，如何回答？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "听我令下！"
        },
        {
          "character": "韩世忠",
          "type": "西皮原板",
          "text": "韩世忠坐宝帐传言发令， 叫一声众将官细听详情： 那孙浩平日间为人不正， 犯军令责四十逃出军营。 逃至在京师地广杨府进， 童太尉听谗言朦胧圣君。 迎接他必须要言语谨慎， 那贼子记前仇暗地伤人。"
        },
        {
          "character": "四将",
          "type": "同西皮原板",
          "text": "韩元帅忠义士谁人不敬， 何惧那孙浩贼势利小人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同下。"
        },
        {
          "character": "韩世忠",
          "type": "西皮原板",
          "text": "大宋朝八代君徽宗失政， 贪酒色慢忠良宠信奸臣。 恨蔡京与童贯伤害民命， 惹得那四路里齐起刀兵。 金兀术兴人马抢夺州郡， 逼元戎伤军兵黎民遭倾。 众将官退大营各归营汛， 只等候四将回遣将调兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士引孙浩同上。"
        },
        {
          "character": "孙浩",
          "type": "引子",
          "text": "奉旨引雄兵，挂罗袍，不愧先人；定斩世忠，消吾恨，还报四十军刑。"
        },
        {
          "character": "孙浩",
          "type": "念",
          "text": "胸怀巧诈极聪明，不近贵人怎升腾？只道一生空劳力，运至时来命亨通。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "俺，孙浩，塞北人也。昔日在韩世忠麾下为步军，终日不守军法，专以花酒为 务。一日，抢一有夫之妇作乐，不想被韩世忠闻知，便要将俺斩首。是俺推在 步军列名身上，彼时将那步兵斩首。又道俺不守军规，捆打四十，削除头领， 赶出不用。是俺又羞又恼，一怒奔到京中。恰遇童太尉朝罢而归，是俺闯了他 的禁道，将我拿到府中拷问。不想，我将韩世忠打革之事诉上，那童太尉大怒， 言道：韩世忠啊，韩世忠，王爷若不杀你，誓不为人也！便将俺收在府中。 是俺百般奉承，受他重用。金兀术兴兵犯界，破数处城池。今又有雄州关韩世 忠本章进京，求将添兵。童太尉启奏一本，命俺领兵，前来剿灭金兵。若是得 胜，道韩世忠贪生怕死；若是损兵折将，道他按兵不举。慢说是一个韩世忠， 就是百个，也化为乌有。前面已是三山口，众将官，催动人马！"
        },
        {
          "character": "孙浩",
          "type": "唱",
          "text": "见旌旗空中飘人声喧震， 抖起了万丈尘沸沸腾腾。 曾记得到京都那般光景， 岂知道今日里督领雄兵。 韩世忠好比作儿童之分， 怎知晓暗中力要尔残生。 咱料他如南柯梦魂未醒， 绑云阳一命倾才晓前情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "雄州关总戎麾下四营将校迎接总爷。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "雄州关总戎麾下四营将校迎接总爷。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "四军士",
          "type": "同白",
          "text": "传。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "雄州关四营将校迎接总爷。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "你主帅有多大的官儿，怎么不来迎接本镇。"
        },
        {
          "character": "四将",
          "type": "白",
          "text": "启禀总爷：主帅为金兵临界，关内空虚，不敢擅离汛地，差末将等来迎总爷。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "住了！本镇钦奉圣命，广杨王的钧旨，领兵剿贼，你主帅也不看在眼中，待本 镇将尔等捆打四十军棍。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "总爷开恩。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "也罢，待本帅破了金兵回来，再与你主帅算账。 来，乱棍打出去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同下。"
        },
        {
          "character": "孙浩",
          "type": "白",
          "text": "催军！"
        },
        {
          "character": "孙浩",
          "type": "唱",
          "text": "定叫他主帅们无处逃遁， 少不得斩尔等碎尸粉身。 叫众将越过了飞龙奇岭， 扫尽了金兵贼奏报捷音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宋兵、中军引韩世忠同上。"
        },
        {
          "character": "韩世忠",
          "type": "唱",
          "text": "命四将接孙浩杳无音信， 好叫我背地里自思自忖。 必然他要报那从前仇恨， 可惜我空费了一片精神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "四将",
          "type": "同唱",
          "text": "贼孙浩忒无礼令人可恨， 全不念数年间共事同营。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "元帅！"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "你们回来了。"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "回来了。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "迎接孙浩可曾说些什么？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "末将等迎接孙浩，那厮问道：你主帅为何不来？"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "你等如何回答？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "末将等回道：关内空虚，不敢擅离汛地，命末将等前来迎接。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "那厮如何言道？"
        },
        {
          "character": "四将",
          "type": "同白",
          "text": "那厮言道：本镇钦奉圣命，广杨王的钧旨，领兵剿贼，你主帅有多大的官儿， 不来迎接本镇。本待将尔等捆责四十，待破金兵回来，再与你主帅算账。将末 将等用乱棍打了出来。"
        },
        {
          "character": "韩世忠",
          "type": "白",
          "text": "小人得志，以致如此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探马上。"
        },
        {
          "character": "探马",
