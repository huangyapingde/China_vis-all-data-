{
  "script_id": "02009040",
  "title": "红桃山",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "郑玉娥",
      "hangdang": "武旦"
    },
    {
      "name": "林冲",
      "hangdang": "生"
    },
    {
      "name": "关胜",
      "hangdang": "净"
    }
  ],
  "plot": "郑玉娥占守红桃山，自立为尊。林冲奉宋江命，前往夺取，被郑玉娥打败。及关胜运粮前来，迎战郑玉娥，\n亦未能得胜。最后宋江又派花荣助阵，林冲、关胜、花荣三人一齐上阵，始得将郑玉娥生擒，押回梁山。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引林冲同上。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "林冲",
          "type": "点绛唇",
          "text": "镇守山岗，剪恶除强，奉将令，消灭奸党，要把狼烟扫荡。"
        },
        {
          "character": "林冲",
          "type": "念",
          "text": "头带金盔耀九州，匣中宝剑度春秋。梁山之上五虎将，谁人不知豹子头。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "俺，豹子头林冲。奉大哥军师将令，前往红桃山，剿灭贼寇。今乃黄道吉日。 喽啰们，"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "趱行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四青旗引余龙同上。"
        },
        {
          "character": "余龙",
          "type": "念",
          "text": "久占红桃山，奉令掌兵权。绿林重义气，威名镇山川。"
        },
        {
          "character": "余龙",
          "type": "白",
          "text": "俺，金眼兽余龙。奉寨主之命，下山会敌。 喽啰们，"
        },
        {
          "character": "四青旗",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "余龙",
          "type": "白",
          "text": "杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "林冲、余龙同上，同杀。"
        },
        {
          "character": "余龙",
          "type": "白",
          "text": "来将何名。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "豹子头林冲。尔是何人？"
        },
        {
          "character": "余龙",
          "type": "白",
          "text": "金眼兽余龙。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "看枪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林冲、余龙同杀，余龙败下，林冲追下，余龙、林冲同上，同杀，余龙死，下。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "开路前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林冲、四下手同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手引郑玉娥同上。"
        },
        {
          "character": "郑玉娥",
          "type": "点绛唇",
          "text": "女将英雄，镇守山峰，金刀动，神鬼皆惊，谁敢樱五锋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郑玉娥上高座。"
        },
        {
          "character": "郑玉娥",
          "type": "念",
          "text": "头戴珍珠明又亮，身披软甲似秋霜。坐下跨定桃花马，要把梁山一扫光。"
        },
        {
          "character": "郑玉娥",
          "type": "白",
          "text": "奴家，郑玉娥，在桃红山上独立为尊。今日命先锋余龙，山前会战梁山贼寇。 也曾命探子打听，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "报启大王：先锋阵前丧命。"
        },
        {
          "character": "郑玉娥",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "郑玉娥",
          "type": "白",
          "text": "三军杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四下手、林冲同上，四下手、郑玉娥同上，林冲、郑玉娥同战，林冲败下，郑玉娥追下，四手下、林冲同"
        },
        {
          "character": null,
          "type": "text",
          "text": "上。）"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "众好汉，这丫头杀法厉害，收兵。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红旗引关胜同上。"
        },
        {
          "character": "关胜",
          "type": "白",
          "text": "俺，大刀关胜，奉了大哥将令，押解粮草，前往红桃山听用。 众好汉，"
        },
        {
          "character": "四红旗",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "关胜",
          "type": "白",
          "text": "就此前往。"
        },
        {
          "character": "四红旗",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "林冲上。"
        },
        {
          "character": "林冲",
          "type": "念",
          "text": "眼盼救兵，坐卧不宁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "关将军到。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖吹打〗。关胜上，林冲、关胜同见，同坐。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "多劳贤弟，远路到此。"
        },
        {
          "character": "关胜",
          "type": "白",
          "text": "好说，大哥为何免战高悬？"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "这丫头杀法厉害，因此免战高悬。"
        },
        {
          "character": "关胜",
          "type": "白",
          "text": "且请后面，待某会她一阵。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "贤弟须要小心。"
        },
        {
          "character": "关胜",
          "type": "白",
          "text": "不劳吩咐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关胜、林冲自两边分下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红旗引关胜、四下手引郑玉娥同上，同杀，过场，同下。四火旗引火星同上。"
        },
        {
          "character": "火星",
          "type": "白",
          "text": "某，火德星君是也。今有关胜，在红桃山中有难，不免前去搭救。 火卒们！"
        },
        {
          "character": "四火旗",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "火星",
          "type": "白",
          "text": "起道前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（郑玉娥上，五色旗同上，同摆阵，众兵卒举火同上，火星上，关胜上，入阵，郑玉娥、关胜同杀，关胜闯"
        },
        {
          "character": null,
          "type": "text",
          "text": "阵，火星救关胜同下，郑玉娥、众兵卒押场同下。〖一江风〗。四喽兵引花荣同上。）"
        },
        {
          "character": "花荣",
          "type": "唱",
          "text": "云雾飘飘绿水茫， 青山照顶白玉霜。 残秋日后飘落叶， 黄花满地放清香。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "俺，神箭手小李广花荣。奉大哥将令，前往红桃山，与林冲助阵。 众好汉！"
        },
        {
          "character": "四喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "趱行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "林冲上。"
        },
        {
          "character": "林冲",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关胜上。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "贤弟，胜负如何？"
        },
        {
          "character": "关胜",
          "type": "白",
          "text": "大败而回。"
        },
        {
          "character": "林冲",
          "type": "白",
          "text": "且候救兵，再作区处。"
        },
        {
          "character": "花荣",
          "type": "内白",
          "text": "花将军到。"
        },
        {
          "character": "关胜、林冲",
          "type": "同白",
          "text": "快快相请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。花荣上，花荣、林冲、关胜同见。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "二位将军，可曾见过阵来？"
        },
        {
          "character": "林冲、关胜",
          "type": "同白",
          "text": "我等大败而回。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "此番一同出马，三下夹攻，必然全胜。"
        },
        {
          "character": "林冲、关胜",
          "type": "同白",
          "text": "就此一同杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "林冲、关胜、花荣同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（林冲、关胜、郑玉娥同上，同杀，关胜、林冲同败下，花荣上，接杀，郑玉娥败下，花荣追下，众人同上"
        },
        {
          "character": null,
          "type": "text",
          "text": "林冲、关胜、花荣、郑玉娥同上，杀，郑玉娥败下，花荣、众人同追下，郑玉娥上，众人同追上，杀，林"
        },
        {
          "character": null,
          "type": "text",
          "text": "冲、关胜同败下，花荣、郑玉娥同杀，郑玉娥被擒，众兵卒同举郑玉娥。）"
        },
        {
          "character": "打单对，扔双躐毛，打双头人跟头，郑玉娥上，跟头，众人同上换刀，闪为四门跟头下，喽兵同上打跟头下、众兵卒",
          "type": "同白",
          "text": "贼寇被擒。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "众好汉。"
        },
        {
          "character": "众兵卒",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "花荣",
          "type": "白",
          "text": "押回山寨。"
        },
        {
          "character": "众兵卒",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}