    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "郝文僧上。"
        },
        {
          "character": "郝文僧",
          "type": "点绛唇",
          "text": "带发出家，不遵佛法，凶心发，要把人杀，哪怕律条大。"
        },
        {
          "character": "郝文僧",
          "type": "念",
          "text": "看破绿林无善终，带发出家假修行。不拜如来不念佛，恼悔天霸与施公。"
        },
        {
          "character": "郝文僧",
          "type": "白",
          "text": "俺姓郝名文僧，法号自然。自幼惯走江湖，本是绿林出身，杀官劫库，多少保 镖的达官，竟死在俺的刀下。这且不言。只因表兄武天虬，在恶虎村拿住赃官 施世纶，要与绿林报仇。不想天霸找上门去，不念结拜之情，镖打天虬，枪挑 天雕，逼死二位仁嫂。是俺一见，心灰一半，转到家中，禀知父母。老母闻知 天虬表兄，命丧天霸之手，每日忧虑，身得重病。是俺看破绿林，为此在这玄 坛寺内，带发出家，倘凑机会，杀了天霸，拿住赃官，与俺表兄报仇，方称我 心愿，今日庄丁来报，老母病体甚重，不免回家探望一番。 小和尚，好好看守庙堂，我回家探望去者。"
        },
        {
          "character": "郝文僧",
          "type": "唱",
          "text": "闻得老母身染病， 不免回家探娘亲。 庙堂之事你照应， 来往休要放过门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郝文僧下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "韩佩上。"
        },
        {
          "character": "韩佩",
          "type": "唱",
          "text": "心中恼恨贼强盗， 谋害我女赴阴曹。 去往京都冤状告， 要与我女儿把恨消。"
        },
        {
          "character": "韩佩",
          "type": "白",
          "text": "小老儿韩佩。所生一女，名叫翠云，配夫何荣，尚未过门。只因她舅娘染病在 床，我同女儿前去探望，不想被镇山东郎如豹抢去，勒逼成亲，我女不从，被 那恶霸贼用滚水烫死。我女婿闻听不忿，找上他家辩理，不想被那贼用乱棍打 死。可叹他尚未合卺的夫妻，命丧毒手。狗强盗，我虽年迈，拚着这条老命不 要，与你作个对头。"
        },
        {
          "character": "韩佩",
          "type": "唱",
          "text": "清平世界乾坤照， 擅抢人间女多姣。 天理二字全不晓， 恶贯满盈哪里逃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩佩下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "施世纶、郭起凤同上。"
        },
        {
          "character": "施世纶",
          "type": "唱",
          "text": "奉王旨意出离朝， 赃官恶霸难脱逃。 钦命二字如山倒， 皇亲国戚也不饶。"
        },
        {
          "character": "郭起凤",
          "type": "白",
          "text": "大人。"
