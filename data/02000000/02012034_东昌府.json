        {
          "character": null,
          "type": "stage",
          "text": "韩佩笑。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "吓，老丈既是东昌府人氏，吾有两个朋友请问老丈可知？"
        },
        {
          "character": "韩佩",
          "type": "白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "施世纶",
