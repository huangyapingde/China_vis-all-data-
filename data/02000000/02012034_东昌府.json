{
  "script_id": "02012034",
  "title": "东昌府",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "郝文僧",
      "hangdang": "净"
    },
    {
      "name": "施世纶",
      "hangdang": "老生"
    },
    {
      "name": "黄天霸",
      "hangdang": "武生"
    }
  ],
  "plot": "施世纶为淮安总漕，夜宿界河驿。梦韩翠云鬼魂谓被郎如豹抢入家中，强奸不遂，用水浇死，请为申雪。施\n世纶醒后，决定微服私访，黄天霸等苦谏不从，只由郭起凤一人随伴。行至里海坞，与韩翠云之父韩佩相遇。\n韩佩因郎如豹烫死其女，打死其婿，正要进京上诉。遂将郎如豹侍其妹，为索国舅之爱妾，及与绿林中郝\n世洪为儿女亲家，在东昌府一带无恶不作等情，向施世纶申诉。施世纶遂决定先至里海坞访郝世洪。原来郝\n世洪曾为绿林，刻已洗手。只因黄天霸归顺施世纶，打死武天虬、枪挑濮天雕，其妻伍氏，念及伍家只此一\n子，因而绝后，致得重病。郝世洪苦劝其妻及女郝素玉，均不听从，其子郝文僧表面上在玄坛寺出家，实则\n无恶不作，见其母病重，对其父所言，亦不赞成。施世纶行至东昌府，天色已晚，乃借玄坛寺中，郝文僧归\n后与施世纶见面，施世纶言系给郝世洪及郎如豹带信而来，郝文僧在恶虎村与施世纶见过，当即看破，持刀\n往杀施世纶等。郭起凤乘间逃脱，施世纶被绑。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸、关泰、王殿臣、何路通、朱光祖同上。"
        },
        {
          "character": "黄天霸",
          "type": "念",
          "text": "弃却绿林将英豪，"
        },
        {
          "character": "关泰、何路通",
          "type": "同念",
          "text": "独闯江湖美名标。"
        },
        {
          "character": "王殿臣、朱光祖",
          "type": "同念",
          "text": "一路剪恶除强暴，"
        },
        {
          "character": "黄天霸、关泰、何路通、王殿臣、朱光祖",
          "type": "同念",
          "text": "土棍刁民望风逃。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "黄天霸。"
        },
        {
          "character": "关泰",
          "type": "白",
          "text": "关泰。"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "何路通。"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "王殿臣。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "朱光祖。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "列位英雄请坐。我等保护大人巡视淮安，一路之上，拿了多少恶棍刁民。前者 在静海县薛家窝，拿获薛家五虎一并余七，全仗何仁兄之力也。"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "岂敢。薛家窝拿了余七众寇，此乃些须小事，何必挂齿。"
        },
        {
          "character": "关泰",
          "type": "白",
          "text": "众家英雄，你我保护大人去至淮安，前面已是山东地方，惯出强盗，大家须要 留心在意。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "关爷，此去淮安，路过山东，纵有盗寇，你我俱是绿林出身，何惧那些毛贼。"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "吓，朱爷此言差矣。强中自有强中手，能人背后有能人。大家保护大人，落得 平安，岂不是好？"
        },
        {
          "character": "何路通",
          "type": "白",
          "text": "列位英雄，此去淮安，水路行舟，盗寇如麻，难免无事，大家小心在意。"
        },
        {
          "character": "黄天霸、关泰、王殿臣",
          "type": "同白",
          "text": "着哇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭起凤上。"
        },
        {
          "character": "黄天霸、关泰、王殿臣",
          "type": "stage",
          "text": "中国京剧戏考 《东昌府》【头本】 2"
        },
        {
          "character": "郭起凤",
          "type": "念",
          "text": "朝中天子三宣诏，关外全凭一令行。"
        },
        {
          "character": "黄天霸、关泰、何路通、王殿臣、朱光祖",
          "type": "同白",
          "text": "守备到此何事？"
        },
        {
          "character": "郭起凤",
          "type": "白",
          "text": "大人有令，传众英雄，齐至公馆伺候。"
        },
        {
          "character": "黄天霸、关泰、何路通、王殿臣、朱光祖",
          "type": "同白",
          "text": "既然如此，一同前往。来，带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同领起走圆场，同挖门。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "大人尚未升堂，你我两厢伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四青袍、四刽子手、四官兵、门子、书吏、施世纶同上。"
        },
        {
          "character": "施世纶",
          "type": "引子",
          "text": "职授金章，秉忠心，除暴安良。"
        },
        {
          "character": "施世纶",
          "type": "念",
          "text": "钦奉王命离九朝，职授淮安为总漕。哪怕恶霸刁民野，就是皇亲难恕饶。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "本院，施世纶。奉旨钦命淮安漕运，代理民词，自离京都以来，在八里桥收了 何路通，又在静海县拿获薛家五虎，一并余七，与民除害。行至沧州，落宿公 馆，今日起马。 副参二将。"
        },
        {
          "character": "黄天霸、关泰",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "吩咐人役，齐至官船伺候。"
        },
        {
          "character": "黄天霸、关泰",
          "type": "同白",
          "text": "齐至官船伺候。带马！ （〖牌子〗。众人同下。四船夫、四文堂、四青袍、四刽子手、四官兵、门子、书吏、施世纶、黄天霸、关 泰、何路通、王殿臣、朱光祖、郭起凤同上。）"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "好一派景象也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大牌子。众官员同上。"
        },
        {
          "character": "众官员",
          "type": "同白",
          "text": "界河驿文武官员迎接大人。"
        },
        {
          "character": "郭起凤",
          "type": "白",
          "text": "候着。 启禀大人：界河驿文武官员迎接大人。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "吩咐预备公馆伺候。"
        },
        {
          "character": "郭起凤",
          "type": "白",
          "text": "公馆伺候。"
        },
        {
          "character": "众官员",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众官员同下。〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "咳呵！"
        },
        {
          "character": "土地",
          "type": "念",
          "text": "地方诚敬吾，福德为正神。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "小神乃界河驿土地是也。今有镇山东郎如豹，谋害民女，名叫韩翠云，那女鬼 冤魂不散，叩求吾神与她报仇。今有施大人在此下马，不免带她前去申诉。 女鬼走动。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩翠云上。"
        },
        {
          "character": "韩翠云",
          "type": "白",
          "text": "苦吓！"
        },
        {
          "character": "韩翠云",
          "type": "二黄摇板",
          "text": "恨狂徒行事心太狠， 勒逼着奴家要成婚。 望神圣与奴来消恨， 灭却了贼子报你恩。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "女鬼不必啼哭，今有施大人在此下马，我带你前去伸冤便了。 中国京剧戏考 《东昌府》【头本】 3"
        },
        {
          "character": "韩翠云",
          "type": "白",
          "text": "多谢神圣。"
        },
        {
          "character": "韩翠云",
          "type": "二黄摇板",
          "text": "谢神圣带我鸣冤枉， 闪开浮云见天堂。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "你随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地、韩翠云同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四文堂、四青袍、四刽子手、四官兵、门子、书吏、施世纶、黄天霸、关泰、何路通、王殿臣、朱光祖、"
        },
        {
          "character": null,
          "type": "text",
          "text": "郭起凤同上。〖牌子〗。）"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "来，吩咐文武官员，不必伺候，各自回衙理事，众人役各自歇息。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "文武官员，不必伺候，各自回衙理事，众人役各自歇息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四青袍、四刽子手、四官兵、书吏、黄天霸、关泰、何路通、王殿臣、朱光祖、郭起凤同下。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "禀大人：吩咐过了。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "来，掌灯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子暗下。"
        },
        {
          "character": "施世纶",
          "type": "唱",
          "text": "大清国锦江洪君王有道， 奉圣旨往淮安身为总漕。 拿多少贼狂徒刁民土豪， 为国家每日里愁锁眉梢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地上。"
        },
        {
          "character": "土地",
          "type": "唱",
          "text": "谯楼打罢三更后， 见了大人说根由。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "小神参见大人。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "吓，那一老者，夤夜至此，姓甚名谁，有何话讲？"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "启禀大人：小神乃界河驿土地便是。只因东昌府有一恶霸，名叫镇山东郎如豹， 谋害民女，名叫韩翠云，女鬼冤魂不散，是小神将他带至大人台前伸诉。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "吓，有这等事。将女鬼带上来。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "女鬼走动。"
        },
        {
          "character": "韩翠云",
          "type": "内白",
          "text": "苦吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩翠云上。"
        },
        {
          "character": "韩翠云",
          "type": "唱",
          "text": "悲惨惨且把公馆进， 叩求大人诉冤情。"
        },
        {
          "character": "施世纶",
          "type": "二黄导板",
          "text": "耳边厢又听得悲声不定，"
        },
        {
          "character": "韩翠云",
          "type": "唱",
          "text": "尊一声老大人细听详情： 小女子家住在东昌府郡， 我的父名韩佩耕耘为生。 镇山东郎如豹为人不正， 将小女抢他家勒逼成婚。 那时节是民女再三不允， 那强盗一霎时顿起毒心。 将小女绑至在花厅之上， 用滚水浇遍身命丧归阴。 求大人与奴家报仇雪恨， 愿大人代代官不离朝门。 听谯楼打罢了四更时分， 冤屈鬼别阳间转回阴城。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": "韩翠云",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地、韩翠云同下。门子暗上。"
        },
        {
          "character": "施世纶",
          "type": "二黄导板",
          "text": "一霎时那女鬼诉冤不见，"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "施世纶",
          "type": "唱",
          "text": "睁朦胧却原来白昼日间。 中国京剧戏考 《东昌府》【头本】 4"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "好奇怪。 来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门子允。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "传副参二将同众来见。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "副参二将同众来见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄天霸、关泰、何路通、王殿臣、朱光祖、郭起凤同上。"
        },
        {
          "character": "黄天霸、关泰、何路通、王殿臣、朱光祖、郭起凤",
          "type": "同白",
          "text": "来也。参加大人。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "黄天霸、关泰、何路通、王殿臣、朱光祖、郭起凤",
          "type": "同白",
          "text": "大人有何吩咐？"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "众位英雄，本院昨晚三更时分，偶得一梦，见当方土地带一女鬼冤魂，名叫韩 翠云，是她言道，被此地恶棍名叫镇山东郎如豹谋害她的性命。女鬼冤魂不散， 到我跟前伸诉。为此聚齐尔等，共同商议。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "启禀大人：此地有这等恶霸，本地官员，也该呈报，况且梦中之言，岂可深信？"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "我想此地既有恶霸，难免官员贪赃受贿。本院欲前去私访，你们意下如何？"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "大人乃朝廷钦命大臣，岂可出外私访。待我等四下访查，再作计较。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "我想此事，你们前去，恐误日期，本院心已定，不必拦阻。郭起凤随我同行， 后面更衣备黑驴伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施世纶、郭起凤同下。"
        },
        {
          "character": "王殿臣",
          "type": "白",
          "text": "列位英雄，看大人此去，只怕又要闯出祸来。"
        },
        {
          "character": "关泰",
          "type": "白",
          "text": "闻听此地恶棍刁民甚众，依俺之见，相留大人不去为妙。"
        },
        {
          "character": "朱光祖",
          "type": "白",
          "text": "想那郭守备武艺平常，跟随大人前去，若有一差二错，那时后悔也就迟了。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "列位英雄言之有理。待俺进内回禀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "郭起凤上。"
        },
        {
          "character": "郭起凤",
          "type": "白",
          "text": "大人出堂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "施世纶上。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "你们看我这等打扮，料人难解机关。"
        },
        {
          "character": "黄天霸",
          "type": "白",
          "text": "启禀大人：闻听此地，刁民甚众，还是不去为妙。"
        },
        {
          "character": "施世纶",
          "type": "白",
          "text": "为大臣者，何惧凶险。你们不必多言，带牲口伺候。"
        },
        {
          "character": "黄天霸、关泰、何路通、王殿臣、朱光祖",
          "type": "同白",
          "text": "送大人！"
        },
        {
          "character": null,
          "type": "stage",
