    },
    {
      "name": "张苞",
      "hangdang": "副净"
    },
    {
      "name": "张夫人",
      "hangdang": "正旦"
    },
    {
      "name": "关兴",
      "hangdang": "小生"
    },
    {
      "name": "刘封",
      "hangdang": "小生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    }
  ],
  "plot": "刘备闻关羽命丧玉泉山，悲痛难忍。当即宣召诸葛亮进帐，商议出兵，为关公复仇。诸葛亮谓现在出兵不利，\n应待至明春。刘备乃令廖化往告张飞，张飞闻信后，随即赶往西川。一面催刘备出兵报仇，一面令范疆、\n张达，赶做白袍白甲，并谓诸葛亮若不出兵，渠即单独出马。适范疆、张达二人尚未将白袍做妥，乃大发雷\n霆，拟将范疆、张达二人斩首。经范疆、张达二人哀求，始各重打百鞭，限七日造成，否则定斩不饶。范疆、\n张达二人认为七日，决不能完成。与其届时被斩，不如将张飞杀死，向东吴报功。乃乘张飞熟睡之际，将\n张飞杀死，携带首级奔往东吴。张苞得知其父死后，遂向刘备报告。适关兴亦赶至。刘备在万分悲痛之下，\n决定令吴班挂帅，御驾亲征云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内西皮导板",
          "text": "废寝忘食难安枕，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "二弟，云长，哎呀桃园吓！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "两泪汪汪湿衣襟。 再不能弟兄们南征北战， 再不能弟兄们东逃西奔。 再不能弟兄们把汉室重整， 再不能弟兄们把孙、曹剿平。 再不能弟兄们共同肝胆， 再不能弟兄们议论军情。 再不能弟兄们朝欢暮乐， 再不能弟兄们训教子孙。 哭得我前走三，后退四，神魂不定， 弟兄们一路死孤才甘心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四札头引张飞同上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "来至午门下能行， 见了大哥说分明。"
        },
        {
          "character": "张飞",
          "type": "叫头",
          "text": "大哥！"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "三弟！"
        },
        {
          "character": "张飞",
          "type": "叫头",
          "text": "兄长！"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "贤弟！"
        },
        {
          "character": "张飞",
          "type": "叫头",
          "text": "哎呀，大哥吓！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "二哥命丧东吴地， 为什么稳坐西川不发兵？"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "止不住心酸两泪淋，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "愚兄要发倾国兵。 中国京剧戏考 《造白袍》【二本】 2 诸葛先生曾阻本，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "他讲些什么？"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "他说道要报冤仇待明春。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈，好一个牛鼻子骚道！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "今日贤弟来到此， 弟兄们商议发大兵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "当初结义人三个， 到如今剩下兄弟两个人。 忍住心头咬一口，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哎呀大哥吓！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "咬你的胳臂疼不疼？ 哪有闲话对你讲， 你不发兵我发兵。 叫人来带过乌骓马， 不报冤仇死不回程。"
        },
        {
          "character": "张飞",
          "type": "叫头",
          "text": "大哥！"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "三弟！"
        },
        {
          "character": "张飞",
          "type": "叫头",
          "text": "哎呀桃园吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "三弟上了马能行， 弩弓射去箭一根。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封上。"
        },
        {
          "character": "刘封",
          "type": "唱",
          "text": "含悲忍泪进午门， 父王驾前奏分明。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "儿臣见驾，父王万岁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "下面跪的敢是刘封？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "儿臣刘封。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "进前来。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备打刘封。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唗！奴才吓！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "你二叔阵前遭围困， 坐视不理为何因？"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "父王吓！"
        },
        {
          "character": "刘封",
          "type": "唱",
          "text": "此乃孟达安排定， 不与儿臣半毫分。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "奴才吓！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "你今无有叔侄义， 谁与你又有父子情。 按律条就该将你斩，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "来了南阳诸葛孔明。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "参见主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，刘封回京，快快将他议个罪名。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔，胆大的刘封，按兵不动，刚强灭伦。 武士手！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将他推出斩首！"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同推刘封，刘封慌。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "哎呀，先生吓！此乃孟达之过，不与小王相干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封哭下。"
        },
        {
          "character": "刘封",
          "type": "stage",
          "text": "中国京剧戏考 《造白袍》【二本】 3"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，刘封平日无过，将他解下桩来，另议个罪名。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "山人领旨。 武士手，将刘封解下桩来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，同献头。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "寡人一言错出唇， 倒把姣儿丧残生。 为孤冲锋打头阵， 为孤大战万马营。 少年英雄丧了命，"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "刚强之子问典刑。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "孤哪怕他是刚强子， 焉能欺压我子孙。 二弟丧命刘封斩， 哭得我头昏眼花少精神。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生吓！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "你与孤快发人和马， 与那东吴孙权定雌雄。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "袖内八卦早算定， 吾主晏驾在白帝城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、诸葛亮同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四札头、四青袍引张飞同上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "只为冤仇事，常怀愤恨心。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "某，张飞。只因二哥命丧东吴，要与兄长报仇，也曾命范疆、张达制造白盔白 甲，不知可曾早齐。 来！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "传范疆、张达进帐。"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "哦。 千岁有令：传范疆、张达进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范疆、张达同上。"
        },
        {
          "character": "范疆",
          "type": "念",
          "text": "忽听千岁唤，"
        },
        {
          "character": "张达",
          "type": "念",
          "text": "慌步到帐前。"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "千岁在上，末将等参见。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "范疆、张达，"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "命尔等所造白盔白甲，可曾完备？"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "启千岁：工程甚大，一时难以完备。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！好狗头吓！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "听罢言来怒冲冠， 把我的军令当等闲。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "将他二人推出斩，"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "可恨贼子慢迟延。 中国京剧戏考 《造白袍》【二本】 4"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "千岁爷饶命吓！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈哈，也罢！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "看在亡故兄长面， 暂且饶恕这一番。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "范疆、张达！"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "打得尔可是？"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "打得是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "打得尔可服？"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "打得服。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "唔唔，尔也该服。命尔七日七夜，造齐白盔白甲，将功折罪；再若迟延，要尔 的狗命！ 来！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "赶出帐去！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、张飞同下。"
        },
        {
          "character": "范疆、张达",
          "type": "同白",
          "text": "哎呀，好打吓！"
        },
        {
          "character": "范疆",
          "type": "唱",
          "text": "白盔白甲造不完，"
        },
        {
          "character": "张达",
          "type": "唱",
          "text": "每人各打一百鞭。"
        },
        {
          "character": "范疆",
          "type": "白",
          "text": "将军你看七日七夜之内，若无白盔白甲，那时如何是好？"
        },
        {
          "character": "张达",
          "type": "白",
          "text": "将军，我这里倒有一计在此。"
        },
        {
          "character": "范疆",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "张达",
          "type": "白",
          "text": "今夜三更时分，身藏短刀一把，将他杀了，带着首级献与东吴，岂不是好？"
        },
        {
          "character": "范疆",
          "type": "白",
          "text": "此计甚妙。将军请。"
        },
        {
          "character": "张达",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "范疆",
          "type": "唱",
          "text": "我不杀他他杀我，"
        },
        {
          "character": "张达",
          "type": "唱",
          "text": "造甲不齐无奈何。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "范疆、张达同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "张飞",
          "type": "内西皮导板",
          "text": "谯楼鼓打初更尽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍引张飞同上。"
        },
        {
          "character": "张飞",
          "type": "三叫头",
          "text": "二哥！兄长！哎呀桃园吓！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "坐不安来睡不宁。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈，二哥，你来了，你来了！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "启千岁：那是走兽壶，不是二王爷。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "那是走兽壶，不是二王爷。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "哈，这是走兽壶，不是二王爷？起过了。 哎，二哥吓！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "走兽壶当作了二哥的模样，"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "二哥，你来了！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "启千岁：这是铁马响，不是二王爷。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "这是铁马响，不是二王爷。"
