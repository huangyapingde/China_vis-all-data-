        },
        {
          "character": "武姜",
          "type": "西皮导板",
          "text": "未曾修书心自念，"
        },
        {
          "character": "武姜",
          "type": "西皮原板",
          "text": "低头辗转忆当年。 产养寤生身遭险， 长大成人不承欢。 因此上喜爱幼子段， 非是老身太心偏。 提起笔来，"
        },
        {
          "character": "武姜",
          "type": "西皮二六板",
          "text": "华笺展，"
        },
        {
          "character": "武姜",
          "type": "西皮流水板",
          "text": "字谕叔段听我言： 尔兄朝周去国远， 五月五日紧加鞭。 前来夺位了吾愿， 书信到日，"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
