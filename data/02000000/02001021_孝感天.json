{
  "script_id": "02001021",
  "title": "孝感天",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "寤生",
      "hangdang": "老生"
    },
    {
      "name": "共叔段",
      "hangdang": "小生"
    },
    {
      "name": "武姜",
      "hangdang": "老旦"
    },
    {
      "name": "卫氏",
      "hangdang": "旦"
    }
  ],
  "plot": "列国时，郑庄公之弟共叔段，恃母武姜宠爱，谋夺君位。庄公知之，用计假言朝周，以观虚实，武姜果命共\n叔段袭城夺位；共叔段妻卫氏苦谏不从，自刎而死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘同上。"
        },
        {
          "character": "公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "同点绛唇",
          "text": "燮理阴阳，朝纲执掌，山河壮，国富兵强，圣主恩波荡。"
        },
        {
          "character": "公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "同白",
          "text": "某——"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "上卿公子吕。"
        },
        {
          "character": "蔡足",
          "type": "白",
          "text": "亚卿蔡足。"
        },
        {
          "character": "高渠弥",
          "type": "白",
          "text": "上大夫高渠弥。"
        },
        {
          "character": "公孙阏",
          "type": "白",
          "text": "下大夫公孙阏。"
        },
        {
          "character": "瑕叔盈",
          "type": "白",
          "text": "行人官瑕叔盈。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "封人官颖考叔。"
        },
        {
          "character": "夷仲年",
          "type": "白",
          "text": "左车官夷仲年。"
        },
        {
          "character": "祝畘",
          "type": "白",
          "text": "右车官祝畘。"
        },
        {
          "character": "公子呂",
          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "今当国母姜夫人寿诞之期，我等理当祝贺。"
        },
        {
          "character": "蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "同白",
          "text": "正是。天色尚早，你我朝房伺候。请！ （公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘自两边分下。四太监、大太监、寤生同 中国京剧戏考 《孝感天》【头本】 2 上。）"
        },
        {
          "character": "寤生",
          "type": "引子",
          "text": "周室宗亲，卫京畿，抚育黎民。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寤生坐。"
        },
        {
          "character": "寤生",
          "type": "念",
          "text": "创业仗先君，守成属寡人。国富民安乐，共享太平春。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "寡人郑伯寤生，自平王东迁以来，世为朝廷卿士。兵强地广，国泰民安。今当 母后姜氏寿诞之期，为此升殿祝贺。 内侍，"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "宣太叔上殿。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨。千岁有旨：太叔上殿哪。"
        },
        {
          "character": "共叔段",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段上。"
        },
        {
          "character": "共叔段",
          "type": "念",
          "text": "志大才高运未通，终当得水化蛟龙。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "参见兄侯。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "贤弟少礼，一旁坐下。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "谢座。宣臣弟上殿有何吩咐？"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "今当母后寿辰，我等先行家人之礼，然后再受群臣祝贺。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "内侍，放下珠帘。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、二夫人、武姜同上。"
        },
        {
          "character": "武姜",
          "type": "引子",
          "text": "颐养天真，但愿得，松柏长春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武姜坐。"
        },
        {
          "character": "寤生、共叔段",
          "type": "同白",
          "text": "儿臣等拜贺母后千秋！"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "生受吾儿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。寤生、共叔段、二夫人同拜。"
        },
        {
          "character": "公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "内同白",
          "text": "群臣与国母祝寿。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "夫人们暂退。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二夫人同下。公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘同上。"
        },
        {
          "character": "公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "同白",
          "text": "臣等恭贺国母圣寿无疆！"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "众卿平身！ 中国京剧戏考 《孝感天》【头本】 3"
        },
        {
          "character": "公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "同白",
          "text": "谢国母。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "宴齐。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "儿臣与母后把盏，以祝千秋。"
        },
        {
          "character": "公子吕、蔡足、高渠弥、公孙阏、瑕叔盈、颖考叔、夷仲年、祝畘",
          "type": "同白",
          "text": "臣等侍饮。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "摆下就是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同入席。"
        },
        {
          "character": "武姜",
          "type": "西皮原板",
          "text": "星辉宝婺岁华新， 画殿筵开锦绣春。"
        },
        {
          "character": "寤生",
          "type": "西皮原板",
          "text": "母子们开怀把酒饮，"
        },
        {
          "character": "共叔段",
          "type": "西皮原板",
          "text": "但愿得高堂永康宁。"
        },
        {
          "character": "武姜",
          "type": "西皮原板",
          "text": "眼观二子，"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "心暗忖，"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "母亲。"
        },
        {
          "character": "武姜",
          "type": "西皮原板",
          "text": "老身有话听分明。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "母亲有何吩咐？"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "今当众卿在此，非是老身偏心，想汝承袭父位，地方千里，今使同胞之弟，栖 身蕞尔共城，于心何忍哪？"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "母亲吩咐，敢不谨遵。但不知要加封何地？"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "你若有意加封，只要京城一地。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "这个……启禀母后：京邑城高地广，民风刁悍，太叔年幼，恐难治理。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "武姜",
          "type": "西皮原板",
          "text": "自古道兄宽弟忍让， 全不念为娘在高堂。 汝承父位多安享， 同胞手足反参商。 共城赋薄难为养， 焉能糊口足衣粮？ 若嫌京邑封地广， 倒不如将弟赶往，"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "他乡。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "母亲不必动怒，儿臣即刻加封。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "这便才是。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "共叔段。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "孤今封你京邑之地，此处城高地广，需要小心镇守，不可疏虞。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "多谢兄侯盛德，母后深恩。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "段儿随为娘来呀，哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女同下，武姜拉共叔段同下。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监、寤生同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、卫氏同上。"
        },
        {
          "character": "卫氏",
          "type": "西皮慢板",
          "text": "我母后庆生辰天开喜象， 中国京剧戏考 《孝感天》【头本】 4 适才间在殿前祝寿称觞。 闻听说我的夫加封地广， 等候他回宫来细问端详。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "奴家太叔之妻卫氏。适才与母后上寿而归，闻得的夫君得封京邑，未知何日起 程，等他回来，便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段上。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "啊哈……"
        },
        {
          "character": "共叔段",
          "type": "西皮散板",
          "text": "封大邑释却了一天愁闷， 但愿得早日里夺位称君。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "夫君万福。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "夫人少礼。请坐。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "有座。贺喜夫君得封京邑。但不知何日起程？"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "即刻就要起程。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "兄侯笃念同胞，真真可感。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "咳，不提兄侯，也还罢了，提起兄侯，真真令人可恨。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "夫君何出此言？"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "尔等退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "我今加封，非出吾兄本意，皆是母后再三告请，兄侯不得不从。啊夫人，适才 母后私自嘱咐于我，言说是兄侯不念同胞之情，待我甚薄，母亲百年之后，恐 有不测。因此母后命我到得京邑，聚兵练将，暗中准备，遇有机会，母后暗通 消息，约我袭取都城，以夺兄位。你道好是不好？"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "夫君此言差矣。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "何差？"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "有道是长幼有序，先君传位兄侯，并无差错，夫君岂可胡行。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "吾意已定，你乃女流之辈，休得多言。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "夫君哪——"
        },
        {
          "character": "卫氏",
          "type": "西皮二六板",
          "text": "夫君言语多蹊跷， 妾身有话听根苗： 兄弟手足两相靠， 君臣名分怎能消。 犯上作乱行无道， 谋朝篡位惹笑嘲。 劝君妄念快息了， 欺天灭理无下梢。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "共叔段",
          "type": "西皮散板",
          "text": "此事原非妇人晓， 休得一旁絮叨叨。 弟接兄位有多少， 日后看我做龙朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "将官上。"
        },
        {
          "character": "将官",
          "type": "白",
          "text": "启禀太叔：人马车辆已齐。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "吩咐下去，起驾京邑去者。"
        },
        {
          "character": "将官",
          "type": "白",
          "text": "众军走上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四大铠、车夫同上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "起驾京邑去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。卫氏上车，共叔段上马，众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、寤生同上。"
        },
        {
          "character": "寤生",
          "type": "西皮散板",
          "text": "郑国江山原非小，"
        },
        {
          "character": "寤生",
          "type": "西皮流水板",
          "text": "孤王有道坐当朝。 中国京剧戏考 《孝感天》【头本】 5 母后做事无分晓， 逼封叔段为哪条？ 口中不言心内恼， 情关手足且含包。 内侍摆驾金殿到， 但愿无形祸自消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寤生坐。公子吕、蔡足同上。"
        },
        {
          "character": "公子吕",
          "type": "西皮散板",
          "text": "忧时不俟君命召，"
        },
        {
          "character": "蔡足",
          "type": "西皮散板",
          "text": "军国大事奏当朝。"
        },
        {
          "character": "公子吕、蔡足",
          "type": "同白",
          "text": "臣等见驾，主公千岁！"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "公子吕、蔡足",
          "type": "同白",
          "text": "千千岁！"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "公子吕、蔡足",
          "type": "同白",
          "text": "谢座。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "二卿上殿，有何本奏？"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "臣闻天无二日，民无二主。国母逼迫主公，加封太叔，只恐养成羽翼，为患非 小。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "叔段乃母后爱子，寡人只得相容。"
        },
        {
          "character": "蔡足",
          "type": "白",
          "text": "主公容得太叔，只怕太叔容不得主公也。"
        },
        {
          "character": "蔡足",
          "type": "西皮散板",
          "text": "主公如同养虎豹，"
