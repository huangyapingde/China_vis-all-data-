        {
          "character": "寤生",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "寤生",
          "type": "念",
          "text": "国本是大亲爱小，"
        },
        {
          "character": "公子吕、蔡足",
          "type": "同念",
          "text": "周公不把管蔡饶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、武姜同上。"
        },
        {
          "character": "武姜",
          "type": "西皮散板",
          "text": "先君做事见识浅，"
        },
        {
          "character": "武姜",
          "type": "西皮流水板",
          "text": "一心立长不立贤。 寤生怎比共叔段， 不忠不孝掌江山。 将身且坐后宫院， 时不甘来寝不安。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武姜坐。大太监上。"
        },
        {
          "character": "武姜",
          "type": "stage",
          "text": "中国京剧戏考 《孝感天》【头本】 6"
        },
        {
          "character": "大太监",
          "type": "念",
          "text": "忙将朝中事，报与国母知。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启禀国母，君侯命亚卿蔡足监国，率领兵车四百乘，起驾朝周去了。"
        },
        {
          "character": "武姜",
          "type": "白",
