        {
          "character": "大太监",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监下。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "书信已去，段儿必然兴兵前来，若能夺国称尊，方遂老身之愿也。"
        },
        {
          "character": "武姜",
          "type": "西皮散板",
          "text": "若得次子来登殿， 免得心神两地悬。 深宫盼望旌旗展，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女同下。"
        },
        {
          "character": "武姜",
          "type": "西皮散板",
          "text": "半由人力半由天。"
