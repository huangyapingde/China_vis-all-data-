        {
          "character": "武姜",
          "type": "白",
          "text": "内侍。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "命你将此书，送往京邑，面交太叔，叫他亲拆亲观，不得有误。"
