        {
          "character": "寤生",
          "type": "西皮散板",
          "text": "才知道为君倒比为民难。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "传能言军士一名进见。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "能言军士一名进见。"
