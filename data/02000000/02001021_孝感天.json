        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "就在此处扎住人马，小心搜查奸细者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将官同允，同扎营。寤生、公子吕同坐。"
