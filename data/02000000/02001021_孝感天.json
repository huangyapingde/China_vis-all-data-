          "character": null,
          "type": "stage",
          "text": "武姜下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四红龙套、四将官、公子吕、寤生同上。"
