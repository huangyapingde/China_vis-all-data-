        {
          "character": "薛应宗",
          "type": "白",
          "text": "哎吓，吓死老子了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内起五更鼓〗。王伯燕上，偷包银，下。元通上。"
        },
        {
          "character": "元通",
          "type": "白",
          "text": "两个徒弟前去，如何不见回来？待我亲身前去，杀了两个客人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨香武上，遇。"
        },
        {
          "character": "杨香武",
          "type": "白",
          "text": "什么人？"
