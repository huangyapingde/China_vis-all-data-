{
  "script_id": "02003001",
  "title": "斩熊虎",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "冯显",
      "hangdang": "净"
    },
    {
      "name": "熊虎",
      "hangdang": "丑"
    },
    {
      "name": "韩守义",
      "hangdang": "生"
    }
  ],
  "plot": "冯显读《春秋》后，到街上散步。忽闻叫苦声，及经询问，始知系韩守义被恶霸熊虎将其妻抢去，复将渠押\n在监狱。冯显极为愤恨，迳往熊虎处欲与理论。适熊虎正在预备与韩妻入洞房，乃将韩妻救出，并杀死熊虎\n而去。",
  "notes": "按一般传说，剧中之冯显，即系关公。冯显因杀熊虎被官搜捕，不得已乃改名易姓为关羽，始得逃脱云。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "冯显上。"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "豪杰英雄为丈夫，能文会武效孙、吴。有朝大展擎天手，定把乾坤一掌扶。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "某姓冯名显，字寿昌。乃蒲州解梁人也。自幼父母双亡，多蒙母舅扶养。今日 母舅下乡讨取账目去了，不免在灯下观看《春秋》一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯显归座，看书。"
        },
        {
          "character": "冯显",
          "type": "点绛唇",
          "text": "鲁史春秋，鲁史春秋，胡文左传，为褒贬。奸佞忠良，正直无偏向。"
        },
        {
          "character": "冯显",
          "type": "混江龙",
          "text": "自古来忠臣良将， 一个儿丹心耿耿气昂昂。 一个儿赤胆忠心扶社稷， 一个儿正诚直烈佐朝堂。 一个儿芳名在， 一个儿臭名扬。 一个儿叨荣显， 一个儿受灾殃。 因此上圣人制律造《春秋》， 乱臣贼子心胆丧。"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "本待要秉正除奸定国安邦，本待要秉正除奸定国安邦。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "看此《春秋》愈加烦闷，不免佩了宝剑到街市之上闲步一回，有何不可。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯显出门。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "出得门来，但见星朗朗、月明明、风飒飒、雾沉沉，好一派晚景也。"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "俺则见万里无云——"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "吐魄光， 万里无云吐魄光， 早不觉冷清清神精气爽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖剑响〗。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "因甚的昆吾应响吐红光？"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "此剑乃周穆王所造，削铁如泥。但有不平之事，它在匣中恋鞘白吼！"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "俺也知道了晓得了， 莫不是今夜晚有什么不平的事儿， 将伊家来冲撞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩守义上。"
        },
        {
          "character": "韩守义",
          "type": "夹白",
          "text": "苦哇！"
        },
        {
          "character": "冯显",
          "type": "夹白",
          "text": "呀！"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "忽听得那壁厢叫苦甚凄凉。 他道是有天无日将人丧， 又道是好夫妻无故的受着灾殃。 他那里诉得断肠， 俺这里听得悽惶。 诉得断肠，听得悽惶， 使人心儿添悒怏。 向前去究问端详， 禁内的因甚的披枷锁坐监房。 莫不是你逞雄斗强， 敢则是你把人杀伤？ 莫不是少人家私债， 敢则是你拖欠官粮？"
        },
        {
          "character": "韩守义",
          "type": "夹白",
          "text": "不是。"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "既不是，其中必有什么含冤枉。"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "对吾行从头细讲，俺与你挺身竭力诉黄堂。"
        },
        {
          "character": "韩守义",
          "type": "白",
          "text": "外面爷爷听者：小人叫作韩守义，只因清明佳节同妻子上坟插柳，偶遇熊虎员 外，见我妻子生得美貌，竟自抢去。将小人送到州里打了四十，监禁在狱呀！ 爷爷！"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "听说罢心中气昂， 不由人恼寸肠。 恨只恨为富不良官吏贪赃， 快说那豪强家住在何方？ 俺与你救转你的妻房。"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "管教你夫妻会合依旧成双，管教你夫妻会合依旧成双。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "韩守义，里面可有躲身之处？"
        },
        {
          "character": "韩守义",
          "type": "白",
          "text": "有哇爷爷。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "闪开！"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "揪断门销打开监房， 将枷钮劈碎将伊来放。 你且不必惊慌， 天来大事俺自承当。 他若是肯放， 俺与他善自开交不逞强梁。"
        },
        {
          "character": "韩守义",
          "type": "油葫芦",
          "text": "他若是不放？"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "他若是不放——"
        },
        {
          "character": "冯显",
          "type": "油葫芦",
          "text": "恼得俺雄心似虎狼。"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "哪怕他铜铸金刚，俺与他搅乱乾坤闹一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯显、韩守义同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四丑院子引熊虎通上。"
        },
        {
          "character": "熊虎",
          "type": "燕儿舞",
          "text": "风流腰摆，风流腰摆， 跨马游街夺美乖。 昨日抢了个俏乖乖， 今日筵席筵席大摆开。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "咱家熊虎员外的便是。昨日清明佳节，带领小厮们上坟插柳，遇见韩守义的妻 子，生得十分美貌，被我抢夺在家，将韩守义送到州里监禁在狱。 吓小子们！"
        },
        {
          "character": "四丑院子",
          "type": "同白",
          "text": "伺候大爷。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "花烛齐备了没有？"
        },
        {
          "character": "四丑院子",
          "type": "同白",
          "text": "齐备了。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "预备的好好儿的，伺候你大爷成亲哪！"
        },
        {
          "character": "韩守义",
          "type": "内白",
          "text": "行过安平县了，爷爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩守义、冯显同上。"
        },
        {
          "character": "冯显",
          "type": "寄生草",
          "text": "行过了安平县，又来到节义仓， 来此是无情地。不忍堂。"
        },
        {
          "character": "熊虎",
          "type": "夹白",
          "text": "外头什么响？拿灯照照。"
        },
        {
          "character": "四丑院子",
          "type": "同白",
          "text": "照照。"
        },
        {
          "character": "冯显",
          "type": "寄生草",
          "text": "俺则见铁桶般将重门闭上， 粉墙头露上灯光。"
        },
        {
          "character": "韩守义",
          "type": "夹白",
          "text": "待我前去叫门。"
        },
        {
          "character": "冯显",
          "type": "寄生草",
          "text": "你且禁住声莫乱嚷， 待某家蹑足潜踪悄地行藏。 待某家蹑足潜踪悄地行藏， 待某家蹑足潜踪悄地行藏， 细听他里边厢说些什么彀当。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "小子们。"
        },
        {
          "character": "四丑院子",
          "type": "同白",
          "text": "伺候大爷。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "你们请新人拜高堂，拜了高堂入洞房。同入销金帐，颠鸾倒凤闹风狂。就是睡 了七八年我也不下炕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四丑院子拉韩妻同上。熊虎抱韩妻。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "韩守义可曾听见？"
        },
        {
          "character": "韩守义",
          "type": "白",
          "text": "不曾听见哪，爷爷！"
        },
        {
          "character": "冯显",
          "type": "寄生草",
          "text": "他道是请新人拜高堂， 拜了高堂入洞房。 同入销金帐， 颠鸾倒凤闹风狂。 贼管叫你空作阳台梦一场！"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "韩守义向前叩门。"
        },
        {
          "character": "韩守义",
          "type": "白",
          "text": "他若问？"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "只说州里太爷差人送贺礼来了。"
        },
        {
          "character": "韩守义",
          "type": "白",
          "text": "开门来！"
        },
        {
          "character": "丑院子甲",
          "type": "白",
          "text": "什么人哪？"
        },
        {
          "character": "韩守义",
          "type": "白",
          "text": "州里太爷差人送贺礼来的。"
        },
        {
          "character": "丑院子甲",
          "type": "白",
          "text": "大爷，州里太爷差人送贺礼来咧。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "什么是贺礼，又是打咱们爷儿们的秋风来咧。开开门连扁担收。"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "打进去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯显进。韩守义扶韩妻同下。"
        },
        {
          "character": "熊虎",
          "type": "白",
          "text": "给我一齐上手！"
        },
        {
          "character": "冯显",
          "type": "白",
          "text": "哪怕你一齐来！"
        },
        {
          "character": "冯显",
          "type": "寄生草",
          "text": "鸦挡凤一齐来， 鸦挡凤单身犹如虎奔羊。 恁道是三拳四手难敌挡， 怎知俺一夫能擒你千员将。 心雄胆壮，不用慌，不用忙， 两争强，必有一伤。 贼俺和你不见输赢不散场！"
        },
        {
          "character": "熊虎",
          "type": "夹白",
          "text": "拿灯照照他是谁。"
        },
        {
          "character": "冯显",
          "type": "青哥儿",
          "text": "呀，你问俺的家乡名望， 你问俺的家乡名望。 灯下来觑着咱形容形容将相， 祖贯蒲州身居解梁。 生成情性刚， 姓冯名显字寿昌。 俺这里亮昆吾， 只教你一个个刀头丧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯显杀。四丑院子、熊虎同下。"
        },
        {
          "character": "冯显",
          "type": "尾声",
          "text": "非是俺把人来杀伤，"
        },
        {
          "character": "冯显",
          "type": "念",
          "text": "都只为救生灵除却奸党，月照浑身鲜血，染遍体绕红光。 堪堪来到州衙畔，哪怕粉墙高万丈，飞身踊跃出东墙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冯显下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}