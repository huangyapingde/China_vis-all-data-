{
  "script_id": "02001008",
  "title": "财源辐辏",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "黑虎玄坛",
      "hangdang": "净"
    }
  ],
  "plot": "天上玉帝，因下界福主，积德累功，特敕天官等，招集五路财神，招聚财源，献与福地。五路财神遵旨，赠\n财赐福而归。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、招财、利市同上，同站门。黑虎玄坛上。"
        },
        {
          "character": "黑虎玄坛",
          "type": "粉蝶儿",
          "text": "百福盈庭，喜的是百福盈庭， 更有那千祥吉庆。 俺职掌天藏金银， 今日个聚财源骈辏， 有的是生生隆顺， 凭着那积玉堆金， 乐善的必生余庆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑虎玄坛坐。"
        },
        {
          "character": "黑虎玄坛",
          "type": "念",
          "text": "鸾鹤纷纷下九天，财源滚滚庆丰年。享受千载皇家禄，皆是阴功绩德全。"
        },
        {
          "character": "黑虎玄坛",
          "type": "白",
          "text": "吾乃龙虎玄坛是也。手执金轮如意，默起千祥吉庆。跨着黑虎，行着大有之年， 所到之处，无不雨顺风调，国泰民安。正是："
        },
        {
          "character": "黑虎玄坛",
          "type": "念",
          "text": "五谷丰登天下乐，民安物阜贺升平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四云童、五天官同上，同挖门，同归坐。"
        },
        {
          "character": "五天官",
          "type": "同念",
          "text": "民安物阜风光好，五谷丰登兆。舜日与尧天，圣德齐天乐。 祝遐龄爵位高，祝丰年长生不老。"
        },
        {
          "character": "五天官",
          "type": "同白",
          "text": "吾等乃天官是也。今有下界福主，阴功浩大，积德累功。奉上帝敕旨，命吾招 聚财源，献与福地。正是："
        },
        {
          "character": "五天官",
          "type": "同念",
          "text": "积善人家当德报，存心自有上苍知。"
        },
        {
          "character": "黑虎玄坛",
          "type": "白",
          "text": "奉命招集财源，俱已聚齐，请天官赐福。"
        },
        {
          "character": "五天官",
          "type": "同白",
          "text": "速诏五路财神来者。"
        },
        {
          "character": "黑虎玄坛",
          "type": "白",
          "text": "领钧旨。 招财、利市。"
        },
        {
          "character": "招财、利市",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "黑虎玄坛",
          "type": "白",
          "text": "速请五路财神来者。"
        },
        {
          "character": "招财、利市",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "招财、利市同同。"
        },
        {
          "character": "黑虎玄坛、五天官",
          "type": "同石榴花",
          "text": "只见那香风阵阵献氤氲， 簇簇的子气满阶庭。 聚金银腰缠十万，跨鹤登程， 勤读的加官进爵，宠锡君恩。 俺如今先把那金银赠， 管教夫妻父子富贵康宁。 得个绵绵不绝，荫袭儿孙， 方显得，管金银掌天库的财神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "招财、利市引五路财神同上。"
        },
        {
          "character": "五路财神",
          "type": "同念",
          "text": "执掌皇家国宝，耑管帑藏金银。经商客旅奉吾神，满载金银堪趁。 分明四方通达，荣封五路将军。乘鸾跨鹤下凡尘，降福添财本分。"
        },
        {
          "character": "五路财神",
          "type": "同白",
          "text": "吾等乃五路财神是也。天官相诏，一同进见。 天官在上，我等参见。"
        },
        {
          "character": "五路天官",
          "type": "同白",
          "text": "命你等招集财源，可曾齐备？"
        },
        {
          "character": "五路财神",
          "type": "同白",
          "text": "俱已齐备。候天官赐福。"
        },
        {
          "character": "五路天官",
          "type": "同白",
          "text": "速诏催旺众神来者。"
        },
        {
          "character": "五路财神",
          "type": "同白",
          "text": "领法旨。 催旺众神何在？"
        },
        {
          "character": "催旺、时运、金神、银神、催财",
          "type": "内同白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "催旺、时运、金神、银神、催财看吉祥如意同跳上。"
        },
        {
          "character": "催旺、时运、金神、银神、催财",
          "type": "同念",
          "text": "大财源百川会海，愿人间六合同春。"
        },
        {
          "character": "催旺、时运、金神、银神、催财",
          "type": "同白",
          "text": "吾乃——"
        },
        {
          "character": "催旺",
          "type": "白",
          "text": "催旺"
        },
        {
          "character": "时运",
          "type": "白",
          "text": "时运。"
        },
        {
          "character": "金神",
          "type": "白",
          "text": "金神。"
        },
        {
          "character": "银神",
          "type": "白",
          "text": "银神。"
        },
        {
          "character": "催财",
          "type": "白",
          "text": "催财。"
        },
        {
          "character": "催旺",
          "type": "白",
          "text": "天官相诏，一同进见。"
        },
        {
          "character": "时运、金神、银神、催财",
          "type": "同白",
          "text": "请。 天官在上，我等参见。"
        },
        {
          "character": "五路天官",
          "type": "同白",
          "text": "将一应财源，献与福主。"
        },
        {
          "character": "催旺、时运",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "催旺、时运同下。"
        },
        {
          "character": "五路天官",
          "type": "同白",
          "text": "我等先赠其财，后赐其福，真乃财源辐辏也。"
        },
        {
          "character": "五路天官",
          "type": "同斗鹌鹑",
          "text": "这的是广众福田临， 今日个添来福份尽。 堂前五路将军， 齐献那财源茂盛。 高照着赐福天官祥瑞呈， 玳筵前满泛着——"
        },
        {
          "character": "五路天官",
          "type": "同夹白",
          "text": "哎——"
        },
        {
          "character": "五路天官",
          "type": "同斗鹌鹑",
          "text": "金樽， 听笙歌一派贺升平， 要与那福主称庆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "催旺、时运引四回回招聚宝盒同上。"
        },
        {
          "character": "催旺、时运",
          "type": "同白",
          "text": "一群财源献上。"
        },
        {
          "character": "五路天官",
          "type": "同白",
          "text": "妙啊！缕缕银光透，层层金气浮。好一座金穴银山也！"
        },
        {
          "character": "五路天官",
          "type": "同上小楼",
          "text": "只见那金银，灿灿灿光明， 喜的是金穴银山，库满箱盈。 齐祝银屏，事业丰隆， 龟鹤宏源，陶朱堪趁，一任价东西行运。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。五路天官同下高台。"
        },
        {
          "character": "五路天官",
          "type": "同白",
          "text": "幅辏已全，一同回奏上帝者。请。"
        },
        {
          "character": "五路天官",
          "type": "同煞尾",
          "text": "听悠扬一派洞仙音， 齐齐的跨鹤乘鸾上码云。 看话日光天，风调雨顺， 指日里称庆丰年定太平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众车同斜门拥众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}