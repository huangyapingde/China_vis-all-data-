{
  "script_id": "02008019",
  "title": "挂印",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "高行周",
      "hangdang": "净"
    },
    {
      "name": "高怀德",
      "hangdang": "小生"
    },
    {
      "name": "高怀亮",
      "hangdang": "小生"
    },
    {
      "name": "田吉",
      "hangdang": "末"
    },
    {
      "name": "田庆",
      "hangdang": "生"
    },
    {
      "name": "刘暗",
      "hangdang": "外"
    },
    {
      "name": "刘明",
      "hangdang": "副净"
    }
  ],
  "plot": "东鲁王高行周，夜观天象，预料赤须火龙即赵匡胤，将前来行刺。欲与抵抗，又恐终遭天谴。不得已召集众\n将，及其二子高怀德、高怀亮至帐内。当面将帅印交与高怀德，又给高怀亮宝剑一口，宫内宫外，先斩后奏。\n并嘱二子，俟赵匡胤到时，他进营时，汝等枪须向内。他回去时，汝等则枪须向外，不淮交战云。",
  "notes": "按此即系《借人头》之前段。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "田吉、田庆、刘暗、刘明同上。"
        },
        {
          "character": "田吉",
          "type": "点绛唇",
          "text": "独坐虎帐，"
        },
        {
          "character": "田庆",
          "type": "点绛唇",
          "text": "威镇一方，"
        },
        {
          "character": "刘暗",
          "type": "点绛唇",
          "text": "英雄猛将，"
        },
        {
          "character": "刘明",
          "type": "点绛唇",
          "text": "各自逞强，"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同点绛唇",
          "text": "管叫胡儿服降。"
        },
        {
          "character": "田吉",
          "type": "白",
          "text": "俺，田吉。"
        },
        {
          "character": "田庆",
          "type": "白",
          "text": "俺，田庆。"
        },
        {
          "character": "刘暗",
          "type": "白",
          "text": "刘暗。"
        },
        {
          "character": "刘明",
          "type": "白",
          "text": "刘明。"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "请了。元帅升帐，在此伺候。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。四大刀手引高行周同上。"
        },
        {
          "character": "四大刀手",
          "type": "同白",
          "text": "呵匕呵。"
        },
        {
          "character": "高行周",
          "type": "引子",
          "text": "威镇高关，执掌兵权。"
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "曾记当年摆战场，五龙二虎逼彦章。兴兵打仗谁敢挡，保定刘王锦家邦。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "老夫，高行周，在刘主驾前为臣，官拜东鲁王之职。昨晚夜观天象，赤须火龙 前来行刺，老夫本当杀他，恐被天谴五雷击顶。 军校！"
        },
        {
          "character": "四大刀手",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "有请众位将军进帐。"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "得令！ 王爷在上，末将等参见。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "众位将军，尔等可曾齐备否？"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "站立两旁听点。"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "田吉。"
        },
        {
          "character": "田吉",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "田庆。"
        },
        {
          "character": "田庆",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "刘暗。"
        },
        {
          "character": "刘暗",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "刘明。"
        },
        {
          "character": "刘明",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "众位将军。"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "王爷。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "老夫传尔等进帐，非为别事。只因老夫年迈，难以执掌虎头金印。列位将军， 有能者，前来执掌。"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "还有二位少爷。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "传。"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "有请二位少爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀亮同上。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "爹爹在上，孩儿拜揖。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿是怀德？"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "儿是怀德。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿是怀亮？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "儿是怀亮。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "哎，哈哈哈！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "擂鼓三通坐大堂， 怀德、怀亮站两厢。 辕门外来了一个赵……"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "赵什么？"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "我一个“赵”字未出口， 两个冤家着了忙。 本待不说真情话， 絮絮叨叨问端详。 罢，罢，罢，且把“赵”字按下了罢， 叫声我儿听端详。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "儿吓，为父唤你二人进帐，非为别事，只因为父年迈，难以执掌虎头金印，你 二人谁能者，前来执掌。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "孩儿年幼。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "孩儿年小。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "唔，动不动年小年幼，可知为父，年方九岁，与尔祖父报仇？"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "孩儿不知。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "为父不讲，谅尔也不知，尔且听着！"
        },
        {
          "character": "高行周",
          "type": "西皮导板",
          "text": "唐僖宗他本是有道皇上，"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "庚子年在长安设下教场。 那曹州有一人名登金榜， 都只为相貌丑赶出科场。 祥梅寺贼造反先杀和尚， 将唐王赶至在西岐美良。 程敬思他本是忠臣良将， 沙陀国搬来了老将晋王。"
        },
        {
          "character": "高行周",
          "type": "西皮快板",
          "text": "卧虎山前收一将， 官封一字勇南王。 打虎将军太原丧， 逼反水贼王彦章。 大太保搬取吾父王。 你祖太平桥上丧， 无影枪下一命亡。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "你祖父丧于无影枪下。那时为父，前发不过齐眉，后发不过雁尾，一马来至水 贼营盘内，高叫水贼彦章，快快出来受死。只见营盘内，闪出一将，头带乌油 盔，身穿乌油铠，跨下乌骓马，亚赛楚霸王。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "他是何人？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "那就是水贼彦章。一马当先问道，尔是谁家之子，哪家之后，到此何事？此时 为父言道，我乃高思继之子，名唤行周，前来与父报仇。那贼闻听，在马上哈 哈大笑。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "他笑什么？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "他笑为父，大不过他一拳，高不过他一膝，劝为父回营，再过三年五载，再来 与父报仇。此时为父言道，有志不在年高，无志空长百岁。那贼大怒，手执浑 铁镐，分心就刺，为父借势空处藏身，滚鞍躲过。那贼在两军阵前，送了为父 一个绰号。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "甚么绰号？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "名曰滚鞍鹞子。为父用回马枪，分心就刺，那贼用钩马枪躲过，大战数十馀合， 不分胜败。为父心生一计，勒马就败，那贼不解其情，催马追赶，为父回头 一看，那贼马头，连住为父马尾，为父马尾，连住那贼马头。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "爹爹可慌？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "为父也不慌。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "可忙？"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "也不忙。紧勒丝繮，将银战杆插在雕鞍，取出祖先铜锤，大叫一声，彦章小儿， 招打！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "时衰遇着高鹞子， 运去又遇史建唐。 铜锤打的兵器丧， 打得水贼吐红光。 五龙二虎逼他丧， 你父才封东鲁王。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "怀德挂帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德拜印。"
        },
        {
          "character": "高怀亮",
          "type": "哭",
          "text": "哎呀，爹爹吓！"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "兵权落在怀德手， 怀亮一旁哭嚎啕。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "怀亮我儿，为父有尚方宝剑一口，如有不遵令者，先斩后奏，拜剑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮拜。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "听爷吩咐：将人马扎在鹞子岭，有一红脸大汉进关。他若来时，枪头朝里，他 若出关，枪头朝外，不要惊唬与他。"
        },
        {
          "character": "田吉、田庆、刘暗、刘明",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "怀德、怀亮我儿，为父有几句言词，尔等牢牢紧记："
        },
        {
          "character": "高行周",
          "type": "念",
          "text": "昔日楚汉两争强，鸿门设宴害高皇。霸王不听范增语，后来自刎在乌江。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "尔等可解得开么？"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "孩儿解不开。"
        },
        {
          "character": "高行周",
          "type": "白",
          "text": "日后自有应验，下关去罢。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "白虎堂上领将令，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "弟兄双双扎大营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀亮同下。"
        },
        {
          "character": "高行周",
          "type": "唱",
          "text": "他弟兄双双下高平， 袖内机关怎知情？ 闷恹恹白虎堂上坐， 等候河东姓赵人。"
        },
        {
          "character": "高行周",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高行周下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}