{
  "script_id": "02002034",
  "title": "汉忠烈",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "张纲",
      "hangdang": "老生"
    }
  ],
  "plot": "张纲杀梁英后，预料梁冀必矫诏拿渠进京，故令其子张士安与家人张禄，逃往昆陵夏少府处，因张纲与夏少\n府曾结为秦晋也。张纲本人候圣旨到后，随即解职上刑。百姓闻信，均执械阻囚车前进，张纲乃亲谕百姓，\n阻止囚车，既犯王法，又累本人，因他人必认为系受其蛊惑也，百姓乃哭泣而退。行至东京，夜宿旅店，适\n梁冀派其内弟孙朗特来暗杀张纲，免进京后有人保救。而开店之刘豹，正直为怀，闻此消息后，将押解人员\n一齐杀死，令其女同张纲一同逃走，并放火焚店。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "四乡绅",
          "type": "内同白",
          "text": "请吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四乡绅同上。"
        },
        {
          "character": "乡绅甲",
          "type": "白",
          "text": "吓，列位先生！"
        },
        {
          "character": "三乡绅",
          "type": "同白",
          "text": "老前辈。"
        },
        {
          "character": "乡绅甲",
          "type": "白",
          "text": "我等这洛阳县俱是顺民。只有梁冀之子梁英，倚父威权，抢人妇女，霸占民房， 无不痛恨。幸遇巡抚张大人，将他打死，人头示众，除了洛阳一害。"
        },
        {
          "character": "乡绅乙",
          "type": "白",
          "text": "咳，老前辈，虽然除了一方之害，抚台张大人难免无事。"
        },
        {
          "character": "乡绅丙",
          "type": "白",
          "text": "他倚仗当今皇太后是他姑母，所以威权势大，凡事不由天子。"
        },
        {
          "character": "乡绅丁",
          "type": "白",
          "text": "张公虽然正直清廉，执法无私，今诛权奸之子，定有祸事临身。"
        },
        {
          "character": "乡绅甲",
          "type": "白",
          "text": "不妨事，朝中有南阳朱季、毛义、郑钧、杨震，人称关西夫子，黄宪量深，虞 诩增灶收付羌兵，俱有美名。张纲微服私访民情，今诛权臣之子，谁不敬心。 老朽相邀列位，要与张公立坊挂匾，以表清廉。"
        },
        {
          "character": "三乡绅",
          "type": "同白",
          "text": "他清廉正直，不惧权奸，我等应当如此。"
        },
        {
          "character": "乡绅甲",
          "type": "白",
          "text": "我等同往各乡村商议。"
        },
        {
          "character": "三乡绅",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四乡绅同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四两段、八校尉、二大校尉同上，同站门。"
        },
        {
          "character": "大校尉甲",
          "type": "念",
          "text": "王府奉君诏，"
        },
        {
          "character": "大校尉乙",
          "type": "念",
          "text": "奋勇出皇朝。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "我等乃梁千岁府中校尉是也。"
        },
        {
          "character": "大校尉甲",
          "type": "白",
          "text": "贤弟，你我奉了千岁之命、圣上旨意，提拿张纲，先到河南府，后进洛阳。"
        },
        {
          "character": "大校尉乙",
          "type": "白",
          "text": "但凭哥哥。"
        },
        {
          "character": "大校尉甲",
          "type": "白",
          "text": "众兄弟催趱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张禄上。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "马来！"
        },
        {
          "character": "张禄",
          "type": "唱",
          "text": "农夫耕种恨天晚， 老人乘马更为难。 中国京剧戏考 《汉忠烈》【三本】 2"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "我，张纲大人府中管家张禄。老爷奉旨巡视河南一省，临行言道，叫我打听他 何处下马，急忙赶去见他。已闻到了洛阳，我也催马到任。"
        },
        {
          "character": "张禄",
          "type": "唱",
          "text": "主恩仆义同患难， 前有结草与衔环。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张禄下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张士安上。"
        },
        {
          "character": "张士安",
          "type": "唱",
          "text": "父命不敢迟行慢， 单身已出淮扬关。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "小生张士安，父讳文纪，官居监察御史，屡有书信叫我进京，为此离了家乡， 单身独行。已到山东，闻听人言，我父升任察院，巡视河南一省，在洛阳下马， 我即往洛阳。"
        },
        {
          "character": "张士安",
          "type": "唱",
          "text": "读书谁不想官宦， 难到蟾宫把桂攀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士安下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张纲上。"
        },
        {
          "character": "张纲",
          "type": "引子",
          "text": "铜肝铁胆，诛强暴，几人生还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张纲外坐。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "可恨梁冀专权误国，纵子擅杀无辜。我已私探民情，目睹眼见，告梁英者状叠 如山，我将犬子拿到公堂，立毙杖下，料想梁冀老贼必不干休。"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "胆大要锯龙上角， 伸手去拔虎口牙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张禄上。"
        },
        {
          "character": "张禄",
          "type": "念",
          "text": "一路单身是孤寡，洛阳虽好不如家。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "老奴叩头。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "起来。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "谢老爷。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "你倒不忘我嘱咐之言。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "老奴岂敢。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "俱是可靠。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "请问老爷，一路之上民情如何？"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哈哈，我有桩痛快之事说与你听。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "我日前下车，埋轮于驿亭，私访豪恶。不料梁冀之子名叫梁英，抢人妇女，霸 占田园房屋，百姓纷纷呈报案下，我即将梁英拿来，乱板打死，与民除了祸害， 岂不痛快人心！"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "吓，梁英被老爷打死了！"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "取了首级，悬挂他门前示众。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "哎呀不好了！"
        },
        {
          "character": "张禄",
          "type": "唱",
          "text": "闻言惊失魂也散， 老爷虎口夺食餐。 梁冀倚仗太后胆， 独掌威权霸朝班。 子仇父报主遭难，"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "哎呀，老爷吓！"
        },
        {
          "character": "张禄",
          "type": "唱",
          "text": "快定良谋心方安。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "胡说！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张禄跪。"
        },
        {
          "character": "张纲",
          "type": "stage",
          "text": "中国京剧戏考 《汉忠烈》【三本】 3"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "是是是。"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "为官当诛国之患， 怕死贪生人笑谈。 梁冀若把国法犯， 按律斩他有何难！ 惧狼见虎心寒战， 樵夫何须进深山？ 我事不用你愁叹，"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "是是是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士安上。"
        },
        {
          "character": "张士安",
          "type": "唱",
          "text": "急趱程途汗难干。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "爹爹在上，孩儿拜揖。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "不消，坐下。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "告坐。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "公子。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "老管家。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "不敢。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "不日父子分离，儿来得正好！"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "吓，爹爹何出此言？"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀儿吓，只因梁冀之子名叫梁英，无恶不为，被为父乱板打死。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "哎呀爹爹吓，谁不知梁冀在朝专权，父亲将他的儿子打死，此仇焉有不报。这 便怎么处？"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "唗！儿言差矣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士安跪。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "为国除奸，乃我分内之事，自蒙圣恩职授封疆，我早把死生置之度外了。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "哎呀爹爹吓，满朝多少臣宰，俱能容过梁冀，爹爹为何独结冤仇？"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀儿吓，为父恨他的吓！"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "恨他何来？"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "嚇！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "顺他者生逆他者斩， 铁人无泪也伤残。 我死不用人顾盼，"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀儿吓！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "为父只为你着难。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "哎呀老爷吓，此事一定祸在目前，还要定个善策方好。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哈哈，我之一死早已打点过了，何惧之有！但是儿身乃遗宗祖之嗣，为父即修 书信，另有吩咐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张纲下。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "哎呀老管家吓，我父舍身，定要与权臣作对，这便怎么处？"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "哎呀公子吓！"
        },
        {
          "character": "张禄",
          "type": "唱",
          "text": "老爷舍身除国患， 比干之心又重繁。 良言阻谏事难返，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张纲自下场门上。"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "一封书信遣儿男。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "儿吓，你幼年曾聘昆陵夏少府之女为室，一向因国事身忙，未曾与儿完婚。这 是你岳父回聘之物，名为金鳌珮。父已修下书信，儿到昆陵就婚，避迹潜踪， 你岳父、岳母见此金鳌珮与你父的书信，自然隐藏你在府中，儿吓，以全张氏 之血脉！ 吓，张禄老管家哎！"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "老爷。 中国京剧戏考 《汉忠烈》【三本】 4"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "你之忠义，我已深知。六尺之孤，能为我力任否？"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "哎呀老爷吓，若以公子托付老奴，自当竭力保护！"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "好，你二人去收拾起行。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "哎呀爹爹吓，那梁冀必有矫旨，前来陷害，爹爹怎么叫儿远离膝下？孩儿不去 吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士安跪。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "唗，为父以身许国，岂惧奸谋陷害。你若与父同死，宗嗣灭绝，反使我忠孝不 能两全了。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "公子吓，老爷之言不差，还是避难的好。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "哎呀爹爹吓，孩儿不孝了。"
        },
        {
          "character": "张禄",
          "type": "白",
          "text": "同去收拾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士安、张禄同下。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "士安，哎呀儿吓！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "世间万事不凄惨， 生离死别最伤残。 宜予之忠人感叹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张禄上。"
        },
        {
          "character": "张禄",
          "type": "唱",
          "text": "学个程婴救主还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张士安上。"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "孩儿拜别。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "槽头有马乘骑。"
        },
        {
          "character": "张士安",
          "type": "唱",
          "text": "为子当替父之难， 忍心离别两为难。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "张士安",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "张士安",
          "type": "唱",
          "text": "拜别严亲暗催趱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟信上。"
        },
        {
          "character": "钟信",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "钟信",
          "type": "唱",
          "text": "知事不报岂隐瞒。"
        },
        {
          "character": "钟信",
          "type": "白",
          "text": "老爷！"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "吓，钟信，何事惊慌？"
