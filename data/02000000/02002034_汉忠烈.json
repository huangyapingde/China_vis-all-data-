        {
          "character": "刘豹",
          "type": "念",
          "text": "狼心不改总有报，"
        },
        {
          "character": "玉姐",
          "type": "念",
          "text": "野鸟惊散难归巢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹、玉姐同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四两段、八校尉、二大校尉、张纲同上，同凹门。店小二自下场门上。"
        },
        {
          "character": "店小二",
          "type": "白",
          "text": "迎接众位老爷。"
        },
        {
          "character": "大校尉甲",
          "type": "白",
          "text": "将钦犯押至后房，紧锁门户。"
        },
        {
          "character": "店小二",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "两段甲押张纲随店小二同下。〖起初更鼓〗。八校尉分站两边。四家丁、孙朗同上。〖水底鱼〗。"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "唤店家！"
        },
        {
          "character": "家丁甲",
          "type": "白",
          "text": "店家店家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店小二上。"
        },
        {
          "character": "店小二",
          "type": "白",
          "text": "来了来了，店家迎接老爷。"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "京都校尉们可在你店中？"
        },
        {
          "character": "店小二",
          "type": "白",
          "text": "在里面。"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "待我进去。 吓，你们俱在这里。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "孙大老爷来了，校尉叩头。"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "起来起来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙朗中坐。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "大老爷为何来此？"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "待我歇歇气，再告诉你。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "是是是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹上。"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "吓，今晚是哪里来的许多人下店，小二说什么校尉解一钦犯，我在暗地听他们 说些什么？"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "张纲父子，俱已拿到了么？"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "只有张纲一人，他的儿子不在任所。"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "吓吓吓，这是梁千岁手批，拿去看。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "孙老爷，张纲既已拿问，该到京都正法，为何要在中途杀他？"
        },
        {
          "character": "孙朗",
          "type": "白",
          "text": "哎呀，这又不是我孙朗的主意，乃是梁千岁的手批。我到京口拿他的儿子张士 安，你等速速结果张纲，好回梁府交差。俺去也！ 带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家丁领孙朗同下。"
        },
        {
          "character": "大校尉甲",
          "type": "白",
          "text": "吓，好奇怪，怎么在饭店内杀朝中大臣，这是什么缘故？"
        },
        {
          "character": "大校尉乙",
          "type": "白",
          "text": "梁千岁要张大人首级，管什么饭铺酒馆。少时将他杀了，就是谁敢阻拦！"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "哎这些王八日的，该死在我手！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹下。"
        },
        {
          "character": "大校尉甲",
          "type": "白",
          "text": "也罢，我等吃了酒饭去杀。"
        },
        {
          "character": "大校尉乙",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八校尉、二大校尉同下。刘豹上。"
        },
        {
          "character": "大校尉乙",
          "type": "stage",
          "text": "中国京剧戏考 《汉忠烈》【三本】 9"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "刘豹",
          "type": "唱",
          "text": "萧何律法今改样， 饭铺当作杀人场。"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "女儿快来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉姐上。"
        },
        {
          "character": "玉姐",
          "type": "白",
          "text": "来了！"
        },
        {
          "character": "玉姐",
          "type": "唱",
          "text": "父唤急行如沧浪， 放下针指出绣房。"
        },
        {
          "character": "玉姐",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "儿吓，为父教你的那些武艺，今晚用得着了！"
        },
        {
          "character": "玉姐",
          "type": "白",
          "text": "与何人争斗？"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "你到房中收拾，少时明白。我叫店内之人，一齐动手，叫那些王八日的，一个 也跑不了！"
        },
        {
          "character": "刘豹",
          "type": "唱",
          "text": "刘豹放开杀人量， 路见不平非张狂。"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "吓，这是什么缘故！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹、玉姐同下。〖起二更鼓〗。张纲上。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "耳听谯楼更鼓响， 心兢胆战意惶惶。 梁英强将民女抢， 占人田地与民房。 件件是真无虚谎， 立毙杖下命该亡。 早料梁冀不擅放， 父报子仇理应当。 设计拿我入罗网， 但愿去见有道王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张纲内场坐。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "这是梁冀矫旨拿我，但愿面见龙颜，以表忠心。咳，士安儿吓，你同张禄去到 昆陵就婚，但愿平安无事，为父的若死于贼之手，儿能报仇，父死瞑目吓！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "苦读诗书名登榜， 子袭父职立朝堂。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "为何不听金鸡唱？ 桌案之上暂为床。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。八校尉、二大校尉同上，八校尉同站一条龙，二大校尉同站中间。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同唱",
          "text": "梁府法令不敢抗， 奉旨斩人非自狂。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "打进去！ 张老爷！"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "吓，天还未明就要趱路么？"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "张老爷不用走了，方才有圣旨到来，就在此请你归天。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "吓，怎么在路上杀我？"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "我们是照旨行事。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "吓，既然如此，待我拜谢圣上爵禄之恩。"
        },
        {
          "character": "大校尉甲、大校尉乙",
          "type": "同白",
          "text": "但凭于你。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀圣上吓！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "翰林身价主恩赏， 中国京剧戏考 《汉忠烈》【三本】 10 御史言官升封疆。 皇王恕臣无福享， 自有忠名万古扬。"
        },
        {
          "character": "八校尉",
          "type": "同白",
          "text": "请老爷受绑。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "张纲",
          "type": "唱",
          "text": "忠良受戮何用绑？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹、玉姐、八上手拿兵器同上，同在外听。"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "打进去！"
        },
        {
          "character": "刘豹",
          "type": "唱",
          "text": "今将尔等当猪羊！ （玉姐拉张纲同下，刘豹、八上手、二大校尉、八校尉同打，八上手推八校尉、大校尉甲同下，刘豹杀死大 校尉，按住。）"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "好王八日的！"
        },
        {
          "character": "刘豹",
          "type": "唱",
          "text": "仗着权臣也结党， 狗倚人势装虎狼。 刘爷砍你为肉酱， 送你阴魂见阎王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹下。八上手同杀死八校尉下。玉姐上。"
        },
        {
          "character": "玉姐",
          "type": "唱",
          "text": "爹爹直言对我讲， 梁冀霸朝欺圣皇。 文武命在他手掌，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四两段同上，玉姐杀四两段死。大校尉乙上，玉姐杀大校尉乙死。张纲上。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀哎呀！"
        },
        {
          "character": "玉姐",
          "type": "唱",
          "text": "路见不平救忠良。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉姐拉张纲。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉姐、张纲同下。刘豹背大行李拿火把上。"
        },
        {
          "character": "刘豹",
          "type": "唱",
          "text": "救人也要自上当， 惜身重命非为强。 对着店房将火放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "火彩。刘豹背大行李。"
        },
        {
          "character": "刘豹",
          "type": "唱",
          "text": "不平之事惹人忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹下。众民人抬水机同上"
        },
        {
          "character": "众民人",
          "type": "同白",
          "text": "刘家饭店火起，快去救！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众民人同闲白，同下。玉姐拉张纲同上。"
        },
        {
          "character": "玉姐",
          "type": "唱",
          "text": "火光照地有方向，"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘豹上。"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "刘豹",
          "type": "唱",
          "text": "弃了家产逃远方。"
        },
        {
          "character": "玉姐",
          "type": "白",
          "text": "爹爹来了！"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "你叫什么什么？"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "你看提纲。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "吓吓吓！"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "什么名字？"
        },
        {
          "character": "刘豹",
          "type": "白",
          "text": "提纲有名，走吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。"
        },
        {
          "character": "张纲",
          "type": "白",
          "text": "哎呀哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张纲、刘豹、玉姐同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}