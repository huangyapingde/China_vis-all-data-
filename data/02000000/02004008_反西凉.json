{
  "script_id": "02004008",
  "title": "反西凉",
  "alias": [
    "割须弃袍"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "马超",
      "hangdang": "武生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "许褚",
      "hangdang": "净"
    },
    {
      "name": "曹洪",
      "hangdang": "净"
    },
    {
      "name": "夏侯惇",
      "hangdang": "丑"
    }
  ],
  "plot": "马腾镇守西凉，奉命调京。行至中途，被曹操派人杀死。长子马超闻言后，即发兵为父报仇。曹营大将徐晃、\n曹洪，相继败北。最后曹操换袍割须，始得逃脱。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同上，同站门。马腾、马岱同上。"
        },
        {
          "character": "马腾",
          "type": "引子",
          "text": "镇守西凉，秉忠心，扶保朝堂。"
        },
        {
          "character": "马腾",
          "type": "念",
          "text": "执掌黄金印，专管各路兵。三军齐骁勇，将令谁不遵。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "老夫马腾。奉主之命，镇守西凉一带等处。今当三六九日大操之期。 马岱听令。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "传令下去：吩咐大小将官，全身披挂，校场操演。"
        },
        {
          "character": "夏侯惇",
          "type": "内白",
          "text": "圣旨下。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "吓。启禀爹爹：圣旨下。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "香案接旨。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "吓，香案接旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍、夏侯惇同上。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "圣旨下跪。"
        },
        {
          "character": "马腾、马岱",
          "type": "同白",
          "text": "万岁。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "听宣读诏曰：圣上念马腾镇守西凉，多受风霜之苦，调进京去，另加爵赏，旨 意读罢，望诏谢恩。"
        },
        {
          "character": "马腾、马岱",
          "type": "同白",
          "text": "万万岁。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "香案供奉。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "有劳将军奉旨前来，后帐摆宴。"
        },
        {
          "character": "夏侯惇",
          "type": "白",
          "text": "且慢，有朝命在身，不敢久停。 带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四青袍同带马，四青袍、夏侯惇同下。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "唗，众将官，回朝去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套领马腾、马岱同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四上手同上，同挖门，董平上，领下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四白龙套、马腾、马岱同上，同挖门。〖牌子〗。董平、四上手同上，同挖门，四上手同杀，马腾死，马"
        },
        {
          "character": null,
          "type": "text",
          "text": "岱逃走，一过，两过，同下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马岱上。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "且住，我父子行至中途，不想曹贼暗地差人前来，将我父杀死，不免回至西凉， 报与兄长知道，马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。马岱下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马超上。"
        },
        {
          "character": "马超",
          "type": "引子",
          "text": "幼习兵机，论韬略，盖世无敌。"
        },
        {
          "character": "马超",
          "type": "念",
          "text": "千里风沙镇烽烟，排兵布阵谈笑间。男儿有志威名显，难得姓名表凌烟。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "姓马名超字孟起。我父马腾在汉室为臣，镇守西凉一带等处。圣上有旨意到来， 调我父进京，不知为了何事，是俺放心不下，命马岱跟随前去，未见回信， 等他到来，便知分晓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱上。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "参见兄长。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "贤弟回来了。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "你为何这等惊慌？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "哎呀兄长，小弟与天伦行至石门，不想那曹贼暗差董平前来，将天伦斩首。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "被那贼斩首了！"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "马超",
          "type": "三叫头",
          "text": "爹爹！我父！哎呀！"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "兄长醒来。"
        },
        {
          "character": "马超",
          "type": "西皮导板",
          "text": "听说我父丧了命，"
        },
        {
          "character": "马超",
          "type": "三叫头",
          "text": "天伦！爹爹！哎呀！"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "点点珠泪望下淋。 我父身犯何条令， 为何斩首在石门。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "马岱听令。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "传令下去，命庞德全身披挂，大堂伺候。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超回头。"
        },
        {
          "character": "马超",
          "type": "三哭",
          "text": "爹爹！我父！哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马超下。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "嘟，下面听着：俺兄长有令，命庞德全身披挂，大堂伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱急下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "庞德上，起霸。"
        },
        {
          "character": "庞德",
          "type": "念",
          "text": "大将生来胆气豪，腰横秋水雁翎刀。只为点兵把仇报，烈烈轰轰闹汉朝。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "俺庞德。元帅与父报仇，不免全身披挂，在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四白龙套同上，同站门。〖急急风〗。马岱、马超同上。"
        },
        {
          "character": "马超",
          "type": "念",
          "text": "我父把命丧，令人痛心肠。"
        },
        {
          "character": "马岱、庞德",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "站立一旁。"
        },
        {
          "character": "马超",
          "type": "念",
          "text": "斩尽奸佞报冤仇，胸中怨恨几时休。人马撤至中原地，不杀奸佞不回头。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "俺，马超。今日兴兵与父报仇，我想人马未动，粮草先行。 马岱听令。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "命你解押粮草，军前听用，不得违误。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "得令。 马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马岱骑马下。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "庞德听令。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "攻打头阵。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "得令。 马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手领庞德同下。"
        },
        {
          "character": "马超",
          "type": "白",
          "text": "哦呵，爹爹，天伦，孩儿今日兴兵与你报仇，望你在阴曹感应，暗地扶儿。 嘟，众将官，起兵前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套领马超同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "董平、四下手拿藤牌同上，同挖门。四上手、庞德同上，上场一字，起打。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "唗，看刀！ （董平、庞德双架住，四上手、四下手会阵，四上手、四下手同下，庞德、董平对刀，董平败下，庞德追下。 庞德上，杀死董平，四上手自两边分上。）"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "那贼落马。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "回营交令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套同上，同站门。徐晃上。"
        },
        {
          "character": "徐晃",
          "type": "点绛唇",
          "text": "杀气冲霄，儿郎虎豹，军威好，地动山摇，要把狼烟扫。"
        },
        {
          "character": "徐晃",
          "type": "念",
          "text": "战鼓响惊天动地，杀气腾鸟不敢飞。帐下将英雄无比，将令出谁敢擅离。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "本帅徐晃，奉魏王之命，把守潼关一带等处。此潼关乃咽喉之径，因此每日操 演人马，紧守城池，也曾命探子打探各路军情，未见回报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！马超倒反西凉。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "今有马超倒反西凉，无人抵挡。 来，免战高悬。"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "免战高悬。"
        },
        {
          "character": "曹洪",
          "type": "内白",
          "text": "呵哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪上。"
        },
        {
          "character": "曹洪",
          "type": "念",
          "text": "赤面红发气冲霄，二目睁红似火烧。站在阵前人皆怕，三国之中逞英豪。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "俺曹洪。忽听马超倒反西凉，元帅免战高悬，不免进帐问个明白。 报，曹洪告进，参见元帅。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "将军少礼请坐。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "将军进帐何事？"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "元帅传下将令，待末将单人独骑，生擒马超入账。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "将军此去，恐不是他人的敌手。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "元帅你好小量也！"
        },
        {
          "character": "曹洪",
          "type": "西皮摇板",
          "text": "元帅把话讲错了， 末将有言听根苗： 少时马超兴兵到， 雪见太阳也化消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报，马超讨战。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子翻筋斗。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "元帅，马超讨战，快快发动人马。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "等候魏王大兵来到，再发动人马不迟。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "元帅快些发动人马。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "发不得人马。"
        },
        {
          "character": "曹洪",
          "type": "白",
          "text": "哎呀！呀呀！呔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹洪拿令旗递红龙套甲，领下，上，曹洪拿刀一夺、二夺、三夺，曹洪急下。"
        },
        {
          "character": "徐晃",
          "type": "白",
          "text": "且住，看曹洪这等性傲，俺不免报与魏王知道。 来，带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套领曹洪同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹洪、庞德自两边分上，会阵，同起打，曹洪杀败庞德，曹洪追下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": "马超",
          "type": "内西皮导板",
          "text": "豪杰兴兵谁敢挡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白龙套同上，同斜胡同。马超上。"
        },
        {
          "character": "马超",
          "type": "唱",
          "text": "恼恨孟德起祸殃。"
        },
        {
          "character": null,
          "type": "stage",
