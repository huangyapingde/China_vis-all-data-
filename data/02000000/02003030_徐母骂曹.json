{
  "script_id": "02003030",
  "title": "徐母骂曹",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "徐母",
      "hangdang": "老旦"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "徐庶",
      "hangdang": "老生"
    },
    {
      "name": "程昱",
      "hangdang": "末"
    }
  ],
  "plot": "刘备得徐庶，曾将曹操打败一次。曹操料想刘备那边，必有能人，多方探听，才知他新得一个谋士叫单福，\n谋略很大。就想用计将单福赚来，收为己用，于是和程昱商量如何用计。程昱知道单福是徐庶的化名，又知\n道他的母亲现在颍州。所以程昱就献一计，教曹操先将徐母赚到许昌，教她写信去招徐庶。以为徐庶极孝，\n接到母亲书信，必定前来。曹操一听此计大妙，就教人赶到颍州，说是徐庶已在许昌，特来请老母前去。徐\n母一到许昌，不见徐庶，知中奸计。及至曹操请她写信去招徐庶，她就大骂曹操奸恶不臣；刘备乃帝室宗亲，\n儿子在那里辅助他，正是臣得其主，怎肯转来事你奸臣？骂完之后，拿起砚台，向曹操打来。本想激怒曹\n操，把自己杀死，反可以教儿子一心一意辅助刘备。曹操被骂，果然大怒，就要杀她。程昱在旁劝止，将徐\n母软禁起来，假冒她的字迹，写了一封假信，将徐庶赚来。后来徐母见儿子被赚而来，深深责骂儿子不明，\n自己到后面，自尽而死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众将引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "执掌威权，收天下，文武英贤。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "汉室江山气运终，群雄四方各争锋。老夫坐镇许昌地，搜罗天下众英雄。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫曹操，汉室为臣。只因曹仁、李典，失守樊城，闻得刘备军中有一单福划 策，不免请程昱进帐，问明来历。 来，请程谋士进帐。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "请程谋士进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程昱上。"
        },
        {
          "character": "程昱",
          "type": "念",
          "text": "胸藏三坟五典，才能调将遣兵。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生少礼。请坐。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "谢坐。唤卑人进帐，有何军情？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "闻得刘备军中，有一单福划策。先生可知单福何人也？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相容禀："
        },
        {
          "character": "程昱",
          "type": "二黄原板",
          "text": "单福家住在颍州， 其中必有细根由： 字表元直徐门后， 单名徐庶有名头。 如今落得刘备手， 丞相兴兵实堪忧。"
        },
        {
          "character": "曹操",
          "type": "二黄原板",
          "text": "此人智高才量有， 丞相我怜才早设计谋。 既与玄德为好友， 要想收他我也无计求。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此人既与刘备相投，恐无外人能下手，真乃可惜了。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相有心要用此人，却也不难。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "卑人素闻徐庶极孝。只消丞相差人，将徐母赚至许昌，令其修书元直，谅无不 来之理。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此计甚好。后堂摆宴，与先生同饮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "引子",
          "text": "闷坐草堂，自凄凉，怎不惨伤。"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "大儿四海访良朋，次子一命赴幽冥。可叹老身无伺奉，凄凉孤苦在家中。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身，徐庶之母。所生二个孩儿：长子徐庶，在外访友；次子徐康，不幸身亡。 撇下老身独守家中，好不伤感人也！"
        },
        {
          "character": "徐母",
          "type": "二黄正板",
          "text": "老身生来命不强， 不幸中年居了孀。 不盼我儿归家往， 但望我儿把名扬。 生养二字全不讲， 怕人说我教子无方。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "丞相差我颍州往， 迎接徐母进许昌。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "俺，曹府家将是也。奉丞相之命，迎接徐庶之母进京。就此马上加鞭。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "催马加鞭朝前闯， 抬头只见一村庄。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "借问一声，此地可有个徐老太太？"
        },
        {
          "character": "路人",
          "type": "内白",
          "text": "哪个徐老太太？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "徐庶、徐康之母——徐老太太。"
        },
        {
          "character": "路人",
          "type": "内白",
          "text": "前面合脊门楼便是。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "多谢多谢。 来此已是。 徐老太太开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "门外有人把话讲， 莫非徐庶转回乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母开门。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你是哪里来的？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "京都来的。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "到此则甚？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "奉了我家主人之命，迎接徐老太太进京。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "你可认识？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "不相认。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身正是。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "原来是徐老太太。小人叩头。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "不消。你奉何人所差？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "小人奉程大老爷与徐大老爷所差。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程大老爷——他是何人？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "我家老爷姓程名昱，与徐大老爷同殿为官，结拜弟兄。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "他二人官居何职？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "俱是议郎。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "因何接我进京？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "二位老爷，闻听徐二老爷亡故，恐老太太无人伺奉，特差小人接老太太进京， 同享荣华。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "可有书信？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "无有。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "为何无有书信？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "官差荣耀，修书不及。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "如此，备车辆伺候。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "好啊！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "我儿官居为议郎， 迎接老身进许昌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "门前备下车一辆， 有请老太太上京城。"
        },
        {
          "character": "徐母",
          "type": "内白",
          "text": "来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "家将引路将车上， 想起徐康两泪汪。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "哎呀，儿啊。你哥哥接为娘进京享荣华，你是怎的不来？徐康，苦命儿啊啊……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、家将同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": "曹操",
          "type": "内西皮摇板",
          "text": "汉室衰危天地荡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "各路烟尘起四方。 老夫时刻将士访， 但愿徐母到许昌。 将身且坐二堂上， 为国求贤日夜忙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "西皮摇板",
          "text": "相府门前住车辆， 见了丞相说端详。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "丞相在上，小人叩头。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "徐母可曾接到？"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "现在府外。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "命众将前去迎接。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "适才家将对我讲，"
        },
        {
          "character": "曹操",
          "type": "西皮流水板",
          "text": "他说徐母到许昌。 徐母到此修书往， 徐庶必定来许昌。 帮助老夫把寇荡， 个中哪有孙、刘做帝王？ 将身且坐我的二堂上， 徐母到来作商量。"
        },
        {
          "character": "徐母",
          "type": "内西皮导板",
          "text": "一路思姣儿泪两行，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将引徐母同上。"
        },
        {
          "character": "徐母",
          "type": "西皮原板",
          "text": "有劳将军列两旁。 我与那曹丞相无有来往， 聘请老身为哪桩？"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "丞相有大事相商。"
        },
        {
          "character": "徐母",
          "type": "西皮原板",
          "text": "旧理根由全不像， 不见徐庶在哪厢。 一路上心急催车辆，"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "太夫人到。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "见了那曹丞相我细问端详。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "徐母到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "未见姣儿面，总然心不安。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "丞相在上，老身万福。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人少礼，请坐。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人一路之上，多受风霜，身体可好？"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身承问。请问丞相，我儿徐庶，他往哪里去了？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "徐元直现在新野。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "但不知他在新野依佐何人？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "在新野帮着谗臣刘备，如美玉陷在淤泥，明珠埋于尘垢。太夫人修书一封，招 他回来。老夫奏闻天子，定有封赏也。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "徐元直本是一英豪， 帮助刘备为哪条？ 太夫人修书将他叫， 保管位列压群僚。 人来看过文房宝——"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "此事其中有蹊跷。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "我闻家将言道，我儿在朝，官居议郎之职。如今又命我修书招他，其中是何道 理？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恐太夫人不允前来，故言在京为官，以安太夫人之心。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "原来你等用的诡计！丞相，你知道刘备是何种人物？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "他乃涿郡小辈，妄称皇叔，所谓外君子而内小人也。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "老夫一番美言讲， 莫把恩情当祸殃。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "听他言来心好恼， 才知中你计一条。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹丞相，我有几句言语，你且听了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "太夫人讲来。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "老身久闻玄德乃中山靖王之后，孝景皇帝玄孙。屈身下士，恭己待人。义气传 于四方，仁声著于天下。虽黄童白叟，牧子樵夫，谁不称他为仁人君子，真乃 盖世英雄、超群豪杰。吾儿若果附之，正是如鱼得水。我徐氏三代宗亲，万千 之幸。想汝虽托名汉相，实为汉贼。内怀谋朝篡位之心，外逞欺主专权之计。 汉都迁驾，百姓流离，众官切齿。辱祢衡为鼓吏，名士寒心；杀太尉于市朝， 忠臣思烈。甚而斩贵妃于宫掖，占甄氏为儿媳。你种种谋逆，彰明昭著。市上 三尺童子，未有不想杀尔之头，食尔之肉，挖尔之心，碎尔之骨。汝今日又离 间我的母子，拆散刘备的谋臣。曹操啊曹操，你真乃名教中的罪人，衣冠中的 禽兽！"
        },
        {
          "character": "徐母",
          "type": "西皮二六板",
          "text": "刘备本是英雄将， 义气仁声著四方。 吾儿附他如臂膀， 仁明之主遇贤良。 你不是那曹嵩的亲胞养， 你本是夏侯族中抛弃的儿郎。 明在朝中为宰相， 内怀篡逆乱朝纲。 许田射猎欺主上， 无故迁都赴许昌。 借手杀人祢衡丧， 最可叹吉平他在剑下亡。 带剑常把宫门闯，"
        },
        {
          "character": "徐母",
          "type": "西皮快板",
          "text": "勒死了贵妃实可伤。 你比那当年贼王莽， 你比那董卓更猖狂。 无故差人家中往， 诓骗老身进许昌。 欲使吾儿归你掌， 你这曹，贼妄想痴心你就枉费心肠！"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "老夫当朝一首相， 恶言恶语把我伤。 相府如同虎口样， 霎时叫你一命亡。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "徐母",
          "type": "西皮快板",
          "text": "听他言来气上闯， 大骂曹操听端详： 老身既来不思往， 休将虎口吓老娘。 文房四宝桌案放——"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "击死奸贼赴无常。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母举砚向曹操掷去，未击中。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "反了啊！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "人来与我上了绑， 推出斩首一命亡。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大胆恶妇，敢击打老夫。武士推出斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将押徐母同下，程昱上。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "刀下留人。"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "将身且把二堂上， 见了丞相说端详。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相因何将徐母斩首？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "恶妇百般叫骂，故而将她斩首。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "斩了徐母，恐大事不利。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "丞相若将她斩首，她子徐庶在彼，闻听此事，必然尽心相助刘备。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "依你之见？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "将她放回，派人侍奉，每天伺候。套她笔迹修书，差人送至新野。徐庶乃是大 孝之人，必然随书前来。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哈哈哈，此计甚好。 来，将徐母放回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母上。"
        },
        {
          "character": "徐母",
          "type": "西皮散板",
          "text": "欲借曹操帐下刀， 全我半世美名标。 忽听堂上传赦诏， 反使老身我的心内焦。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "曹操，要杀就该开刀，为何又将老身放回，真真岂有此理！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "非是老夫不杀于你，程先生言道，他与你子有八拜之交，斩了你，如斩他母亲 一般，故而放回。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "程先生为何多事？"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母啊！"
        },
        {
          "character": "程昱",
          "type": "西皮摇板",
          "text": "我与元直曾交好， 岂肯叫伯母吃一刀。"
        },
        {
          "character": "徐母",
          "type": "西皮摇板",
          "text": "先生只顾将我保， 我儿新野住不牢。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "先生，将徐母小心伺候。 掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        },
        {
          "character": "徐母",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "徐母",
          "type": "念",
          "text": "久闻曹操多奸诈，今日一见果不差。"
        },
        {
          "character": "程昱",
          "type": "白",
          "text": "伯母，随小侄来啊。"
        },
        {
          "character": "程昱",
          "type": "笑",
          "text": "哈哈哈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐母、程昱同下。"
        }
      ]
    },
