{
  "script_id": "02001046",
  "title": "装疯",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "孙膑",
      "hangdang": "老生"
    },
    {
      "name": "园丁",
      "hangdang": "丑"
    },
    {
      "name": "庞涓",
      "hangdang": "净"
    }
  ],
  "plot": "孙膑被庞涓陷害，刖足毁容后，庞涓仍想得到孙膑所知之三部天书，故假意殷勤，留孙膑在其家中，由园丁\n服侍，一面养病，一面抄写天书。园丁知庞涓之用心，天书抄完，即将孙膑杀死。又念孙膑系忠良之士，不\n忍其落此下场。暗中示意孙膑，应谋良策，孙膑遂装疯逃脱云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "园丁上。"
        },
        {
          "character": "园丁",
          "type": "念",
          "text": "有福之人人服侍，无福之人服侍人。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "自家庞府中园丁的便是。奉我家老爷之命，服侍孙老爷，抄写天书。今日天气 晴和，不免扶他出来，抄写一番。 孙老爷有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑内作哀声，上。"
        },
        {
          "character": "孙膑",
          "type": "引子",
          "text": "浑难料，险遭诛戮，将微躯保，只是毁伤遗体，形容枯槁。"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "十年磨练用精功，谁想今朝总是空。屋漏更遭连夜雨，行船又遇打头风。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "我，孙膑。辞师下山，指望际会风云，愿我胸中大志。谁想魏王，将我毁面刖 足，若不亏庞兄搭救，我命险遭齑粉。只是他有救命之恩，我无以为报，情愿 将三卷天书，抄写与他，方才完我一桩心事。 园丁！"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "取杯茶来我吃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "园丁允，下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "不免抄写一番。"
        },
        {
          "character": "孙膑",
          "type": "解三酲",
          "text": "论兴兵先须度料， 方才去作政当朝。 我想那善用兵的， 偏心巧凑着韬略； 那不善用兵的， 偏往往自夸豪。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "我想但凡为将帅的呵！"
        },
        {
          "character": "孙膑",
          "type": "解三酲",
          "text": "必须要驱神移鬼书黄甲， 鼓瑟琴调各有妙。 算得个才高智广， 智广才高，志广才高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二将官引庞涓同上。"
        },
        {
          "character": "庞涓",
          "type": "念",
          "text": "恨小非君子，无毒不丈夫。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "我，庞涓。为何道此两句言语？可恨孙膑这厮，在魏王驾前，连打我三次下马， 本该杀却，方消吾恨。奈他腹内有三卷天书，未曾到手。待等到手时节，杀 他未迟。 左右唤园丁。"
        },
        {
          "character": "二将官",
          "type": "同白",
          "text": "园丁，园丁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "园丁上。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "有有。 园丁与老爷叩头。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "园丁！"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "你孙老爷现在何处？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "现在书房中抄写天书。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "说我到了。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "是。 孙老爷，我家主人到了。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "道有请。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "是。 孙老爷道有请。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "孙兄哪里？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "庞兄哪里？"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "孙兄。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "庞兄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑、庞涓对笑。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "有坐。孙兄，小弟一向事忙，未能奉陪，多有简慢了。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "好说。小弟在府，多有打搅了。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "好说。疮痕可曾痊愈？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "尚未。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "天书可曾抄完？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "不曾。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "可曾用过饭了？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "也不曾。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "这样时候，还不与你孙老爷摆饭？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "预备在厨下。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "取来。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "是。 厨下的拿饭来呀。 饭到。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "嗐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞涓怒。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "这样饭食，也是你孙老爷用的？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "啊，庞兄，小弟往日，就是这样饭食。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "一定是园丁之过。 左右。"
        },
        {
          "character": "二将官",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "扯下去打。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "这不干小人之事。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二将官同打园丁。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "孙老爷讨情啊。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "啊，庞兄，看小弟薄面，饶过他吧。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "若不是你孙老爷讨情，一定将腿敲折。起来谢了你孙老爷。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "是。 谢孙老爷讨情。 谢我家主人不打。 谢你们俩狠刑。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "孙兄，小弟朝中事忙，不能奉陪了。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "小弟刀疮疼痛不能远送了。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "庞涓",
          "type": "念",
          "text": "仁兄且自放宽心，"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "怎奈时乖命运微。"
        },
        {
          "character": "庞涓",
          "type": "念",
          "text": "梧桐叶落根还在，"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "兄啊！"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "寒冬不死又逢春。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "好好个“寒冬不死又逢春”。请。 唤园丁。"
        },
        {
          "character": "二将",
          "type": "同白",
          "text": "园丁。"
        },
        {
          "character": "园丁官",
          "type": "白",
          "text": "有。园丁伺候老爷。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "园丁，以后你孙老爷的饭食，还是照常的预备。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "小人禁不住照常的板子。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "呆狗才，老爷抬举你就是了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞涓、二将官同下。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "是。谢老爷抬举。园丁送老爷、爷、爷，呀呀呀啐！"
        },
        {
          "character": "园丁",
          "type": "快索南枝",
          "text": "你是个狼心肺，特不仁， 狼心肺，特不仁。 设计施谋任所为， 反把忠良来害取。 天网恢恢，"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "唉，老天，像这样人，留他在世何用？哦。"
        },
        {
          "character": "园丁",
          "type": "快索南枝",
          "text": "何不将他杀却！"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "且住，我想孙老爷乃是忠良之辈，我若不说，他如何晓得？有咧，不免假哭三 声，假笑三声，打动他老人家便了。 这个孙老爷，你哪睄我。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "园丁哭，笑。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "哈，狗才你为何又哭又笑？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "小人这哭笑俱有了个缘故。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "讲。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "小人这哭呢，是哭孙老爷的命苦。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "唉罢了。你这笑呢？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "笑孙老爷无用。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "啊，呆狗才，怎见得你孙老爷就无用？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "我想孙老爷的刀疮疼痛，这天书不写倒也罢了。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "啊，园丁，虽然刀疮疼痛，这天书少不得要慢慢地抄写。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "你就慢慢地死。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "我如今要快快地写。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "快快地死。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "不写。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "不死。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "要写。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "要死，死定咧！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "唗！狗才！哦是了，方才你家主人，责打你几板，在我跟前搬弄是非么？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "小人不敢。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "起来。取我烫足的花椒水来。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "预备在哪里？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "取来。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "是。这个孙……"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "哎，多讲！"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "嗐！"
        },
        {
          "character": "园丁",
          "type": "念",
          "text": "分明指引平川路，反把忠言当恶言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "园丁下。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "方才细听园丁之言，莫非庞兄他有害我之意？哎呀，我那师父哇！哈哈，当初 弟子不肯下山，是你苦苦逼我下山，如今弟子有难，怎的不来搭救搭救？唔， 且自由他是，且自由他啊。 笔管内什么东西？原来是一纸卷，待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑嗽一声，看。"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "“奈何奈何，孙”……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑嗽一声，想，看。"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "“孙膑遭魔。若要逃生，假装疯魔。”"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "是假装疯魔！原来是师父的先兆到了。我有道理。 园丁哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "园丁上。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "来了，园丁伺候孙老爷。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "园丁，你方才说的话，我一些也是不懂。你须要慢慢地讲来。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "孙老爷不问，小人也不敢讲。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "讲来。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "是。孙老爷容禀。"
        },
        {
          "character": "园丁",
          "type": "风入松",
          "text": "都只为先生神机妙高，"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "孙老爷曾记得那年，魏王有旨，命两家老爷摆阵，哪家老爷摆得好，破得妙， 圣上赐御酒三杯；哪家老爷摆得不好，破得不妙，圣上罚凉水三杯。可是有的？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "有的。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "那时命孙老爷摆阵，一摆摆了个金锁八卦连环阵，摆摆得好，破得又妙，圣上 大喜，赐了御酒三杯。那时命我家老爷摆阵咧，一摆摆了个咭伦撅伦的长虫阵。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "长蛇阵。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "就是那个阵哪，摆摆得不好，破破得不妙，圣上恼咧，罚了凉水三杯。可是有 的？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "啊，园丁，那凉水无非入腹罢了。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "凉水虽然入腹呵！"
        },
        {
          "character": "园丁",
          "type": "风入松",
          "text": "点点在心头， 孙老爷恁不见他心生奸狡， 设计施谋，害伊曹。 每日里凌逼小人，所为何来， 孙老爷，都只为这三卷天书未曾到手。 因此上设下了刖足计，损容颜，"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "孙老爷与我家主人是什么人？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "不过是好朋友。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "却又来！自古交朋友须胜己哟！"
        },
        {
          "character": "园丁",
          "type": "风入松",
          "text": "似他不如无了。 孙老爷细思量， 与他有什么相交， 这灾祸终须难逃。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "哈，我今把笔为刀剑，刎下贼头来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑疯。"
        },
        {
          "character": "孙膑",
          "type": "下山虎",
          "text": "我冲霄汉， 一拳打破太行山。 浑将一脚， 我踏破了天关。 你把我天书哎哎我扯得来纷纷烂， 专打你这无知汉。 因甚谋反， 那玉皇他见我太谦。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "天宫将军，地宫将军，阎王老官，你们都都请了。"
        },
        {
          "character": "孙膑",
          "type": "下山虎",
          "text": "我和你齐飞上天。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "这些神圣都在哪儿呢？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "那不是？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "孙老爷，放手哇！"
        },
        {
          "character": "孙膑",
          "type": "下山虎",
          "text": "若要我放手，只待三年。"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "唯呀我的财和宝尽皆抛散。"
        },
        {
          "character": "孙膑",
          "type": "下山虎",
          "text": "只落得我愁无限。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑笑。"
        },
        {
          "character": "孙膑",
          "type": "念",
          "text": "我明明笑十分欢颜。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "园丁你过来。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "我不过去，我怕孙老爷打我。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "我不打你，你只管的过来。"
        },
        {
          "character": "孙膑",
          "type": "下山虎",
          "text": "我与你安置了吧。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "说了不打，又是一下子。安置了？我明白咧，你哪想是困了。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "着哇！"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "你哪请睡罢咧。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "你呢？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "我还服侍你哪呢么？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "如此我便得罪了。"
        },
        {
          "character": "孙膑",
          "type": "下山虎",
          "text": "且自向竹床安眠，向竹床安眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑下。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "天有不测风云，人有旦夕祸福。孙老爷方才抄写天书，一霎时就疯了。这个事 情，我担不住，请我们老爷。 老爷有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞涓上。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "园丁，你为何这等大惊小怪？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "孙老爷疯咧！"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "现在何处？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "花椒树底下打盹儿呢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑上。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "孙膑",
          "type": "扑灯蛾",
          "text": "天赫地暗颠倒颠， 洞里须是闹中闲。 神仙不管凡间事， 只在人间颠倒颠。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "唯呀好冷天哪！"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "这样炎热天气，还嚷冷！"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "好大雪！"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "青天白日，哪里来的雪？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "你看那不是？"
        },
        {
          "character": "孙膑",
          "type": "急三枪",
          "text": "雪贯风亭， 原来是雪天王，错行了冬令。 雪天王下这般大雪纷纷， 可怜我身上无衣，腹内无食，"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "可不冻死我了！"
        },
        {
          "character": "孙膑",
          "type": "急三枪",
          "text": "好教我冻播播冻播播我的骨透难禁。 艳色倾，危豪，气贯冲凌云， 便堆积了满径。 有谁怜念我难中人， 这便是我孙膑全身大病， 我的全身大病。 我在月宫里抱嫦娥，嫦娥， 我又不是薄幸人。 你在广寒宫内， 冷清清， 尚兀自浑明睡未醒。 适才朝罢了太真， 我在天门边打碎了玉鼎。 又遇着许氏飞琼， 才了却相思病症， 我的相思病症。 倚灯清不怕照灯清， 倚围屏依靠围屏， 隔窗棂隔却窗棂。 夜来之雨待晓声， 嫦娥不待多薄幸。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "你我男子汉，要这朵花儿何用？"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "这朵花儿有无穷的妙用咧！"
        },
        {
          "character": "孙膑",
          "type": "急三枪",
          "text": "插花月明， 琼花乱纷惟此独生。 里面插却花三径， 笑葵花弄影能知足，向日烘腾。 一盖琼瑶径，藕丝断梗， 浪迹泛浮萍。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "列位呀！明日三月三日，王母娘娘蟠桃大会，你我可去走走。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "我们是凡人，上不去天。"
        },
        {
          "character": "孙膑",
          "type": "白",
          "text": "如此我便得罪了！"
        },
        {
          "character": "孙膑",
          "type": "尾声",
          "text": "我饮寿酒下，下仙棋， 骑竹马，满街驱。 今日在这里， 明日在那里。 我袖吞乾坤他怎知！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙膑下。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "园丁，你孙老爷这病是真是假？"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "病自然是真的，哪儿有假的呢？"
        },
        {
          "character": "庞涓",
          "type": "念",
          "text": "恼恨孙膑太张狂，"
        },
        {
          "character": "园丁",
          "type": "念",
          "text": "天书不得气满腔。"
        },
        {
          "character": "庞涓",
          "type": "白",
          "text": "唔，记打！"
        },
        {
          "character": "庞涓",
          "type": "念",
          "text": "除非杀却消吾恨，"
        },
        {
          "character": "园丁",
          "type": "念",
          "text": "你饶人一命待何妨？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞涓怒，下。"
        },
        {
          "character": "园丁",
          "type": "白",
          "text": "你们太爷们交朋友，照例是这个样儿的交。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "园丁下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}