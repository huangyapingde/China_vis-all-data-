{
  "script_id": "02004028",
  "title": "造白袍",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "刘封",
      "hangdang": "小生"
    },
    {
      "name": "孟达",
      "hangdang": "净"
    }
  ],
  "plot": "刘备闻关羽命丧玉泉山，悲痛难忍。当即宣召诸葛亮进帐，商议出兵，为关公复仇。诸葛亮谓现在出兵不利，\n应待至明春。刘备乃令廖化往告张飞，张飞闻信后，随即赶往西川。一面催刘备出兵报仇，一面令范疆、\n张达，赶做白袍白甲，并谓诸葛亮若不出兵，渠即单独出马。适范疆、张达二人尚未将白袍做妥，乃大发雷\n霆，拟将范疆、张达二人斩首。经范疆、张达二人哀求，始各重打百鞭，限七日造成，否则定斩不饶。范疆、\n张达二人认为七日，决不能完成。与其届时被斩，不如将张飞杀死，向东吴报功。乃乘张飞熟睡之际，将\n张飞杀死，携带首级奔往东吴。张苞得知其父死后，遂向刘备报告。适关兴亦赶至。刘备在万分悲痛之下，\n决定令吴班挂帅，御驾亲征云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、刘备同上。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "血战数十春，怎能够，汉土归原根。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "献帝软弱宠权臣，锦绣山川为他人。孤王顺天行仁政，扭转汉室鼎三分。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤，刘备，字玄德，国号章武在位。自桃园结义以来，灭黄巾，扫群雄，血战 疆场，数十余年，得了南北荆襄，东西二川，三分鼎足。二弟镇守荆州，三弟 阆中为将，孤王驾坐西川，这也不在话下。昨夜三更时分，偶得一梦，梦见二 弟浑身是血，不知主何吉凶。 内侍！"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宣诸葛先生上殿。"
        },
        {
          "character": "太监甲",
          "type": "白",
          "text": "领旨。 万岁有旨：宣诸葛先生上殿。"
        },
        {
          "character": "诸葛亮",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮上。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "忠心扶汉王，南阳美丈夫。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣，诸葛亮见驾，愿吾皇万岁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生平身。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "谢座。宣山人上殿，有何国事议论？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "寡人夜得一梦，请先生上殿详解。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公得何梦兆，待臣详解。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "寡人梦见二弟浑身是血，不知主何吉凶？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "臣告便。 哎呀且住，山人昨夜仰观天象，见一斗大红星坠落西北，主公又得此梦，应在 二千岁归天。待我朦胧启奏。 臣启主公：日有所思，夜有所梦。想是主公思念二千岁心胜矣。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，二弟若有差迟，吾命休矣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "刘备",
          "type": "stage",
          "text": "中国京剧戏考 《造白袍》【头本】 2"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！ 启主公：廖化披头散发，午门候旨。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "哦！ 宣廖化上殿。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "廖化",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化上。"
        },
        {
          "character": "廖化",
          "type": "念",
          "text": "山崩地裂事，报与主公知。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "哎呀万岁爷吓！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "廖化为何披头散发，这等光景？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二千岁命丧玉泉山！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二千岁命丧玉泉山！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，不好了！"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "听说二弟丧玉泉， 魂飞天涯不拢边。 雨打梨花分落瓣， 心中犹如乱箭攒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "廖化，二千岁因何归天？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "东吴人马白衣渡江，二千岁命丧玉泉山。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "就该到上鄘搬兵求救。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "臣已曾到上鄘搬兵，怎奈刘封、孟达按兵不动。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "快到阆中报与三千岁知道。"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，刘封、孟达按兵不出，理应将他二人治罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "事急有变，且缓图之。还要加升他二人官职才是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "如此传孤旨意：加升刘封为绵竹郡主，即日来京，共议报仇之策。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公明见。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，还要发兵与孤二弟报仇才是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "今冬发兵，不利我国。等待明春发兵，必要大获全胜。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "若待明春报仇，寡人心中难消恶气。"
        },
        {
          "character": "刘备",
          "type": "唱",
          "text": "泪汪汪吩咐且退班， 咬牙切齿骂孙权。 哭了声二弟难得见， 眼睁睁一旦失桃园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备、诸葛亮同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四札头、四青袍引张飞同上。"
        },
        {
          "character": "张飞",
          "type": "引子",
          "text": "威镇阆州，雄心贯斗牛。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "乌袍皂甲黑缨盔，丈八蛇矛逞雄威。虎牢关前战吕布，当阳桥下唬曹贼。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "某，汉将张翼德。自从桃园结义以来，血战数十余年，大哥驾坐西川，二哥镇 守荆州，俺奉军师将令，阆中守御。昨夜三更时分，偶得一梦，见一斗大红星， 从东南而起，呼啦啦坠落西北海底。也不知主何吉凶。阿嚏，阿嚏。哈，想 当日老张鼻孔发燥，弟兄们在徐州失散，到后来在古城才得团圆。今日鼻孔又 来发燥，不知为着何情？ 来！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "伺候了。"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "哦。 中国京剧戏考 《造白袍》【头本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！ 三千岁：廖化披头散发，急奔阆州而来。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "哦。 有请廖将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化上。"
        },
        {
          "character": "廖化",
          "type": "唱",
          "text": "来至营门下雕鞍， 见了千岁把话言。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖化披头散发，为了何事？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "哎呀三千岁吓！只因二千岁命丧玉泉山。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "怎么讲？"
        },
        {
          "character": "廖化",
          "type": "白",
          "text": "二千岁命丧玉泉山！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "张飞",
          "type": "三叫头",
          "text": "二哥！兄长！哎呀桃园吓！"
        },
        {
          "character": "张飞",
          "type": "西皮导板",
          "text": "听说二哥丧玉泉，"
        },
        {
          "character": "张飞",
          "type": "三叫头",
          "text": "二哥！兄长！哎呀桃园吓！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "环眼不住上下翻。 当初桃园曾结义， 乌牛白马祭上天。 一人在来三人在， 山崩地裂海水干。 到如今山海皆能见， 二哥名丧玉泉山。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖化！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "二千岁因何把驾晏， 一一从头说一番。"
        },
        {
          "character": "廖化",
          "type": "唱",
          "text": "东吴吕蒙巧机变， 白衣渡江占据关。 麦城受困救兵远， 二千岁命丧玉泉山。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "听一言来怒冲冠， 手指东吴骂孙权。 有朝见了尔的面， 剥尔的皮来报仇冤！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖化！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "你本是英雄一好汉， 就该四路把兵搬。"
        },
        {
          "character": "廖化",
          "type": "唱",
          "text": "也曾四路把兵搬， 刘封、孟达谋江山。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "听说刘封谋江山， 老张七孔冒火烟。 有日见了奴才面， 拿住亲手把眼剜。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "廖化！"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "你在此处莫久恋， 速到花关把兵搬。"
        },
        {
          "character": "廖化",
          "type": "唱",
          "text": "辞别千岁上雕鞍， 去到花关把兵搬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廖化下。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "廖化马走如闪电， 中国京剧戏考 《造白袍》【头本】 4 心急意乱奔西川。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！三军的！"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "兵发西川。"
        },
        {
          "character": "四青袍",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引刘封同上。"
        },
        {
          "character": "刘封",
          "type": "念",
          "text": "镇守引胜关，儿郎心胆寒。"
        },
        {
          "character": "旗牌",
          "type": "内白",
          "text": "圣旨下！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "启千岁：圣旨下。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "看香案伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "圣旨下，跪听宣读。诏曰：“刘封镇守边关，受尽风霜。圣上见喜，封为绵竹 郡主。命尔带领人马，擒拿孟达，候有功再赏。即日回京，共议报仇之策。” 圣旨读罢，望诏谢恩。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "请过圣旨。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "香案供奉。不知大人驾到，未曾远迎，多多有罪。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "吩咐后堂摆宴。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "君命在身，不敢久停。就此回朝复命。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "如此送过大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。旗牌下。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "人马班师回朝。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四札头引孟达同上。"
        },
        {
          "character": "孟达",
          "type": "念",
          "text": "当初一时错，如今后悔迟。"
        },
        {
          "character": "孟达",
          "type": "白",
          "text": "俺，孟达。只因二千岁命丧玉泉山，廖化前来搬兵。是我按兵不出，因此弃蜀 归魏。今有刘封提兵到此，不免说他降魏便了。 众将官！"
        },
        {
          "character": "四札头",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "孟达",
          "type": "白",
          "text": "起兵前往。"
        },
        {
          "character": "四札头",
          "type": "同白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂引刘封同上，会阵。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "呔！胆大孟达，前番失我叔父之义，今日又来则甚！"
        },
        {
          "character": "孟达",
          "type": "白",
          "text": "啊，小千岁请息怒，末将有言告禀：想主公立了阿斗守阙东宫，小千岁作了分 外之人。依末将相劝，弃蜀归魏，不失封侯之位。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "一派胡言，放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘封、孟达同开打，刘封败下，孟达追下。四札头同下。刘封上，四文堂同上。"
        },
        {
          "character": "刘封",
          "type": "白",
          "text": "杀败了，杀败了！你看孟达甚是骁勇，这便如何是好？也罢，不免回朝搬兵报 仇便了。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "刘封",
