{
  "script_id": "02005029",
  "title": "倒铜旗",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "罗成",
      "hangdang": "小生"
    }
  ],
  "plot": "杨林在汜水关摆下铜旗阵，由守关大将东方旺护卫铜旗，阻挡西魏人马。魏王乃令秦琼为帅，前往倒旗。并\n派程咬金、王伯当等，从旁协助。同时罗成亦奉父命，前往汜水关，帮助东方旺，保护铜旗。罗成到后，得\n悉前来倒旗阵者，系其表兄秦琼，乃暗中多方协助。初则令东方旺下令，不许斗门暗放冷箭。继则令东方旺，\n不加拦阻，令秦琼去倒旗。殆铜旗倒后，东方旺追杀秦琼时，罗成看秦琼已疲，局势危急。乃挺身而出，\n大战东方旺，将其杀死，帮助秦琼成功。秦琼乃向程咬金等介绍罗成，并会师直捣关中云。",
  "notes": "按此系名伶杨小楼秘本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "程咬金、齐国远、尤俊达、王伯当同上，同起霸。"
        },
        {
          "character": "程咬金",
          "type": "粉蝶儿",
          "text": "创业英奇，雄纠纠创业英奇。"
        },
        {
          "character": "尤俊达",
          "type": "粉蝶儿",
          "text": "气昂昂雄威盖世，吼一声似炮如雷。"
        },
        {
          "character": "齐国远",
          "type": "粉蝶儿",
          "text": "按兵机，柱国材匡扶社稷， 扑咚咚，擂鼓摇旗。"
        },
        {
          "character": "程咬金、齐国远、尤俊达、王伯当",
          "type": "同粉蝶儿",
          "text": "伫看取，挽天河，把氛侵尽洗。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "程咬金。"
        },
        {
          "character": "齐国远",
          "type": "白",
          "text": "齐国远。"
        },
        {
          "character": "尤俊达",
          "type": "白",
          "text": "尤俊达。"
        },
        {
          "character": "王伯当",
          "type": "白",
          "text": "王伯当。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "众位哥弟请了！"
        },
        {
          "character": "齐国远、尤俊达、王伯当",
          "type": "同白",
          "text": "请了！"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "我等只为杨龄诡计，在汜水关设立铜旗，为此主公命秦二哥领兵，前往倒旗， 只得在此伺候。"
        },
        {
          "character": "齐国远、尤俊达、王伯当",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。四文堂引秦琼同上。"
        },
        {
          "character": "秦琼",
          "type": "点绛唇",
          "text": "万马驱驰，千军奋臂，张威势，斩将搴旗，大显屠龙技。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼坐。"
        },
        {
          "character": "程咬金、齐国远、尤俊达、王伯当",
          "type": "同白",
          "text": "参见二哥！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "众位贤弟少礼。"
        },
        {
          "character": "程咬金、齐国远、尤俊达、王伯当",
          "type": "同白",
          "text": "呵！"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "丈夫威名宇宙中，胸藏豪气镇秋风。要为天下奇男子，须建人间未有功。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "本帅，姓秦名琼字叔宝。只因隋主无道，四方云扰。吾主魏王大举义旗，齐聚 英贤，为是弃舍瓦岗，投奔金墉。前者兵破虹霓，可惜大将裴元庆阵亡。今因 杨龄在汜水关，设立铜旗阵，欲难天下好汉。俺奉魏王令旨，率领强兵，前往 倒旗。 众位贤弟！"
        },
        {
          "character": "程咬金、齐国远、尤俊达、王伯当",
          "type": "同白",
          "text": "二哥。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "人马可曾齐备？"
        },
        {
          "character": "程咬金、齐国远、尤俊达、王伯当",
          "type": "同白",
          "text": "齐备多时。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "吩咐兵伐汜水关去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金、齐国远、尤俊达、王伯当同应。〖江儿水〗。众人同斜门下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。四白文堂、罗成同上。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "俺罗成。奉父帅之命，往汜水关保护铜旗。看前面已是汜水关了。 众将官，趱行者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四上手引东方旺同上。"
        },
        {
          "character": "东方旺",
          "type": "快点绛唇",
          "text": "百尺铜旗，八方奇遁，操持纵，一任兵锋，休想轻摇动。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方旺上高台。"
        },
        {
          "character": "东方旺",
          "type": "念",
          "text": "铜旗翻展定雌雄，哪怕横行十万兵。阵上霜风凌草木，关中杀气卷旗旌。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "某，守关大将东方旺。奉老大王令旨，保护铜旗，挡住西魏人马。今闻魏王拜 秦琼为帅，前来倒旗破阵。昨日燕山罗元帅，有书信前来。命其子罗成，亦来 保护铜旗。也曾命杨家四将，前去迎接。此时尚未到来。 小校们，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨龙、杨虎、杨彪、杨豹同上。"
        },
        {
          "character": "杨龙、杨虎、杨彪、杨豹",
          "type": "同白",
          "text": "参见元帅。罗公子到。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "杨龙、杨虎、杨彪、杨豹",
          "type": "同白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂同上，同站门，罗成骑马上。"
        },
        {
          "character": "罗成",
          "type": "念",
          "text": "英声怀绝域，威德镇边疆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下马，归座。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "小将甲胄在身，不能全礼，祈公子恕罪。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "岂敢。请问将军：贵关设立铜旗，可曾有人打过否？"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "这座铜旗，非同小可。自布阵以来，不知杀了多少英雄了。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "原来如此。但不知目下西魏，何人来到？"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "现闻西魏王已遣秦琼带领人马，前来倒旗破阵。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "原来秦琼投奔西魏了。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成作神色。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "贵关有将军勇悍，又添小将帮扶，谅彼秦琼小小技能，何足道哉。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "全仗公子虎威。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：西魏人马，已到汜水关，安营扎寨。"
        },
        {
          "character": "罗成、东方旺",
          "type": "同白",
          "text": "再探！"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "西魏人马已到，就请公子上台押阵。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "请！ 带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成上马，众人同领下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "秦琼",
          "type": "内白",
          "text": "众将官扎住营头，不得擅动者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂内同应。秦琼持虎头枪、鞭子上。"
        },
        {
          "character": "秦琼",
          "type": "醉花荫",
          "text": "万丈铜杆半天耸， 惨昏昏愁云乱拥。 护围着众英雄， 一个个似虎如龙。 铜旗阵，施神勇。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺，秦琼。自从大兵来到汜水关，扎下营寨。是俺与众弟兄言定，凭着俺一人 一骑，直入旗阵，前往倒旗。哎呀！看关前千军万马，黄灿灿一座铜旗，好不 厉害也！"
        },
        {
          "character": "秦琼",
          "type": "醉花荫",
          "text": "凭着俺金枪上显神通。 纵然是虎穴龙潭， 亦须要除祸种。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、罗成上。"
        },
        {
          "character": "罗成",
          "type": "画眉序",
          "text": "新掌小元戎， 赏罚机谋暂时用。 岂离情旧谊， 狭路相逢。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "俺，罗成。闻得表兄秦琼来倒铜旗，阵中必有暗算。俺想当日言定，有功同建， 有难相扶。今日我不助他一臂之力，更待何时！"
        },
        {
          "character": "罗成",
          "type": "画眉序",
          "text": "论临期忠孝难忘， 记当年盟隆山重。 从权不必多疑恐， 却难道作为哑装聋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。罗成上正场高台座。秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "喜迁莺",
          "text": "用不着驱兵拥众， 紧加鞭急跨青骢。 匆也么匆， 非是俺轻生懵懂。 也只为夺取王家第一功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方旺自下场门上。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "呔！倒旗将官听者：进阵只许鞭敲锤打，不许斧砍刀伤。倘有差池，即发乱箭 射死。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "住了！俺今倒旗亦要讲过。第一入阵不许拦阻，第二不许暗放冷箭，第三倒旗 之后，再为厮杀。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "但凭于你。随俺进阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方旺作门阵稍战，下。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "如此你且闪开了！"
        },
        {
          "character": "秦琼",
          "type": "喜迁莺",
          "text": "雕鞍纵，乱纷纷把旗门直撞， 扑喇喇将阵角横冲。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呔！守旗将官听者：俺秦琼初次倒旗来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼耍下场下。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呀，听他一声喊叫，抢入阵中去了。"
        },
        {
          "character": "罗成",
          "type": "画眉序",
          "text": "喊声似雷轰， 起壁搴岂庸庸。 万千军英勇， 八面威风。"
        },
        {
          "character": "四上手",
          "type": "内同白",
          "text": "看箭！"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "哎呀，且住！看铜斗内，四名神箭手，在那里暗射俺表兄了。"
        },
        {
          "character": "罗成",
          "type": "画眉序",
          "text": "奉雕弓明月高张， 发羽箭流星抵控。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内喊声。"
        },
        {
          "character": "罗成",
          "type": "画眉序",
          "text": "一声看箭魂惊恐， 怎免得吉少多凶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方旺追秦琼同上。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呔！东方旺，我入阵之先，也曾讲过：不许暗放冷箭。怎么叫众军射俺头盔， 你也非为好汉！"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "秦琼，你道不要放箭。那个旗上大斗之内，四名神箭手，凡遇打旗将官，躲得 他的神箭，方容倒旗！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "这个……"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "东方将军听令：今后不许斗门暗放冷箭，看他如何倒旗。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "得令。 呔！军中不许暗放冷箭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手内同应。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "秦琼随俺进阵来呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方旺稍战，下。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼舞。"
        },
        {
          "character": "秦琼",
          "type": "出队子",
          "text": "小将军把兵权卖弄， 哪怕东方敢不从。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "且住，方才东方旺言过，这铜旗只许鞭敲锤打。我如今到他阵中，不免用金锏 打他几下，挫其锋芒，有何不可！"
        },
        {
          "character": "秦琼",
          "type": "出队子",
          "text": "俺的精神抖擞尽从容。 作一个伍明辅举鼎超群。 绝胜似楚重瞳拔山出众。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呔！守旗将官听者：俺秦琼二次倒旗来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼耍下场下。"
        },
        {
          "character": "罗成",
          "type": "滴溜子",
          "text": "铜旗阵，铜旗阵，紧不放松， 打旗将，打旗将，狠不放空。"
        },
        {
          "character": "四上手",
          "type": "内同白",
          "text": "铜斗打下来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成望。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "呀，果然铜斗打下来了！"
        },
        {
          "character": "罗成",
          "type": "滴溜子",
          "text": "听军声振天喧哄， 挡车怒臂强，霎时摇动。 齐逞高强，交锋斗锋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼持枪、锏与东方旺同杀上。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呔，东方旺，你好生无礼！方才讲过，倒了铜旗，然后厮杀。怎么我才打了一 下，就不容俺动手，是何道理？"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "呔！秦琼你进阵倒也罢了，因何把铜斗打将下来，跌死了四名神箭手，岂不是 倒了俺的铜旗么？"
        },
        {
          "character": "秦琼",
          "type": "四门子",
          "text": "嗳呀，你逞花言，把俺作婴儿哄， 顿叫人怒气冲！"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "你倒不得铜旗，休想逃命！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "住口。"
        },
        {
          "character": "秦琼",
          "type": "四门子",
          "text": "俺倒旗的敢把残生送， 你护旗的太不公。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "东方将军听令：今后不许拦阻，竟叫他倒旗，如旗不倒，再和他较量。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "啊，公子竟容他倒旗么？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "嘿！ 呔，秦琼你果然要倒旗么？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "你秦爷岂能反悔。"
        },
        {
          "character": "东方旺",
          "type": "白",
          "text": "也罢，随俺进阵来呀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东方旺耍下场下。秦琼三笑。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "且住，看那小将军与俺同心合胆，俺如今三次倒旗，倘得成功，岂不是上天助 我也。"
        },
        {
          "character": "秦琼",
          "type": "四门子",
          "text": "俺营不用偷，寨不用攻， 都只为汜水关铜旗惊怕恐。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呔！守旗将官听者：俺秦琼三次倒旗来也！"
        },
        {
          "character": "秦琼",
          "type": "四门子",
          "text": "舞着这枪，挺着这胸呀， 转眼间剪除祸种。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼耍下场下。"
        },
        {
          "character": "罗成",
          "type": "鲍老催",
          "text": "神嚎鬼痛，愿共工触得周山动， 霎时搏浪秦军中。"
        },
        {
          "character": "四上手",
          "type": "内同白",
          "text": "铜旗已倒！ （内喊声。秦琼上，东方旺追上。杨龙、杨虎、杨彪、杨豹同上，同战，秦琼下。东方旺、杨龙、杨虎、杨 彪、杨豹同追下。）"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呀，不好了，我表兄拔倒铜旗。人困马乏，被东方旺等追赶去了，此时不救， 待等何时。 来，抬枪带马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下高台，脱蟒，带马下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
