        {
          "character": "秦琼",
          "type": "白",
          "text": "想是姑父差你保护铜旗么？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "正是。怎奈我呵！"
        },
        {
          "character": "罗成",
          "type": "双声子",
          "text": "义气浓，双手把危关送， 机会逢，胆气同，危途祸转，绝处逢生。"
        },
        {
          "character": "秦琼",
