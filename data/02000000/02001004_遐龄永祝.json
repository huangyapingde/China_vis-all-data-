{
  "script_id": "02001004",
  "title": "遐龄永祝",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "天官",
      "hangdang": "老生"
    }
  ],
  "plot": "赐福天官紫微大帝、赦罪地官清虚大帝及解厄水官洞音大帝，因下界善门福地，荫功浩大，特奉玉帝敕旨，\n前往福地，赐宝降祥。途中遇四时嘉祥如意大仙等，亦奉玉帝赦旨，前赐宝降祥，后又遇天福星君、天禄星\n君、天寿星君、天财星君与天喜星君等，乃一同前往。到福地后，各献吉言，最后一同合唱颂词而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四仙官引天官、地官、水官同上。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同新水令",
          "text": "欣逢化宇日时长， 启瞳胧。万年枝上。 云璈仙乐响， 拂袖筵张。洪幔祥光。 盖公照长垣朗， 盖公照长垣朗。"
        },
        {
          "character": "天官",
          "type": "念",
          "text": "上元赐福到人间，"
        },
        {
          "character": "地官",
          "type": "念",
          "text": "中元赦罪百禄添。"
        },
        {
          "character": "水官",
          "type": "白",
          "text": "下元解厄频增寿，"
        },
        {
          "character": "天官、地官、水官",
          "type": "同念",
          "text": "永祝遐龄亿万年。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "吾乃上元一品赐福天官紫微大帝是也。"
        },
        {
          "character": "地官",
          "type": "白",
          "text": "吾乃中元二品赦罪地官清虚大帝是也。"
        },
        {
          "character": "水官",
          "type": "白",
          "text": "吾乃下元三品解厄水官洞音大帝是也。"
        },
        {
          "character": "天官",
          "type": "白",
          "text": "今有善门福地，荫功浩大，德行无边。我等奉玉帝敕旨前往赐宝降祥。 仙官！"
        },
        {
          "character": "四仙官",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同白",
          "text": "吩咐摆齐幢旛。往福地去者。"
        },
        {
          "character": "四仙官",
          "type": "同白",
          "text": "领旨。 大帝有旨：摆齐幢旛。往福地去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众瓜棍同上。"
        },
        {
          "character": "众瓜棍",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同驻马听",
          "text": "三素飘扬， 鹤驭翩翩。披鹤氅。 风骛霞响， 十州端嘘五云乡。 中流不见海波扬， 天空但听罡气响， 富贵安康。 熙朝绘出升平像。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。八如意同上。"
        },
        {
          "character": "八如意",
          "type": "同沉醉东风",
          "text": "喜海外仙家疏放， 望环中人物殷昌。 玉女迎，瑶池降， 蟠桃熟，度色提浆。"
        },
        {
          "character": "八如意",
          "type": "同念",
          "text": "积善之家庆有余，神仙永祝照环区。四时安乐声康泰，八节康宁永不移。"
        },
        {
          "character": "八如意",
          "type": "同白",
          "text": "我等乃四时嘉祥如意大仙是也。我等奉玉帝敕旨前往福地。赐宝降祥。你我一 同前往。请。"
        },
        {
          "character": "八如意",
          "type": "同沉醉东风",
          "text": "衣冠身惹御烛香， 天保颂齐声高唱， 天保颂齐高唱。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八如意同下。八如意、天福星、天禄星、天寿星、天财星、天喜星同上。"
        },
        {
          "character": "八如意、天福星、天禄星、天寿星、天财星、天喜星",
          "type": "同收江南",
          "text": "路迢迢皇域地脉长， 喜盈盈赐福群星降。 步冉冉六珠云外飘香， 戈铮铮九奏风中响。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八如意同排后，天福星、天禄星、天寿星、天财星、天喜星同排前。"
        },
        {
          "character": "天福星",
          "type": "白",
          "text": "吾乃天福星君是也。"
        },
        {
          "character": "天禄星",
          "type": "白",
          "text": "吾乃天禄星君是也。"
        },
        {
          "character": "天寿星",
          "type": "白",
          "text": "吾乃天寿星君是也。"
        },
        {
          "character": "天财星",
          "type": "白",
          "text": "吾乃天财星君是也。"
        },
        {
          "character": "天喜星",
          "type": "白",
          "text": "吾乃天喜星君是也。"
        },
        {
          "character": "天福星、天禄星、天寿星、天财星、天喜星",
          "type": "同白",
          "text": "奉玉帝敕旨前往福地。赐宝降祥。你我一同前往。"
        },
        {
          "character": "天福星、天禄星、天寿星、天财星、天喜星",
          "type": "同收江南",
          "text": "遥望着金屋恁辉煌， 玉珮夜叮当。 细微的端霭浮青琐， 氤氲的祥烟绕碧幢洋洋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "天官、地官、水官、四仙官同上，众人合一处。"
        },
        {
          "character": "天官、地官、水官、天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同川拨禅",
          "text": "分道移仙杖， 忙忙祝华筵献寿章， 忙祝华筵献寿章。"
        },
        {
          "character": "八如意、天福星、天禄星、天寿星、天财星、天喜星",
          "type": "同白",
          "text": "请问三位大帝何往？"
        },
        {
          "character": "天官、地官、水官",
          "type": "同白",
          "text": "今有善门福地，荫功浩大，德行无边，我等奉玉帝敕旨前往赐宝降祥。列位大 仙何往？"
        },
        {
          "character": "八如意、天福星、天禄星、天寿星、天财星、天喜星",
          "type": "同白",
          "text": "我等也为此事而来。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同白",
          "text": "如此一同前往。"
        },
        {
          "character": "天官、地官、水官、天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同挂玉钩",
          "text": "蔺殿逍遥添寿长， 日月光天壤。 重润重辉普乐章， 揆得金声响。 鹤禁中龙楼旁， 叠沐天庥，庆贺吉祥，庆贺吉祥。"
        },
        {
          "character": "四仙官",
          "type": "同白",
          "text": "已到福地。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同白",
          "text": "妙哇。但见炉烟结彩，瑞霭缤纷，时逢美景，欣遇良辰。正是："
        },
        {
          "character": "天官、地官、水官",
          "type": "同念",
          "text": "地灵产瑞草，"
        },
        {
          "character": "天官、地官、水官、天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同念",
          "text": "天相吉人家。"
        },
        {
          "character": "天官、地官、水官、天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同挂玉钩",
          "text": "早则见善门福地喜非常， 听声声仙乐奏铿锵。 看纷纷霓珮影飘扬， 更重重灿光。 共把这吉言称颂献诗章， 吉言称颂献诗章。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同白",
          "text": "众位大仙各将吉言献上。"
        },
        {
          "character": "八如意",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "天福星",
          "type": "念",
          "text": "福堂霭霭瑞云生，"
        },
        {
          "character": "天禄星",
          "type": "念",
          "text": "禄坐千钟享万灵。"
        },
        {
          "character": "天寿星",
          "type": "念",
          "text": "寿同山岳添筹算，"
        },
        {
          "character": "天财星",
          "type": "念",
          "text": "财源广聚库填盈。"
        },
        {
          "character": "天喜星",
          "type": "念",
          "text": "喜从天降重重至，"
        },
        {
          "character": "八如意",
          "type": "同念",
          "text": "八节康宁事事成。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同念",
          "text": "兰孙桂子多荣耀，"
        },
        {
          "character": "天官、地官、水官、天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同念",
          "text": "满门欢乐贺升平。"
        },
        {
          "character": "天官、地官、水官、天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同梅花酒",
          "text": "献蟠桃，帝露扬， 见宝炬辉煌， 紫气腾祥，瑞霭摇漾， 韵悠悠按工商。 歌喉转绕画梁， 众真捧霞觞。 歌喉转，鉴微忱进琼浆， 鸾鹤来，任翱翔， 乐雍熙，德汪洋。 看从今降祯祥， 看从今降祯祥。"
        },
        {
          "character": "天官、地官、水官、天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同白",
          "text": "庆贺已毕。"
        },
        {
          "character": "天官、地官、水官",
          "type": "同白",
          "text": "列为大仙各归洞府。"
        },
        {
          "character": "天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "天福星、天禄星、天寿星、天财星、天喜星、八如意、四仙官",
          "type": "同清江引",
          "text": "赏心乐事如天上， 德泽千秋旷。 紫气自东来， 南极西池望。 指日里，下纶音恩沛广， 下纶音恩沛广。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}