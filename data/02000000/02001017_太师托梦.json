{
  "script_id": "02001017",
  "title": "太师托梦",
  "alias": [
    "阴回朝"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "闻仲",
      "hangdang": "净"
    },
    {
      "name": "纣王",
      "hangdang": "净"
    },
    {
      "name": "妲己",
      "hangdang": "旦"
    }
  ],
  "plot": "闻仲奉命抵御姜尚，战死绝龙岭前。忠魂不散，转回朝歌。向纣王报告战死经过及商朝将亡情形。惜纣王仍\n不悔悟，荒淫如故，以为有妲己御侮，定可无事云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手拿云牌、四鬼卒拿风旗、马童甲拉马、马童乙背鞭、闻仲同上。"
        },
        {
          "character": "闻仲",
          "type": "引子",
          "text": "忠魂未散，回朝歌，面见龙颜。"
        },
        {
          "character": "闻仲",
          "type": "念",
          "text": "商汤创业立帝基，各路诸侯保华夷。六百余年气数尽，可叹忠良丧西歧。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "老夫，太宰闻仲魂灵是也。奉命征剿西歧，不幸命丧绝龙岭。本当封神台下听 候法旨。奈因商汤江山，不久将终，为此回至朝歌，与昏王托一梦兆。 鬼卒们驾起阴风，往朝歌去者。"
        },
        {
          "character": "闻仲",
          "type": "二黄原板",
          "text": "在生时保我主东征西战， 小昏王宠妲己残害百官。 姜国母炮烙死十分伤惨， 比干相剖心亡令人可怜。 此一番进宫帷将主来劝， 但愿得天下转恢复江山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗，〖吹打〗。四小太监、二大太监引纣王同上。"
        },
        {
          "character": "纣王",
          "type": "引子",
          "text": "皇宫内院，喜爱妃，常伴龙眠。"
        },
        {
          "character": "纣王",
          "type": "念",
          "text": "红旦一轮照四方，人君有道自当阳。姜后欺孤炮烙丧，飞虎西歧反朝堂。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "孤，大商天子受辛在位。恼恨西歧，听信黄飞虎之言，口称吊民罚罪。孤命太 宰闻仲，前去征剿，不见回朝。为此十分忧虑，不免宣苏妃上殿，共论大事。 内臣！"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "宣苏国母上殿。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "领旨。 万岁有旨：宣苏国母上殿"
        },
        {
          "character": "妲己",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、妲己同上。"
        },
        {
          "character": "妲己",
          "type": "念",
          "text": "忽听万岁宣，急忙上金銮。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "妾妃见驾，吾皇万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "梓童平身。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "谢万岁。启奏万岁：将妾妃宣上殿来，不知有何谕诏？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "梓童有所不知：只因太宰征剿西歧，未见回音。因此宣上爱妃，商议此事，以 免寡人忧虑。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "我主但放宽心，太宰乃是安邦之将，国家栋梁。自然扫灭西贼，不久得胜而归。 万岁何必忧虑？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "梓童言之有理。 内臣看酒，孤与梓童共饮一番。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "妾妃把盏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。妲己敬酒。牌子完。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "万岁再饮几杯。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "寡人酒已够了。 内臣撤去酒宴"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹打完。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "启奏我主：不知今晚宿在哪一宫？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "宿在寿仙宫。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "内臣打扫寿仙宫"
        },
        {
          "character": "二大太监",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监同下。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "纣王",
          "type": "念",
          "text": "朝欢暮乐在宫帷，哪管朝中是与非。"
        },
        {
          "character": "妲己",
          "type": "念",
          "text": "蒙恩万岁将妃宠，陪王伴驾更有谁？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "摆驾寿仙宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纣王、妲己同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二大太监同上，同打扫。〖小吹打〗。"
        },
        {
          "character": "二大太监",
          "type": "同白",
          "text": "有请万岁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、二宫娥、纣王、妲己同上。吹打完。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "梓童随孤来呀，哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纣王入帐子。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "回避了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监、四小太监、二宫娥自两边分下。起更鼓。"
        },
        {
          "character": "闻仲",
          "type": "内二黄导板",
          "text": "最可叹为国家身遭大难，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四上手、四鬼卒、二马童、闻仲同上，同斜椅。"
        },
        {
          "character": "闻仲",
          "type": "回龙",
          "text": "我的命丧至在绝龙岭前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲上椅子，归正。"
        },
        {
          "character": "闻仲",
          "type": "唢呐二黄正板",
          "text": "半空中云磨响霹雳闪电， 一口气吹散了云雾归天。 奉圣命伐西歧威风八面， 到如今只落得孤身回还。 身穿着连环甲腥腥血染， 恶狠狠三只眼杀气冲天。 跨下的墨麒麟疆场游遍， 我背后身插着打将神鞭。 阴惨惨来至在皇宫内院，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二冲头，打堂鼓。"
        },
        {
          "character": "闻仲",
          "type": "二黄摇板",
          "text": "站至在金阶上且把话言： 我本是老闻仲西歧回转， 寿仙宫请我主驾出金銮。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "万岁醒来！"
        },
        {
          "character": "纣王",
          "type": "二黄导板",
          "text": "龙床上只听得有人呼唤，"
        },
        {
          "character": "纣王",
          "type": "二黄摇板",
          "text": "梦见了朝歌城塌了半边。 有孤王睁龙目抬头观看，"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "纣王",
          "type": "二黄摇板",
          "text": "只觉得阴风吹体似冰寒。 你是妖你是怪细说一遍，"
        },
        {
          "character": "闻仲",
          "type": "回龙",
          "text": "我的主休惊怕细听根源："
        },
        {
          "character": "闻仲",
          "type": "唢呐二黄正板",
          "text": "臣本是老闻仲西歧回转， 魂灵儿进朝歌面见龙颜。 臣奉命到西歧与他交战， 怒恼了众弟子会战阵前： 头一阵杨二郎七十二变， 李哪吒手使相乾坤神圈； 土行孙会地遁甚是灵便， 邓蝉玉五色石无人敢拦； 雷震子在空中苦苦鏖战， 龙须虎发飞石重如泰山。 臣调来赵公明前去交战， 全仗着定海珠蛟龙神鞭。 只杀得周营中东逃西散， 他请来燃灯道下了高山。 与公明在阵前一场交战， 惹恼了三教主下了凡间。 摆下了阵一座十分凶险， 将为臣围至在绝龙岭前。 有杨戬与哪吒法宝来献， 九龙罩罩为臣化为灰烟。 我本当封神台听候旨选， 怎能舍我主爷锦绣江山？ 劝我主与妲己休得怜恋， 最可叹锦江山六百余年。 臣本当与我主——"
        },
        {
          "character": "闻仲",
          "type": "二黄摇板",
          "text": "再诉一遍， 怕只怕五更尽难去归天。 叫鬼卒驾云雾封神台转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手、四鬼卒、二马童同下。"
        },
        {
          "character": "闻仲",
          "type": "二黄摇板",
          "text": "周室兴商汤灭就在眼前。"
        },
        {
          "character": "闻仲",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "闻仲下。天亮。"
        },
        {
          "character": "大太监甲",
          "type": "白",
          "text": "万岁醒来！"
        },
        {
          "character": "纣王",
          "type": "二黄导板",
          "text": "时才间听闻仲细说一遍，"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "纣王",
          "type": "二黄摇板",
          "text": "醒来时不由我胆战心寒。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "哎呀呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "妲己醒。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "万岁为何这般模样？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "咳，梓童有所不知：昨夜三更，偶得一兆。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "不知主公得何龙兆？"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "梦见太师闻仲，回转朝歌。他言到命丧西歧，因此心惊胆怕。"
        },
        {
          "character": "妲己",
          "type": "白",
          "text": "启奏万岁：倘若有不测，妾妃自能领兵，剿灭西歧。我主但放宽心。"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "如此说来，全仗梓童你了。"
        },
        {
          "character": "纣王",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "纣王",
          "type": "二黄摇板",
          "text": "这江山有梓童定无凶险， 哪管那西伯侯出兵歧山。 在宫中摆下了琼浆御宴， 但愿你怀龙胎生下儿男。"
        },
        {
          "character": "纣王",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "纣王",
          "type": "白",
          "text": "梓童随寡人来呀！"
        },
        {
          "character": "纣王",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纣王、妲己同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}