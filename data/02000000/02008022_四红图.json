{
  "script_id": "02008022",
  "title": "四红图",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "刘化王",
      "hangdang": "丑"
    }
  ],
  "plot": "刘主化王，闻赵匡胤特来燕京行刺，乃命大将等分别把守城门，画图捉拿。计杨滚把守东门，崔龙把守西门，\n高怀德、高怀亮兄弟把守南北门。适商贾曹仁，由外归来。因貌与赵匡胤相似，路过东门，被杨滚擒住。\n同时西城崔龙，亦擒得一人，谓系赵匡胤。刘主命将二人押解金殿，均云是曹仁，无法审清。后刘主谓朝中\n之曹义，系曹仁之胞弟。将曹义唤来，定知真假。但将曹义唤来。曹义亦认不清楚。请准将二人带回家中，\n由家人共同辨认。及曹义带至家中，赵匡胤乃自己承认。曹义兄弟，认赵匡胤将来必登帝位，乃允拯救。后\n刘主诏令，将二个刺客带至殿前比武，赵匡胤、曹仁二人乘机，将刘主杀死云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手同上，杨滚上。"
        },
        {
          "character": "杨滚",
          "type": "点绛唇",
          "text": "掌理朝纲，镇压封疆，心雄壮，何惧强梁？威名俱传讲。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "白发如霜心性刚，帐下三军似虎狼。文韬武略怀智量，恩赐爵位火山王。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "老夫，杨滚。扶保刘王。官居极品，位列朝班。今早主公传下旨意，道赵匡胤 私下燕京，行刺我主。老夫奉旨把守禁城东门。张挂图形，捉拿刺客匡胤。 嘟，众军校校尉，打道上关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹仁上。"
        },
        {
          "character": "曹仁",
          "type": "唱",
          "text": "经营贸易他乡奔， 心怀慈亲转家门。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "俺，曹仁。先父去世，老母在堂。兄弟曹义，在朝居官。俺平生喜走江湖，今 三江贸易，得利而归家庭探母。看天色尚早，前面已是燕京东门。不免打马归 家便了。"
        },
        {
          "character": "曹仁",
          "type": "唱",
          "text": "别却家乡日已深， 千里迢迢少信音。 归家喜得团圆庆，"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同暗上。"
        },
        {
          "character": "曹仁",
          "type": "唱",
          "text": "因何城边有军兵？"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "吓，因何关前有许多官兵在此？待俺下马过去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚上，看图、曹仁。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "来，与我拿下了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四上手同上，同站门。高怀德、高怀亮同上。"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "奉命昼夜守禁门，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "捉拿刺客要小心。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "俺，高怀德。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "俺，高怀亮。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "贤弟请了。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "你我弟兄，奉旨把守南北二门。今闻伯父崔龙，在西门拿住刺客匡胤，不知真 假。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "一同入朝，看个明白，也好放心。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "贤弟之见不差，一同前去。"
        },
        {
          "character": "高怀德、高怀亮",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": "高怀德",
          "type": "唱",
          "text": "若是奸人来拿定，"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "以免终日费辛勤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德、高怀亮领四上手同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，同站门。大太监、刘化王同上。"
        },
        {
          "character": "刘化王",
          "type": "引子",
          "text": "四时吉庆，每日里，快乐无穷。"
        },
        {
          "character": "刘化王",
          "type": "念",
          "text": "为君要有道，自然乐逍遥。不论文共武，孤全管得着。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "孤，刘化王。承父之大业，坐守燕京，这也不在话下。那个又在话上。近臣奏 道，仰观天象，说赤须火龙压住孤的星相，才算出是刺客赵匡胤，要私下燕京， 要摘孤的龙头。不知老天绝我不绝。已命众卿画影图形，守住禁城。捉拿刺 客赵匡胤，还未见交旨。 内侍，闪放龙棚。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "吓，闪放龙棚！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔龙上。"
        },
        {
          "character": "崔龙",
          "type": "念",
          "text": "擒得奸细到，定然爵位高。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "臣崔龙见驾，愿大王千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "谢大王。恭喜主公，贺喜主公！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "孤喜从何来呢？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "臣在西门，仗主洪福，拿住刺客赵匡胤，前来交旨。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "怎么着，赵匡胤被你拿住了？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘化王",
          "type": "笑",
          "text": "啊啊哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚上。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "用尽千般计，国运与天齐。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "臣杨滚见驾，大王千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "吓，老千岁平身，赐坐。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "谢大王！臣在东门，仗主洪福，拿得刺客赵匡胤，前来交旨。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "吓，你在东门，拿住一个刺客赵匡胤？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "崔大人，你在西门拿住一个刺客赵匡胤？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "怪呀，一个赵匡胤，你们二位到是谁拿住的？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "臣在东门，照画图拿来，现在殿角以下。有军校看守。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "臣在西门，照画图拿来，现在午门候旨。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "你拿住一个？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "是臣拿住一个。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "你么，也拿住一个？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "是臣拿住一个。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "好，拿住刺客，功劳非小。都带上殿来，孤王观看。"
        },
        {
          "character": "杨滚、崔龙",
          "type": "同白",
          "text": "领旨！ 下面听者，大王有旨：将刺客赵匡胤押上殿来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八军校押赵匡胤、曹仁自两边分上。"
        },
        {
          "character": "杨滚、崔龙",
          "type": "同白",
          "text": "刺客当面。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "赵匡胤，赵匡胤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、曹仁互指。刘化王看。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "这可到好，两个全是哑巴。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "刺客，大王唤你因何不应？"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "呔，俺是草民曹仁。哪个是什么刺客赵匡胤吓？"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "刺客，大王唤你，为何不应？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "呔，俺是草民曹仁，哪个是什么刺客赵匡胤吓？"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "咳，这不是糟吗，二位辛苦劳驾，听见没有。两个全不是。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "启奏大王：臣闻曹义有一兄长，名唤曹仁。难道有两个不成？"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "是吓！"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "大王，臣将他二人带回衙去，五刑拷打，定有匡胤在内。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "也好。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "且慢，何必如此，待王就在金殿亲审，定知真假。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "咳，你们二位真是老糊涂了。曹义的哥哥叫曹仁，把曹义宣来。叫他认认么， 就明白了。费这们大事做什么？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "大王之见不差，臣领旨。 大王有旨：宣曹义上殿。"
        },
        {
          "character": "曹义",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹义上。"
        },
        {
          "character": "曹义",
          "type": "念",
          "text": "丹书非龙诏，居官在群僚。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "臣，曹义见驾，愿大王千岁！"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "千千岁。宣臣上殿，有何国事议论？"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "他是这们件事情：杨老千岁在东门拿来一个刺客匡胤，崔大人在西门拿来一个 刺客匡胤。方才孤家审问，两个都是曹仁。闹不清楚。宣卿上殿。曹仁是你胞 兄，自然你总认得明白。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "今在何处，待臣看来。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "来，将他们带上殿来。"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "吓，你是兄长曹仁？"
        },
        {
          "character": "曹仁",
          "type": "白",
          "text": "正是愚兄。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "你是兄长曹仁？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "正是愚兄。"
        },
        {
          "character": "崔龙",
          "type": "白",
          "text": "哪个是令兄吓？曹仁，带回府去。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "这二人一样，皂白难分。启奏大王：臣认不出真假。臣将二人带回家去，有老 少人等，认明回奏。"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "这是打哪说起，连你也闹不清楚。也罢，就命卿带回家去，审明回奏。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "曹义",
          "type": "唱",
          "text": "主公驾前领圣命， 丹墀吩咐御林军： 两个刺客来压定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八军校押赵匡胤、曹仁同下。"
        },
        {
          "character": "曹义",
          "type": "唱",
          "text": "倒叫下官解不明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹义下。"
        },
        {
          "character": "杨滚",
          "type": "唱",
          "text": "曹府去把二人问， 时下皂白要分清。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚下。"
        },
        {
          "character": "崔龙",
          "type": "唱",
          "text": "辨不出曹仁与匡胤， 空费忠勤一片心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔龙下。"
        },
        {
          "character": "刘化王",
          "type": "唱",
          "text": "清天白日如梦景， 两个匡胤都叫曹仁。 亲弟亲兄认不准，"
        },
        {
          "character": "刘化王",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监、四太监自两边分下。"
        },
        {
          "character": "刘化王",
          "type": "唱",
          "text": "孤王怎好放此心。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘化王下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八军校、曹仁、赵匡胤、曹义同上。"
        },
        {
          "character": "曹义",
          "type": "唱",
          "text": "众家护送到府门， 此事须当要问明。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "来，将他二人吊在两廊，尔等回避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八军校同下。"
        },
        {
          "character": "曹义",
          "type": "白",
          "text": "你二人谁是刺客匡胤，从实讲来。"
        },
        {
          "character": "曹仁",
          "type": "白",
