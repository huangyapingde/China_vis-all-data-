{
  "script_id": "02006008",
  "title": "秦王吊孝",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李世民",
      "hangdang": "小生"
    },
    {
      "name": "徐勣",
      "hangdang": "外"
    },
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "秦琼",
      "hangdang": "末"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    },
    {
      "name": "王氏",
      "hangdang": "旦"
    },
    {
      "name": "罗春",
      "hangdang": "占"
    },
    {
      "name": "罗成",
      "hangdang": "生，戴头面"
    }
  ],
  "plot": "罗成被李建成、李元吉陷害，单身出战苏定方，深陷淤泥河中，乱箭身亡。秦王李世民平定高丽后，令徐勣、\n秦琼、尉迟恭及程咬金等同来吊丧，并将苏定方首级，献于灵前，痛苦追悼而去。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "场上设白布孝堂，外用桌子，上摆“忠勇公罗成之位”。王氏上。"
        },
        {
          "character": "王氏",
          "type": "引子",
          "text": "儿夫一命丧沙场，撇奴昼夜好悲伤。"
        },
        {
          "character": "王氏",
          "type": "念",
          "text": "独坐深闺且自伤，痛夫屈死在沙场。奸王何故行残虐，折我鸾凰梦杳茫。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "妾乃罗门王氏。丈夫罗成，为国征讨河北，被二王残害，致遭深陷淤泥河，乱 箭射死。撇得奴独守孤帷，好生悲惨。今已午牌时候，不免到灵前哭拜一番。"
        },
        {
          "character": "王氏",
          "type": "唱",
          "text": "想儿夫文武英雄将， 南征北讨世无双。 皇天何故不保佑？ 深陷淤泥万箭亡。 愿你早早登仙界， 望你阴灵保护我妻房。 保佑伊子官高大， 荣封追赠恤忠良。 可怜不见亲夫面， 含悲痛切苦心伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗春穿孝服上。"
        },
        {
          "character": "罗春",
          "type": "念",
          "text": "父骨沙场丧，忠魂化鹤归。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "母亲拜揖。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "告母亲知道：方才徐茂功老伯差人来说，秦王赦出天牢，领兵征服河北高丽， 杀了苏定方，今已班师。秦王传旨，将苏定方首级，同众公卿赉赠灵前奠祭。 即刻就到了。"
        },
        {
          "character": "王氏",
          "type": "白",
          "text": "既如此，快摆香案迎接。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王氏、罗春同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐勣上。"
        },
        {
          "character": "徐勣",
          "type": "念",
          "text": "深惜皇朝折栋梁，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "堪怜忠义丧沙场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "中表一生成永别，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "奸王误国害忠良。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "我徐绩。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "某尉迟恭。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺秦琼。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "咱程咬金。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐勣",
          "type": "白",
          "text": "可喜秦王平定高丽，回朝奏凯，圣上命我等一同到罗贤弟灵前祭奠，并将苏定 方首级献于灵前。"
        },
        {
          "character": "尉迟恭、秦琼、程咬金",
          "type": "同白",
          "text": "一言未了，想必殿下来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二内侍⑴一捧祭祀一背人头桶同上，李世民上。"
        },
        {
          "character": "李世民",
          "type": "引子",
          "text": "烽烟扫尽，痛擎夭摧折，屈坏着万里长城。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "type": "同白",
          "text": "臣等接驾。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "type": "同白",
          "text": "愿殿下千岁千千岁。"
        },
        {
          "character": "李世民",
          "type": "念",
          "text": "扰攘烟尘起战争，专征独扫宇寰清。化家为国皇图永，一统山河乐太平。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "孤家秦王世民。为二位王兄王弟谗诤，将孤拘禁天牢。不想河北高丽反叛，父 兄命三王元吉领兵征剿，保奏罗王兄为先锋，不发兵卒，只命单身出战，致他 马陷淤泥河，乱箭射死。不意被苏定方长驱直进，三王元吉逃回太原，父王命 孤出狱，立功赎罪。赖诸将协力，众士同心，平服了河北。今带苏定方首级， 同众公卿到罗王兄灵前祭奠。 众公卿！"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "type": "同白",
          "text": "臣等有。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "就此一同前往。"
        },
        {
          "character": "徐勣、尉迟恭、秦琼、程咬金",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "跃马扬鞭驾轻车， 河北一带惨凄凄。 功臣负屈黄泉地， 孤王奉旨拜灵祇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "士卒上，报。"
        },
        {
          "character": "士卒",
          "type": "白",
          "text": "千岁驾到。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗春上，跪。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "臣罗春接驾，愿殿下千岁千千岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "罗王兄灵柩在哪里？"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "请在中堂。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "卿家引孤进去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗春应，进。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "摆下祭礼。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "吓。 （二内侍同摆祭礼并人头桶。李世民拜。徐勣、尉迟恭、秦琼、程咬金同扶住，同作揖让。徐勣、尉迟恭、 秦琼、程咬金同拜，同起。）"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "啊呀，罗王兄吓！"
        },
        {
          "character": "李世民",
          "type": "唱",
          "text": "想王兄相从已有年， 情同骨肉赛桃园。 卿家开国功勋大， 旗开得胜非等闲。 只因误被奸王害， 害你屈死在河边。 悲伤折我擎天柱， 思卿何日还阳间？"
        },
        {
          "character": "徐勣",
          "type": "唱",
          "text": "拜灵前祭奠真悲惨， 止不住腮边泪涟涟。 可怜你是英雄汉， 被奸王害你一命丧黄泉。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "哭一声贤弟干城将， 你代我探主到牢房。 冤遇奸王把你害， 害你忠良年少亡。"
        },
        {
          "character": "尉迟恭、程咬金",
          "type": "同唱",
          "text": "忙上前祷告心悲切， 哭一声贤弟好惨伤。 自从识荆来结义， 并胆同心扶大唐。 恨杀奸王来害你， 可怜万箭丧郊荒。"
        },
        {
          "character": "罗春",
          "type": "唱",
          "text": "稽首叩谢贤恩主， 回身谢了伯父众贤良。 可怜父亲身先丧， 不能同辅大唐王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内作响〗。"
        },
        {
          "character": "李世民、徐勣、尉迟恭、秦琼、程咬金、罗春",
          "type": "同白",
          "text": "吓，什么响？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成浑身插箭流血手执白绫暗上，立孝堂后高桌上。"
        },
        {
          "character": "罗成",
          "type": "唱",
          "text": "半空中跑坏了白龙马， 为闻吾主祭灵堂。 不胜惶悚来款首， 感谢王恩天浩荡。 又谢众位恩兄长， 阴阳间隔泪滂惶。 本待犬马图保效， 可怜我深陷淤泥魂渺茫。 只因气数应该绝， 箭下难逃一命亡。 但愿吾王登龙位， 太平千载庆大唐。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "臣启殿下：阴阳间隔，不便下云相见。敢蒙千岁亲临祭奠，为此驾云前来面谢。 臣今已列星班，不敢久停，愿千岁善保龙体，以遂众望。各位兄长同心辅政， 以助太平。 我儿你须孝养母亲，尽孝王事，就此去也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成下。李世民、徐勣、尉迟恭、秦琼、程咬金、罗春同哭。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "哎，你们为何方才不扯他下来，竟由他去了？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "罗贤侄过来。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "你今在守孝，不便入朝。孤家将你父亲显灵之事，奏闻父王，必加追赠。俟你 服满入朝，荫袭你父之职便了。"
        },
        {
          "character": "罗春",
          "type": "白",
          "text": "多谢千岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "内侍过来。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "将苏定方首级赉出号令。就此回朝复旨。"
        },
        {
          "character": "二内侍",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "二内侍",
          "type": "stage",
          "text": "—————————— ⑴ 或四内侍。"
        }
      ]
    }
  ]
}