{
  "script_id": "02010010",
  "title": "擒方腊",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "宋江",
      "hangdang": "老生"
    },
    {
      "name": "武松",
      "hangdang": "武生"
    },
    {
      "name": "张顺",
      "hangdang": "净"
    }
  ],
  "plot": "张顺死后，宋江正烦闷中，忽燕青归来报信，为方腊已封柴进宝状元，并招为驸马，可为内应。宋江乃假意\n祭弟张顺，因有方天定出兵。在重重埋伏之下，遂将方天定擒住斩杀，继即进攻方腊。方腊原拟亲自出战，\n柴进乃自告奋勇，开城迎战。遂将宋江所派来之李逵、武松等擒入城内，假意投降。最后由鲁智深帮助武松，\n将方腊擒住云。",
  "notes": "此应系《龙虎玉》之后本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "金童、玉女、水卒、龙王同上。"
        },
        {
          "character": "龙王",
          "type": "引子",
          "text": "烟波浩淼，水府中，金碧琼瑶。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "我乃，西湖龙君是也。今奉玉帝敕旨，见张顺死在涌金门下，上帝垂念，敕封 金华太保。远远观看张顺鬼魂来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺上，跪。"
        },
        {
          "character": "龙王",
          "type": "白",
          "text": "玉旨下跪。张顺死在涌金门下，上帝垂念，敕封金华太保，永镇西湖。玉旨毕。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "圣寿无疆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。张顺换衣，送龙王下。"
        },
        {
          "character": "张顺",
          "type": "白",
          "text": "且喜上帝垂念，封我金华太保。相送大哥怎生得知，不免去到帐中，托他一梦。 金童、玉女，带路。"
        },
        {
          "character": "张顺",
          "type": "唱",
          "text": "这风光分明是平地登仙， 托梦兆见大哥细诉根源。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "宋江",
          "type": "内二黄导板",
          "text": "奉君命下江南战灭草寇，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同上，同站门，宋江上，四文堂同扯四门。"
        },
        {
          "character": "宋江",
          "type": "二黄正板",
          "text": "破宣湖抢苏昌战夺四州。 兵行到杭州城天定把守， 都招管卢俊义统领貔貅。 命柴进入虎穴音讯无有， 小燕青此一去不见回头。 公孙胜为老母辞病告走， 乔道清倦红尘入山苦修。 这几月为什么不思茶酒，"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "回避了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂自两边分下。"
        },
        {
          "character": "宋江",
          "type": "二黄正板",
          "text": "纵有那珍馐味难下咽喉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江进帐睡。金童、玉女引张顺同上。"
        },
        {
          "character": "张顺",
          "type": "唱",
          "text": "想当日浔阳江英雄盖世， 到如今涌金门魄散魂飞。 叫金童把他的梦魂揭起，"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "猛抬头见贤弟泪珠下滴。 我命你破杭州李俊同去， 为什么不征战身挂紫衣？ 想必是背愚兄不顾忠义，"
        },
        {
          "character": "张顺",
          "type": "唱",
          "text": "宋大哥且慢睡细听端的： 弟在那涌金门舍生取义， 蒙天帝封忠魂已登仙籍。 兄要破杭州城实实容易， 打动了聚将鼓把英雄点齐。 假意儿西陵桥吊孝设祭， 方天定不提放泄漏兵机。 擒方腊兄休想封妻荫子， 马到了临崖晚后悔已迟。 嘱咐的言和语你牢牢紧记，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "金童、玉女同下。"
        },
        {
          "character": "张顺",
          "type": "唱",
          "text": "大限到各自飞两下分离。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张顺下。四文堂自两边分上。"
        },
        {
          "character": "四文堂",
          "type": "同白",
          "text": "元帅醒来。"
        },
        {
          "character": "宋江",
          "type": "二黄导板",
          "text": "适才间在帐中偶得一梦，"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "醒来时又只见红日当空。 适才间弟兄们对面叙话， 一霎时魂魄飞各奔西东。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青上。"
        },
        {
          "character": "燕青",
          "type": "念",
          "text": "忙将喜气事，报与大哥知。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "大哥在上，小弟参见。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "贤弟回来了。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "柴进诈降如何？"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "方腊重用，招为东床驸马。请大哥早发人马，免漏消息。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "请先生进帐。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "有请军师进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴用上。"
        },
        {
          "character": "吴用",
          "type": "念",
          "text": "忆昔当年居茅村，袖内八卦按乾坤。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "贤弟，请坐。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "谢坐。大哥为何双眼垂泪？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "时才愚兄三更时分，梦见张顺死在涌金门下，故而如此。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "这是大哥思弟之心。若有此事，李俊必来报之。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李俊上。"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "走哇！"
        },
        {
          "character": "李俊",
          "type": "念",
          "text": "祸是天来降，皆因不吉祥。"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "大哥，先生，大事不好了。"
        },
        {
          "character": "宋江、吴用",
          "type": "同白",
          "text": "啊，何事惊慌？"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "张顺死在涌金门。"
        },
        {
          "character": "宋江、吴用",
          "type": "同白",
          "text": "啊呀！"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "你死后兄与你把孝来挂， 我死后谁与我戴孝披麻。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "军师，我要与张顺贤弟祭奠一番。但不知可有凶吉？"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "大哥既要前去，却也无妨。 燕青听令。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "传众哥弟姐妹进帐。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "军师有令：众位哥弟姐妹进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史进、石秀、武松、李逵、孙二娘、顾大嫂、扈三娘、玉花娘自两边分上。"
        },
        {
          "character": "史进、石秀、武松、李逵、孙二娘、顾大嫂、扈三娘、玉花娘",
          "type": "同白",
          "text": "来也。 众兄弟姐妹参见大哥，军师为何这等模样？"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "众位贤弟，适才李俊说张顺死在涌金门水闸之下。"
        },
        {
          "character": "史进、石秀、武松、李逵、孙二娘、顾大嫂、扈三娘、玉花娘",
          "type": "同白",
          "text": "哎。"
        },
        {
          "character": "史进、石秀、武松、李逵、孙二娘、顾大嫂、扈三娘、玉花娘",
          "type": "同驻云飞",
          "text": "怒气冲霄，肺腑如同烈火焚， 廿二肝肠碎，点点珠泪滚， 眸子裂，双睛吴广邀，仅跺脚捶胸， 咬定银牙恨，叫我无计可施掌上珍。"
        },
        {
          "character": "李逵",
          "type": "白",
          "text": "待俺杀上前去。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "不可造次。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "史进、石秀、武松、李逵听令。"
        },
        {
          "character": "史进、石秀、武松、李逵",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你四人埋伏西陵桥，等方天定出城，断他的出路，不得有误。"
        },
        {
          "character": "史进、石秀、武松、李逵",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史进、石秀、武松、李逵同下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "众姐妹听令。"
        },
        {
          "character": "孙二娘、顾大嫂、扈三娘、玉花娘",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你四人埋伏西陵桥左，方天定出城，断他的去路，不得有误。"
        },
        {
          "character": "孙二娘、顾大嫂、扈三娘、玉花娘",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙二娘、顾大嫂、扈三娘、玉花娘同下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "燕青听令。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你去请卢尊官。合兵一处，不得有误。"
        },
        {
          "character": "燕青",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "燕青下。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "李俊听令。"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "吴用",
          "type": "白",
          "text": "命你带领战船二十只，江口伺候。"
        },
        {
          "character": "李俊",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李俊下。"
        },
        {
          "character": "宋江",
          "type": "白",
          "text": "贤弟，看守大营，愚兄去也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂同领下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同上，同站门。方天定上。"
        },
        {
          "character": "方天定",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓元觉、石宝同上。"
        },
        {
          "character": "邓元觉、石宝",
          "type": "同白",
          "text": "郝思文被擒。"
        },
        {
          "character": "方天定",
          "type": "白",
          "text": "此乃将军头功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！张顺死在涌金门。"
        },
        {
          "character": "方天定",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "方天定",
          "type": "白",
          "text": "来，将张顺首级，悬挂城头。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！宋江偷祭。"
        },
        {
          "character": "方天定",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "邓元觉、石宝",
          "type": "同白",
          "text": "宋江既来偷祭，千岁可点齐人马出城，拿住宋江，有道蛇无头不行，鸟无翅不 飞。徽宗江山，岂不唾手可得？"
        },
        {
          "character": "方天定",
          "type": "白",
          "text": "言之有理。 众将官，催动人马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖吹打〗。桌子摆斜场。四文堂、中军、唱礼官同上。桌上摆灵牌，上写“亡故镇国大将军张顺之灵魂”。"
        },
        {
          "character": null,
          "type": "text",
          "text": "旗幡。宋江上，叩首。唱礼官唱礼。）"
        },
        {
          "character": "宋江",
          "type": "念",
          "text": "奠酒焚香三叩首，西陵桥下水东流。贤弟阴魂今何在，野草闲花满地愁。"
        },
        {
          "character": "宋江",
          "type": "二黄导板",
          "text": "想当日梁山寨一同结拜，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋江三哭。"
        },
        {
          "character": "宋江",
          "type": "反二黄原板",
          "text": "胜似那共爹娘一母投胎。 曾许下山不崩兄弟常在， 到如今涌金门命丧泉台。 下河北灭田虎英雄气概， 下淮西灭王庆旗还未开。 下江南灭方腊不到半载，不到半载， 我只得望空祭表一表心怀。 好贤弟你在那阴曹路休把兄怪，"
        },
        {
          "character": "宋江",
          "type": "哭",
          "text": "哎呀，贤弟吓！"
        },
        {
          "character": "宋江",
          "type": "唱",
          "text": "回朝去奏天子封王立牌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小吹打〗。宋江叩首。"
        },
        {
          "character": "方天定",
          "type": "内白",
          "text": "呔，宋江前来偷祭。众将官，开城迎敌。"
        },
        {
          "character": "四文堂",
          "type": "内同白",
          "text": "啊。 （宋江、四文堂、中军、唱礼官自上场门同下。李逵、石秀、武松、史进、石宝、邓元觉、方天定同上，会 扈三娘破打。李逵、邓元觉同下。方天定打败石秀，史进打方天定，追下。清场。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "船夫、张横同上。"
        },
        {
          "character": "张横",
