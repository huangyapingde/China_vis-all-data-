{
  "script_id": "02001022",
  "title": "孝感天",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "寤生",
      "hangdang": "老生"
    },
    {
      "name": "共叔段",
      "hangdang": "小生"
    },
    {
      "name": "武姜",
      "hangdang": "老旦"
    },
    {
      "name": "卫氏",
      "hangdang": "正旦"
    },
    {
      "name": "王后",
      "hangdang": "贴旦"
    }
  ],
  "plot": "共叔段不听妻谏，领兵袭取都城，为郑庄公伏兵所困，刎颈而死。郑庄公愤母助弟谋反，将武姜幽于城颖。\n发誓不到黄泉，不复相见。武姜既到城颖，哀伤幼子，终日啼哭。一夜，共叔段夫妻双双入梦。劝母勿再悲\n啼，耐心等候，郑庄公不久将迎母还朝云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，共叔段上，起霸。"
        },
        {
          "character": "共叔段",
          "type": "念",
          "text": "少小英豪非等闲，威风出众胆包天。某今发动兵和将，要夺郑国锦江山。 俺，太叔段。皆因母后有书信到来，命俺带领人马，袭取都城。可恨卫氏贱婢， 苦苦拦挡，是俺执意不从，她便自刎而亡了。哎也！有道是谋大事者，不顾 家室。 这众将官——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同允。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "偃旗息鼓，杀奔都城去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段、四龙套同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、四将、公子吕、寤生同上。"
        },
        {
          "character": "寤生",
          "type": "西皮散板",
          "text": "母后爱子有偏见， 萧墙之内起祸端。 发兵点将心悲惨， 可叹手足自相残。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "军卒上。"
        },
        {
          "character": "军卒",
          "type": "念",
          "text": "奉了君侯命，昼夜不消停。"
        },
        {
          "character": "军卒",
          "type": "白",
          "text": "叩见千岁。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "罢了。书信可曾送到？"
        },
        {
          "character": "军卒",
          "type": "白",
          "text": "已然送到。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "太叔怎生言讲？"
        },
        {
          "character": "军卒",
          "type": "白",
          "text": "太叔言道：拜上国母，照书行事。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "好贼子！"
        },
        {
          "character": "寤生",
          "type": "西皮摇板",
          "text": "听一言来怒冲冠， 贼子做事理不端。 竟要谋朝将国篡， 再与卿家把话言。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "公子吕。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "吩咐众将，只打卿家的旗号，就在这鄢邑埋伏，擒拿太叔者！"
        },
        {
          "character": "寤生",
          "type": "西皮快板",
          "text": "无知竖子敢造反， 中国京剧戏考 《孝感天》【二本】 2 纸上何能把兵谈。 众将努力擒叛贼， 克段于鄢莫停骖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。四下手、二将、共叔段同上。"
        },
        {
          "character": "共叔段",
          "type": "西皮快板",
          "text": "母后书信将我宣， 三军踊跃跨雕鞍。 卷旗息鼓暗催趱， 休要惊动百姓观。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "前面有人马挡道！"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "看是何人旗号？"
        },
        {
          "character": "四下手",
          "type": "白",
          "text": "是公子吕的旗号。"
        },
        {
          "character": "太叔段",
          "type": "白",
          "text": "哦，公子吕的旗号！哎也——骑虎之势，难以收歇。 众将官，杀上前去！"
        },
        {
          "character": "太叔段",
          "type": "西皮快板",
          "text": "势成骑虎难回挽， 岂肯休兵转回还。 三军与爷向前趱——"
        },
        {
          "character": "太叔段",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "太叔段",
          "type": "西皮摇板",
          "text": "又见征尘遮满天！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子吕、寤生引四红龙套同上。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "呔！太叔休得无理，主公在此！"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "呸呸呸！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子吕、寤生、四红龙套同冲杀。共叔段败，下。公子吕、寤生、四红龙套同追下。共叔段急上。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "共叔段",
          "type": "西皮摇板",
          "text": "马到悬崖收缰晚， 祸已临头后悔难。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "罢了吓罢了！我只道是公子吕的人马，岂知兄侯并未朝周，亲身在此，这却怎 么处？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喊声〗。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "哎呀，四面车马围困，有何颜面见得兄侯，不如自刎一死，免遭羞辱。苍天哪 天！此乃母后误我也。"
        },
        {
          "character": "共叔段",
          "type": "西皮摇板",
          "text": "不听贤妻良言劝， 欲见兄面又羞惭。 背主欺兄报应显，"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "共叔段",
          "type": "西皮摇板",
          "text": "枉在人间走一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段自刎，死。寤生、公子吕、四红龙套同上。"
        },
        {
          "character": "四红龙套",
          "type": "同白",
          "text": "太叔自刎。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "闪开了。 哎呀！"
        },
        {
          "character": "寤生",
          "type": "西皮摇板",
          "text": "见贤弟自刎身肝肠痛断， 不由人放悲声珠泪涟涟。 我和你同胞谊有甚长短， 你争什么社稷夺什么江山！ 老母后多溺爱她的见识太浅， 痴贤弟却不该起下兵端。 拿住你并不要开刀问斩， 又何必萌短见自刎身残！ 可叹你正青春尘埃血溅，"
        },
        {
          "character": "寤生",
          "type": "哭",
          "text": "贤弟吓……"
        },
        {
          "character": "寤生",
          "type": "西皮摇板",
          "text": "恨不得拚一死同赴黄泉！"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "主公事已至此，哭也无益。只得将太叔好为安葬，也就是了。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "此皆国母所误也。 来，将太叔尸首，用黄绫裹定，棺殓埋葬，不可轻慢。 中国京剧戏考 《孝感天》【二本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套抬共叔段同下。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "吓，公子吕。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "命你去到宫中，将此书呈与国母观看，请国母到颖地安居，说我发下誓言：不 及黄泉，无相见也。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子吕下。"
        },
        {
          "character": "寤生",
          "type": "哭",
          "text": "唉，贤弟呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寤生下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女、武姜同上。"
        },
        {
          "character": "武姜",
          "type": "西皮散板",
          "text": "寄书后我的儿全无音讯， 这几日只觉得坐卧不宁。 莫不是小宫奴泄漏书信？ 莫不是京邑中少将缺兵？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公子吕上。"
        },
        {
          "character": "公子吕",
          "type": "念",
          "text": "领了君侯命，特地到宫廷。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "参见国母。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "到此何干？"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "奉了君侯之命，有书信一封，请国母观看。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "见书信不由我心神不定， 泄漏了机密事难以调停。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "我儿叔段他……他现在哪里？"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "太叔夫妻俱都自尽了。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "夫妻自尽了。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "武姜",
          "type": "西皮导板",
          "text": "猛听得小娇儿夫妻自刎，"
        },
        {
          "character": "武姜",
          "type": "三叫头",
          "text": "叔段！我儿！唉，儿呀……"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "吓坏了年迈人丧胆离魂。 实指望接君位母子同庆， 实指望来膝前侍奉晨昏。 可叹你正青春一旦命丧， 可叹你抛为娘竟赴幽冥。 再不能祝寿筵兄弟孝顺， 再不能守封疆仍回共城。 这是我溺爱过枉送儿呀——"
        },
        {
          "character": "武姜",
          "type": "哭头",
          "text": "命！我的姣儿呀——"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "肠寸断悔已晚痛杀老身。"
        },
        {
          "character": "四宫女",
          "type": "同白",
          "text": "人死不能复生，请国母保重。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "奉君侯之命，请国母驾至颖地行宫居住。君侯发有誓言：不及黄泉，无相见也。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "哦，罢了吓罢了！寤生这样忍心，竟将老身贬往颖城居住么？唉，我好苦命也。"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "死一子别一子又悲又恨， 一旦间母与子反面无情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女引王后同上。"
        },
        {
          "character": "王后",
          "type": "西皮摇板",
          "text": "忽听得众宫娥前来报信， 怎能够将老母贬出宫庭？"
        },
        {
          "character": "王后",
          "type": "白",
          "text": "参见母后。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "哎呀媳妇呀，那寤生竟要将为娘贬出宫庭去了！"
        },
        {
          "character": "王后",
          "type": "白",
          "text": "哎呀母后哇！君侯纵有请驾别居之意，不过一时愤怒。母后且休烦恼，待儿媳 中国京剧戏考 《孝感天》【二本】 4 赶往军前，劝谏君侯便了。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "你虽然有此孝心，只是我亦羞见你夫君之面，还是迁往颖地，以了残生便了。"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "要留我除非是海枯石尽， 且到那颖城地苦度光阴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、四御林军、二大太监自两边分上。"
        },
        {
          "character": "四太监、四御林军、二大太监",
          "type": "同白",
          "text": "臣等叩见国母。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "你们做什么？"
        },
        {
          "character": "四太监、四御林军、二大太监",
          "type": "同白",
          "text": "奉君侯之命，护送国母起程。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "哦，你们送我起程？"
        },
        {
          "character": "四太监、四御林军、二大太监",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "君侯何在？"
        },
        {
          "character": "四太监、四御林军、二大太监",
          "type": "同白",
          "text": "君侯发下誓言，不及黄泉无相见也。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "寤生！我儿！你好狠的心肠也！"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "寤生儿发誓言心肠太狠， 从今后母子们两下离分。 叫人来看车辆颖城够奔，"
        },
        {
          "character": "王后",
          "type": "白",
          "text": "母后一路保重，媳妇不能远送了。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "此一去真好似凤鸟失群。"
        },
        {
          "character": "王后",
          "type": "白",
          "text": "摆驾回宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "共叔段、卫氏同上。"
        },
        {
          "character": "共叔段",
          "type": "念",
          "text": "丹心天地惨，黄泉路途遥。"
        },
        {
          "character": "卫氏",
          "type": "念",
          "text": "溺爱反成害，恩情一旦抛。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "我乃共叔段鬼魂是也。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "我乃卫云环鬼魂是也。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "可叹母后，在颖地离宫，思儿想媳，你我夫妻不免前去托梦，劝解一番。"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "请。正是："
        },
        {
          "character": "共叔段",
          "type": "念",
          "text": "鹃血啼残三月雨，"
        },
        {
          "character": "卫氏",
          "type": "念",
          "text": "梦魂惊断五更风。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段、卫氏同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同上，同站门。武姜上。"
        },
        {
          "character": "武姜",
          "type": "引子",
          "text": "身似羁囚，思姣儿，珠泪双流。"
        },
        {
          "character": "武姜",
          "type": "念",
          "text": "生离最是苦，死别何伤乎！可叹年垂暮，有子不如无。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "哀家姜氏，只因溺爱次子共叔段，反累他夫妻双亡。可恨寤生，将我迁入颖地 居住，举目无亲。思想起来，好不惨伤人也。"
        },
        {
          "character": "武姜",
          "type": "二黄慢板",
          "text": "姜国母居颖地长吁短叹， 思皇儿昼夜里珠泪不干。 中国京剧戏考 《孝感天》【二本】 5 恨寤生他与我母子情断， 但不知何日里得转故园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起更鼓〗。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "尔等退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": "武姜",
          "type": "二黄慢板",
          "text": "居离宫冷清清无依无伴， 思姣儿睡不稳月照栏杆。 对银灯眼昏花自悲自惨， 有谁人怜念我孤影形单？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段、卫氏同上。"
        },
        {
          "character": "共叔段",
          "type": "二黄慢板",
          "text": "风飘飘冷飕飕阴风惨淡， 想当初在宫中奉母承欢。"
        },
        {
          "character": "卫氏",
          "type": "二黄慢板",
          "text": "这时候只落得阴阳路判， 进寝宫见国母且莫心酸。"
        },
        {
          "character": "共叔段、卫氏",
          "type": "同白",
          "text": "母后醒来！"
        },
        {
          "character": "武姜",
          "type": "二黄导板",
          "text": "梦儿里只听得有人呼唤，"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "武姜",
          "type": "二黄摇板",
          "text": "又只见灯光下双影蹁跹。 看不明拭一拭昏花老眼，"
        },
        {
          "character": "共叔段",
          "type": "白",
          "text": "母后！"
        },
        {
          "character": "卫氏",
          "type": "白",
          "text": "婆母！"
        },
        {
          "character": "共叔段、卫氏",
          "type": "同白",
          "text": "唉，母亲哪！"
        },
        {
          "character": "武姜",
          "type": "二黄摇板",
          "text": "却原来是姣儿叔段、爱媳云环。 曾记得寿宴前金樽酒满， 你夫妻双双拜色笑承欢。 儿自从到京城未能相见，"
        },
        {
          "character": "共叔段",
          "type": "回龙",
          "text": "儿死在九泉下魂魄不安。"
        },
        {
          "character": "共叔段",
          "type": "反二黄慢板",
          "text": "悲切切劝母后不必悲惨， 悔不该谋兄位自惹祸端。 连累了儿母后无依无伴， 因此上到离宫劝解一番。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武姜哭。"
        },
        {
          "character": "卫氏",
          "type": "反二黄慢板",
          "text": "这也是天命定数有修短， 劝母后切莫要终日泪涟。 未报恩来世里重亲慈范， 千古来有谁人百岁同餐？"
        },
        {
          "character": "武姜",
          "type": "反二黄慢板",
          "text": "听他言不由我心中悲惨， 分明是我的儿站立面前。 莫非是母子们梦里相见， 纵然是在阴曹娘也心甘。"
        },
        {
          "character": "共叔段",
          "type": "反二黄摇板",
          "text": "娘在阳儿在阴两厢隔断， 母子们要相逢难上加难。"
        },
        {
          "character": "卫氏",
          "type": "反二黄摇板",
          "text": "天将明儿要归不必惨念， 郑君侯指日里重会慈颜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "共叔段、卫氏同下。二宫女同上。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "国母醒来。"
        },
        {
          "character": "武姜",
          "type": "二黄导板",
          "text": "适才间见姣儿肝肠痛断，"
        },
        {
          "character": "武姜",
          "type": "三叫头",
          "text": "叔段！云环！唉儿吓！"
        },
        {
          "character": "武姜",
          "type": "二黄摇板",
          "text": "醒来时又听得玉漏声残。 相劝我言和语甚是悲惨。 中国京剧戏考 《孝感天》【二本】 6"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二宫女同下。"
        },
        {
          "character": "武姜",
          "type": "二黄摇板",
          "text": "但不知何日里才得回还。"
        },
        {
          "character": "武姜",
          "type": "哭",
          "text": "唉儿吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武姜下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}