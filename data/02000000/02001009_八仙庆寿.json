          "type": "白",
          "text": "张果老。"
        },
        {
          "character": "张果老",
          "type": "念",
          "text": "倒骑驴儿遍琼岛，"
        },
        {
          "character": "蓝采和",
          "type": "白",
          "text": "蓝采和。"
        },
        {
          "character": "蓝采和",
          "type": "念",
          "text": "玉板轻敲踏道歌。"
        },
