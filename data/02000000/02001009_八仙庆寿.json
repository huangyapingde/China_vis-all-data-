        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑同进。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "金母在上，我等稽首。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众仙少礼。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "圣寿。请问金母，相召我等，有何见谕？"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "今有长寿星君，千秋华诞之日。特邀众仙到此，一同前去祝寿。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "既如此，一同驾云前往。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同驻马听",
          "text": "鸾鹤遨游， 千风万岫归苍秀。 笙簧叠奏， 笙萧列锦讴。 虚飘飘， 恰似天台山下去寻刘。 响潺潺， 只见那桃园洞口波声流。 停猿鹤，驻千秋， 早向那白云峰，齐庆祝千年叟。 向那白云峰，齐庆祝千年叟。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "已到寿筵前。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众仙各将寿物献上。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "汉钟离",
          "type": "白",
          "text": "小仙呵！"
        },
        {
          "character": "汉钟离",
          "type": "折桂令",
          "text": "汉钟离遥献紫琼勾，"
        },
        {
          "character": "吕洞宾",
          "type": "折桂令",
          "text": "吕洞宾满捧着玉液金瓯。"
        },
        {
          "character": "张果老",
          "type": "折桂令",
          "text": "张果老擎着千岁烛，"
        },
        {
          "character": "蓝采和",
          "type": "折桂令",
          "text": "蓝采和慢舞着长衫袖。"
        },
        {
          "character": "曹国舅",
          "type": "折桂令",
          "text": "捧寿面的曹国舅，"
        },
        {
          "character": "李铁拐",
          "type": "折桂令",
          "text": "岳孔目将铁拐住，祝千秋。"
        },
        {
          "character": "韩湘子",
          "type": "折桂令",
          "text": "献牡丹的韩湘子，"
        },
        {
          "character": "何仙姑",
          "type": "折桂令",
          "text": "进灵龟的何仙姑，在笟篱内游。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "请问金母，将何物为寿？"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "我有蟠桃。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "妙哇。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "白猿何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鹤、鹿、寿物随白猿同上。白猿跳，捧桃放生。鹤、鹿、寿物、白猿同下。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "妙哇。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同雁儿落",
          "text": "将仙桃仙果收， 把仙箓仙丹授。 闻仙酒香， 听仙乐、仙音奏。 迓迎仙子下瀛洲， 引仙鹿到丹丘。 看仙童、仙鹤舞， 听仙家、仙女讴。 仙座下嬉游。 九尾龟，独角兽， 仙苑内清幽。 万年松千岁竹， 万年松千岁竹。"
        },
        {
          "character": "金母",
          "type": "雁儿落",
          "text": "向金盘取一棵寿果， 俺将这蟠桃刊为首。 同祝你寿筵前，般般有。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同雁儿落",
          "text": "寿筵前，般般有。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "祝寿已毕。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众仙就此拜寿者。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同沽美酒",
          "text": "礼三星，慌叩首， 与众仙打稽首。 俺向那金母筵前，敢问候， 提起这蟠桃的话头。 被方朔小儿常偷。 但吃的是都叫有寿， 但尝的是永远千秋。 全仗俺神通广厚， 管教恁仙缘幅辏。 俺呵。只将那道修德修， 作一个圣流。 呀。播万载，清风宇宙， 清飞宇宙。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "拜寿已毕。"
        },
        {
          "character": "金母",
          "type": "白",
          "text": "众位大仙，各归洞府。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "汉钟离、吕洞宾、张果老、蓝采和、曹国舅、李铁拐、韩湘子、何仙姑",
          "type": "同清江引",
          "text": "瑶池捧献蟠桃酒， 福禄寿，三星岫。 永享万年春， 快乐年年有。 倾刻间，到蓬莱，同聚首， 到蓬莱，同聚首。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
