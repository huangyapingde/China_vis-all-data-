{
  "script_id": "02003022",
  "title": "打吉平",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "吉平",
      "hangdang": "老生"
    }
  ],
  "plot": "曹操得病，令吉平医治。吉平恨曹操奸险，想夺篡汉室，想用毒药害死曹操。经曹操发觉，乃召至公堂，且\n令各大臣陪审，藉发现同谋之人。最后又令各大臣依次鞭打，吉平终不屈身死云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "龙套引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "出队子",
          "text": "心肠怀抱，心肠怀抱， 一夜思量恨怎消，何人惹起祸根苗？ 今日公庭勘问招， 招出何人，把他戮剿。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "心事不平空宴乐，除非杀却事方休。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "孤家曹孟德，偶得一病，命吉平前来医治，谁想他用毒药害孤。幸喜苍天鉴怜， 露出真情。今日至公庭勘问吉平。 左右，"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "众官员到来，着他们排班而进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兵卒允。王允上。"
        },
        {
          "character": "王允",
          "type": "引子",
          "text": "策马加鞭，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柴老爷上。"
        },
        {
          "character": "柴老爷",
          "type": "引子",
          "text": "早来到，至公庭畔。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "明公相召，须索向前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董承上。"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "不好了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马腾上。"
        },
        {
          "character": "董承",
          "type": "不是路",
          "text": "干戈乱如麻，"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "大人！"
        },
        {
          "character": "董承",
          "type": "不是路",
          "text": "你我来便来了，使我心惊怕。"
        },
        {
          "character": "董承",
          "type": "念",
          "text": "若到那期间，"
        },
        {
          "character": "董承",
          "type": "不是路",
          "text": "语言须带三分诈。"
        },
        {
          "character": "马腾",
          "type": "不是路",
          "text": "不必嗟呀，"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "自古为臣尽忠，为子尽孝。"
        },
        {
          "character": "马腾",
          "type": "不是路",
          "text": "全凭你一点丹心，何足怕！"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "明公相召，不知为着何事？"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "想是为平儿的那件事情罢咧。"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "吉平乃是好人，大家方便一二才是。"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "见景儿生情罢咧。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "众位老爷到齐了？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "到齐了。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "明公有令：教你们排班而进。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "哎哟，连个“请”字都没有了，排班而进。"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "将就年成儿罢咧，报门罢噻。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "众官员告进。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "众官员告进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同进见曹操。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "明公在上，我等参拜。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "列位少礼。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "侍立。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "话长，坐了好讲。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "告坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同坐。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "明公相召，有何见谕？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊，列位呀，孤家自兖州而来，带领父子兵八十三万，救驾于洛阳，有功于社 稷，无罪于朝庭。今日命吉平前来，用毒药害孤，是何道理，是何道理？"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "明公东挡西除，"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "南征北讨；"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "满朝文武，"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "谁不敬你？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "无不感仰！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这是尔等面奉之言，背地里怨孤者尽多。"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "只怕也是有的罢咧。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "这也不足计较。今日至公庭勘问吉平，不许尔等交头接耳。如有交头接耳者， 一体同罪。 左右，"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "带吉平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二兵卒同下。"
        },
        {
          "character": "吉平",
          "type": "内掉角儿",
          "text": "奸臣误国民遭困，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二兵卒扶吉平同上。"
        },
        {
          "character": "吉平",
          "type": "掉角儿",
          "text": "篡国欺君移汉室。 我今特来除奸佞， 怎奈我一点丹心天不容。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "犯官告进。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "住了！俺吉平一死罢了，什么犯官不犯官的？"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "该死的告进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二兵卒扶吉平同进。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "下面敢是吉平？"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "上面敢是曹操？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你为何道孤之名？"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "你为何称咱之讳？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "见孤为何不跪？"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "呀呀呸，俺吉平这双膝盖，上跪天子，下跪父母，岂肯跪你这篡国的奸贼？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "左右。"
        },
        {
          "character": "众兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "与我打膝盖，重责四十！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众兵卒同喊，打。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吉平，谁人与你同谋，哪个与你主谋？从实招上来，免得我三推六问。"
        },
        {
          "character": "众兵卒",
          "type": "同白",
          "text": "招。"
        },
        {
          "character": "吉平",
          "type": "念",
          "text": "俺平生正直，"
        },
        {
          "character": "吉平",
          "type": "梁州序",
          "text": "常怀忠义， 要与国家除贼。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你要与国家除贼？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操笑。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好大的个显职吓！"
        },
        {
          "character": "吉平",
          "type": "梁州序",
          "text": "怎奈我官卑职小， 又没个相扶助，又没个相扶助， 奈力弱也难成事。 幸尔有病危，幸尔有病危， 着我来医； 正中我的机谋，正中我的机谋， 贼是我欲害你。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "你要害我这干国的忠良，就是那天也不容你。"
        },
        {
          "character": "吉平",
          "type": "梁州序",
          "text": "是了么，贼，此乃是天不顺，事难齐，事难齐。 反把忠良，就遭屈死。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "左右。看铜锤伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吉平笑。"
        },
        {
          "character": "吉平",
          "type": "梁州序",
          "text": "贼徒势，你看贼徒势， 又未知天理如何。"
        },
        {
          "character": "曹操",
          "type": "忒忒令",
          "text": "俺从来正直无私， 秉赤心匡扶王室； 替天行道，扫尽了海外蛮夷。 与士卒同甘共苦，赏罚分明， 每日里勤王事。 贼无故的用毒药害孤体， 可见天公不顺伊。 今日里须从直当堂一一供招取， 是何人与你共同谋计？"
        },
        {
          "character": "众人",
          "type": "同忒忒令",
          "text": "望明公暂息虎威， 且宽容议他何罪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "依列位说，议他何罪，是议他何罪？"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "依小官说，议他个酒后无德儿罢咧。"
        },
        {
          "character": "曹操",
          "type": "忒忒令",
          "text": "这其间就里我尽知， 莫不是一党同为？"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "启上明公：吉平浑身打得稀烂，无处加刑。望明公赐皮鞭一把，每官各打三鞭， 如有不打者，即与他一党同谋之故耳。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "言之有理。 看鞭伺候。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "啊。请丞相老爷验鞭。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "挨次而打。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "啊。 请王老爷打鞭。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "吉平，谁人与你同谋，哪个与你主谋？从实招上去。你若不招，明公赐得皮鞭， 我就要打了。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "打罢，问什么！"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "报数。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "一鞭、二鞭、三鞭，打完。"
        },
        {
          "character": "王允",
          "type": "白",
          "text": "不招。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "请马老爷打鞭。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "吉平，谁人与你同谋，哪个与你主谋？从实招上去。你若不招，明公赐得皮鞭， 我就要打了。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "打罢，问什么！"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "报数。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "一鞭、二鞭、三鞭，打完。"
        },
        {
          "character": "马腾",
          "type": "白",
          "text": "不招。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "请柴老爷打鞭。"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "我比你还柴吓，抄个近儿。 平儿吓，平儿，我的琉璃瓶儿！谁人与你同谋，哪个与你主谋？从实招上去。 你若不招，明公赐得幺二三，我就要打你这眼儿猴了。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "打罢，问什么！"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "报数。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "一鞭、二鞭、三鞭、四鞭，多打了一鞭。"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "多打了一鞭，有个缘故。这天我害眼，他拿痔疮药与我上上了。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "请国舅老爷打鞭。"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "下官年迈，不打倒也罢了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "一定要打。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董承出座。"
        },
        {
          "character": "董承",
          "type": "忒忒令",
          "text": "他那里叫我行打， 我这里怎敢推辞？"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "我想此事，乃是我三人做的，如何下得毒手去打他？"
        },
        {
          "character": "董承",
          "type": "忒忒令",
          "text": "且慢说打了， 就是我行也是不安，坐也是不宁了。 好叫我心下战兢兢，战兢兢， 却也难回避。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "国舅为何不打？"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "是，下官就打。 喂呀你看，奸贼坐在上面，如狼似虎。我若不打，被他看破，如何是好？也罢， 不免假装年迈，或者遮掩过去，也未见得。 扶侍了。 吉平，谁人与你同谋，哪个与你主谋？从实招上去。你若不招，明公赐得皮鞭， 我就要打了。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "打罢，问什么！"
        },
        {
          "character": "董承",
          "type": "白",
          "text": "报数。"
        },
        {
          "character": "董承",
          "type": "忒忒令",
          "text": "恨不能一鞭下打， 叫你血溅泥。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "绑了！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "年迈了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "松了绑。"
        },
        {
          "character": "董承",
          "type": "忒忒令",
          "text": "苦了么天，适才若不亏“年迈”二字， 险些被他拿下。 苦好叫我生吞下，生吞下， 泪暗垂，泪暗垂。 心中一似钢刀刺， 伤心处，怕人知，怕人知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董承归座。"
        },
        {
          "character": "吉平",
          "type": "吉庆子",
          "text": "我招承说与你知，同谋的……"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "是哪一个？"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "是这一个。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "绑了。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "还有这一个。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "绑了。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "都不是。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "松了绑。"
        },
        {
          "character": "吉平",
          "type": "吉庆子",
          "text": "共同谋是你曹贼为主！"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "下来罢，曹胡子。你自个儿做的，望我们老哥儿们遭什么毛儿呢？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哪有自己害自己的道理？"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "是吓，哪有曹操害曹操的呢？ 吓，平儿吓，你别这么混指烂指的。只顾你这么一指，把你柴大老爷，吓了一 裤子稀屎吓。"
        },
        {
          "character": "吉平",
          "type": "吉庆子",
          "text": "只消我一句言语，只消我一句言语， 唬得他慌张失志。 此乃是我一人做的， 又何须将他连累，又何须将他连累。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "国舅、西凉侯，你二人密密问来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董承、马腾同出座。"
        },
        {
          "character": "董承、马腾",
          "type": "同吉庆子",
          "text": "适才打得他慌张语，适才打得他慌张语， 言东语西，东扯西扳，东扯西扳，又未知主何其意。"
        },
        {
          "character": "董承、马腾",
          "type": "同白",
          "text": "吉先生，受刑不过，将我二人招出来罢。"
        },
        {
          "character": "吉平",
          "type": "玉交枝",
          "text": "国舅、西凉侯，你二人既为国家臣宰， 必须要烈烈轰轰，磊磊落落，才是忠臣之道理。 你二人若大年纪，还怕一死， 日后怎么成其国家大事，怎么成其国家大事了？ 国舅、西凉侯，你二人慌怎的， 我死后，还有天来大事，尽付你干系。"
        },
        {
          "character": "董承、马腾",
          "type": "同玉交枝",
          "text": "吉平为国反受刑， 奸佞盈朝天不容。 可怜汉室遭衰朽， 反把忠良就受酷刑。 伤心事怕人知， 伤心事怕人知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "董承、马腾同归座。"
        },
        {
          "character": "吉平",
          "type": "尾声",
          "text": "吉平今日遭屈死， 不是冤家不到底。"
        },
        {
          "character": "吉平",
          "type": "白",
          "text": "同谋主谋各有了，叫曹贼附耳过来。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "请爷附耳。"
        },
        {
          "character": "柴老爷",
          "type": "白",
          "text": "待小官代劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吉平打柴老爷。"
        },
        {
          "character": "吉平",
          "type": "尾声",
          "text": "恨不能举枷肘打死谗臣，吾心足矣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吉平撞死，吉平、柴老爷自两边分下。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "禀爷：吉平打死柴爷，触阶而死。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吉平已死，一概不究。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "枉自欺心害大臣，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "谁想今朝害自身。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "劝君各自行天理，"
        },
        {
          "character": "众人",
          "type": "同念",
          "text": "天眼分明报应真。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}