{
  "script_id": "02001056",
  "title": "幻化",
  "alias": [
    "叹骷髅"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "庄周",
      "hangdang": "老生"
    },
    {
      "name": "老人",
      "hangdang": "外"
    }
  ],
  "plot": "庄周闲步田间，见骷髅一堆，无人葬埋，不胜叹息。骷髅乃乘庄周入睡，向庄周历述死后之乐与生前之苦，\n最后庄周反被骷髅说服，出家修道。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "庄周上。"
        },
        {
          "character": "庄周",
          "type": "一江风",
          "text": "晓风凉，旭日遮晴障， 信步荒芜上。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "卑人庄周，乃楚国梦邑人也。不受赵国之聘，隐迹山林，一心悟道。今早出门， 来此荒郊游玩。但见乌鸦群噪，白骨成堆嗐！好伤感人也！"
        },
        {
          "character": "庄周",
          "type": "一江风",
          "text": "见苍松满树枯藤，听鸟语悠扬， 共噪枝头上。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "呜呼呀，这是一堆骷髅，为何暴露在此？嗳！"
        },
        {
          "character": "庄周",
          "type": "一江风",
          "text": "想人生空自忙，空自忙，"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "骷髅哇，骷髅！"
        },
        {
          "character": "庄周",
          "type": "一江风",
          "text": "你的形容在哪厢？ 这一堆白骨倩谁埋葬？"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "感叹一回，身子有些困倦，不免在柳荫之下，打睡片时，起来再行。正是："
        },
        {
          "character": "庄周",
          "type": "念",
          "text": "残骨尚留芳草地，一番清话有谁知？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庄周睡。老人上。"
        },
        {
          "character": "老人",
          "type": "念",
          "text": "茫茫不知处，悠悠何所归？生前无人识，死后有谁知？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "某骷髅是也。方才闻得庄先生之言，甚有训誚之意。不免把生死之事，与他辩 论一番。 庄先生！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庄周起。"
        },
        {
          "character": "庄周",
          "type": "念",
          "text": "梦里不知身是客，"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "庄周",
          "type": "念",
          "text": "谁来耳畔唤先生？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "先生请了。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "请了。足下何来？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "适闻先生所言，句句真切。如仆者，则无斯患也。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "如此说来，足下莫非是骷髅么？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "正要请教，但不知富不如贵贫不如贱则生不如死，望足下教之。"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "既蒙垂问，敢呈所知。夫死者无君于上，无臣于下，无四时之患，无万感之劳， 仆今在飘飘渺渺之间，其乐无穷。虽南面帝王之乐，不我过也。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "如此说来那生不如死了？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "请教。"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "老人",
          "type": "宜春令",
          "text": "生能几，死较长， 有谁逃无常这桩。 这腌拶臭胕， 把幻身躯抛却无真相。 讨得来富贵皮囊，富贵皮囊， 只不过王侯尊长。"
        },
        {
          "character": "老人",
          "type": "念",
          "text": "未归三尺土，难保百年坟。"
        },
        {
          "character": "老人",
          "type": "宜春令",
          "text": "悲伤！ 怕提起在生时，有千万魔障，有千万魔障。"
        },
        {
          "character": "庄周",
          "type": "宜春令",
          "text": "生堪惜，死最伤， 万千傀猥扮演演这场。 似电光石火， 一灵怎肯归黄壤？ 纵然是再得入身， 浑不似旧时的形象。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "庄周",
          "type": "念",
          "text": "败坏不如猪狗相，人生莫作等闲看。"
        },
        {
          "character": "庄周",
          "type": "宜春令",
          "text": "堪伤！ 想贤愚贵贱， 逃不得这般模样。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "骷髅，我当为汝告过阴司，命汝再转阳世，你意如何？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "老人",
          "type": "念",
          "text": "我今为鬼已数秋，也无欢乐也无愁。先生叫我还阳去，只恐为人不到头。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "唯呀是呀！请问足下，在生时作何事业？请道其详。"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "言之可伤，恐君不忍闻耳。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "愿闻。"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "先生！"
        },
        {
          "character": "老人",
          "type": "解三酲",
          "text": "俺也曾为功名勤劳鞅掌， 为儿孙积下了万廩千箱。 俺也曾珠围翠绕在销金帐， 俺也曾为国家，为国家晓夜思量。 俺也曾忘餐废寝， 记不尽千年帐。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "如此说你倒是个忙人了！"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "忙他何用啊？"
        },
        {
          "character": "老人",
          "type": "解三酲",
          "text": "尽作了黄粱梦一场， 顷刻无常！ 问你忙也不忙？"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "你到底是何等样人物呢？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "喏！"
        },
        {
          "character": "老人",
          "type": "解三酲",
          "text": "你我同一样， 你便问我是何人， 我便问你是谁行？"
        },
        {
          "character": "庄周",
          "type": "解三酲",
          "text": "听说罢令人惨伤， 这言词果不荒唐。 臭皮囊暂且为人样， 碎纷纷把骨骸包藏。 凭你经文纬武拜了公侯相， 少不得死后同登白骨场。 承你开迷纲， 怎能够跳出轮回，方免无常？"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "先生要免无常二字，我有一偈，你必须牢牢紧记。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "领教。"
        },
        {
          "character": "老人",
          "type": "念",
          "text": "满腹贪生怕死期，死中荣处有谁知？先生要免无常路，除是长桑公子知。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "承教了。"
        },
        {
          "character": "老人",
          "type": "尾声",
          "text": "记真言，还提想， 模糊醉眼似徉。"
        },
        {
          "character": "老人",
          "type": "白",
          "text": "庄先生！"
        },
        {
          "character": "老人",
          "type": "尾声",
          "text": "这的是生死关头，和你梦一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老人下。庄周睡。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "骷髅，骷髅，转来，不要远去，我还有话问你。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庄周起。"
        },
        {
          "character": "庄周",
          "type": "白",
          "text": "哎呀，奇怪，方才明明与骷髅把生死之事，辩论一番，临别时赠我一偈。他道： “满腹贪生怕死期，死中荣处有谁知？先生要免无常路，除是长桑公子知。” 哎呀且住！我想那长桑公子，乃是道德真君，我一时焉能得见？也罢，不免 回去撇了妻子，弃却田园，游遍天下，寻访长桑公子便了。正是："
        },
        {
          "character": "庄周",
          "type": "念",
          "text": "百年浑似梦，大梦古今同。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庄周下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}