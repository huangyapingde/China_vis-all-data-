{
  "script_id": "02008023",
  "title": "泗水关",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "杨滚",
      "hangdang": "净"
    },
    {
      "name": "赵匡胤",
      "hangdang": "红生"
    },
    {
      "name": "高怀亮",
      "hangdang": "小生"
    },
    {
      "name": "杨继业",
      "hangdang": "小生"
    }
  ],
  "plot": "火山王杨滚，与东鲁王高行周，为结义兄弟。高行周将其子高怀德，托于杨滚。杨滚爱如己出，排行第四。\n将杨家秘法杨家枪传将于他。但因与杨滚之子杨继康、杨继铠、杨继业不睦，故杨滚又令高怀德，仍回高平，\n认姓归宗。行至中途，遇崔应龙回朝。交战之时，高怀德用杨家枪法，将崔应龙打败。崔应龙回朝之后，\n向刘主禀告，杨滚将杨家枪法，传与高怀德，有意谋反。刘主大怒，下令将杨滚斩首。经众大臣保奏，刘主\n乃令杨滚往拿高怀德。高怀德闻讯，亲自向杨滚认罪。杨滚乃令其子等追赶高怀德，每人让他一阵，以便回\n朝交旨。长子杨继康、次子杨继铠，虽均遵命。三子杨继业，却真与高怀德交战，反被高怀德刺伤。杨滚大\n怒，亲自出马。高怀德哭诉真情，杨滚逐谅解。乃令高怀德与他交战，高怀德不肯。谓父子无交战之理，杨\n滚乃令高怀德用枪强刺杨滚之胸膛。杨滚乃告高怀德，此乃杨家落地梅花点钢枪祕法，要牢牢记住，逃走去\n罢。最后赵匡胤亲来应战，亦被杨滚打败。正拟杀伤，忽然乌云遮日。杨滚知赵匡胤将来必为天子，遂下马\n归顺云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠、杨继康、杨继铠、杨继业、杨滚同上。"
        },
        {
          "character": "杨滚",
          "type": "点绛唇",
          "text": "盖世豪强，威风飘荡，英名望，韬略无双，气吞山河壮。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "老夫出世在火塘，谁人不知火山王。心中恼恨杨怀亮，临阵失漏杨家枪。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "老夫，火山王杨滚，在刘主驾前为臣。只因十数年前，曾与东鲁王高兴州义结 金兰，他将次子怀亮，托继老夫。此子生来伶俐，老夫爱如珍宝，将杨家花枪 传授与他，谁知他弟兄们不睦，是老夫命他去往高平认姓归宗，行在中途，偶 遇崔应龙回朝，他二人反目争斗，那怀亮施展杨家花枪。谁想崔应龙启奏一本， 他道老夫失漏杨家花枪，有谋反之意，立时将老夫推去取斩。多亏众令公保 奏，才得活命。因此命老夫带罪出朝，捉拿怀亮回朝问罪。今乃黄道吉日。 众家儿郎。"
        },
        {
          "character": "杨继康、杨继铠、杨继业",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "杨继康、杨继铠、杨继业",
          "type": "同白",
          "text": "俱已齐备。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "兵伐高平。"
        },
        {
          "character": "杨继康、杨继铠、杨继业",
          "type": "同白",
          "text": "得令。 嘟，众将官，兵伐高平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上。〖牌子〗。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "俺杨怀亮。奉了爹爹之命，去往高平，认姓归宗。行至中途，偶遇崔子建应龙， 将那贼杀得大败。那贼回朝奏与圣上，道俺杨家临阵，暗使花枪，有谋反之 意。圣上大怒，就要将我爹爹斩首，多亏王子令公保奏下来，才得活命。闻听 我父带兵，捉拿与我，不免去至爹爹台前，请罪便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。高怀亮下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠、杨滚同上。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "老夫兴大兵，四路扫烟尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿是怀亮？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "儿是怀亮。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "杨滚",
          "type": "二黄摇板",
          "text": "一见怀亮怒气生， 不由老夫咬牙恨。 叫人来将他忙上捆，"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "冤枉！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "招回来！"
        },
        {
          "character": "杨滚",
          "type": "二黄摇板",
          "text": "奴才有话快说明。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "奴才还有何话讲？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "哦，呵呵爹爹！孩儿奉命去至高平，认姓归宗，行至中途，偶遇崔子建应龙， 将孩儿杀得大败。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "呸，那崔应龙有多大本领，儿就战他不过？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "爹爹，那贼人马犹如潮水一般，儿杀前不能顾后，杀左不能顾右。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "呸，儿既杀前不能顾后，战左不能顾右，两军阵前，性命有亏，儿就该使起杨 家花——"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "枪！"
        },
        {
          "character": "高怀亮",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "高怀亮",
          "type": "二黄摇板",
          "text": "不是花枪来敌挡， 险些阵前一命亡。"
        },
        {
          "character": "杨滚",
          "type": "二黄摇板",
          "text": "听罢言来才知情， 这是我错怪小姣生。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "崔应龙，崔子建！老夫与你有多大的仇恨？害我父子，是何道理？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮哭。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "哎呀，儿吓！不必啼哭，你且出营，为父的命你三个兄长，每人让你一阵，以 遮众军耳目，老夫回朝之日，定不与那贼干休，出帐去罢。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "来，传你三位少爷进帐。"
        },
        {
          "character": "四白文堂、四白大铠",
          "type": "同白",
          "text": "三位少爷进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继康、杨继铠、杨继业同上。"
        },
        {
          "character": "杨继康、杨继铠、杨继业",
          "type": "同念",
          "text": "辕角升平，想是干戈宁静。"
        },
        {
          "character": "杨继康、杨继铠、杨继业",
          "type": "白",
          "text": "参见爹爹！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "杨继康、杨继铠、杨继业",
          "type": "同白",
          "text": "适才四弟进帐，讲些什么？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "你四弟言道：并无反意，俱是那崔应龙之过，不与你四弟相干。为父的命你三 人，假意去至阵前，每人让他一阵，父子们也好回朝，交旨复命。"
        },
        {
          "character": "杨继康、杨继铠、杨继业",
          "type": "同白",
          "text": "孩儿们遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继康、杨继铠同下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "继业儿转来。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿在。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿须要紧遵父命。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上。杨继康上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "大哥，敢是让小弟一阵？"
        },
        {
          "character": "杨继康",
          "type": "白",
          "text": "奉了爹爹之命，让你一阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继康败下。杨继铠上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "二哥，敢是让小弟一阵？"
        },
        {
          "character": "杨继铠",
          "type": "白",
          "text": "奉了爹爹之命，让你一阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继铠败下。杨继业上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "三哥，敢是让小弟一阵？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "奉了爹爹之命，前来与你交战。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业、高怀亮同起打，杨继业败下，高怀亮追下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四白文堂、四白大铠同上，同站门。杨滚上。"
        },
        {
          "character": "杨滚",
          "type": "念",
          "text": "眼观旌旗起，耳听好消息。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀，爹爹！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "继业儿，为何这等模样呢？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哦呵，爹爹！孩儿奉了爹爹之命，护四弟一阵，谁想他竟无手足之情，照定孩 儿肚腹就刺。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "为父不信。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "爹爹请看。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "啊，果然如此。你且下去，为父自有道理。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "是，孩儿遵命。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "怀亮，怀亮！为父的好意命你三位兄长，每人让你一阵，你不念手足之情，提 枪就刺，你既无手足之情，为父的还有什么父子之义！ 来，抬枪带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮上。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "爹爹！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "好奴才！为父的好意命你三个兄长，每人让你一阵，你不念手足之情。为父的 知道你的为人，也是好的。来来来，与为父的较量较量！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "哦！呵呵爹爹，大哥、二哥，俱让孩儿一阵，唯有三哥不让孩儿，还则罢了， 反用铜锤，将护心宝镜击破，在爹爹面前搬动是非，要害孩儿性命。也罢，今 日老爹爹用枪，将孩儿刺死了罢！"
        },
        {
          "character": "高怀亮",
          "type": "哭",
          "text": "哎呀！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "杨滚",
          "type": "唱",
          "text": "听罢言来珠泪滚， 倒叫老夫痛伤心。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "继业儿吓，好奴才！为父的早已知道你要害你四弟性命，有老夫在世，那是万 万不能！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "爹爹。"
        },
        {
          "character": "高怀亮",
          "type": "唱",
          "text": "三哥定下牢笼计， 要害孩儿命归西。"
        },
        {
          "character": "高怀亮",
          "type": "哭",
          "text": "喂呀！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿吓，不必啼哭，上马去与为父战上几合，也好回复圣命。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "哎呀，爹爹！自盘古以来，哪有父子交战之理？"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "你待怎讲？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "哪有父子交战之理？"
        },
        {
          "character": "杨滚",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "是吓，自盘古以来，哪有父子交战之理。儿吓，我杨家花枪，儿可能全记？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "孩儿不能全记。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "着哇！儿上马去，将杨家花枪，传授与你。"
        },
        {
          "character": "杨滚",
          "type": "西皮导板",
          "text": "叫三军与爷战鼓起，"
        },
        {
          "character": "杨滚",
          "type": "西皮正板",
          "text": "勒住了丝缰看端的： 杨怀亮生得来多伶俐， 亚赛过当年的伍子胥。 赛韦陀，赛韦陀缺少了降魔宝杵， 赛吕布，赛吕布又缺少画杆戟。 老夫命里有四子， 唯有这冤家他最出奇。 杨家花枪传授了你， 只要儿手急眼快躲得急。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚、高怀亮对枪，同起打。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "哎呀，儿吓，这一枪儿刺得好！来来来，照为父的胸膛来刺呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮刺，高怀亮追杨滚同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "龙争虎斗，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德上。"
        },
        {
          "character": "高怀德",
          "type": "念",
          "text": "干戈何日罢休？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哪里人马呐喊？登高一望。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨滚、高怀亮同上，同起打。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "儿吓，这一枪儿可认得？"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "孩儿不认识。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "此乃我杨家落地梅花点刚枪。儿牢牢紧记，上马去罢！"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀亮在下场门站。赵匡胤对高怀德。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "老将军将你兄弟挑下马来，速命武王七侯出马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下。"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高怀德下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！武王七侯讨战。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "再探！"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "杨滚",
          "type": "唱",
          "text": "武王七侯把战讨， 不由老夫喜眉稍。"
        },
        {
          "character": "高怀亮",
          "type": "白",
          "text": "爹爹老了哇。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "杨滚",
          "type": "唱",
          "text": "有人再说为父老， 钢刀之下不恕饶。 一叫怀亮与我闪战道，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。杨滚 、高怀亮同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "石守能、杨滚自两边分上，同起打。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "尔是何人？"
        },
        {
          "character": "石守能",
          "type": "白",
          "text": "俺乃石守能。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "上马去罢！"
        },
        {
          "character": "石守能",
