          "text": "咳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "石守能下。高怀德上，起打。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "尔是怀德？"
        },
        {
          "character": "高怀德",
          "type": "白",
          "text": "正是怀德。"
        },
        {
          "character": "杨滚",
          "type": "白",
          "text": "上马去罢！"
