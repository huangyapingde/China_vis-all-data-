{
  "script_id": "02001003",
  "title": "福禄寿荣",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "福星",
      "hangdang": "老生"
    },
    {
      "name": "禄星",
      "hangdang": "老生"
    },
    {
      "name": "寿星",
      "hangdang": "老生"
    }
  ],
  "plot": "福德星君寿之日，福禄寿三位星君特邀赤松子、偓佺、王子乔、琴高、安期生、梅福、稽康与玉姜等，同往\n贺寿，并各献礼物。福禄寿三星一齐拜寿，众仙女共同起舞，并高唱颂诗而归。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众云童引众仙同上。"
        },
        {
          "character": "众仙",
          "type": "同粉蝶儿",
          "text": "海岛逍遥，采仙药，长生不老， 稳坐着碧云车，好趋扶摇。 过沧溟，排阊阖，一霎里飞腾光耀， 不虚那桂酒佳肴。 献寿筵擎来奇宾，擎来奇宾。"
        },
        {
          "character": "众仙",
          "type": "同念",
          "text": "碧瓦朱楹十二楼，瞳眬日窟尽仙州。方知前路无多远，白鹤长添海屋筹。"
        },
        {
          "character": "赤松子",
          "type": "白",
          "text": "小仙赤松子是也。"
        },
        {
          "character": "偓佺",
          "type": "白",
          "text": "小仙偓佺是也。"
        },
        {
          "character": "王子乔",
          "type": "白",
          "text": "小仙王子乔是也。"
        },
        {
          "character": "琴高",
          "type": "白",
          "text": "小仙琴高是也。"
        },
        {
          "character": "安期生",
          "type": "白",
          "text": "小仙安期生是也。"
        },
        {
          "character": "梅福",
          "type": "白",
          "text": "小仙梅福是也。"
        },
        {
          "character": "稽康",
          "type": "白",
          "text": "小仙稽康是也。"
        },
        {
          "character": "玉姜",
          "type": "白",
          "text": "小仙玉姜是也。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "今当福德星君千秋华诞，我等奉福禄寿三位星君相召随往筵前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "你看祥云光耀，星君来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。众仙引福星、禄星、寿星同上。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同新水令",
          "text": "步云程，双手捧蟠桃， 俺寿星鬓眉未老。 福田开荡荡， 禄利水迢迢。 眉比同曹， 祝华筵同来到。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "三位星君在上，我等稽首。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同白",
          "text": "列位大仙少礼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙同允。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同念",
          "text": "五福丛中寿为先，享受荣华万金川。夫妻到老双福寿，福寿图中善庆缘。"
        },
        {
          "character": "福星",
          "type": "白",
          "text": "吾乃天福星君是也。"
        },
        {
          "character": "禄星",
          "type": "白",
          "text": "吾乃天禄星君是也。"
        },
        {
          "character": "寿星",
          "type": "白",
          "text": "吾乃天寿星君是也。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同白",
          "text": "今当福德星君千秋华诞，我等特邀海外群仙，前往福地庆祝。 众仙可曾到齐？"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "到齐了。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同白",
          "text": "一同前往。"
        },
        {
          "character": "众云童",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "众仙",
          "type": "同驻马听",
          "text": "跨凤乘鰲， 星龕万仞芙蓉峤。 打精神笑， 怎比那天门太乙浪遊遨。 慢低回，急向长安孔道， 须臾到，聆法曲，奏箫韶。 早对着寿筵前， 知有喜福颜笑。"
        },
        {
          "character": "众云童",
          "type": "同白",
          "text": "已到寿筵前。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同白",
          "text": "众位大仙各将如意献上。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙同献彩。"
        },
        {
          "character": "赤松子",
          "type": "拆桂令",
          "text": "俺赤松喜的是岁月丰饶，"
        },
        {
          "character": "偓佺",
          "type": "拆桂令",
          "text": "俺偓佺喜的是雨顺风调。"
        },
        {
          "character": "王子乔",
          "type": "拆桂令",
          "text": "王子乔喜的是八方泰，"
        },
        {
          "character": "琴高",
          "type": "拆桂令",
          "text": "琴舍人喜的是歌天尧。"
        },
        {
          "character": "安期生",
          "type": "拆桂令",
          "text": "喜金壁的安期叟，"
        },
        {
          "character": "梅福",
          "type": "拆桂令",
          "text": "喜仙禄俺梅福逞英豪。"
        },
        {
          "character": "稽康",
          "type": "拆桂令",
          "text": "喜吉生的稽中散，"
        },
        {
          "character": "玉姜",
          "type": "拆桂令",
          "text": "喜吉祥的俺玉姜休徽时者。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同拆桂令",
          "text": "俺喜这蟠桃将熟了，"
        },
        {
          "character": "众仙",
          "type": "同拆桂令",
          "text": "喜如意，许多般天花挥落，天花挥落。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "献寿已毕。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同白",
          "text": "筵前叩祝者。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "福星、禄星、寿星同拜。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同收江南",
          "text": "俺三星齐拜寿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙同拜。"
        },
        {
          "character": "众仙",
          "type": "同收江南",
          "text": "俺群仙随舞蹈。 同向这筵前齐奏乐声高， 笑吾等仙骨灵苗皓髯萧萧。 怎比得重瞳珠皎， 龙耳闻遥。 每日价万几机要， 还有暇诗文振藻。 颐养得阴阳气调， 共天长地沓。 呀，看万岁扶桑方晓。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "庆祝已毕。"
        },
        {
          "character": "福星、禄星、寿星",
          "type": "同白",
          "text": "众位大仙各归洞府。"
        },
        {
          "character": "众仙",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "众仙",
          "type": "同清江引",
          "text": "天衢倾刻霓旌导， 福禄寿多光耀。 宇宙有同春， 日月无偏照。 亿万年常拜瑶阶，聆帝教， 常拜瑶阶，聆帝教。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众仙自两边分下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}