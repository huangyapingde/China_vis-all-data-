          "text": "有。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "掌灯入穴者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四宫女掌灯、二太监引武姜同过桌子。四太监、寤生自下场门同上。"
        },
        {
          "character": "寤生",
          "type": "叫头",
