          "character": "寤生",
          "type": "白",
          "text": "内侍掌起红灯，穴中去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监掌灯引寤生过桌子同下。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "有请国母！"
