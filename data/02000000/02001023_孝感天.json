{
  "script_id": "02001023",
  "title": "孝感天",
  "alias": [
    "掘地见母"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "寤生",
      "hangdang": "老生"
    },
    {
      "name": "武姜",
      "hangdang": "老旦"
    },
    {
      "name": "颖考叔",
      "hangdang": "净"
    }
  ],
  "plot": "庄公之母武姜自迁居颖邑后，终日郁郁不乐。颖考叔得知其情，入朝述职，于庄公赐宴之际，饮酒而遗其肉。\n庄公问故，颖考叔称臣有老母，未曾食君之赐，故留而不食，欲怀归奉母。庄公闻言，大受感动。惟以发\n誓在先，无法挽转。颖考叔乃献策掘地及泉，遂而相见。庄公从之，遂与武姜为母子如初。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套、四马夫、中军、颖考叔同上。"
        },
        {
          "character": "颖考叔",
          "type": "点绛唇",
          "text": "镇守封疆，人强马壮，休兵将，亲课农桑，国泰民安享。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔上高台。"
        },
        {
          "character": "颖考叔",
          "type": "念",
          "text": "几年镇守在边疆，物阜民丰士马壮。只为吾君亏孝道，一心进谏入朝纲。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "某颖考叔。郑国为臣，官居颖谷封人之职。皆因共叔段兴兵造反，身死鄢城， 主公一怒，将国母姜夫人迁于城颖，形同贬谪。国母思念幼子，终日悲啼，恹 恹成病，倘有不测，我主难逃不孝之名。因此回朝述职，用言语劝谏主公，使 他母子团聚。只是主公十分恼怒，某今此去，必须见景生情。 中军！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "兵发都城。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套同允。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "兵发都城！"
        },
        {
          "character": "颖考叔",
          "type": "西皮导板",
          "text": "姜国母偏爱那共叔段，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔上马。"
        },
        {
          "character": "颖考叔",
          "type": "西皮原板",
          "text": "废长立幼理不端。 叔段兴兵来造反， 可叹他手足自相残。 夫妻双双颈血溅， 青春短命实可怜。 郑侯一怒将母贬， 贬至在颖城受熬煎。 姜母虽是"
        },
        {
          "character": "颖考叔",
          "type": "西皮二六板",
          "text": "妇人见，"
        },
        {
          "character": "颖考叔",
          "type": "西皮流水板",
          "text": "哪有个子女贬椿萱？ 主公与母情义断， 唯恐后人作笑谈。 某今还朝将主劝， 但愿她母子得团圆。 三军引路回朝转，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四绿龙套、四马夫、中军同下。"
        },
        {
          "character": "颖考叔",
          "type": "西皮摇板",
          "text": "见了主公上谏言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔下。"
        },
        {
          "character": "颖考叔",
          "type": "stage",
          "text": "中国京剧戏考 《孝感天》【三本】 2"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "寤生",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监、大太监同上，寤生上。"
        },
        {
          "character": "寤生",
          "type": "西皮慢板",
          "text": "盘古开辟天地展， 伏羲神农立轩辕。 天运循环轮流转， 唐尧访舜象耕田。 禹王治水人罕见， 三过其门不回还。 受禅继位登宝殿， 君民同乐太平年。 后出夏桀民遭惨， 弹打百姓肆凶残。 商汤伐桀舒民难， 四百余载乐安然。 又出纣王朝政乱， 宠爱妲己丧江山。 凤鸣岐山真主现， 文王仁德可配天。 武王伐纣除大患， 天遣英雄到世间。 成康二主多为善， 幽王无道民不安。 迷恋褒姒事荒诞， 戏耍诸侯焚狼烟。 纷纷列国刀兵惨， 黎民涂炭似倒悬。 我父创业江山占， 子承父业理当然。 母后喜爱共叔段， 废长立幼理不端。 手足相争两交战， 同胞情义难周全。 悔不该一怒将母贬， 悔不该发下洪誓言。 不到黄泉难相见， 思前想后心怎安。 内侍臣摆驾银安殿， 再与群臣国事谈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寤生坐。公子吕上。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "臣公子吕见驾，主公千岁。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "今有颖考叔回朝述职。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "是。 主公有旨：颖考叔上殿。"
        },
        {
          "character": "颖考叔",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔上。"
        },
        {
          "character": "颖考叔",
          "type": "西皮快板",
          "text": "银安殿上珠帘卷， 文臣武将列朝班。 中国京剧戏考 《孝感天》【三本】 3 千岁爷传旨将某宣， 全凭言语要回天。 撩袍端带某就上银安，"
        },
        {
          "character": "颖考叔",
          "type": "西皮散板",
          "text": "龙书案前把驾参。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "臣颖考叔见驾，主公千岁。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "卿家镇守颖城，景况如何？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "颖城物阜民丰，化行俗美，特来奏知。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "此卿家之功也。 公子吕，"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "考叔守土有功，吩咐摆下筵席，宣群臣上殿，相陪共饮。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "谢主公。"
        },
        {
          "character": "公子吕",
          "type": "白",
          "text": "主公有旨，众家公卿上殿。"
        },
        {
          "character": "蔡足、子都、高渠弥、瑕叔盈",
          "type": "内同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡足、子都、高渠弥、瑕叔盈同上。"
        },
        {
          "character": "蔡足、子都、高渠弥、瑕叔盈",
          "type": "同念",
          "text": "忽听主公宣，上殿把驾参。"
        },
        {
          "character": "蔡足、子都、高渠弥、瑕叔盈",
          "type": "同白",
          "text": "臣等见驾，主公千岁！"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "蔡足、子都、高渠弥、瑕叔盈",
          "type": "同白",
          "text": "千千岁。宣臣等上殿，有何国事议论？"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "今有颖考叔，守土有功，孤王赐宴，众卿作陪。"
        },
        {
          "character": "蔡足、子都、高渠弥、瑕叔盈",
          "type": "同白",
          "text": "遵旨。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "酒宴摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。寤生中坐，公子吕、颖考叔、蔡足、子都、高渠弥、瑕叔盈同八字坐。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "众卿请——"
        },
        {
          "character": "公子吕、颖考叔、蔡足、子都、高渠弥、瑕叔盈",
          "type": "同白",
          "text": "主公请——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同饮，颖考叔以箸夹肉。"
        },
        {
          "character": "窹生",
          "type": "白",
          "text": "啊考叔！"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "窹生",
          "type": "白",
          "text": "有道是“长者赐，不敢辞”，卿为何饮酒遗肉，敢是轻孤之赐否？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "为臣怎敢轻君之赐！只因家有老母，臣虽日奉甘旨，却不曾尝过主公所赐之物， 故而留下此肉，怀归奉母，望求主公恕罪。"
        },
        {
          "character": "窹生",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "窹生",
          "type": "西皮摇板",
          "text": "听一言来心惨伤， 中国京剧戏考 《孝感天》【三本】 4 点点珠泪撒胸膛。 当初做事太无状， 不该立誓弃亲娘。 带愧含悲心暗想……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窹生拭泪。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "颖考叔",
          "type": "西皮摇板",
          "text": "停杯不饮为哪般？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "主公为何满眼垂泪，停杯不饮？"
        },
        {
          "character": "窹生",
          "type": "白",
          "text": "卿家有老母在堂，克尽孝道，寡人身为一国之主，却成无母之人，故此伤心落 泪耳。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "姜氏国母，现在颖城，何言无有？"
        },
        {
          "character": "窹生",
          "type": "白",
          "text": "卿家有所不知，只因母后相助我弟叔段，谋夺江山，是孤一时愤怒，将国母送 往颖城，更不该发下誓言，君臣尽皆知晓，要得母子重逢，除非在九泉之下了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "窹生哭。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "这有何难，主公要与国母相会，可在颖城之外，挖一地穴，请国母在穴中相会， 上无天日，下及黄泉，岂不应了主公之誓！"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "有理呀有理！"
        },
        {
          "character": "寤生",
          "type": "西皮摇板",
          "text": "听一言来心欢畅， 忧愁化喜乐非常。"
        },
        {
          "character": "寤生",
          "type": "白",
          "text": "此计甚好，就命卿家速速回转颖城，挖掘地穴，孤随后而行。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "臣遵旨！"
        },
        {
          "character": "颖考叔",
          "type": "西皮摇板",
          "text": "叩罢头来辞主上，"
        },
        {
          "character": "颖考叔",
          "type": "西皮快板",
          "text": "背转身来自思量： 主公当初太莽撞， 哪有个为子贬亲娘？ 此一番听了某言讲， 前嫌旧恨两相忘。 下得银安颖城往，"
        },
        {
          "character": "颖考叔",
          "type": "西皮摇板",
          "text": "从此国母转还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔下。"
        },
        {
          "character": "寤生",
          "type": "笑",
          "text": "啊哈……"
        },
        {
          "character": "寤生",
          "type": "西皮摇板",
          "text": "考叔献计孤心爽， 可算国家一栋梁。 众卿随孤一同往……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红龙套、四大铠自两边分上，领公子吕、蔡足、子都、高渠弥、瑕叔盈同下。"
        },
        {
          "character": "寤生",
          "type": "西皮摇板",
          "text": "黄泉之下会亲娘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "寤生下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二宫女、武姜同上。"
        },
        {
          "character": "武姜",
          "type": "西皮散板",
          "text": "日在愁城常悲叹， 思念我儿梦中言。 将身且坐离宫院， 不知何日转回还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武姜坐。二宫女同上。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "启国母：颖考叔求见。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "宣他进来。"
        },
        {
          "character": "二宫女",
          "type": "同白",
          "text": "是。 国母有旨，颖考叔进见。"
        },
        {
          "character": "颖考叔",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔上。"
        },
        {
          "character": "颖考叔",
          "type": "念",
          "text": "全凭三寸舌，打动万乘君。 中国京剧戏考 《孝感天》【三本】 5"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "臣颖考叔见驾，国母千岁！"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "赐坐。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "颖考叔坐大边。"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "恭喜国母，贺喜国母！"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "老身喜从何来呀？"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "国母有所不知，那日为臣入朝述职，君侯有意迎接国母还宫，只是有誓在先： 不入黄泉，难以相见。是臣献上一计：掘地及泉，母子相会，以应誓言。君侯 准臣所奏，已到城郊，就请国母起驾。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "哎呀呀！待我谢天谢地！"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "当谢天地。"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "我儿回心转意，皆卿家之功也！"
        },
        {
          "character": "颖考叔",
          "type": "白",
          "text": "此乃主公孝心，臣何功之有？"
        },
        {
          "character": "武姜",
          "type": "白",
          "text": "车辆伺候！"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "梦中言语不虚谎， 果然今日回朝堂。 出得宫门把辇上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫上，武姜上车。四宫女、颖考叔同下。"
        },
        {
          "character": "武姜",
          "type": "西皮摇板",
          "text": "母子重逢喜气扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武姜、车夫同下。"
        }
      ]
    },
    {
