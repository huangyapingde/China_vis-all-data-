{
  "script_id": "02012037",
  "title": "弓砚缘",
  "alias": [
    "红柳村"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "何玉凤",
      "hangdang": "旦"
    },
    {
      "name": "何母",
      "hangdang": "老旦"
    },
    {
      "name": "纪献唐",
      "hangdang": "净"
    }
  ],
  "plot": "前清雍正时，统辖兵马大将军纪献唐，因何杞之女何玉凤文武双全，拟求与其子纪多文联婚。何杞不允，纪\n献唐乃藉词将何杞压入监牢毙命。又派亲信包成功刺杀何玉凤母女，以绝后患。何玉凤母女逃至店中，包成\n功赶至，反被何玉凤打倒。但却不杀，令伊逃生。包成功基于意气，告何往投邓九公，否则纪献唐必继续派\n人行刺。何玉凤母女至红柳村时，适邓九公八十大寿，亲朋庆贺。当年被邓九公打倒之海马周三亦特来报仇。\n邓、周比武时，何玉凤加入将周德胜打倒，并告周德胜之部下，若有动手者，彼即杀周德胜。何玉凤旋与\n邓九公、周德胜说合，彼此和好。何玉凤并拜邓九公为师，从此母女遂移居邓九公之别庄青云山居住云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四文官、四大铠、中军、纪献唐同上。"
        },
        {
          "character": "纪献唐",
          "type": "引子",
          "text": "为天朝一功臣，统雄兵，四海闻名。镇东南七省，文武官谁敢不尊。"
        },
        {
          "character": "纪献唐",
          "type": "念",
          "text": "威震朝纲第一人，文武百官谁不尊。顺者高升得荣禄，逆俺罢职定亡身。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "某，统辖兵马大将军纪献唐。蒙圣恩身授九头狮子黄金印，钦赐上方宝剑。天 下兵将，恁某调遣。若有违误，某就先斩后奏。都府提镇，升迁调补，皆凭某 所为，谁不尊敬。只因同朝，有一何杞。他有一女，名唤何玉凤。生得美貌， 又有一身武艺，可称文武奇能，老夫意欲与我儿多文为婚。可恨那何杞，老夫 命人提亲，他不应允，倒也罢了，他反口出不逊。某怀恨在心，寻机将他参奏， 囚禁监牢丧命。老夫打听何玉凤同她母亲，逃往外乡，恐有后患，必须早做 准备，方保日后无虑。 中军，浓墨伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐写书。〖牌子〗。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "传包成功进见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "包成功进见。"
        },
        {
          "character": "包成功",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包成功上。"
        },
        {
          "character": "包成功",
          "type": "念",
          "text": "将相本无种，男儿当自强。"
        },
        {
          "character": "包成功",
          "type": "白",
          "text": "包成功参见帅爷。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "将军少礼。"
        },
        {
          "character": "包成功",
          "type": "白",
          "text": "谢帅爷。唤末将有何将令。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "这有书信一封，命你在僻静处开看，照书行事，不得有误。"
        },
        {
          "character": "包成功",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "包成功",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "不可泄露机密。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包成功允，下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "中军，传少爷进见。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "少爷进见。"
        },
        {
          "character": "纪多文",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文上。"
        },
        {
          "character": "纪多文",
          "type": "念",
          "text": "父子成名大，将门第一家。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "俺纪多文。父帅传唤，不免进帐参见。 中国京剧戏考 《弓砚缘》【头本】 2 报，纪多文告进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文进。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "纪多文参见父帅。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "我儿少礼，坐下。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "谢坐。唤儿进帐，有何教训？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "为父闻得朝中有人内奏，昨日又有圣旨到来，查看为父本处仓库，兵马钱粮， 恐有异变，为父命你带金珠十万进京，探访消息。若知何人入奏，可将金珠打 点此人，为酧资之用，必须谨慎，后面改装，即刻起程。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "孩儿遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "传排衙家将进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "排衙家将进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四家将自两边分上。"
        },
        {
          "character": "四家将",
          "type": "同白",
          "text": "参见老爷，有何将令？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "站立两旁，听我令下。"
        },
        {
          "character": "纪献唐",
          "type": "唱",
          "text": "宝帐传令鬼神忧， 保定少爷往京投。 一路需要紧防守， 若有差池定斩不留。"
        },
        {
          "character": "纪多文",
          "type": "内西皮导板",
          "text": "奉命解宝威风抖，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手推车自两边分上。纪多文上。"
        },
        {
          "character": "纪多文",
          "type": "唱",
          "text": "改换行装往京投。 辞别父帅跨走兽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文上马。四上手、四家将同领下。"
        },
        {
          "character": "纪多文",
          "type": "唱",
          "text": "打探动静用计谋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文下。"
        },
        {
          "character": "纪献唐",
          "type": "唱",
          "text": "我儿跨马京中走， 老夫心中自揣谋。 三军暂退宝帐口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "纪献唐",
          "type": "唱",
          "text": "早作良谋免后忧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李茂、吕芳、韩勇、郝武同上。"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同念",
          "text": "弟兄招聚在山林，截抢官商过往人。任你英雄难逃走，爱惜忠义与廉明。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "李茂。"
        },
        {
          "character": "吕芳",
          "type": "白",
          "text": "吕芳。"
        },
        {
          "character": "韩勇",
          "type": "白",
          "text": "韩勇。"
        },
        {
          "character": "郝武",
          "type": "白",
          "text": "郝武。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "众家兄弟请了。"
        },
        {
          "character": "吕芳、韩勇、郝武",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "三哥齐聚我等，不知为了何事，大家同到分金厅伺候。"
        },
        {
          "character": "吕芳、韩勇、郝武",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李茂、吕芳、韩勇、郝武同下。"
        },
        {
          "character": "吕芳、韩勇、郝武",
          "type": "stage",
          "text": "中国京剧戏考 《弓砚缘》【头本】 3"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四喽啰、四下手、周德胜同上。"
        },
        {
          "character": "周德胜",
          "type": "点绛唇",
          "text": "镇坐山岗，武艺高强，习鞭法，盖世无双，四海尊仰。"
        },
        {
          "character": "周德胜",
          "type": "念",
          "text": "生成水性天然，练就钢鞭名传。绿林闻俺丧胆，人称海马周三。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "俺，周德胜。天生水性能藏海底，自幼习就一身武艺，久在水旱两路，剪径客 商。绿林称俺海马周三，昔年某劫一宦门镖车，那些保镖之人，被俺杀散，看 看银子到手。不想道旁闪出一年老之人，拦阻与俺，是俺问他姓名，他道姓邓 名振彪，人称九公。俺与他动起手来，被他将俺打倒尘埃，是俺气走天涯，重 习武艺，来在这莽牛山，蒙众家弟兄，见俺武艺高，立我为尊。俺怀此仇数十 年，尚未得报。今日不免对众家弟兄说明，俺独自下山，到红柳村，寻访邓振 彪，好报当年仇恨。 来，请众位英雄。"
        },
        {
          "character": "四下手",
          "type": "同白",
          "text": "有请众位英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李茂、吕芳、韩勇、郝武同上。"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "来也！ 参见三哥。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "众位贤弟少礼。"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "三哥齐聚弟等，有何事议。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "愚兄备得有酒，与众贤弟同饮。"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "弟等奉陪。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "众位贤弟请坐，看酒来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同坐。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "众位贤弟请。"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "三哥请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "三哥为何咳声不止？"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "只因愚兄有一家大大的仇人，常挂在心。此仇未报，故而烦闷。"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "但不知三哥仇人，是哪一家？"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "众位要问，将酒撤去，请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同起，至外场。"
        },
        {
          "character": "周德胜",
          "type": "stage",
          "text": "中国京剧戏考 《弓砚缘》【头本】 4"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "三哥请讲。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "愚兄当年劫一宦家镖银，那些保镖之人，被俺杀散。不想来了一个年老之人， 名唤邓振彪，人称九公。与俺争斗起来，愚兄被那老儿打倒，是我气走天涯， 访问此人。久居荏萍县红柳村，此仇怀恨数十余年，不曾得报。俺今日与众位 说明，俺要独自下山，前去报仇。山寨之事，交付众位掌管。"
        },
        {
          "character": "李茂、吕芳、韩勇、郝武",
          "type": "同白",
          "text": "三哥既有此仇，弟等也要一同下山帮助。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "此事要俺独自会他，才算得英雄好汉。"
        },
        {
          "character": "李茂",
          "type": "白",
          "text": "三哥既要独自会会此人，弟等同去观看，见机行事如何。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "这也使得。来，看衣更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德胜脱衣。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "喽啰们，你等小心把守山寨，俺此去多则一月，少则十日就回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "喽啰同允。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "众喽兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手同允。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "随俺下山。带马。"
        },
        {
          "character": "周德胜",
          "type": "唱",
          "text": "你等山寨紧防守， 俺要前去报冤仇。 喽兵引路下山口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、李茂、吕芳、韩勇、郝武同下。"
        },
        {
          "character": "四喽啰",
          "type": "同白",
          "text": "送寨主。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "免。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "周德胜",
          "type": "唱",
          "text": "仇人相逢岂容留。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周德胜下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤上，趟马。"
        },
        {
          "character": "何玉凤",
          "type": "唱",
          "text": "纪贼害父遭毒手， 不报冤仇怎罢休。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "我，何玉凤。爹爹何杞，在朝供职，自幼习就一身武艺。可恨纪献唐老贼，为 与他子求亲，我父不允。纪贼怀恨，谋害我父，囚禁监牢丧命。奴本当杀贼与 父报仇，奈因我母年迈，既无所靠，又恐连累老母不便，只得暂时忍耐。为此 我将玉字拆为十三，改名十三妹。保定母亲，远逃他乡。但愿老母有安身之所， 再来寻机杀贼报仇。今日行了一程，看此时天色已晚。在此等候母亲车辆到 来，一同趱路便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "车夫、何母同上。"
        },
        {
          "character": "何母",
          "type": "唱",
          "text": "恼恨奸贼成仇寇， 无故害人一命休。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "孩儿参见母亲。"
        },
        {
          "character": "何母",
          "type": "白",
