          "character": "邓振彪",
          "type": "白",
          "text": "不知有何厚礼？ 中国京剧戏考 《弓砚缘》【头本】 9"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "俺备脂粉钗裙。"
        },
        {
          "character": "邓振彪",
          "type": "白",
          "text": "这要它何用？"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "俺今与你较量，你若不能胜俺，你就擦脂抹粉，穿戴钗裙，扮作女子，与俺纳 头谢罪。还要你备银三千两，算还俺当年劫银之数，方能饶恕与你。"
        },
        {
          "character": "邓振彪",
          "type": "白",
          "text": "老汉好言相劝，你执意不听，家院过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子允。"
        },
        {
          "character": "邓振彪",
          "type": "白",
          "text": "即请众位亲友到庄外，看我二人比较，不许帮助。快去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子允，下。何玉凤下。"
        },
        {
          "character": "邓振彪",
          "type": "白",
          "text": "周德胜，庄外与你见个高下。"
        },
        {
          "character": "周德胜",
          "type": "白",
          "text": "一同出庄，请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓振彪、周德胜同下。"
        }
