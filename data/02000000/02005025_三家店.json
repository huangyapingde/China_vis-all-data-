{
  "script_id": "02005025",
  "title": "三家店",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "秦琼",
      "hangdang": "老生"
    },
    {
      "name": "罗周",
      "hangdang": "小生"
    },
    {
      "name": "史大奈",
      "hangdang": "净"
    }
  ],
  "plot": "秦琼由罗周押解赴登州，夜宿三家店。瓦岗寨上程咬金、徐勣等特派史大奈前往搭救。当押解官罗周发觉秦\n琼与罗成关系时，遂与史大奈共同商议营救秦琼办法，遂由罗周代秦琼给瓦岗寨上魏徵、徐勣等写信，约定\n八月十五日一同往登州攻打杨林，并由罗周等里应外合。",
  "notes": "本剧之后段，即《观阵》与《打登州》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "史大奈上。"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "光武岭上军器摆， 豪杰一人下山来。 弟兄结拜瓦岗寨， 一个个齐成栋梁材。 秦二哥不入天蓬寨， 徐三哥八卦巧安排。 搭救二哥上山寨， 差咱一人下山来。 扬长大步往前迈， 神机妙算难解开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史大奈下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "罗周、秦琼同上。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "历城县登程往前走， 年迈高堂泪双流。 母子生离难忍受， 又无兄弟奉珍馐。 养儿本是娘身肉， 长亭别母两忧愁， 红日滚滚西山后， 儿行千里母担忧。 黄土岗上实难走， 尊一声差官把店投。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "店家走来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家上。"
        },
        {
          "character": "店家",
          "type": "念",
          "text": "饭店实难开，锅内起青苔。灶里着上一把火，叽哩嘎啦跳出一个客官来！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "呀，原来是二位醋爷。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "将爷。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "酱醋俱是一样。小老儿迎接差官老爷，请进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家、秦琼、罗周同进店。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "请坐，办饭。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "不用，只要明灯一盏，热茶一壶，不许闲人罗唣。去吧！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史大奈上。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "店家，店家！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哪一个囚囊的这样凶头凶脑？ 哎呀，打鬼，打鬼！"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "咱是个人。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "你是个神，为何不到庙里去？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "嗐，咱是生成的雄脸。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，你是生成的哝脸。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "雄脸。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，雄脸。 唔，且慢。人人说道，有下巴的就是个人，没有下巴的就是个鬼。我到底信不 过，待我摸他一摸。 喂，客官！你是两个人，还是一个？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "咱是一个人。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "后面还有一个呢！"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家顶史大奈下巴，笑。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是个人，是个人。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "这作什么？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "你老人家不晓得，人人说道，有下巴的就是个人，没下巴就是个鬼。你老人家 有下巴，是个人。我且问你，你老人家到我店中有何事情？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "老子到店中来安歇的。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "客官儿子，店中歇不得了。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "怎样歇不得？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "杨千岁皇犯在此，差官老爷吩咐不许闲杂人罗唣。你老人家前面去歇息去吧！"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "店家，有道是一品的官，二品的客。他歇得，咱也歇得。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "实实难歇。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "又道歇店歇店。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "也罢，随便安歇吧。请进，请进！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼见史大奈。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "吓，前面走的敢是史……"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "住了，我与你人生面不熟，使什么？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "你老人家听错了，他使我店家的哦。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "好一个店家，说话很在理。我看你这个汉子面黄饥瘦，敢则是有病？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "正是有病。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "我这里有膏药两张，丸药一付，到了三更时分，内七个，外八个。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "什么为引？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "三把黄土，紧紧记在心下。店家在哪里安宿？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "慢些，我只道你是兽医，原来是个内科。我也有个病。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "什么病？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "古里古怪的病。吃饱了就不想饭吃，睡了觉就不想睡，就是这个病。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "你站过来。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "作什么？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "取出钢刀一把。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "取出钢刀作什么？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "将你这么一刀，把这个肚子破开，将你的肠子扒将出来，放在清水河中，这么 洗上几洗，洒在你的肚内外，用针线缝将起来就好了。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "那个人可就没有命了。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "咱只要治病，不管你的命。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "罢罢罢，杀牛的打一下杀猪的——"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "此话怎讲？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "饶命喝汤。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "哪里安宿？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "西楼安宿。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "店家，到了三更时分，没有响动便罢；若有响动，你切不要大呼小叫。你若大 呼小叫，老子就是这么一刀！"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哎呀！你老人家请安歇吧！"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史大奈下。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "店家走来。"
        },
        {
          "character": "店家",
          "type": "念",
          "text": "忽听差家叫，慌忙就来到。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "叫小的哪厢使用？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "我对你说，这是杨千岁的皇犯，路途之上，这个就是我的关系；若在你的店中 走了，就是你的关系。还是要用下一个计才好。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "啊，你老人家叫小的放上一个屁。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "用下一个计。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦，用下一个计……小的有一个计。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "什么计？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "取下门板一块，铁钉四个，将他扯直放在板上，用钉钉在门板上，好不好？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "人岂不死了？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "只要他不走，哪还管他死？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "这个计不好。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "啊，这个不好。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "不好。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "唔，还有一个计。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "还有什么计？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "叫做关门夜壶计。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "怎么叫做关门夜壶计？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我把这个囚囊的一关关在这个厢房内，门外放夜壶一把。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "这叫做什么计？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "就叫做关门夜壶计。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "那人岂不是跑掉了？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "他若是有良心的，就会送夜壶来还我。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "吓，这个计不好。还要想一个妙计。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哎，你老人家还要叫我放上一个屁。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "用上一个计。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "啊啊啊，小的有一个计。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "有何妙计？快快讲来。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "凤凰单展翅的计。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "怎么叫凤凰单展翅？"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "我把这个囚囊的秦琼连手带脚吊将起来，难道还会跑了不成？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "唔，此计甚妙。快快办来。"
        },
        {
          "character": "店家",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "店家将秦琼吊起。"
        },
        {
          "character": "罗周",
          "type": "唱",
          "text": "凤凰单翅上了吊， 料你插翅也难逃。"
        },
        {
          "character": "秦琼",
          "type": "二黄慢板",
          "text": "三家店内上了绳， 吊得豪杰两膀疼。 我也曾走过两京十三省， 未曾受过这苦情。 自幼儿在公衙办过事， 杀得人来救得人。 马渴思饮长江水， 人到难中想宾朋。 猛然想起瓦岗寨， 瓦岗寨上众弟兄： 头一个就是魏老道， 第二山东徐茂功； 王伯当，单雄信， 还有寨主程咬金。 罗士宣，罗士信， 金甲、童环二弟兄。 众家兄弟都去想一想， 又想八弟小罗成。 眼前若有罗士信， 要把登州一扫平。"
        },
        {
          "character": "罗周",
          "type": "唱",
          "text": "听罢言来察其情， 罗成是你什么人？"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "尊一声差爷不知情， 罗成是我姑表亲。"
        },
        {
          "character": "罗周",
          "type": "唱",
          "text": "听罢言来吃一惊， 自己反吊自己人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗周将秦琼解下。"
        },
        {
          "character": "罗周",
          "type": "唱",
          "text": "凤凰单翅下了吊， 双膝跪在地埃尘。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "一见差爷跪埃尘， 倒把秦琼解不明。 走上前来轻声问。 尊一声差官爷你是何人？"
        },
        {
          "character": "罗周",
          "type": "唱",
          "text": "尊一声二哥不知情， 姑表罗周是我名。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "听说来了罗门后， 不由豪杰怒满怀。 开言就把罗周骂， 骂一声奴才大不该。 明知老贼苦害我， 为什么绳捆索绑到此来？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "小弟不知。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "你不知来我不怪， 尊一声贤弟请起来。 杨林结仇如山海， 你把为兄怎安排？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "二哥但放宽心，明日再作道理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史大奈上。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "看天色将近三更时分，正好下手。内七个，外八个，里面可是秦？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "外面敢莫是史贤弟？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "里面敢莫是秦二哥？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "二哥，走，走，走！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "走不得！"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "怎么走不得？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "现有罗贤弟在此。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "只有一个罗贤弟，哪里又有什么罗贤弟？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "表弟罗周。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "待咱进去杀！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "杀不得！"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "怎么杀不得？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "杀了贤弟，不甚要紧，岂不连累与我？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "现在哪里？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "现在上房。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "待咱前去与他见个礼儿，可使得？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "使得。 罗贤弟，史贤弟与你见礼，你却要小心些。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "晓得。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "罗贤弟在哪里？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "史大哥在哪里？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "咱这里有礼。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "有礼相迎。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "呔，看刀！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "呔，这却为何？"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "咱试试他的胆量。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "他乃将门之子，胆量是好的。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "罗老爷，我且问你，你与二哥还是内亲外亲？"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "是内亲。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "既是内亲，二哥有难，就该搭救，放了他才是。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "小弟实有此心，奈二哥说道又恐连累小弟。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "贤弟还要用下一计方好。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "小弟倒有一计。只要秦表兄修下书信一封，命人送上瓦岗，搬请众家兄弟来到 登州，搭救二哥，岂不是好？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "怎奈无有带书之人，也是枉然。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "咱带。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "如此看文房四宝过来。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "听罢言来心上喜， 猛虎离山抖雄威。 好一个神机妙算徐三弟， 算人生不差半毫厘。 三人同宿店房里， 表弟罗周请代笔。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史大奈力劈罗周，罗周惊，走开。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "写，写，写！"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "这却为何？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "他与你玩呢，只管放心。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "上写拜上多拜上， 拜上瓦岗众兄弟。 头一拜就是魏老道， 二拜沔阳徐三弟； 王伯当，单雄信， 又拜寨主程咬金。 众家兄弟都拜到， 再拜八弟小罗成。 愚兄解粮登州去， 辕门高挂免战旂。 杨林不解其中意， 要与八弟比高低。 悔不该辕门来发笑， 悔不该帐前把印追。 龙牌来到历城县， 拿我秦琼比高低。 弟兄们若念结拜访义， 早发人马到登州； 弟兄们若还不念结拜情， 稳坐瓦岗休要提。 一封书信忙修起， 再写虎男十贤弟。 三人跌跪店房里，"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "愚兄把搬兵大事交与你。"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "用手儿接过书和信，"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "二哥！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟！"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "搬兵大事咱担承。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "罗老爷！"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "史大哥！"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "上前来受咱一腿，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史大奈打罗周，罗周反将史大奈打倒。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "哦，好的，好的。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "史大哥休怪。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "不怪，不怪！"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "史大哥有何吩咐小弟？"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "三家店将二哥交与你。 咱弟兄们结拜有三十六个， 内有一个徐三哥。 他的八卦威名真不错， 昨晚在灯前卜下一课。 差豪杰下山来杀……"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "杀什么？"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "杀了你搭救咱的二哥， 还念你是亲朋将你饶过。 路途上若再有差错， 那时节撞着咱休想命活。 江湖上耍朴刀不才是我， 罗贤弟耍长枪亚赛阎罗。 弟兄们中秋八月来到登州放火， 那时节难为你杀他娘的一个里应外合。 你二人一个个随定了我， 又只见店房门前后上锁。 恨不得用朴刀将门劈破，"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "使不得。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "怎么就使不得？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "恐怕店家走漏了风声。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "不错。"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "又恐怕天明了惹下风波。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "罗老爷，秦二哥。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "贤弟。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "史大哥。"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "我这里拍一掌越墙而过， 且听他两姑表说些什么。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "罗贤弟。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "秦二哥。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "史大奈贤弟，乃是瓦岗寨上第一条好汉。"
        },
        {
          "character": "罗周",
          "type": "白",
          "text": "果然算得是第一条好汉。"
        },
        {
          "character": "史大奈",
          "type": "白",
          "text": "着，着，着！"
        },
        {
          "character": "史大奈",
          "type": "唱",
          "text": "听二人在里面夸奖于我， 夸奖俺史大奈乃是第一个好汉哥哥。 迈开大步往前走， 咱要学一个矮脚虎逃上山坡。 瓦岗寨搬动了那众家兄和弟， 搭救咱的秦二哥。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史大奈下。"
        },
        {
          "character": "秦琼",
          "type": "唱",
          "text": "尊一声罗贤弟听我说， 我和你在此且等着。 史贤弟到瓦岗搬动人和马， 那时节到登州杀一个里应外合。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、罗周同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}