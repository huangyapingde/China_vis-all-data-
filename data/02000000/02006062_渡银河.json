{
  "script_id": "02006062",
  "title": "渡银河",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "杨玉环",
      "hangdang": "旦"
    },
    {
      "name": "李隆基",
      "hangdang": "老生"
    }
  ],
  "plot": "七月七日，天上牛郎、织女相会。适见下界唐明皇与杨贵妃，正设香案，向牛郎、织女乞巧。并鉴于牛、女\n之年年相会，两人密誓盟约，在天愿为比翼鸟，在地愿为连理枝，请牛、女作证云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "织女上。"
        },
        {
          "character": "织女",
          "type": "浪淘沙",
          "text": "云护玉梭儿，巧织机丝， 天宫原不管相思。 报道今宵七夕， 忽忆年时。"
        },
        {
          "character": "织女",
          "type": "念",
          "text": "纤云弄巧，飞星传恨，银汉秋光暗度。金风玉露一相逢，便胜却人间无数。 柔肠似水，佳期如梦，遥指鹊桥前路。两情若是久长时，又岂在朝朝暮暮。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "我乃天孙织女是也。蒙上帝谕旨，与牛郎结为天上夫妇。年年七夕，渡河相见。 今乃下界天宝十载，七月七夕。你看银河无浪，喜鹊将填，不免暂撤机丝， 整妆而待。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "织女梳妆毕。"
        },
        {
          "character": "织女",
          "type": "山桃花",
          "text": "俺这里乍跑锦字， 暂驾香辎。 趁碧落无云滞，新凉暮飔， 踹上这桥影参差，俯映着河光净止。 更喜杀新月纤，花露湿， 低绕喜鹊双飞翅也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛郎上。"
        },
        {
          "character": "牛郎",
          "type": "山桃花",
          "text": "只觉得银汉秋生别样姿。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "天孙一向安否？"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "仙郎别来无恙。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "我与你天上良缘，一年一度，皆赖上帝恩赐也。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "便是。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "你看星河之下，香烟缭绕，云雾腾空，却是何处？"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "是唐天子与杨妃在长生殿乞巧。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "天孙，看她们一片诚心，和你到彼一望。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "牛郎、织女",
          "type": "同山桃花",
          "text": "天上留佳会，年年在斯。 却笑他人世，情怨顷刻时。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "织女、牛郎同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "设鹊桥、百鸟、玩艺、月宫、云片、彩切。杨玉环上。"
        },
        {
          "character": "杨玉环",
          "type": "二郎神",
          "text": "宫廷金炉篆霭，烛光掩映， 米大蜘蛛，喜冰盘种荳，花枝招展银瓶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众宫女同设香案。杨玉环拈香。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "妾身杨玉环，虔诚心香，拜告双星，伏乞鉴佑。"
        },
        {
          "character": "杨玉环",
          "type": "二郎神",
          "text": "愿钗盒情缘久订，莫使做秋风冷扇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众内监执扇伞同上，李隆基上。"
        },
        {
          "character": "李隆基",
          "type": "二郎神",
          "text": "好一片皓月当天。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "妾身接驾。"
        },
        {
          "character": "李隆基",
          "type": "白",
          "text": "梓童平身。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "今因七夕佳期，敬排香果，特设天孙乞巧。"
        },
        {
          "character": "李隆基",
          "type": "白",
          "text": "却是爱卿至诚。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "惶恐。"
        },
        {
          "character": "李隆基",
          "type": "白",
          "text": "唉，叹双星一年一度，岂无离恨。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "陛下言及双星别恨，使妾凄然，只可惜人间不知天上的事。"
        },
        {
          "character": "杨玉环",
          "type": "二郎神",
          "text": "如打听，决疑了相思成病。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨玉环哭。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "妾思牛郎织女，虽则七夕一度，却是地久天长。只恐陛下与妾的恩情，不能够 似他们长远。"
        },
        {
          "character": "李隆基",
          "type": "白",
          "text": "同心合意，不离龙床，时刻之思，心可知矣。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "臣妾受恩深重，今夜有句话儿。"
        },
        {
          "character": "李隆基",
          "type": "白",
          "text": "讲来。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "妾蒙宠眷，六宫无比，只怕日久恩疏，难免白首之叹。"
        },
        {
          "character": "杨玉环",
          "type": "二郎神",
          "text": "提起便心痛，念寒微侍夜廷， 更依傍辇多荣幸。 瞬息间怕花谢春去际，实难凭， 论恩情，若得个久长时，死也幸。 若得个到头时，死也瞑， 抵多少平阳歌舞，恩移爱更， 长门孤寂寞，暗涕零， 断肠枉泣红颜命。"
        },
        {
          "character": "李隆基",
          "type": "白",
          "text": "孤与你好似比目之鱼，爱妃何必多虑。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "既蒙陛下如此情浓，趁此双星之下，乞赐盟约，一见始终。"
        },
        {
          "character": "李隆基",
          "type": "白",
          "text": "如此香案伺候。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众内监、众宫女同设罢。〖吹打〗。牛郎、织女同上，同上桌子。百鸟彩切托明月。"
        },
        {
          "character": "李隆基、杨玉环",
          "type": "同猫儿坠",
          "text": "香肩斜靠，携手下阶行， 一片因何当殿横，罗衣陡觉夜凉生。"
        },
        {
          "character": "杨玉环",
          "type": "念",
          "text": "愿得你我福寿齐，"
        },
        {
          "character": "李隆基",
          "type": "念",
          "text": "在地同为连理枝。"
        },
        {
          "character": "杨玉环",
          "type": "念",
          "text": "天长地久情无尽，"
        },
        {
          "character": "李隆基",
          "type": "念",
          "text": "此誓绵绵永佳期。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李隆基、杨玉环同拜，同起。"
        },
        {
          "character": "杨玉环",
          "type": "白",
          "text": "妾感陛下今夕之盟，死生守之矣。"
        },
        {
          "character": "李隆基",
          "type": "猫儿坠",
          "text": "喜今夕同把心结，"
        },
        {
          "character": "杨玉环",
          "type": "猫儿坠",
          "text": "问今夜有谁折证？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众內监、众宫女引李隆基、杨玉环同下。"
        },
        {
          "character": "牛郎",
          "type": "猫儿坠",
          "text": "只见他盟誓密，此拜祷孜孜， 两情洽无二意，同一词。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "天孙，你看唐天子与贵妃，好不恩爱也。"
        },
        {
          "character": "牛郎",
          "type": "猫儿坠",
          "text": "俏相偎倚着香肩没些缝儿。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "我与你既缔天上良缘，当做情场管领，况二人向我等说誓，须当保护。"
        },
        {
          "character": "牛郎",
          "type": "猫儿坠",
          "text": "见了他恋比翼慕并枝， 愿生生世世，情真至也， 合令他长作人间风月司。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "只是他二人劫难将至，免不得生离死别，若果后来不能背今盟，决当为之管合。"
        },
        {
          "character": "牛郎",
          "type": "白",
          "text": "天孙之言有理。你看夜色将阑，且回斗牛宫去者。"
        },
        {
          "character": "织女",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "牛郎、织女",
          "type": "同猫儿坠",
          "text": "天上留佳会， 年年在斯。 却笑他人世， 情缘顷刻时。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "牛郎、织女相扶下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}