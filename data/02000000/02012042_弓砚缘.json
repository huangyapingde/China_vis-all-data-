{
  "script_id": "02012042",
  "title": "弓砚缘",
  "alias": [
    "调纪进京"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "纪献唐",
      "hangdang": "净"
    },
    {
      "name": "纪多文",
      "hangdang": "武生"
    }
  ],
  "plot": "总督李尉奉圣旨调纪献唐晋京，纪献唐知凶多吉少，托故迟不晋京。雍正又派定南王赵惠前来，催纪献唐速\n速晋京。纪献唐知圣旨不可违抗，遂一同启行云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李尉上。"
        },
        {
          "character": "李尉",
          "type": "引子",
          "text": "钦奉王命，怎敢辞，昼夜辛勤。"
        },
        {
          "character": "李尉",
          "type": "念",
          "text": "自从离都城，昼夜不稍停。到此留驿馆，思想不安宁。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "下官，李尉。奉旨前来宣诏纪大将军回朝，开读已毕，他将我留至驿馆，言道 候他料理军务，一同进京。一连数日，并无动静，又命副将梅高看管与我，一 不准交往官民，二不准私自求见，教我十分惊恐。我不免背了副将梅高，去到 辕门，探其动静。 来，带马！"
        },
        {
          "character": "李尉",
          "type": "西皮原板",
          "text": "我主爷有道君万民欢庆，⑴ 普天下仰圣恩共享太平。 都只为纪献堂镇守七省， 自专权又卖法目无朝廷。 奉圣命到此间调他回京， 他将我留驿馆见面难能。 数日间未见他有何动静， 莫非是那老儿解透其情？ 教人来你与我前把路引， 到辕门且看他怎样施行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李尉下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四家将、中军引纪献唐同上。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "某，纪献唐。前日李尉奉圣旨到来，调老夫回京，是我将他留在驿馆，候吾儿 回来再作道理。 中军，伺候了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。纪多文上。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "参见父帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐急拉纪多文同下。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "且住！少爷回来，被元帅扯至后面，其中必有原故，不免在辕门等候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。李尉上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "烦劳通禀：押旨官求见大将军。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "且慢。大将军吩咐下来，无令不能得见。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "哦，待我闯进辕门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军三冲。梅高上，梅高扯李尉同下。"
        },
        {
          "character": "李尉",
          "type": "stage",
          "text": "中国京剧戏考 《弓砚缘》【六本】 2"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐拉纪多文同上，同坐。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "父帅为何这等模样？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "哎呀，儿吓。只因圣上命李尉调为父进京，追回尚方宝剑及九头狮子印，此番 进京凶多吉少，故而叫吾儿回来商议此事。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "那李尉今在何处？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "我将他留在驿馆，由梅高看守。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "孩儿倒有一计：今当大操之期，教那李尉随定爹爹去到教场观操。他观我营将 士威武，然后爹爹启奏一本，言道军务事大，难离任署。万岁不论命哪部大臣 前来代替署任，方可回京。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "此计甚好，照计而行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喧哗声〗。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "何人喧哗？前去问来。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "辕门外何人喧哗？"
        },
        {
          "character": "中军",
          "type": "内白",
          "text": "李尉擅闯辕门。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "哦，胆大李尉擅闯辕门。吩咐击鼓升帐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。中军、李尉同上。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "李尉到此，教他报门而进。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "嘚，李尉！大将军有令：教你报门而进，你要仔细了，打点了！"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "李尉告进。 参见大将军。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "唗！胆大李尉，擅闯辕门。 中军，推去斩了！"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "大将军！想我李尉乃是奉旨前来，宣诏大将军回京，下官开读已毕，大将军就 该遵旨进京才是，怎么你不遵诏进京，反将我留在驿馆，又命副将梅高看管与 我，一不准交往官民，二不准私自求见，一连数日，不见动静？有道是食君之 禄，当报君恩，为此特到辕门听候你的议论，怎道我擅闯辕门，是何意也？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "你钦命事大，难道不知我军令如山？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李尉冷笑。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "大将军。虽然你的军令如山，下官我是奉旨的官员，钦命在身，并非是大将军 手下的兵丁。将士犯令，可以斩首，你若将我斩首，下官倒也不怕，死于九泉， 也是为国尽忠。似你这等行为，分明依权仗势欺压于我，藐视当今，后来自 有评论也。"
        },
        {
          "character": "李尉",
          "type": "唱",
          "text": "我今前来奉君命， 欺我如同欺当今。"
        },
        {
          "character": "纪献唐",
          "type": "唱",
          "text": "张仪之舌实可敬， 看他不是等闲人。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "此乃梅高之过。 中军，传梅高进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "梅高进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "梅高上。"
        },
        {
          "character": "梅高",
          "type": "白",
          "text": "参见大将军。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "唗！胆大梅高，老夫无令，竟放李尉闯进辕门。 中军，斩了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军斩梅高。李尉惊坐。梅高下。"
        },
        {
          "character": "纪献唐",
          "type": "唱",
          "text": "口传军令如雷震， 剑下头落血染尘。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "这是梅高之过，不与大人相干。 中军尸首搭下去。 李大人请坐。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "中军传我将令：大小三军，五营四哨，齐下教场操演。 中国京剧戏考 《弓砚缘》【六本】 3"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "大小三军，五营四哨，齐下教场操演。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "李大人随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐、李尉、纪多文、中军同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四文堂、四下手引赵惠同上。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "本番，定南王赵惠。只因纪献唐在外专权卖法，圣上命李尉奉旨前行调他回京， 去了许久，不见复命，为此圣上又命本番前去摘他的剑印。 军士们，一路之上不许交头接耳，到彼处看我眼色行事。趱行者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "纪多文上，起霸。"
        },
        {
          "character": "纪多文",
          "type": "念",
          "text": "少小英雄将，威名振四方。斩将如瓜滚，四海把名扬。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "俺，纪多文。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将、四长枪手、四藤牌手、四撩刀手、四火炮手同上。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "众位将军请了。今当大操之期，同到教场。请！"
        },
        {
          "character": "四将",
          "type": "同将",
          "text": "请！"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "纪献唐",
          "type": "内西皮导板",
          "text": "自古军令如山倒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂同上，同斜门。李尉上，纪献唐上。"
        },
        {
          "character": "纪献唐",
          "type": "西皮流水板",
          "text": "层层队伍似涌潮。 大权在握难提调， 将帅用兵鬼神号。 本当不遵皇王诏， 哪一个大胆犯律条？ 来在教场下虎豹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐下马，上高台。"
        },
        {
          "character": "纪献唐",
          "type": "西皮流水板",
          "text": "刀枪明亮放光豪。 传齐队伍听令号，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文、四将、四长枪手、四撩刀手、四藤牌手、四火炮手同上。"
        },
        {
          "character": "纪献唐",
          "type": "西皮流水板",
          "text": "大小儿郎听根苗： 今日若错乱了， 定斩人头不容饶。 各归队伍休罗唣，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将、四长枪手、四撩刀手、四藤牌手、四火炮手自两边分下。"
        },
        {
          "character": "纪献唐",
          "type": "西皮流水板",
          "text": "好似雀鸟把凤朝。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "儿呀，见过李大人。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "李大人。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "中军，长枪手开操。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "长枪手开操。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四长枪手同上，同操演，同下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "藤牌手开操。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "藤牌手开操。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四藤牌手同上，同操演，同下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "撩刀手开操。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "撩刀手开操。 中国京剧戏考 《弓砚缘》【六本】 4"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四撩刀手同上，同操演，同下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "火炮手开操。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "火炮手开操。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四火炮手同上，同操演，同下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "合操上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四长枪手、四撩刀手、四藤牌手、四火炮手同上，同操演，同下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "李大人，可曾看见老夫兵丁将士？"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "甚是雄壮整齐。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "带马回营。"
        },
        {
          "character": "纪献唐",
          "type": "唱",
          "text": "好似蛟龙归海岛， 狂风大浪一旦消。 永管千里谁敢傲，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐下马，进帐。"
        },
        {
          "character": "纪献唐",
          "type": "唱",
          "text": "忙修本章奏当朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪献唐写本。〖牌子〗。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "李大人与我转奏。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "大将军若不遵诏进京，恐圣上龙心不悦。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "本章上写的明白，圣上不论命哪部大臣前来代替，方可回都。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "大将军只管进京，圣上自有安排。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "老夫若是去后，哪路将官若是谋反，管叫你吃罪不起。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "哦，是。"
        },
        {
          "character": "赵惠",
          "type": "内白",
          "text": "定南王到。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "李大人帐外伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李尉下。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "有请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵惠上。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "不知王爷驾到，未曾远迎，面前恕罪。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "岂敢。本番来得卤莽，大将军海涵。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "前者圣上命总督李尉，调大将军回朝，为何不见？他在何处？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "现在帐外。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "传来一见。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "来，有请李大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李尉上。"
        },
        {
          "character": "李尉",
          "type": "白",
          "text": "参见王爷。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "唗！胆大李尉，圣上命你宣诏大将军回朝，为何这等迟慢？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "此乃我迟慢，不与他相干。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "哦，原来如此。大将军是怎样安排？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "军务事大，难离任署。不论哪部大臣前来代替，方可回都。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "闻得大将军法令森严，可将统领大将传来本爵一见。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "传众将进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将同上。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "见过王爷。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "圣旨下跪。宣读诏曰：只因大将军纪献唐，镇守东南七省，受尽风霜辛苦，寡 人思念功臣，况有军情大事要与纪卿面议，因此命总督李尉，定南王赵惠先后 前往，旨意到彼，即日来京。属下兵丁将士，有标归标，有镇归镇，各自分散。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "请过圣旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四将、李尉同下。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "大将军几时回京？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "容我父子一别。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "容你父子一别。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵惠下。"
        },
        {
          "character": "赵惠",
          "type": "stage",
          "text": "中国京剧戏考 《弓砚缘》【六本】 5"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "我儿快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文上。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "爹爹为何惊惶？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "儿吓。定南王赵惠奉旨前来，调为父进京，追回尚方宝剑，九头狮子印。此番 进京，性命难保。"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "孩儿有一计在此。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "纪多文",
          "type": "白",
          "text": "待孩儿去到番邦，借来番兵番将，去到京都搭救爹爹便了。"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "此计甚好，照计而行。"
        },
        {
          "character": "纪献唐",
          "type": "念",
          "text": "蛟龙焉失水，"
        },
        {
          "character": "纪多文",
          "type": "念",
          "text": "猛虎怕离山！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "纪多文下。赵惠上。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "你父子可曾分别？"
        },
        {
          "character": "纪献唐",
          "type": "白",
          "text": "我父子已经分别，随王爷进京。"
        },
        {
          "character": "赵惠",
          "type": "白",
          "text": "带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵惠、纪献唐同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "赵惠",
          "type": "stage",
          "text": "—————————— ⑴ 本段或唱〖西皮慢板〗。唱时李尉扯四门。"
        }
      ]
    }
  ]
}