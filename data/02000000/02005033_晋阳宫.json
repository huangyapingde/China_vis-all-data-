{
  "script_id": "02005033",
  "title": "晋阳宫",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李渊",
      "hangdang": "老生"
    },
    {
      "name": "张妃",
      "hangdang": "旦"
    },
    {
      "name": "尹妃",
      "hangdang": "旦"
    },
    {
      "name": "裴寂",
      "hangdang": "丑"
    }
  ],
  "plot": "隋炀帝不修国政，专事巡幸。命唐公李渊（即唐高祖）为晋阳（即山西太原府隋之东都）留守，率领宫眷，\n驻跸江都（小说本载炀帝至扬州看琼花即是），乐而忘返。晋阳宫内，只有张、尹二妃，寂寞良宵，不无觖\n望。外间又喧传盗贼烽起，路途阻隔，恐无回銮之日。二妃欲自为计，与司理监裴寂定计，邀唐公入宫，醉\n以酒，扶睡二妃床榻。候酒醒时，说唐公起兵，以图帝业。唐公为二妃所挟持，不得不从。于是移檄远近，\n征集兵马，劖除隋乱，开一统之基焉。",
  "notes": "按正史，炀帝荒淫，四方英雄窃据。烽烟告警，已无一片干净土。唐公李渊，留守晋阳。其子李世民（即唐\n太宗）欲兴义师，举大事，久不敢言。乃与宫监裴寂密商，私以宫人侍李渊。李渊恐及祸，遂从李世民计划，\n起兵于晋阳。所以李渊谓李世民，有“破家亡身由汝，化家为国亦由汝”之言。可知唐之开基立业，实李\n世民之功也。小说本谓张、尹二妃，保全身命起见，不顾荐枕之羞，怂恿而成。诚小说之趣谈也。此剧本亦\n系依此编排。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "裴寂上。"
        },
        {
          "character": "裴寂",
          "type": "引子",
          "text": "怀抱剑，手扶琴，巡察宫门。"
        },
        {
          "character": "裴寂",
          "type": "念",
          "text": "霸王力举千斤鼎，后来乌江自刎身。韩信未央一命倾，轰轰烈烈鬼神惊。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "咱家、司理监裴寂。只因主子，久恋江都。撇下二位娘娘，好不冷淡，屡问炀 帝踪迹。今朝命咱巡视宫门，只见两个道人，非癫非痴，丢下柬帖一道，化阵 清风而去，好生奇怪。不免进宫，报与二位娘娘得知。正是："
        },
        {
          "character": "裴寂",
          "type": "念",
          "text": "宫中粉黛有三千，谁能常伴君王眠。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴寂下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张妃、尹妃同上。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同西皮摇板",
          "text": "俏东君薄情隋炀帝， 撇下我姊妹受苦悽。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴寂上。"
        },
        {
          "character": "裴寂",
          "type": "西皮摇板",
          "text": "可叹烟尘遍地起， 皆因我主酒色迷。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "二位娘娘千岁！"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "圣驾几时回来？"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "尚无归期。奴婢今日巡视宫门，见有两个道人非仙非怪，临行之时丢下柬帖一 道，不知何故。二位娘娘请看。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "呈上来。 中国京剧戏考 《晋阳宫》【二本】 2"
        },
        {
          "character": "张妃",
          "type": "白",
          "text": "御妹请看。"
        },
        {
          "character": "尹妃",
          "type": "白",
          "text": "一同看来。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同念",
          "text": "黄河澄清别有天，隋室社稷不周全。神尧高祖木结子，一统山河灵归渊。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "这诗句怎么解？"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "据奴婢看来，我朝江山不久了。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "哦，圣上可有回来之日否？"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "奴婢亦明阴阳，圣上有去无回。目下真主已出，早晚起兵矣。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "真主却是何人？"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "就是唐公李渊。况这柬帖上后两句亦明现也。"
        },
        {
          "character": "张妃",
          "type": "白",
          "text": "御妹。"
        },
        {
          "character": "尹妃",
          "type": "白",
          "text": "皇姊。"
        },
        {
          "character": "张妃",
          "type": "白",
          "text": "李渊雄居太原，将来大事必成。"
        },
        {
          "character": "尹妃",
          "type": "白",
          "text": "便是圣上宠幸萧后将你我冷淡，不如扶李渊登位，以图你我后路终身富贵如何？"
        },
        {
          "character": "张妃",
          "type": "白",
          "text": "御妹所言极是。 裴卿有何计策，玉成其事？"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "这有何难。娘娘即出旨召李渊进宫，命奴婢陪宴。将他灌醉，扶上龙床。娘娘 看他果有帝王之相，即扶他登基。他若不从，问他个乱宫之罪，那时不怕他不 允。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "此计甚好。就命卿安排，依计而行便了。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴寂下。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同念",
          "text": "计定终身邀新宠，谋成富贵弃旧君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张妃、尹妃同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "二大将、李渊同上。"
        },
        {
          "character": "李渊",
          "type": "引子",
          "text": "虎踞龙蟠镇太原，为国忧民事转烦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴寂上。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "奉张、尹二位娘娘旨意，宣召千岁进宫。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "即刻就到。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "告辞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴寂下。二大将、李渊同下，同上。"
        },
        {
          "character": "二大将",
          "type": "同白",
          "text": "已是宫门。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "通禀。"
        },
        {
          "character": "二大将",
          "type": "同白",
          "text": "哪位公公在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小太监同上。"
        },
        {
          "character": "二小太监",
          "type": "同念",
          "text": "每日宫中乐逍遥，睁开两眼睡不着。"
        },
        {
          "character": "二小太监",
          "type": "同白",
          "text": "什么人？"
        },
        {
          "character": "二大将",
          "type": "同白",
          "text": "唐国公到。"
        },
        {
          "character": "二小太监",
          "type": "同白",
          "text": "候着。 有请公爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴寂上。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "甚么事？"
        },
        {
          "character": "二小太监",
          "type": "同白",
          "text": "千岁驾到。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "到了么？待咱家出迎。 呀，李千岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "老尊贵！ 中国京剧戏考 《晋阳宫》【二本】 3"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "今娘娘召见，恐有面谕国事。来人在外伺候可也。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "是。 来，宫门伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大将同应，同下。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "千岁请！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "请！"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "有坐。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "咱家奉二位娘娘旨意，命咱陪宴。礼仪不恭，求千岁海涵。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "岂敢。少来亲候，恕罪。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "好说。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "不知二位娘娘有何吩咐？"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "娘娘有事，要与千岁商议。且与咱家饮了酒，自有密旨。 孩子们看宴，待咱把盏。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "不敢，摆下就是。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "遵命。千岁请！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "公公请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。李渊坐。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "酒已够了。不及谢宴，告辞了！"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "且慢，还要敬个大杯，方好复旨。 孩子们，把那御制上用的长春酒取来。"
        },
        {
          "character": "二小太监",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "斟酒。 千岁请！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "难饮了。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "有咱家奉陪，请呀请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗，〖合头〗。李渊醉。"
        },
        {
          "character": "二小太监",
          "type": "同白",
          "text": "千岁醉了。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "酒内有那话儿么？"
        },
        {
          "character": "二小太监",
          "type": "同白",
          "text": "嗻。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "扶到龙床上去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小太监扶李渊入帐。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "李千岁醉了。 来，你们将圣上皇衣皇帽与他穿了。"
        },
        {
          "character": "二小太监",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "退下。 有请二位娘娘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张妃、尹妃同上。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同西皮摇板",
          "text": "头戴珠冠双凤飞， 妆成仙子下瑶池。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "命卿安排如何？"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "已将李渊灌醉，抬在龙床。少刻就要醒了。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "好，谨守宫门。"
        },
        {
          "character": "裴寂",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "裴寂下。"
        },
        {
          "character": "张妃",
          "type": "白",
          "text": "妹妹你我前去看来。"
        },
        {
          "character": "尹妃",
          "type": "白",
          "text": "姐姐请。"
        },
        {
          "character": "张妃",
          "type": "西皮摇板",
          "text": "姊妹姣态真妍丽，"
        },
        {
          "character": "尹妃",
          "type": "西皮摇板",
          "text": "娥皇、女英连理栖。"
        },
        {
          "character": "张妃",
          "type": "西皮摇板",
          "text": "为着神尧新皇帝，"
        },
        {
          "character": "尹妃",
          "type": "西皮摇板",
          "text": "早定终身免悔迟。 中国京剧戏考 《晋阳宫》【二本】 4"
        },
        {
          "character": "张妃",
          "type": "西皮摇板",
          "text": "忙将锦帐来钩起，"
        },
        {
          "character": "尹妃",
          "type": "西皮摇板",
          "text": "不避酒气看端的。"
        },
        {
          "character": "张妃",
          "type": "西皮摇板",
          "text": "龙眉凤目帝王相，"
        },
        {
          "character": "尹妃",
          "type": "西皮摇板",
          "text": "两耳垂肩手过膝。"
        },
        {
          "character": "张妃",
          "type": "西皮摇板",
          "text": "他背上硃红书印记，"
        },
        {
          "character": "尹妃",
          "type": "西皮摇板",
          "text": "神尧高祖果然奇。"
        },
        {
          "character": "张妃",
          "type": "西皮摇板",
          "text": "姊妹看罢心欢喜，"
        },
        {
          "character": "尹妃",
          "type": "西皮摇板",
          "text": "推他醒来讨封妃。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "万岁醒来！"
        },
        {
          "character": "李渊",
          "type": "西皮导板",
          "text": "三台府赴宴酒甚涌，"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "好一似杨柳舞东风。 吾主爷扬州去玩景， 晋阳宫大事托本宫。"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "万岁醒来！"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "耳边听得姣声语，"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "哟！"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "龙凤灯照得满堂红。 宫灯绣的是丹山凤， 这一旁绣的云罩金龙。 端详不是我国公府， 好一似炀帝晋阳宫。 醉醺醺忙把牙床下，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊跌倒，张妃、尹妃同扶李渊。"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "呵呀！"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "浑身上下冷汗淋。 猛然睁开昏花眼，"
        },
        {
          "character": "张妃、尹妃",
          "type": "同白",
          "text": "万岁！"
        },
        {
          "character": "李渊",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "二位皇娘把万岁称。 吓得我魂魄不附体， 吾主知道罪难容。"
        },
        {
          "character": "张妃",
          "type": "西皮摇板",
          "text": "尊声万岁休惊惧， 奴二人扶你坐九重。"
        },
        {
          "character": "尹妃",
          "type": "西皮摇板",
          "text": "今晚共入销金帐， 齐跪御前先讨封。"
        },
        {
          "character": "李渊",
          "type": "西皮摇板",
          "text": "二位娘娘不尊重， 我李渊怎做新君龙？ 忙将二妃推在地， 急忙忙跑出晋阳宫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李渊下。"
