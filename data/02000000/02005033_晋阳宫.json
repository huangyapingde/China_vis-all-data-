          "character": "张妃",
          "type": "白",
          "text": "谢龙恩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张妃起，坐李渊腿。尹妃气，跪。"
        },
        {
          "character": "尹妃",
          "type": "白",
          "text": "万岁，妾妃讨封。 中国京剧戏考 《晋阳宫》【二本】 7"
        },
        {
          "character": "张妃",
          "type": "白",
          "text": "万岁封一不封二。"
