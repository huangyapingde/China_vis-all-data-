{
  "script_id": "02011040",
  "title": "宁武关",
  "alias": [
    "对刀步战·求子"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "周遇吉",
      "hangdang": "老生"
    },
    {
      "name": "李洪基",
      "hangdang": "小生"
    },
    {
      "name": "李自成",
      "hangdang": "净"
    },
    {
      "name": "宋献策",
      "hangdang": "丑"
    },
    {
      "name": "一支虎",
      "hangdang": "副净"
    }
  ],
  "plot": "明末总兵周遇吉，镇守岱州宁武关，李闯屡攻不下。诸将遇周遇吉，皆披靡败北。惟李闯子李洪基，足与周\n遇吉旗鼓相当。论兵势则李军势方盛，周遇吉究孤立无援，理宜早为李自成所胜。无如李洪基因乃叔一支虎\n之忌妬，极爱重周遇吉之才，拟收为心腹。每稍让一步，而周遇吉则拼命而上，故反占胜。前已交绥，此次\n李洪基又奉命往攻岱，与周遇吉相遇。李洪基反复苦劝，周遇吉终不听，乃开展厮杀。却仍是棋逢敌手，莫\n决雌雄。战至兴起，李洪基乃约周遇吉舍枪而用刀，周遇吉即允用刀。始不分上下。李洪基又约周遇吉下马\n而比步，周遇吉即允步战。然周遇吉方患李洪基之得藉宝马之力而占优势（马名闪电光），今弃马用步，则\n正中下怀矣。因此李洪基卒被擒。李闯求释李洪基未果，卒为周遇吉枭首示众。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉上。"
        },
        {
          "character": "周遇吉",
          "type": "引子",
          "text": "旌旗恁飘荡，万骑皆龙骧。"
        },
        {
          "character": "周遇吉",
          "type": "念",
          "text": "渺渺戈纹贯落星，长幡早已动高旌。丈夫鹊印摇边月，大将龙韬旧有声。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "本帅，周遇吉。奉命镇守岱州等处。可恨闯贼统领大兵，直压城下，昨日与他 爱子李洪基，连战数阵，看他有惧怯之意。怎奈他马骤如飞，不能擒获。今日 交锋，随机擒他。 众将官，杀上前去！"
        },
        {
          "character": "周遇吉",
          "type": "金钱花",
          "text": "旌旗云绕，迷漫迷漫， 摆开阵势，城南城南。 只一战，凯歌旋， 擒虎兕寸心丹，擒虎兕寸心丹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李洪基上。"
        },
        {
          "character": "李洪基",
          "type": "引子",
          "text": "将遇良才，棋逢对手，越令人豪气频添，把精神抖擞。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "俺，李洪基。奉父命，提兵攻打岱州。那周遇吉，他将人马尽屯于城外，排成 犄角之势，使我兵不能前进，攻东则应东，攻西则应西，此乃以逸待劳，以寡 敌众之计。前日与他交战数次，他的枪法神出鬼入，不能招架。只得诈败，诱 他到来，俺使飞刀斩他，反被接住，掷来斩俺。亏俺的坐骑，乃千里驹，名曰 闪电光，若迟一步，险些被伤了。自从父王与我改名洪基，名字应了年号，只 是叔父一支虎，有些妬忌。俺若招降此人，与俺作个心腹，传位天下，稳如磐 石。今日再去交锋，降伏此人便了。 众孩儿兵，杀上前去！"
        },
        {
          "character": "李洪基",
          "type": "滴溜子",
          "text": "催铁骑，催铁骑，如云骤， 挽金戈，挽金戈，如霜，光溜溜。 中国京剧戏考 《宁武关》【头、二本】 2 捣雄关烽堠，把熊罴两翅排，旌门紧守， 各显威，神惊鬼愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、四上手、四小军同迎上，见。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "周遇吉。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "贼子！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "吓，周将军。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "李洪基！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "你我生得恁般英雄，也算天下间一个好汉。可惜你生于末世，未逢明主。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "唗，胡说！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "俺堂堂帝统御中州， 版图四海全收。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "主弱臣庸，将见败亡耳！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "俺圣上呵！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "比隆尧舜功德茂， 少甚么稷契皋夔名胄。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "谅你一旅之师，济得甚事，为人也要见机而行，才是英雄。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "本帅呵！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "忠和孝，平生自守， 身和命笑浮沤。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "哎，你昂昂气宇恁风流， 更艺勇可称琼玖。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "你若倾心归顺，与你结为兄弟。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "真果是，云龙风虎金兰友， 保毕世恩荣化胄。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "看枪！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "吓，周将军，你执意如此。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "刀头丧身家尽休， 英雄骨弃荒丘。"
        },
        {
          "character": "周遇吉",
          "type": "急三枪",
          "text": "俺心如铁，意如石，胆如天， 任你随何口，难动我寸心头。"
        },
        {
          "character": "李洪基",
          "type": "急三枪",
          "text": "莫待钟鸣漏尽，山水穷头， 灾星至，欲悔无由。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、李洪基同杀下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李洪基上。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "看他枪法，十分厉害，不能取胜，待他来时，与他对刀，必然胜他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "呔！哪里走！"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "吓，周将军，我想凡为大将，十八般武艺，件件皆能，方为大将，你敢与俺对 刀么？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "刀乃兵家所用，怎么不知！就与你对。"
        },
        {
          "character": "周遇吉",
          "type": "急三枪",
          "text": "披风泼雪猛如彪， 万丈寒光飞骤。 似玉龙银蟒旋抖擞， 耳边风声频吼。 冷飕飕，闪烁光侔， 干羽振舞阶溜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、李洪基同杀下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《宁武关》【头、二本】 3"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李洪基上。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "我的刀法，数年以来，并无对手，待他来时，与他比拳步战，必然成功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "你这般畏怯潜逃，不像个英雄好汉。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "你我马上武艺，彼此皆知。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "你要怎样战法？"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "当初张飞与马超步战，杨再兴与庚丙文步战。俺如今与你比拳步战，若胜你不 得，情愿收兵回去，永不犯你的边界。"
        },
        {
          "character": "李洪基",
          "type": "风入松",
          "text": "和你较拳纵飞演，比进步， 这秘法可周知。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "且往。我为他马骤如飞，不能擒他，反与俺步战，岂非天赐我成功！ 呔，李洪基！"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "你待要撼天山穿云斗海蛟， 俺对你这小猕猴。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "周将军，今日英雄遇英雄，好汉遇好汉，只可阵上赌输赢，不可暗箭伤人，方 为好汉。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "俺平生，正直待人。 众将官，不可暗使冷箭者。"
        },
        {
          "character": "周遇吉",
          "type": "风入松",
          "text": "狻猊摆尾下山头， 彩凤穿花唧溜。 撩衣托塔君知否， 举鼎势，伍子胥传授， 双展翅，鹰拿燕雀，龙探爪戏蛛球。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "众将！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉喘。四上手同上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "将他的营盘闪电光抢过来。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "启元帅：闪电光抢过来了。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "好，记功领赏。摆队进关。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "恭喜元帅，天神威武，擒此巨寇，威震华夷，小将等不胜忻贺。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "小丑虽擒，大逆尚存，何喜何贺？"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "看此子虽然年幼，英勇非常，何不亲解其缚，劝他降顺，岂不是好？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "咳，你们哪里晓得！"
        },
        {
          "character": "周遇吉",
          "type": "煞尾",
          "text": "他狼心野性岂驯柔， 暂降伏终成仇寇。"
        },
        {
          "character": "周遇吉",
          "type": "夹白",
          "text": "若留在关内呵！"
        },
        {
          "character": "周遇吉",
          "type": "煞尾",
          "text": "反贼内外难防守，"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "如此，加恩放回去。"
        },
        {
          "character": "周遇吉",
          "type": "煞尾",
          "text": "纵猛虎归山差谬。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "元帅如何处治？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "众将官听令：那闯贼知我擒他爱子，必然统领大兵，前来劫夺。这场厮杀非比 小可，我军当预先准备，吩咐阵前，多排鹿角，广布蒺藜，头层藤牌手，二层 火炮手，三层弩弓手，第四层长枪手，第五层攒箭手，必须人人奋勇，个个当 先，国家兴亡，在此一阵成功，奏凯论功升赏。众将官！"
        },
        {
          "character": "周遇吉",
          "type": "煞尾",
          "text": "当一纶香饵在钩， 要把鳌鱼钓，方得海波休！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "周遇吉",
          "type": "stage",
          "text": "《求子》"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套引李自成、宋献策、一支虎、兵卒同上。"
        },
        {
          "character": "李自成",
          "type": "剔银灯",
          "text": "闻说孩儿失阵， 好教俺断魄消魂。 将金珠，撵载赎身命， 中国京剧戏考 《宁武关》【头、二本】 4 到城下须当哀恳。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "我孩儿被周遇吉擒去，就要统领大兵劫夺。军师说道，若要强夺，必伤我儿的 性命。须多带金帛送去，下礼相求，方可放回，也未可知。 将校们快快趱行。"
        },
        {
          "character": "李自成",
          "type": "剔银灯",
          "text": "将军未识依允， 若收取，千欢万忻，千欢万忻。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "已到城下。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "军师，御弟，你看枪刀密密，戈戟森森，好严整也！"
        },
        {
          "character": "宋献策、一支虎",
          "type": "同白",
          "text": "那周遇吉果然厉害。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "小校，你问小将军怎么样了？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同上城。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "呔！城上的，大王问我家小将军怎么样了？"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "俺家好好养在后营。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "启大王：他家好好养在那里。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "周总兵不敢难为他。再去问，说俺在此，请他主帅出来答话。"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "城上的，俺大王在此，请你主将答话。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "俺家元帅少刻就到，看你们这些毛贼，小心伺候！"
        },
        {
          "character": "兵卒",
          "type": "白",
          "text": "他家元帅少刻就到。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "元帅有令，将洪基绑吊旗杆上者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李洪基上。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "吓父王，快救孩儿罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李自成看。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "气死我也！"
        },
        {
          "character": "李自成",
          "type": "驻云飞",
          "text": "怒气冲巾， 五内如同烈火焚。 寸寸肝肠断， 点点珠泪淋。 嗏睚眦裂双眼， 天关摇振。 跺足捶胸， 咬定银牙根。 教我无计掌上珍， 教我无计掌上珍。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "爹爹，只可善言哀求，方保孩儿的性命。若是攻城，孩儿的性命休矣。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "哎呀，我的儿吓，依你就是了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉上城。"
        },
        {
          "character": "周遇吉",
          "type": "引子",
          "text": "咆哮猛虎牙吻，痛子命，吼叫频频。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉看李自成。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "呔！周遇吉！俺与你有何冤仇，将我的孩儿恁般摆布，好好送下城来，万事皆 休；少言半个不字，杀进城来，休想俺轻轻饶你。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "唗！闯贼！你欺藐我君父，蹂躏我国家，屠戮人民，摧残州郡，汝子助你为恶。 今被我擒，也是尔等恶贯满盈，应遭天谴。早当改过，自保全蚁命。还敢放 肆么！"
        },
        {
          "character": "宋献策",
          "type": "白",
          "text": "吓，大王，将带来的金帛献上，再将软语哀求他才好。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "是吓，我倒忘记了。 吓，周遇吉，俺方才失言得罪，望勿记怀。聊具黄金万两、彩缎千端、珍珠宝 玩二十车、名马五百匹、美女百名献上，望元帅笑纳。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "本帅奉命镇守城池，身命轻如鸿毛，家室弃如敝履，这些污秽之物何用？"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "求你放了我孩儿罢！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "要我放了你的孩儿么，这也不难。"
        },
        {
          "character": "周遇吉",
          "type": "榴花泣",
          "text": "只要投戈解胄， 拜倒在辕门。 中国京剧戏考 《宁武关》【头、二本】 5"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "俺就下马拜求。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "不是这等拜法。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "要怎样拜？"
        },
        {
          "character": "周遇吉",
          "type": "榴花泣",
          "text": "叩头缚绑捧降文， 洗心改过口称臣。 鑚刀设誓， 从此息烟氛。"
        },
        {
          "character": "周遇吉",
          "type": "夹白",
          "text": "本帅呵！"
        },
        {
          "character": "周遇吉",
          "type": "榴花泣",
          "text": "封章达至尊， 听金鸡衔赦邀怜悯。 方保得父子团圆， 君与臣，尽沐天恩，尽沐天恩！"
        },
        {
          "character": "李自成",
          "type": "榴花泣",
          "text": "俺本是惊天动地，豪杰气凌云， 何曾低头屈膝乞哀怜。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "周将军，小儿年幼，冒犯虎威，望开天地之恩，饶了他罢。周将军，周元帅， 哎，我的周老爷！"
        },
        {
          "character": "李自成",
          "type": "榴花泣",
          "text": "在麾下顿首恁谆谆， 骄矜傲慢，太无一人， 比拼力攻城，比拼力攻城。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "李自成！那李洪基，是你伙党之人，被俺拿他个榜样。你伙党中，有武艺高过 他的，挑选几百名，比个手段，拿齐了这伙毛贼，一齐开刀！"
        },
        {
          "character": "李自成",
          "type": "榴花泣",
          "text": "腾腾怒气愤， 似周山触得头颅损，似周山触得头颅损。"
        },
        {
          "character": "李洪基",
          "type": "白",
          "text": "吓，爹爹，还是哀求，若是攻城，孩儿休矣。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "我的儿吓，我在此求哩！ 吓，周元帅，周将军，周老爷，哎，我的周祖宗！"
        },
        {
          "character": "李自成",
          "type": "榴花泣",
          "text": "望早施天地洪恩， 保全我父子天伦，保全我父子天伦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李自成拜恳。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "李自成，你好蠢也！你只知父子天伦，不知君臣大义。君臣乃三纲五常之首， 父子次之。你既有这般爱子之心，怎不敬君？你若归顺天朝，光明正大，做个 天地间，节烈大丈夫，庙堂忠义士。上合君臣大义，下全你父子天伦，岂不美 哉？你自去想来！"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "吓，周将军，蒙你这番教训，如梦方醒，俺去收拾了甲兵，写了降书降表就来。 周元帅，望你不要难为了我的孩儿。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "你既归顺天朝，就是天朝贵客，哪有不尊敬的道理？ 众将官，把小将军放下来，请到后营款待。"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李洪基下。"
        },
        {
          "character": "宋献策",
          "type": "白",
          "text": "吓，大王差矣。自古人无远虑，必有近忧。向来争雄定霸，全赖军威，如今帝 业将成，岂可半途而废？如若投降，众将必然星散，犹如孤豚腐鼠，生死听于 他人，富贵尚属虚无，性命却在刀口。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "军师说得是。"
        },
        {
          "character": "宋献策",
          "type": "渔家傲",
          "text": "须三思反侧评论， 肯无端吞却线钩。 常言道酒刃为山， 岂功亏一篑而陨？"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "军师言之有理，只是何忍他死于非命？"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "哥哥，你若作了皇帝，自有三千粉黛，八百姣娥，怕生不下一个好儿子来么？ 况此人呵！"
        },
        {
          "character": "一支虎",
          "type": "渔家傲",
          "text": "非是我宗亲，"
        },
        {
          "character": "一支虎",
          "type": "夹白",
          "text": "呵！"
        },
        {
          "character": "一支虎",
          "type": "渔家傲",
          "text": "全没些孝顺恭敬。 中国京剧戏考 《宁武关》【头、二本】 6"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "二位言之有理。但此人虽非吾嫡子，他曾为我建下许多大功，何忍抛弃与他？"
        },
        {
          "character": "宋献策",
          "type": "白",
          "text": "大王，你不见乐洋子中山焚子，薛平辽海岸射儿，此二人岂不念父子之情？只 为功在垂成，不可因此而误也！"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "大王，今传各路人马呵！"
        },
        {
          "character": "一支虎",
          "type": "渔家傲",
          "text": "齐夺踹孤城齑粉， 掌中珍还当再亲。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "军师言之有理，就此杀上前去。 呔！周遇吉！俺的儿子也不要了，出来拼个你死我活！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "众将官，李洪基砍了！"
        },
        {
          "character": "四上手",
          "type": "同白",
          "text": "得令。 首级献上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "号令城上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李自成看。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "哎儿吓！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "开城者！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉、四上手同下城，同开打。周遇吉、四上手同下。"
        },
        {
          "character": "四龙套",
          "type": "同白",
          "text": "周遇吉逃往宁武关去了。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "御弟、军师追赶。 将校们，随我收葬了小将军的尸首去者。"
        },
        {
          "character": "李自成",
          "type": "尾声",
          "text": "可怜爱子餐刀刃， 狼藉尸骸何处存？"
        },
        {
          "character": "李自成",
          "type": "夹白",
          "text": "周遇吉呀，周遇吉！"
        },
        {
          "character": "李自成",
          "type": "尾声",
          "text": "沥血坟前地酬怨魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}