    },
    {
      "name": "佟夫人",
      "hangdang": "旦"
    }
  ],
  "plot": "何玉凤运灵回京安葬后，并在坟旁盖一茅庵独自居住。三年孝满，安学海又特为何杞盖一祠堂。张金凤自经\n何玉凤救出，并为订婚，为报再生之恩，拟令何玉凤亦嫁安骥。并商得其公婆同意，邀邓九公前来作媒。经\n许多曲折，终得如愿，完成花烛，彩凤成双云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "云童、何杞同上。"
        },
        {
          "character": "何杞",
          "type": "念",
          "text": "生为英杰死为神，俱是千秋正气人。"
        },
        {
          "character": "何杞",
          "type": "白",
          "text": "吾神，何杞，在阳世官居总兵，被纪献唐所害。上帝念我正直，封为德州城隍。 夫人阳数已尽，也曾迎至神庙。只因夫人思念女儿，暗地保护他回京。去了 许久，未见归庙。想必来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侍女引何母同上，何母坐。"
        },
        {
          "character": "何杞",
          "type": "白",
          "text": "夫人，保护女儿回京，为何去了一日，才得归庙？"
        },
        {
          "character": "何母",
          "type": "白",
          "text": "天上一日，地下三年。你我那玉凤女儿，跟随安家伯伯，回京之后，埋葬我二 老亡骨。又在坟前盖一茅庵，定要终身守志。怎奈他与安家侄儿，有姻缘定分。 如今三年孝满，安家伯伯，替我二老盖造祠堂，不久就要提亲，我恐女儿性 情执傲，也曾梦中点化于他，故尔归庙迟延。"
        },
        {
          "character": "何杞",
          "type": "白",
          "text": "善哉，善哉。"
        },
        {
          "character": "何杞",
          "type": "念",
          "text": "从此了却儿女事，"
        },
        {
          "character": "何母",
          "type": "念",
          "text": "前因后果总成空。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张金凤上。"
        },
        {
          "character": "张金凤",
          "type": "引子",
          "text": "向阳门第春常在，积善人家庆有馀。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "奴家，张金凤。在能仁寺遭难，得遇义姐搭救，又凭他为媒，许配安公子。到 了淮阳，公婆见爱，六礼成婚。这且不在话下。可叹我那义姐何玉凤，家遭大 难，父母双亡，如今虽然安葬双亲，三年孝满，怎奈她立志尽孝，独住祠堂。 奴家有意劝她同嫁安郎，共效于飞之乐。昨日密告安郎知晓，不免禀明公婆， 再作道理。 有请公婆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海、佟夫人同上。"
        },
        {
          "character": "安学海",
          "type": "念",
          "text": "侠义英雄孝女郎，"
        },
        {
          "character": "佟夫人",
          "type": "念",
          "text": "可怜独自守祠堂。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "参见公婆。"
        },
        {
          "character": "安学海、佟夫人",
          "type": "同白",
          "text": "罢了。坐下。 中国京剧戏考 《弓砚缘》【九本】 2"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": "安学海、佟夫人",
          "type": "同白",
          "text": "请我二老，所为何事？"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "禀公婆：何家姐姐，自从安葬双亲，三年孝满，如今独住祠堂，终非了局。儿 媳有意，劝她同嫁夫君，共效于飞之乐。故尔先禀公婆。"
        },
        {
          "character": "安学海、佟夫人",
          "type": "同白",
          "text": "我二老早有此心。你既然情愿，真乃贤德。也曾修书与邓九公，候他到来，方 可为媒。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "何家姐姐性情执傲，儿媳累累探问于她，她立志独身，心如铁石。此事还求公 婆，思想万全之策。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "妆奁花烛，早已准备。等候九公到来，即选良辰。以祭奠祠堂为由，立刻劝她 成婚。只是话到其间，须仗你劝说于她。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "邓九公",
          "type": "内白",
          "text": "邓九公到。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "邓九公到。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓九公上。安学海出迎。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "不知仁兄驾到，少迎恕罪。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "岂敢。愚兄来得卤莽，贤弟海涵。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "岂敢。可曾见小弟书信？"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "特为书信而来。愚兄随带两万银子，以为赠嫁。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "不敢当此厚礼。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "何家小姐今在哪里？"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "小弟替她亡过父母，盖下祠堂。现在祠堂居住。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "待我师徒一见，当面为媒。谅她必然应允。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "且慢。她性情执傲，若先对她说明，定然不允。仁兄到得正好，明日良辰，小 弟已有安排。仁兄且请后面款待。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "安骥、院子同上。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "小生安骥，且喜秋闱得中。 来，打道回府。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请老爷、夫人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海、佟夫人同上，同坐。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "少老爷回府。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "爹娘请上，孩儿拜见。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "儿吓，你少年登科，可喜可贺，生受你了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥拜。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "儿吓，随为父拜见祖先堂。 （〖吹打〗。安学海、安骥、佟夫人同下。〖牌子〗。二院子同上。安学海、佟夫人同上。安骥红袍纱帽上。 安骥、张金凤对拜，张金凤下。二院子端两盘，一放弓一放砚。众吹手、众鼓手同上，引安骥同下。）"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤上。"
        },
        {
          "character": "何玉凤",
          "type": "念",
          "text": "双亲在天多保佑，灭却仇人展眉头。"
        },
        {
          "character": "安学海",
          "type": "内白",
          "text": "安老爷来到。 （何玉凤下。二院子、众吹手、众鼓手同上。〖吹打〗。中挂幔子。二院子同将弓、砚放好。安学海、佟夫 人同上，同进门，张金凤搀何玉凤同上，何玉凤行礼，安学海、佟夫人对行礼，张金凤行礼，何玉凤向安学 中国京剧戏考 《弓砚缘》【九本】 3 海、佟夫人行礼，张金凤扶起，何玉凤、张金凤对拜。）"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "多谢伯父伯母，亲自前来祭奠，"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "贤侄女，伯父有一言奉告：想你一人独守祠堂，终非了局。男婚女嫁，大礼难 违。今日一来祭奠你双亲，二来我夫妇为子求婚，即日良辰，快叫你妹子，与 你冠带，成其大礼。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "且慢。伯父此言差矣。侄女在青云山，曾与伯父言明，要终身守志。今日为何 出此无理之言？"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "金凤媳妇过来。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "将我二老诚意，告你义姐知道。我二老外面等候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海、佟夫人同下。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "吓，姐姐！"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "贤妹何事？"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "小妹有一言禀告。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "若有别的言语请讲，若方才伯父之言，我早已知道，断难从命。贤妹免讲的好。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "姐姐吓！"
        },
        {
          "character": "张金凤",
          "type": "西皮慢板",
          "text": "姐休要烈性将奴恼， 细听小妹说根苗： 男婚女嫁礼正道， 纵然是英雄也难逃。"
        },
        {
          "character": "何玉凤",
          "type": "西皮慢板",
          "text": "贤妹休要来罗唣， 姐把阳世当阴曹。 二爹娘为奴命丧掉， 若不尽孝天不饶。"
        },
        {
          "character": "张金凤",
          "type": "西皮慢板",
          "text": "姐把心肠用差了， 你可有弟兄与同胞？ 姐姐要终身守孤庙， 不孝有三绝后苗。"
        },
        {
          "character": "何玉凤",
          "type": "西皮慢板",
          "text": "任凭你能说又善道， 奴好似古井无波涛。 劝贤妹休要多口好， 又恐伤却结拜交。"
        },
        {
          "character": "张金凤",
          "type": "西皮二六板",
          "text": "说什么伤却结拜交， 提起结拜记心梢。 能仁寺内遇强盗， 多蒙你搭救命一条。 蒙你当面为月老， 蒙你与妹结同胞。 自古有恩将恩报， 知而不言罪难饶。 弹打凶僧救年少， 瓜田李下有分毫。 纵取西江难洗掉， 倒不如一床锦被遮盖牢。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "何玉凤",
          "type": "西皮紧板",
          "text": "好一个能言张金凤， 说得奴家满脸红。 低头不语把计用，"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "贤妹！"
        },
        {
          "character": "何玉凤",
          "type": "西皮紧板",
          "text": "三件大事难依从。"
        },
        {
          "character": "张金凤",
          "type": "西皮紧板",
          "text": "说什么三件事难从， 一桩一件表从容。"
        },
        {
          "character": "何玉凤",
          "type": "西皮紧板",
          "text": "第一件无有父母命， 中国京剧戏考 《弓砚缘》【九本】 4"
        },
        {
          "character": "张金凤",
          "type": "西皮紧板",
          "text": "你二老神位在当中。"
        },
        {
          "character": "何玉凤",
          "type": "西皮紧板",
          "text": "第二件无有礼物聘，"
        },
        {
          "character": "张金凤",
          "type": "西皮紧板",
          "text": "现有宝砚和雕弓。"
        },
        {
          "character": "何玉凤",
          "type": "西皮紧板",
          "text": "第三件还比此事重， 眼前缺少一媒红。"
        },
        {
          "character": "张金凤",
          "type": "西皮紧板",
          "text": "闻言喜坏了张金凤， 你看小妹显神通。 千里迢迢能请动， 请动冰人大媒红。"
        },
        {
          "character": "邓九公",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓九公上。"
        },
        {
          "character": "邓九公",
          "type": "西皮紧板",
          "text": "听说一声请媒红， 来了荏平的邓九公。 见了神牌先拜定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓九公拜。"
        },
        {
          "character": "邓九公",
          "type": "西皮紧板",
          "text": "再与小姐说从容： 我为你神前把香供， 我为你日夜挂心中。 今日且喜红鸾动， 天合姻缘要允从。"
        },
        {
          "character": "何玉凤",
          "type": "西皮紧板",
          "text": "见师父叫人好懞懂， 上了他们计牢笼。 思想起爹娘心酸痛，"
        },
        {
          "character": "何玉凤",
          "type": "哭头",
          "text": "爹娘吓！"
        },
        {
          "character": "何玉凤",
          "type": "西皮紧板",
          "text": "撇下孤女无定踪。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "休要悲泪，后面冠带。 （张金凤扶何玉凤同下。〖吹打〗。安骥上，拜神牌，拜邓九公。何玉凤冠带盖头上，邓九公暗下。安骥骑 马下，何玉凤坐轿下。）"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖吹打〗。二院子、邓九公、安学海、佟夫人、四青袍同上，安骥上，何玉凤、张金凤同上。何玉凤站左，"
        },
        {
          "character": null,
          "type": "text",
          "text": "安骥站中，张金凤站右。傧相上。）"
        },
        {
          "character": "傧相",
          "type": "白",
          "text": "伏以："
        },
        {
          "character": "傧相",
          "type": "念",
          "text": "花开并蒂玉成双，一凤何妨配两凰。偕老齐眉三不朽，孙孙子子更绵长。"
        },
        {
          "character": "傧相",
          "type": "白",
          "text": "新人先拜天地，后拜高堂，三人交拜，送入洞房。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "傧相送安骥、何玉凤、张金凤同下。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "贤弟、弟妇请上，愚兄贺喜，定要一拜。"
        },
        {
          "character": "安学海、佟夫人",
          "type": "同白",
          "text": "我夫妻也有一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓九公、安学海、佟夫人同拜，佟夫人暗下。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "前堂备酒宴，与仁兄痛饮一醉。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "这酒自然要讨扰吓！哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（〖细吹打〗。丫头掌灯上，安骥上，入洞房。张金凤、何玉凤同上，同入洞房。丫头扶何玉凤卸凤冠换衣，"
        },
        {
          "character": null,
          "type": "text",
          "text": "坐。）"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "吓，安郎，你我与姐姐在能仁寺一聚，如今终成眷属，真乃天从人愿。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "小生得报大恩，乃贤妻之功也。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "吓，姐姐。今夜良辰，小妹不能奉陪，明日侍奉姐姐罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤拉张金凤，摇手。"
        },
        {
          "character": "张金凤",
          "type": "stage",
          "text": "中国京剧戏考 《弓砚缘》【九本】 5"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "姐姐放了小妹罢，姐姐放了小妹罢。哎呀，有个蜜蜂在姐姐头上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤撒手。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张金凤跑出，指安骥。"
        },
        {
          "character": "张金凤",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张金凤下。"
        },
        {
          "character": "安骥",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥关门。何玉凤坐。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "自蒙姐姐搭救，时刻挂心。如今得遂姻缘，大恩可报也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥看何玉凤十，何玉凤背脸。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "我爹娘为姐姐一事，费了多少心机。从今我夫妇三人，要同心合意，孝奉双亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤背脸。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "天已不早，请姐姐安歇罢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤背脸。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "你我携手并入罗帏可好？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥拉何玉凤袖，何玉凤带安骥跌倒，何玉凤脚挑安骥。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "姐姐金口难开，苦苦守住房门，想是放心不下，姐姐何不开门请出？"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "唗！安龙媒。我在能仁寺救你性命，如今公婆苦苦相央，才到你家。今日良辰， 你敢大胆轰我出去么？"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "非轰也，吓，非轰也。你出了房门，便出院门，出了院门，便出大门，出了大 门，直奔东南，乾方震位，一片打麦场上，有一好大石块，你可搬了进来，顶 住房门，岂不可放心大胆安歇了么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤笑。"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "何玉凤",
          "type": "唱",
          "text": "提起了悦来店那样石块， 这才是好姻缘棒打不开。 做夫妻从今后听奴劝解， 男儿家志青云方显奇才。"
        },
        {
          "character": "安骥",
          "type": "白",
          "text": "姐姐吓！"
        },
        {
          "character": "安骥",
          "type": "唱",
          "text": "蒙姐姐好言语千金难买， 今秋月开科选大典抡才。 安龙媒为两卿努力自爱， 登黄榜步青云方对裙钗。"
        },
        {
          "character": "安骥",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安骥、何玉凤同进帐。贼首上。"
        },
        {
          "character": "贼首",
          "type": "念",
          "text": "自幼生来善偷盗，飞墙走壁武艺高。白日观见财和宝，夜晚定要走一遭。"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "我，京都内面第一个做贼高手，跳梁鼠是也。今有安府娶亲，从山东荏平来了 一位大媒，随带两万银子赠嫁。被我看在眼里。约会众家兄弟，今晚前去偷盗， 怎么还不见到来？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖撕边〗。四贼同翻上。"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "兄弟们都来了。"
        },
        {
          "character": "四贼",
          "type": "同白",
          "text": "都来呐。"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "白日所说，你们可记下？"
        },
        {
          "character": "四贼",
          "type": "同白",
          "text": "记下呐。"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "咱们走，走，走，走。 （贼首、四贼同转场，同翻过墙，同作推门势。何玉凤、安骥同掀幔。安骥抖。何玉凤摇手藏入幔，起摸刀， 觅杆手提坐。贼首拨门，贼首、四贼同进抬箱。何玉凤用杆按箱，贼首、四贼同抬不动，同两边贼摸床。）"
        },
        {
          "character": "何玉凤",
          "type": "白",
          "text": "好贼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "何玉凤打贼首、四贼同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（邓九公上，打呵。贼首、四贼同上，碰邓九公。邓九公脱衣打，何玉凤上，看，下。邓九公打贼首、四贼"
        },
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《弓砚缘》【九本】 6"
        },
        {
          "character": null,
          "type": "text",
          "text": "同下。）"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "众家丁走上！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四院子同上。"
        },
        {
          "character": "四院子",
          "type": "同白",
          "text": "何事？"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "你家有了贼盗，准备绳索伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓九公、四院子同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "贼首、四贼同上，邓九公追上，打贼首、四贼同倒。四院子同上，同捆。安学海上。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "贼盗在哪里？贼盗在哪里？"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "俱已捆绑在此。掌灯问来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子甲取灯。邓九公、安学海同坐。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "你们是哪里贼盗，为何起此不良？"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "我们远方人氏，闻听尊府娶亲，从山东荏平来了一位大媒，随带两万银子赠嫁， 故而起此歹意。不想去至洞房，被你家新娘子，用棍打伤，故尔被擒。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "哎呀，他们先到了洞房。 家院快去问来。可曾失落何物？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子甲应，下。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "我且问你：你们知道山东来了一位大媒，随带两万银子，可知道山东来的是哪 一人？"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "小人们只认得银子，不认识人。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "你们可到过山东？"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "也曾到过。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "山东有一邓九公，你可知道？"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "不知道。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "好贼！"
        },
        {
          "character": "邓九公",
          "type": "唱",
          "text": "骂声贼人眼瞎了， 不认得九爷邓振彪！ 钢鞭一举三魂掉，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "邓九公打。"
        },
        {
          "character": "安学海",
          "type": "唱",
          "text": "仁兄请坐把怒消。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "吓，仁兄。你的大名，必须海马周三、醉金刚郝武等，方可知晓。这些毛贼， 如何得知吓？哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子甲上。"
        },
        {
          "character": "院子甲",
          "type": "白",
          "text": "洞房不曾失落何物。"
        },
        {
          "character": "安学海",
          "type": "白",
          "text": "既然不曾失落何物，这等小小毛贼，放他去罢。"
        },
        {
          "character": "邓九公",
          "type": "白",
          "text": "便宜了这些毛贼。"
        },
        {
          "character": "贼首",
          "type": "白",
          "text": "谢爷爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贼首、四贼同下。"
        },
        {
          "character": "邓九公",
          "type": "念",
          "text": "贤弟果然积善家，"
        },
        {
          "character": "安学海",
          "type": "念",
          "text": "善因善果定无差。"
        },
        {
          "character": "邓九公",
          "type": "念",
          "text": "佳儿佳妇门庭喜，何日成名报皇家。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "安学海、邓九公同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}