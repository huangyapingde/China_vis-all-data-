{
  "script_id": "02002005",
  "title": "大十面",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "韩信",
      "hangdang": "老生"
    },
    {
      "name": "项羽",
      "hangdang": "净"
    },
    {
      "name": "魏豹",
      "hangdang": "丑"
    }
  ],
  "plot": "本剧系韩信在九里山，调兵遣将，摆十面埋伏大阵，捉拿项羽。项羽陷入重围，虽经魏豹掩护，相偕逃走，\n终至垓下自刎身亡。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "龙套引韩信同上。"
        },
        {
          "character": "韩信",
          "type": "点绛唇",
          "text": "天澹云孤，怨云愁雾，施威武，镇征夫，取胜如神助。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩信上高台，坐。曹参上。"
        },
        {
          "character": "曹参",
          "type": "白",
          "text": "曹参打躬。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "一旁侍立。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹参允。"
        },
        {
          "character": "韩信",
          "type": "念",
          "text": "暗列兵机神鬼欺，胸藏奥妙少人知。不施万丈深潭计，怎得骊龙项下珠？"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "俺，韩信。今在九里山下，摆下一座十面阵式，要擒拿项羽。 曹参听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹参允。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "命众将披挂整齐，上帐听令。"
        },
        {
          "character": "曹参",
          "type": "白",
          "text": "得令。 呔，众将官！"
        },
        {
          "character": "众将",
          "type": "内同白",
          "text": "吓！"
        },
        {
          "character": "曹参",
          "type": "白",
          "text": "元帅有令：披挂整齐，上帐听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹参下。"
        },
        {
          "character": "韩信",
          "type": "混江龙",
          "text": "全按着九天之术， 九宫八卦列昆吾。 俺怎肯差误了旗号，错配了军卒， 安排下走龙飞龙图社稷，准备着钓鳌网锁困江湖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹参、众将同上。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "众将打躬。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "众将官。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "本帅今在九里山下，摆下一座十面阵式，要擒拿项羽。你等听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允，侍立。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "曹参，"
        },
        {
          "character": "曹参",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "韩信",
          "type": "念",
          "text": "第一阵，"
        },
        {
          "character": "韩信",
          "type": "混江龙",
          "text": "乾为天，天门引战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹参下。"
        },
        {
          "character": "韩信",
          "type": "混江龙",
          "text": "第二阵坎为水，水底同谋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "将官甲下。"
        },
        {
          "character": "韩信",
          "type": "混江龙",
          "text": "第三阵艮为山，深伏隘口， 第四阵震为雷，实若玄虚。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "将官乙、将官丙同下。"
        },
        {
          "character": "韩信",
          "type": "混江龙",
          "text": "第五阵巽为风，烟尘浩荡， 第六阵离为火，火耗成墟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "将官丁、将官戊同下。"
        },
        {
          "character": "韩信",
          "type": "混江龙",
          "text": "第七阵坤为地，要移花接木， 第八阵兑为泽，潜在那踪迹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "将官己、将官庚同下。"
        },
        {
          "character": "韩信",
          "type": "混江龙",
          "text": "第九阵安营下寨， 第十阵傲荡凶徒，傲荡凶徒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "将官辛、魏豹同下。八将同上，四角列阵，二将引项羽同上，入阵，开打，众人同下。"
        },
        {
          "character": "韩信",
          "type": "油葫芦",
          "text": "上接着九天纷纷之数， 下镇着九天泉以似荒芜。 量你有万夫之勇， 难逃俺十面埋伏。 天之理，天之数， 张良用黄公三略法，俺韩信有吕望六韬书，吕望六韬书。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将、项羽同上，开打，同下。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "好一场鏖战也！"
        },
        {
          "character": "韩信",
          "type": "油葫芦",
          "text": "只听得呐喊摇旗齐操鼓， 纵征驼，亲去取，今番一战定输赢。 为君的开基创业，齐天福， 为臣的要安邦定国，上功劳簿。 平地上起一座战场高埠处， 高埠处，列着帅府。 更有那张司徒、萧丞相，和那刘高祖， 俺韩信在山顶上运计谋，山顶上运计谋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将、项羽同上，开打，同下。"
        },
        {
          "character": "韩信",
          "type": "天下乐",
          "text": "又听得动一派萧韵品奏曲， 见霸王，见霸王高也么呼，骂韩信是一恶夫。 俺只待立刘邦觑伊行如粪土， 山顶上常则是活捉拿，纵征驼，亲去取。 不提防，列千枝脚登弩，列千枝脚登弩，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同上，同耍刀。马童上，开打，同下。"
        },
        {
          "character": "韩信",
          "type": "天下乐",
          "text": "一个逞着雄图，九里山摆着阵图。"
        },
        {
          "character": "韩信",
          "type": "念",
          "text": "俺这里！"
        },
        {
          "character": "韩信",
          "type": "哪吒令",
          "text": "望上射似飞蝗骤雨， 望下看，大刀和那巨斧。 密匝匝队伍，要擒拿项羽， 见樊哙旗在手，便麾在垓心内，点起着百万军卒。"
        },
        {
          "character": "韩信",
          "type": "鹊踏枝",
          "text": "汉高祖洪福大，俺韩信思扶助， 九里山施展六韬书。 大会合，亲摆布， 托赖着圣天子百灵扶。 张子房在高埠处， 悲歌声能散楚。 楚歌儿吹散了八千子弟归何处？ 不提防先有埋伏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将、项羽同上，开打，同下。"
        },
        {
          "character": "韩信",
          "type": "胜葫芦",
          "text": "中军帐里梦回初， 原来是霸王要登途。 那虞姬亲把离情诉， 腰下借昆吾，血溅了美人图，血溅了美人图。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人、项羽同上，开打，同下。"
        },
        {
          "character": "韩信",
          "type": "么篇",
          "text": "正撞着九江王英布， 难逃俺十面埋伏。 这的是乌江，不是无船渡， 错走阴灵路，耻向东吴，耻向东吴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将同上，项羽上。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "杀了半天，并无问个名儿。 呔！尔叫何名？"
        },
        {
          "character": "魏豹",
          "type": "念",
          "text": "魏豹大将军，何须通姓名？闻俺须下马，饶恕你残生！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "魏豹，孤在彭城救你一十八口家眷，今日为何挡孤的去路？看枪！"
        },
        {
          "character": "魏豹",
          "type": "白",
          "text": "大王，我岂不知“报恩”二字？奈韩元帅在山顶上瞭战。我与大王假战三合， 引大王出阵便了。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "魏豹！"
        },
        {
          "character": "魏豹",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "我的儿！"
        },
        {
          "character": "魏豹",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "孤家枪尖下无眼，要你仔细！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "魏豹引项羽同下。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "项羽逃生！"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "何人放走？"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "魏豹放走。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "将魏豹斩首。"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "魏豹也逃走！"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "带马追至乌江！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}