{
  "script_id": "02005034",
  "title": "千金闸",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "李玄霸",
      "hangdang": "净"
    },
    {
      "name": "杨林",
      "hangdang": "净"
    },
    {
      "name": "罗成",
      "hangdang": "小生"
    },
    {
      "name": "靓旋妃",
      "hangdang": "小旦"
    },
    {
      "name": "李靖",
      "hangdang": "生"
    }
  ],
  "plot": "李世民同李元霸、李靖出兵征王世充途中，忽遇罗成。据言往应朝廷武场考试，夺取功名。李靖谓此乃杨林\n辈诱杀天下英雄之诡计，千万不可前往。李元霸闻知：“杨贼欲杀天下英雄，吾必须前往拯救”。遂与罗成\n同往。至考场后，罗成夺得状元，程咬金夺得榜眼。第三场争探花时，杨林命其大将左杰出马，秦琼将左杰\n打死。杨林不但不令秦琼为探花，反念倒铜旗之怨，要与秦琼比枪。秦琼败下，杨林正追秦琼时，罗成乘机\n将杨林杀死，武场大乱。官兵蜂拥前来，秦琼乃与罗成奔往东门，夺关而出。惟离城十里，有关隘一座，名\n千金闸。由靓旋妃把守。善用飞铙，英武过人。罗成因靓旋妃曾隶其父部下，百般恳求，靓旋妃始应允将闸\n吊起，秦琼等一行，得以逃出云。",
  "notes": "剧本中李元霸作李玄霸。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八小军、八将官、四大将引李世民同上。"
        },
        {
          "character": "李世民",
          "type": "玉玲珑",
          "text": "武德欲昌汉鼎， 义旗待扫秦灰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李玄霸上。"
        },
        {
          "character": "李玄霸",
          "type": "念",
          "text": "休夸霸王无双勇，斩将搴旗立大功。三锤击走裴元庆，两手擎天赤胆忠。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "吾乃李世民是也。"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "俺乃李玄霸是也。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "我父王初登大位，据守太原，听从吾计，奋图大业，赖有李药师弃暗投明，归 附吾下，我已授为参谋。奉父王之命，同弟领兵进讨萧铣，且待参谋到营，然 后发兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李靖上。"
        },
        {
          "character": "李靖",
          "type": "玉玲珑",
          "text": "骏马千金逢信， 鹏程万里初飞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李靖见。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "参谋，孤奉父王之命，同四弟进讨萧铣，专候参谋发兵。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "臣启殿下：想东都萧铣，虽然强暴，尚为后着。即今王世充聚兵数万，屯于河 南，必难摇动。为今之计，莫若移兵先征世充，世充若破，则唇亡齿寒，那萧 铣不攻而自破矣。"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "参谋差矣！休长他人志气，灭俺自己威风，凭着俺父王的福量，哥哥的英名， 俺玄霸的武艺，怕甚么萧铣，怕甚么世充，总是发兵前去。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "贤弟，军机自有妙用。毕竟参谋主见不差，我们移兵先打河南王世充便了。 众将官往河南进兵，不许惊动百姓，有犯条约，斩首示众。"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "大小三军，就此发兵。"
        },
        {
          "character": "八小军、八将官、四大将、李世民、李玄霸、李靖",
          "type": "同芙蓉普天",
          "text": "兵扬破敌威， 令出排山势尽。 披坚执锐， 气吐虹霓。 扫除风火金戈沸， 涤荡烟尘铁马驰。 看堂堂义旗， 管先声到处，尽勦鲸鲵。"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "好严整人马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。罗成上。"
        },
        {
          "character": "罗成",
          "type": "普天红",
          "text": "鬼门关、轻锤碎， 阴灵道，求活计。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "我、罗成。得蒙靓旋妃相救，意欲投奔表兄。一路行来，听说颁下郊天大赦诏 书，赦取一应反叛烟尘之罪，一面江都设立武场，命天下英雄好汉，尽来考夺 状元。我想此乃英雄队里驰名，好汉场中出色之事，岂可不去。"
        },
        {
          "character": "罗成",
          "type": "普天红",
          "text": "须不是逞微能， 逐浪随波，夺元魁好胜争奇。"
        },
        {
          "character": "李靖",
          "type": "内白",
          "text": "公子慢行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民、李靖、李玄霸、八小军、八将官、四大将同上。"
        },
        {
          "character": "八小军、八将官、四大将、李世民、李玄霸、李靖",
          "type": "同普天红",
          "text": "雄名久提， 岂陌路萍踪会。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "原来药师公。自蒙汲引之恩，未尽涓埃之报，空铭五内，徒戴二天。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "相逢半面，未罄寸心，复得班荆，顿消尘渴。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "此位？"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "是太原二殿下。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "嗄，原来就是李公子，真乃异人异相。那江中跃鲤十八子，岂不应在他身上？ 公子，久仰英名，每萦梦想，得占芝宇，足慰葵心。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "罗兄名闻四海，气压千秋，一旦垂青，少伸积愫。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "此位？"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "就是主公令弟讳玄霸。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "哦这就是四公子么？"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "着嗄罗大哥，俺向来也闻你的好名，今日相逢，俺李玄霸好快活也。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "久闻四公子，天下好汉名魁第一，今朝见面，名不虚传。"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "罗大哥，俺也不会通文调武，你我都是英雄好汉。"
        },
        {
          "character": "李靖",
          "type": "念",
          "text": "相逢不用多开口，都是龙华会里人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李玄霸背躬。"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "果是英雄才品。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "请问罗兄，前日闻得帮着秦叔宝，倒了铜旗，天下英雄，尽皆惊服，今日为何 独自在此？"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "不要说起，为了此事，得罪于家严，要将我乱箭射死。幸亏沙陀国公主相救， 逃难到此。因闻朝庭开设武场，先颁郊天诏书，招取天下英雄，不论叛臣草寇， 尽准入场会试，考夺状元，因此小弟呵！"
        },
        {
          "character": "罗成",
          "type": "朱奴剔银灯",
          "text": "附骥影，观光武围， 展倦翮，少做雄飞。"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "妙嗄！"
        },
        {
          "character": "李玄霸",
          "type": "朱奴剔银灯",
          "text": "闻说风声好臊皮，"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "兄嗄！"
        },
        {
          "character": "李玄霸",
          "type": "朱奴剔银灯",
          "text": "这快活事要做成兄弟。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "公子！"
        },
        {
          "character": "李靖",
          "type": "朱奴剔银灯",
          "text": "休题这机关，怎知英雄辈， 必遭祸危。"
        },
        {
          "character": "李世民、李玄霸、罗成",
          "type": "同白",
          "text": "请问先生，为何天下英雄遭祸起来？"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "这是杨林与宇文化及商量的钓鳌设饵，调虎离山之计。"
        },
        {
          "character": "李世民、李玄霸、罗成",
          "type": "同白",
          "text": "何以见得。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "目今天下豪杰，反叛朝庭，俱有虎噬狼吞之志。他特设此计，赚取英雄入彀， 使彼自相吞并，必欲杀尽天下好汉，方为畅快。你二人如何去得？"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "先生不说这话，倒也罢了。你若说起，使我怒从心上起，恶向胆边生。杨林你 这厮要杀尽天下的好汉，我李玄霸偏要去保救天下的好汉哩！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "贤弟少要卤莽，我与隋朝，乃仇敌之国，你一人如何去得？"
        },
        {
          "character": "李玄霸",
          "type": "白",
          "text": "王兄嗄！"
        },
        {
          "character": "李玄霸",
          "type": "银灯炤芙蓉",
          "text": "那三百辈都是俺一身护持， 偏要在万人场，做个出人头地。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "那杨林这一根虎头枪也非同小可。"
        },
        {
          "character": "罗成",
          "type": "白",
          "text": "嗄公子，舍下罗家枪，也不弱与他。"
        },
        {
          "character": "罗成",
          "type": "银灯炤芙蓉",
          "text": "这虎头枪伎俩如儿戏， 管替那英雄争气。"
        },
        {
          "character": "罗成、李玄霸",
          "type": "同白",
          "text": "我二人去也，请了！"
        },
        {
          "character": "罗成、李玄霸",
          "type": "同银灯炤芙蓉",
          "text": "休迟滞，把行旗暂离， 管一朝天关，夺得锦标归。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "罗成、李玄霸同下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "他二人竟自去了。 主公暂把人马扎住，前途差人，悄到江都，暗暗打听便了。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "有理。 众将官到前面扎住营寨，打听消息，方可进兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八小军、八将官、四大将同应。"
        },
        {
          "character": "八小军、八将官、四大将、李世民、李靖",
          "type": "同尾声",
          "text": "奸雄摆下牢笼计， 较胜争强任我为， 看此日搅海翻江名儿天下知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四小军、四将官、左杰引杨林同上。"
        },
        {
          "character": "杨林",
          "type": "点绛唇",
          "text": "大设张罗，玉关添锁，非小可，只看俺扫荡群魔，反掌把升平贺。"
        },
        {
          "character": "左杰",
          "type": "白",
          "text": "左杰宣令官打躬。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "起过一边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左杰应。"
        },
        {
          "character": "杨林",
          "type": "念",
          "text": "心事如麻把剑弹，一朝调虎便离山。总然山泽英雄众，只当平常卒隶看。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "孤、杨林。前与许国公定计，大开武场，已颁赦诏。那各路草寇，及将士军民 人等，尽来考试，争夺状元。我已设计，暗地将大炮施放，将他们一齐震死。 不想天降大雨，平地水深三尺，大炮不能燃点，第一计就不能行了，只得要用 第二计了。 宣令官，即着天下举子，按册点名，教他们鱼贯而入，前来听令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左杰应。"
        },
        {
          "character": "左杰",
          "type": "白",
          "text": "天下举子，按册点名，鱼贯而入，前来听令。 （苏定方、沈千金、姚大勇、祁大炮、马大头、秦琼、罗成、程咬金、王伯党、尤俊达、齐国远内同应。苏 定方、沈千金、姚大勇、祁大炮、马大头、秦琼、罗成、程咬金、王伯党、尤俊达、齐国远同上。）"
        },
        {
          "character": "苏定方、沈千金、姚大勇、祁大炮、马大头、秦琼、罗成、程咬金、王伯党、尤俊达、齐国远",
          "type": "同白",
          "text": "大王在上，众举子参见。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "分列两边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏定方、沈千金、姚大勇、祁大炮、马大头、秦琼、罗成、程咬金、王伯党、尤俊达、齐国远同应。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "众举子听者：第一场比箭，场角头建立高杆，杆上挂一金钱，有能射中者，取 为状元。第二场较力，台前有青石夔龙一座，重有千斤，有人举得动者，取为 榜眼。第三场比试武艺，高强胜者取为探花，台下候令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏定方、沈千金、姚大勇、祁大炮、马大头、秦琼、罗成、程咬金、王伯党、尤俊达、齐国远同应，同下。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "你看众举子英才济济，杀气腾腾，眼见得不知分量的人，皆入我彀中也！"
        },
        {
          "character": "杨林",
          "type": "混江龙",
          "text": "他那里雄星飞布， 俺这里惊天撼地， 大开科，端则为金鸡颁赦， 铁骑飞凫，总不论法遐荒雕提黑齿。 也莫问哨萑篝犬鸣孤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "沈千金、齐国远、苏定方、罗成同上，同绕场，同下。"
        },
        {
          "character": "杨林",
          "type": "混江龙",
          "text": "但得他鹰扬名姓登榜记， 少不得龙虎排位次调和。 也不用咬文字，掉书囊，文章班马， 也不用动王侯，倾世主，口舌随何。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "沈千金上，射，下。齐国远上，射，下。"
        },
        {
          "character": "苏定方",
          "type": "内白",
          "text": "俺来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏定方上。"
        },
        {
          "character": "苏定方",
          "type": "白",
          "text": "大王，俺苏定方愿射金钱。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "你就射来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏定方应，射中。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "妙嗄！"
        },
        {
          "character": "杨林",
          "type": "混江龙",
          "text": "百花丛争夺这状元红， 万人场独显的英雄武。 这才是第一筹的好汉， 压倒了千百辈的价偻㑩。"
        },
        {
          "character": "左杰",
          "type": "白",
          "text": "启大王：苏定方三箭中金钱。"
