      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈氏、田奶公、田奶母、田翠兰同上。"
        },
        {
          "character": "田奶公",
          "type": "白",
          "text": "哎呀！ 中国京剧戏考 《九莲灯》【八本】 5"
        },
        {
          "character": "田奶公",
          "type": "二黄摇板",
          "text": "一连走了三日整， 受尽风霜劳苦情。 忽然前面征云起， 杀气腾腾冲碧空。 连珠火炮声声振， 迎头来了众贼兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八难民、四下手自两边分抄上，同跑过场，同下。"
        },
        {
          "character": "田奶公",
          "type": "白",
          "text": "哎呀！"
