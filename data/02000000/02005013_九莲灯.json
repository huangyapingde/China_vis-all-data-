          "type": "同唱",
          "text": "恨不得插双翅飞往都郡， 但愿得早进京诸事安宁。"
        },
        {
          "character": "田奶公、田奶母、陈氏、田翠兰",
          "type": "同白",
          "text": "走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田奶公、田奶母、陈氏、田翠兰同下。"
        }
      ]
    },
    {
