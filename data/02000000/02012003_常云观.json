          "character": "张杰",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马盛玄、张杰、高珍、庞德同坐。"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "张二爷，方才言道，净街太岁江三虎，莫非就是那江环？"
        },
        {
          "character": "张杰",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "他可在家？"
        },
        {
          "character": "张杰",
          "type": "白",
          "text": "二位休要提起，前日被赃官于德水斩首法场，故而我逃在此处。"
        },
        {
          "character": "高珍、庞德",
          "type": "同叫头",
          "text": "赃官哪赃官！"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "这绿林英雄，与你有何仇恨，因甚苦苦相害？"
        },
        {
          "character": "高珍、庞德",
          "type": "同西皮摇板",
          "text": "可恨赃官理不端， 苦害绿林为哪般？ 有日见了赃官面， 碎尸万段心方甘！"
        },
        {
          "character": "马盛玄",
          "type": "白",
          "text": "众位英雄，后面摆筵，一同畅饮。"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "来此就要打搅。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
