      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "高曾、计迁、于德水同改扮上。"
        },
        {
          "character": "于德水",
          "type": "西皮摇板",
          "text": "本来面目暗藏隐， 巧装改扮一民人。"
