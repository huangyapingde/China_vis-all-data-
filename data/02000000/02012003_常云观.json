          "character": "李虎",
          "type": "白",
          "text": "老爷你若不服，敢与我擦拳比武么？"
        },
        {
          "character": "王雷",
          "type": "白",
          "text": "怎的不敢？"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "我们这里有规矩，若输若赢必有赏罚。"
        },
        {
          "character": "王雷",
          "type": "白",
          "text": "输了怎说，赢了怎讲？"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "我们若输，将擂台立刻急收。老爷呢？"
        },
        {
          "character": "王雷",
          "type": "白",
          "text": "你们只管摆。"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "一言为定。如此小人等得罪了。"
        },
        {
          "character": "王雷",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王雷、李虎同比拳。李虎打。王雷倒。"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "老爷你有何话讲？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王雷起。"
        },
        {
          "character": "王雷",
          "type": "白",
          "text": "咳！你们只管摆着，我不管了。 众官兵，回衙！ （四黑文堂、四上手、四官兵、王雷同下。四红文堂、四红大铠、书吏、门子、轿夫、东方溥、路凯、欧阳 山同上，过场，同下。）"
        },
        {
          "character": "李虎",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "看大人大轿已到，我不免请出师父商议。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "三下手、高士虎、董瑞、王龙、高珍、庞德同上。"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "徒弟何事？"
        },
        {
          "character": "李虎",
          "type": "白",
          "text": "于大人大轿已到。"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "好哇，迎上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、书吏、门子、轿夫、东方溥、路凯、欧阳山同上。"
        },
        {
          "character": "东方溥",
          "type": "白",
          "text": "准备了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、高士虎、李虎、董瑞、王龙、庞德、高珍同上。"
        },
        {
          "character": "东方溥",
          "type": "白",
          "text": "待我向前。 呔，何处贼寇，敢挡住大轿的去路！"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "原来是东方大哥，小弟不知，望乞恕罪。"
        },
        {
          "character": "东方溥",
          "type": "白",
          "text": "呵，我道谁人挡住大轿的去路，原来是高、庞二位贤弟。我且问你，挡住大轿 去路何事？"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "要刺杀赃官。"
        },
        {
          "character": "东方溥",
          "type": "叫头",
          "text": "贤弟！"
        },
        {
          "character": "东方溥",
          "type": "白",
          "text": "想那于大人乃是一位忠良，为国爱民，到处捕强拿盗，除恶安良，为何要刺杀 于他？我劝你等早回通天寨，如若不然，尔等可知道某家的夺命狼镖的厉害！"
        },
        {
          "character": "高珍",
          "type": "叫头",
          "text": "东方溥！"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "想你当年发下誓愿，永不出世。再若出世，死在药箭之下。今日保护赃官，苦 害绿林，老匹夫你为了何事？"
        },
        {
          "character": "东方溥",
          "type": "叫头",
          "text": "高珍！"
        },
        {
          "character": "东方溥",
          "type": "白",
          "text": "我劝你等好好走去，如若不然，某家就要得罪了！"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "众英雄杀上前去。 （高珍、东方溥同起打。〖牌子〗。马盛玄、张杰同上，同续打。四下手、高士虎、李虎、董瑞、王龙、庞 德、高珍、马盛玄、张杰同败下。四红文堂、四红大铠、书吏、门子、轿夫、东方溥、路凯、欧阳山同追下。）"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马盛玄、张杰同上。"
        },
        {
          "character": "马盛玄",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": "马盛玄",
          "type": "白",
          "text": "看东方溥他等杀法厉害，逃走了罢。"
        },
        {
          "character": "张杰",
          "type": "白",
          "text": "你我兄弟逃往何处。"
        },
        {
          "character": "马盛玄",
          "type": "白",
          "text": "看前面不远，地名月屯，那里有一毗卢铁佛寺。我有一师弟名唤蓝脸头陀僧海 元，你我到那里可以安身，待等锐气养足，再报此仇不迟。"
        },
        {
          "character": "张杰",
          "type": "白",
          "text": "如此走哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。马盛玄、张杰同下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四下手、高士虎、李虎、董瑞、王龙、庞德、高珍、四红文堂、四红大铠、书吏、门子、轿夫、东方溥、"
        },
        {
          "character": null,
          "type": "text",
          "text": "路凯、欧阳山同上，同打。四下手、高珍、庞德、高士虎、董瑞同逃走下。李虎、王龙同被擒。）"
        },
        {
          "character": "东方溥",
          "type": "白",
          "text": "将贼寇绑至定兴县，去见大人去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、高珍、庞德、高士虎、董瑞同上。"
        },
        {
          "character": "高珍",
          "type": "西皮摇板",
          "text": "高碑店前逃性命，"
        },
        {
          "character": "庞德",
          "type": "西皮摇板",
          "text": "跳出龙潭虎穴中。"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "贤弟，你我只望将赃官于德水杀死。不料东方溥定计，将赃官巧扮私行。你我 大败，李虎、王龙被擒，如何是好？这才是画虎不成反类犬！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "大哥不必着急，看前面离东方老儿家下不远。你我去至他家，将他妻室宋氏杀 死。然后将他家中金银劫抢，也算报了此仇。回到通天寨，见了龙大王，再想 计策，复报此仇。大哥你意下如何？"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "贤弟言得极是，趁此他家中无人，就此打抢去者！"
        },
        {
          "character": "高珍",
          "type": "西皮摇板",
          "text": "休怪你我太不仁，"
        },
        {
          "character": "庞德",
          "type": "西皮摇板",
          "text": "皆因老儿害绿林。"
        },
        {
          "character": "高珍",
          "type": "西皮摇板",
          "text": "众家英雄朝前进，"
        },
        {
          "character": "庞德",
          "type": "西皮摇板",
          "text": "劫抢他家金共银。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宋氏上。"
        },
        {
          "character": "宋氏",
          "type": "西皮摇板",
          "text": "乌鸦不住当头叫， 叫得老身心内焦。 将身且把前庭到，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内喊声〗。"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "宋氏",
          "type": "西皮摇板",
          "text": "又听人马闹吵吵。 内侄宋成一声叫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋成上。"
        },
        {
          "character": "宋成",
          "type": "西皮摇板",
          "text": "急忙上前问根苗。"
        },
        {
          "character": "宋成",
          "type": "白",
          "text": "参见姑母。"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "罢了。一旁坐下。"
        },
        {
          "character": "宋成",
          "type": "白",
          "text": "谢坐。姑母唤侄儿出来，有何训教？"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "儿吓，你在外面不曾听见么？"
        },
        {
          "character": "宋成",
          "type": "白",
          "text": "听见什么？"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "为姑母方才听见外面马嘶人吼，不知为了何事？"
        },
        {
          "character": "宋成",
          "type": "白",
          "text": "为侄儿不曾听见。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庄丁上。"
        },
        {
          "character": "庄丁",
          "type": "白",
          "text": "老夫人，大事不好了！"
        },
        {
          "character": "宋氏、宋成",
          "type": "同白",
          "text": "何事惊慌？"
        },
        {
          "character": "庄丁",
          "type": "白",
          "text": "外面有无数贼寇，将庄子围住了。"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "哪里贼寇？"
        },
        {
          "character": "庄丁",
          "type": "白",
          "text": "也不知哪里贼寇。杀进来了！"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": "宋氏",
          "type": "西皮摇板",
          "text": "听一言来吃一惊， 何处贼寇来行凶！ 员外若在家中坐，"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "贼呀！"
        },
        {
          "character": "宋氏",
          "type": "西皮摇板",
          "text": "管叫贼寇丧手中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四下手、高珍、庞德、高士虎、董瑞同上。"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "来者莫非是高、庞两位贤弟？你哥哥不在家中，为何一拥而进？敢是欺我家中 无人么？"
        },
        {
          "character": "高珍、庞德",
          "type": "同叫头",
          "text": "嫂嫂哇！"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "我等此来，实对你说：只因那东方溥帮助赃官于德水，与绿林作对，将我两个 徒弟在高碑店前擒去。我二人怀恨在心，因此来到你家，要报仇恨！"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "好贼子！"
        },
        {
          "character": "宋氏",
          "type": "西皮摇板",
          "text": "看你人多凶又猛， 敢把老身怎样行！"
        },
        {
          "character": "高珍",
          "type": "西皮摇板",
          "text": "听一言来怒气冲， 大胆乞婆敢逞能。 手持金锏要你命！"
        },
        {
          "character": "宋成",
          "type": "西皮摇板",
          "text": "一群贼寇乱胡行。 钢刀举起追尔命！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋成、高珍同杀过合。"
        },
        {
          "character": "高珍",
          "type": "西皮摇板",
          "text": "一锏打倒地流平。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋成跑下。"
        },
        {
          "character": "高珍、庞德",
          "type": "同叫头",
          "text": "老乞婆！"
        },
        {
          "character": "高珍、庞德",
          "type": "同白",
          "text": "你快快说，你金银放在何处？我等自取，以为路费。"
        },
        {
          "character": "宋氏",
          "type": "叫头",
          "text": "贼寇！"
        },
        {
          "character": "宋氏",
          "type": "白",
          "text": "你就将老身打死，也无金银！"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "看锏！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高珍打死宋氏，宋氏下。"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "贤弟，看老乞婆已死，那小畜牲也不知往哪里去了。你我不免将金银劫抢回山 便了！"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "言得有理。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高珍、庞德同盗金银。"
        },
        {
          "character": "庞德",
          "type": "白",
          "text": "仁兄，金银倒也足够，不免外面，将他的驴马牵走便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "庞德牵牲口。"
        },
        {
          "character": "高珍",
          "type": "白",
          "text": "牲口金银，业已到手。 徒弟们，回山交令去者！"
        },
        {
          "character": "四下手、高士虎、董瑞",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "高珍、庞德",
          "type": "同三笑",
          "text": "咿嘻，啊哈，哇呀呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高珍、庞德同放火烧房。火彩。众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宋成上。"
        },
        {
          "character": "宋成",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": "宋成",
          "type": "白",
          "text": "看这伙贼人将金银牲口盗走，又将俺姑母打死，趁贼人走远，我不免去至公馆， 与姑爹送信便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖扫头〗。宋成下。〖尾声〗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
