    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "（四红文堂、四红大铠、书吏、门子、高曾、东方溥、路凯、欧阳山、计迁、于德水同上。〖牌子〗。四红"
        },
        {
          "character": null,
          "type": "text",
          "text": "文堂、四红大铠、书吏、门子同斜一字。）"
        },
        {
          "character": "于德水",
          "type": "白",
          "text": "公馆去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四红文堂、四红大铠、书吏、门子同凹门。"
        },
        {
          "character": "门子",
          "type": "白",
          "text": "人役两厢退下。"
