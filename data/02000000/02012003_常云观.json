        {
          "character": "王雷",
          "type": "白",
          "text": "掩门！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手同领下。"
        },
        {
          "character": "王雷",
          "type": "西皮摇板",
          "text": "要想摆擂不许他。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王雷下。"
        }
      ]
