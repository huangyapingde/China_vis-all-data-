  ],
  "plot": "卫小申出马与番邦人才驸马交战，大败而归。继由高能、杨仙童与二位公主玉宝、玉珍交战，二位公主并将\n杨仙童、高能二将留宿，最后又将原来之人才驸马杀死。",
  "notes": "剧中情节，极不伦类。殆系一个喜剧，不必深究也。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张天龙上。"
        },
        {
          "character": "张天龙",
          "type": "引子",
          "text": "虎踞番邦，招纳东床。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵引玉珍公主、玉宝公主同上。"
        },
        {
          "character": "玉珍公主、玉宝公主",
          "type": "同引子",
          "text": "为大将，邪术无挡，中原反掌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉珍公主、玉宝公主同见礼。"
        },
        {
          "character": "张天龙",
          "type": "念",
          "text": "身驱高大似天罡，南朝将士谁敢挡。"
        },
        {
          "character": "玉珍公主",
          "type": "念",
          "text": "上阵不用多费力，"
        },
        {
          "character": "玉宝公主",
          "type": "念",
          "text": "仗着邪术把人降。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "俺乃土番国人才驸马张天龙是也。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "俺乃赛天仙玉珍公主是也。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "俺乃赛美人玉宝公主是也。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "可恨南朝杨家玉芙蓉挂印为帅，统兵前来扫灭番邦。前番一战被我擒了她上将 多名，囚禁在此。待等擒了玉芙蓉解送我国献功便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌上。"
        },
        {
          "character": "旗牌",
          "type": "白",
          "text": "启驸马：南朝搬来救兵前来讨战。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "旗牌下。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "南蛮被困沙河，水洩不通，何处救兵得到此处？"
        },
        {
          "character": "玉珍公主、玉宝公主",
          "type": "同白",
          "text": "驸马不要管他，有我二人。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "不用你二人，且为后队。待我攻打头阵。"
        },
        {
          "character": "张天龙",
          "type": "唱",
          "text": "听说南蛮有救兵， 口内不言心内明。 个个前来把命送，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉珍公主、玉宝公主、四女兵同下。"
        },
        {
          "character": "张天龙",
          "type": "唱",
          "text": "使起法宝一股擒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《双沙河》【二本】 2"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申上。"
        },
        {
          "character": "卫小申",
          "type": "唱",
          "text": "我奉元帅令，来打张天龙，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙上。"
        },
        {
          "character": "张天龙",
          "type": "唱",
          "text": "骂声黑贼哪里行！"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "马前来的丑鬼，通名受死。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "什么？他妈的。卫爷。你叫什样东西？"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "你要问俺，俺乃人才驸马张天龙。"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "我把你这个贼王八日的！"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "你大不过我拳头，高不过我的膝盖，待你驸马擒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙杀，张天龙下，卫小申追下。张天龙上。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "这厮倒也厉害，用招魂旗擒他便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申上，杀。张天龙用大手抓卫小申，卫小申下，狗形上，下。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "我看你哪里走！ 哎吓，跑了跑了。 黑蛋慢走，你驸马爷来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四手下、杨仙童同上。〖水底鱼〗。卫小申上。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "表兄回来了？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "回来了。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "可曾见过阵了？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "见过了。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "人有多高？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "有天高。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "马呢？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "有象大。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "兵器呢？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "都是丈七丈八的。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "他叫什么名字？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "人才驸马张天龙。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "胜败如何？"
        },
        {
          "character": "卫小申",
          "type": "白",
          "text": "变狗而逃。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "怎么变犬败回？如今怎么样？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申虚白。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "可笑表兄太无能， 待俺前去看分明。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童、四手下同下，卫小申下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四手下、高能同上。"
        },
        {
          "character": "高能",
          "type": "唱",
          "text": "兄弟三人要争功， 不知谁雌与谁雄？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四女兵引玉珍公主同上，会阵，杀，对把子。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "来将通名。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "俺乃天朝大将高能是也。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "高将军，你我这么交战为什么？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "为主江山。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "江山得了，还是你坐我坐？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "哪有臣坐君位之礼？ 中国京剧戏考 《双沙河》【二本】 3"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "却又来。你我都不能坐，为什样这么冤呢？"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "依你便怎么样。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "依我你且收兵回去，晚上我在帐中等你。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "你的帐房在哪里？"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "你看黄罗帐。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "是哪个的？"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "是我们驸马的。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "可是张天龙？"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "是了。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "待我去杀了他。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "不用杀他。你要成功全在我哪！"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "你的帐房呢？"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "你看那红罗帐。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "今晚到你帐房去。"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "来者君子。"
        },
        {
          "character": "高能",
          "type": "白",
          "text": "不来呢？"
        },
        {
          "character": "玉珍公主",
          "type": "白",
          "text": "不来者小人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高能、四手下、玉珍公主、四女兵同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "卫小申上，唱〖耍孩儿〗。张天龙上。"
        },
        {
          "character": "张天龙",
          "type": "唱",
          "text": "两家大战在杀场，"
        },
        {
          "character": "卫小申",
          "type": "唱",
          "text": "一来一往各逞强。"
        },
        {
          "character": "张天龙",
          "type": "唱",
          "text": "霸王逞强乌江丧，"
        },
        {
          "character": "卫小申",
          "type": "唱",
          "text": "韩信丧命在未央。"
        },
        {
          "character": "张天龙",
          "type": "唱",
          "text": "天龙祭起神法宝，"
        },
        {
          "character": "卫小申",
          "type": "唱",
          "text": "卫爷跑了又跑了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申下。"
        },
        {
          "character": "张天龙",
          "type": "白",
          "text": "哎，又跑了。扫兴。"
        },
        {
          "character": "张天龙",
          "type": "唱",
          "text": "天龙败了神法宝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "卫小申上。"
        },
        {
          "character": "卫小申",
          "type": "唱",
          "text": "流星断送你一命消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张天龙下，卫小申追下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四手下引杨仙童同上，四女兵、玉宝公主同上。"
        },
        {
          "character": "玉宝公主",
          "type": "唱",
          "text": "两家交战同勒马， 阵前来了一小娃。 看他不是凡人样， 好似天宫小哪叱。"
        },
        {
          "character": "杨仙童",
          "type": "唱",
          "text": "站立阵前用目观， 那旁来了一婵娟。 虽然她是胡地女， 聘婷容貌似天仙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仙童、玉宝公主同杀，同下。四女兵、四手下同对把子，同下。杨仙童、玉宝公主同上，同杀。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "不用动手咧。你叫什么名字？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "少爷杨仙童。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "你我杀来杀去，弄个稀烂，为的是什么？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "俺要你的命。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "我和你有冤？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "无冤。 中国京剧戏考 《双沙河》【二本】 4"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "有仇？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "无仇。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "既无冤仇，为什么要我的命呢？"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "俺要扫尽番奴，保俺元帅回朝。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "你要保你家元帅回朝，我与你商量商量。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "商量什么？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "你我暂且收兵，咱们俩留个交情。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "我们南朝人不懂交情。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "好。南朝人连交情都不懂得，怎么好呢？ 吓，附耳过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "玉宝公主附耳。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "且住。我下山时节，师父言道：有花就采。莫非就此成功？ 吓，你的帐房在哪里？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "你瞧那黄罗帐。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "是谁的？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "是我们驸马的。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "可是那张天龙？待我去毁了他。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "你毁不成他，再叫他干了。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "不能。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "你瞧那红罗帐。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "又是哪个的？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "是我姐姐的。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "你姐姐比你长的怎么样？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "这个色鬼。你瞧那素罗帐。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "是谁的？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "是我的。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "巧了，素罗帐对我出家的劲。"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "我在素罗帐等你。"
        },
        {
          "character": "杨仙童",
          "type": "白",
          "text": "等我作什么？"
        },
        {
          "character": "玉宝公主",
          "type": "白",
          "text": "与你开荤。"
        },
