        {
          "character": "严颜",
          "type": "白",
          "text": "好。赏他们银牌一面，免差一月，后帐歇息去吧。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "谢元帅。"
        },
        {
          "character": null,
          "type": "stage",
