          "type": "白",
          "text": "是。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "抬起头来。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "小人不敢抬头。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞笑。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嘿，你千岁就像他这个样儿吗？"
