        {
          "character": "严颜",
          "type": "唱",
          "text": "老军探信未回营， 不由老夫心内惊。 闷忧忧坐在莲花帐， 待等探马报军情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同上。"
        },
