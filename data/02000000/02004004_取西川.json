        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "哎呀，唬死我啦，这是哪里打霹雷？"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "是千岁爷声音洪亮。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "徐大汗，随你千岁爷到两军阵前。倘若有人问你，来将通名，你就说汉将张飞。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "小人不敢。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "恕你无罪。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "谢千岁。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "来来来，我们来演习演习。 呔，来将通名。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "炮手徐大汗。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "放屁！叫你说汉将张飞。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "重来，重来。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，来将通名。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "汉将张飞。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "声高些。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "汉将张飞。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "取爷的丈八蛇矛与他。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "啊呀呀，我可拿不动他。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "无用的东西，换个旂枪儿与他。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "着吓，这才是我的兵器。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "千岁与你就此前去。 三军的，小心看守营盘。 徐大汗向前带来，马来。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "军师锦囊费猜疑， 徐大汗扮作假张飞。 没奈何拨草把路觅， 夺取西川见先机。"
        },
        {
          "character": "徐大汗",
          "type": "白",
          "text": "千岁随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
