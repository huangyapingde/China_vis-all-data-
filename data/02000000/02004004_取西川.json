{
  "script_id": "02004004",
  "title": "取西川",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "张飞",
      "hangdang": "净"
    },
    {
      "name": "严颜",
      "hangdang": "老生"
    },
    {
      "name": "徐大汗",
      "hangdang": "丑"
    }
  ],
  "plot": "张飞攻打西川，守将严颜，骁勇善战，不能取胜。最后用诸葛亮之计，先令另一人假装张飞，与严颜交战，\n然后自己抄袭后路，始得将严颜生擒。张飞亲为严颜解绑，并跪在地下，求严颜归降。严颜激于义气，遂归\n降汉营。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八卒引张飞同上。〖风入松〗。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "铁甲玲珑背，青巾压豹头。胯下乌骓马，手提丈八矛。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "某，张飞。奉军师将令，带领人马，攻打西川。 三军的，"
        },
        {
          "character": "八卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "催动人马。"
        },
        {
          "character": "八卒",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "严颜上，起霸。"
        },
        {
          "character": "严颜",
          "type": "念",
          "text": "白盔白甲素白旗，白旗招展似雪飞。胯下能行如白虎，要擒汉室猛张飞。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "老夫，严颜。西蜀刘王驾前为臣，官居五马太守，镇守通江巴州。适才探子报 道，张飞兴兵前来，夺取西川。老夫镇守此处，岂肯容他闯去。 众将官，"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "就此起兵前往。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八卒、张飞同冲上。〖牌子〗。会阵。"
        },
        {
          "character": "张飞",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "呔！张飞。见了老爷，为何发笑？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "也呔！严颜，我把你这老贼！看你上马，不过拳头大，下马，不过磕膝高。有 何本领，霸占通江巴州？归顺桃园便罢，倘若不然，死在俺枪尖之下。那时悔 之晚矣！"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "若问老爷威风，尔稳坐雕鞍。听俺道来。"
        },
        {
          "character": "严颜",
          "type": "西皮导板",
          "text": "烈烈轰轰摆战场，"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "呵呵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兵卒同走圆场。严颜、张飞同战。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "二国不和动刀枪。 人道张飞是好将， 大喝一声透天堂。 巴州城内访一访， 老爷武艺比尔强。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "住了！"
        },
        {
          "character": "张飞",
          "type": "西皮导板",
          "text": "听罢言来心焦躁，"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "呵呵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兵卒同走圆场。严颜、张飞同战。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "二目圆睁似火烧。 向前来把严颜叫， 老爷言来你听着： 将而比作笼中鸟， 杀鸡焉用宰牛刀。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "两下交锋不肯让， 一来一往动刀枪。 三军儿郎齐呐喊， 老爷与尔战一场。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜杀。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "慢着慢着。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "呔，张飞，战未数合为何口吐白沫，想是尔怯战么？"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "呔，严颜，非是老爷怯战。俺口吐白沫，越战越勇。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "看枪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜杀，张飞败下，严颜追下。张飞上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊呀。你看严颜老贼，虽然年迈，枪法甚是厉害。这便怎处？吓，有了。想俺 当年在虎牢关，曾用打将钢鞭。 三军的！"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "取鞭来。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "钢鞭一举鬼神惊， 管教严颜命归阴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜上，杀。张飞打严颜败下。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "一鞭打败严颜老将， 不知老将奔何方。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞下。严颜上。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "一鞭打下千斤重， 振得老夫两膀疼。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "方才张飞一鞭打下，不是老夫躲闪得快，险遭不测。想俺幼年间，习就百步穿 杨，不免转至敌楼，射他一箭。 左右！"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "看弓箭伺候。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "安排打虎牢笼计， 谅他插翅也难飞。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜下。"
        },
        {
          "character": "张飞",
          "type": "内西皮导板",
          "text": "乌骓马不住连声吼，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "打将钢鞭马后拖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜上。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "看箭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊呀且住，你看严颜老贼，埋伏敌楼，暗放冷箭。不是俺手急眼快，险些性命 丧于他手。这个老贼果然厉害。 三军的！"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "快快地收兵罢。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、兵卒同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "严颜上。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "一箭射去叮当响， 不知张飞生死存亡。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "方才一箭射去，不知张飞生死存亡，不免命老军前去，探听虚实。 左右！"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "传老军进帐。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "吓。 传老军进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同白。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "来了。"
        },
        {
          "character": "老军甲",
          "type": "念",
          "text": "老是老了，"
        },
        {
          "character": "老军乙",
          "type": "念",
          "text": "再也不能小了。"
        },
        {
          "character": "老军甲",
          "type": "念",
          "text": "若要小了，"
        },
        {
          "character": "老军乙",
          "type": "念",
          "text": "除非死了。"
        },
        {
          "character": "老军甲",
          "type": "白",
          "text": "嗐。那就好了。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "元帅在上，小人们叩头。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "罢了。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "唤小人们，哪方使用？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "命你们前去，探听张飞的虚实。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "哎呀，那张飞杀人不展眼，小人们不敢去。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "唔！张飞会杀人，难道你爷，就不会杀人？待我教导与你们。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "你们前去，就说是通江巴州好百姓，去朝四川峨眉山。去时没有千岁营盘，回 来时遇见千岁营盘挡路，望千岁开一线之恩，放小人们过去，到家见了妻儿老 小，一家感恩非浅。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "倘若问小人们路途呢？"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "倘若问你们路途，就说南是山，北是水，中间有羊肠小道，只消一人一骑，方 能过去。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "小人们领命。"
        },
        {
          "character": "严颜",
          "type": "念",
          "text": "我今吩咐你。"
        },
        {
          "character": "二老军",
          "type": "同念",
          "text": "怎敢慢迟延。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同下。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "严颜",
          "type": "白",
          "text": "听俺号令。"
        },
        {
          "character": "严颜",
          "type": "唱",
          "text": "今番不消去打仗， 准备刀枪入营房。 若能擒得张飞将， 凌烟阁把名扬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "严颜、兵卒同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": "张飞",
          "type": "内西皮导板",
          "text": "张翼德在营盘自解自叹，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞上。"
        },
        {
          "character": "张飞",
          "type": "唱",
          "text": "思想大哥泪不干。 想前番带人马来交战， 不能够取胜甚是羞惭。 在营中想兄王难得相见， 眼睁睁怕的是拆散桃园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同上。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "启千岁：有奸细。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "抓过来。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "你们是严颜差来的奸细，探听你千岁的军情。 来，拿去砍了！"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "哎呀，千岁爷饶命！小人们不是奸细。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊，你们是什么人？"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "小人们是通江巴州好百姓，去朝四川峨眉山。去时没有千岁营盘，回来遇见千 岁营盘挡路，望千岁开一线之恩，放小人们过去。到家见了妻儿老小，一家感 恩非浅。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "我且问你们，此去西川，哪条路近？"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "此去西川，南是山，北是水，中间有条羊肠小道，必须一人一骑，方能过去。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "果然是好百姓。 来，每人赏他们两串铜钱，放他们过去。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "谢千岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同暗下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "三军的，听俺号令：今夜一更上草，二更上料，三更时分，悄悄偷过通江巴州。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同暗上。"
        },
        {
          "character": "二老军",
          "type": "同白",
          "text": "听见啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二老军同下。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "启千岁：果然是奸细。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "抓回来。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "去远了。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嗳，老张方才定下此计，又被严颜的细作听去，这便咱处？哦、哦，有了！想 我起兵的时节，军师与我锦囊一封，说事到危急，方可开看。如今事在两难之 际，何不将锦囊拆开一看，便知明白。 来。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "取锦囊来。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "吓。 锦囊呈上。"
        },
        {
          "character": "张飞",
          "type": "念",
          "text": "“书上有封皮，将军看仔细。若要擒严颜，除非两张飞。”"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "咳，想汉营中，只有老张一个，哪里还有一个？ 唔，唔，三军的，"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "看营中，可有像你千岁这样的？"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "有个炮手徐大汗，仿佛千岁的模样。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "好，传徐大汗。"
        },
        {
          "character": "兵卒",
          "type": "同白",
          "text": "传徐大汗进帐。"
        },
        {
          "character": null,
