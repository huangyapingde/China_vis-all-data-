{
  "script_id": "02004047",
  "title": "撤兵增灶",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "司马懿",
      "hangdang": "净"
    },
    {
      "name": "苟安",
      "hangdang": "丑"
    }
  ],
  "plot": "诸葛亮四出祁山，骂死王朗，气死曹真，正节节胜利之时，后主忽中司马懿用苟安散布流言之计，调诸葛亮\n回朝。蒋琬、杨仪谏阻无效。诸葛亮接旨后，即发令转回成都。又虑司马懿尾追，乃一面撤兵，一面又增添\n炉灶，使司马懿生疑。始得安然退兵，未受损失。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、戴凌、司马昭、张虎、乐琳、司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "点绛唇",
          "text": "勇冠三军，威武神勇，魏国整，西蜀擒吞，马到旗得胜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿上高台，坐。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "先帝托孤保魏邦，主听流言贬还乡。蜀兵屡犯中原地，奉命收服孔明降。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "本帅复姓司马名懿字仲达，魏王驾前为臣，官拜平西都督。与曹真共奉敕命征 服孔明，曹真、王郎倶已丧命，本帅征剿不能取胜，今又聚齐人马，与他定个 胜负。 众将官前往祁山，捉拿诸葛去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖泣颜回〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四两段头、马岱、王平、魏延、关兴、姜维接合头同上，同挖门。"
        },
        {
          "character": "马岱",
          "type": "白",
          "text": "马岱。"
        },
        {
          "character": "王平",
          "type": "白",
          "text": "王平。"
        },
        {
          "character": "魏延",
          "type": "白",
          "text": "魏延。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "关兴。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "姜维。 请了，我丞相骂死王朗，气死曹真，司马懿屡战不胜，今又领兵踹营，你我奉 命迎敌。 众将官，催动人马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。四龙套、四大铠、戴凌、司马昭、张虎、乐琳、司马懿同上，会阵，站上场。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "呔，司马懿，屡败之将，又来作甚？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "呔，姜维，反国之贼，不必多言。看枪。 （众人同杀，自两边分下，司马懿、姜维同杀下。王平擒戴凌、四文堂绑戴凌同下，马岱擒张虎，四两段头 绑张虎同下，魏延擒乐琳，四大铠绑乐琳同下，司马昭、关兴同杀，司马昭败下，司马懿接杀姜维，接杀马 岱、王平、魏延、关兴同上过门推司马懿、司马昭同下，蜀将押戴凌、张虎、乐琳自两边分上。）"
        },
        {
          "character": "众将",
          "type": "同白",
          "text": "司马懿父子逃走。"
        },
        {
          "character": "姜维、马岱、王平、魏延、关兴",
          "type": "同白",
          "text": "不必追赶，将魏将绑回大营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、司马昭、司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哎呀，蜀将甚是骁勇，将我军杀散，擒去三将，这便如何是好？也罢，不免退 于渭滨南岸下寨坚守不出。且候聚齐人马再来复战。 众将官，退于渭滨去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四车夫、四长枪上下手同上，苟安骑马上。"
        },
        {
          "character": "苟安",
          "type": "念",
          "text": "一路长行贪杯酒，故将粮草慢消停。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "俺都尉苟安是也，在永安城奉了李严将军将令，解压粮草，军中应用。 众将士，粮草打往前行。"
        },
        {
          "character": "苟安",
          "type": "唱",
          "text": "永安城奉将令催趱粮饷， 君国事何须我一人慌忙。 无边景花世界尽情玩赏， 想人生不欢乐误了时光。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "风虎云龙，报先王，托孤为重。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮坐。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "运筹帷幄感君恩，节制遗表白帝城。二度兵败司马懿，一书气死贼曹真。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吾诸葛亮。四出祁山，兵败仲达，气死曹真。今司马懿又来复战，曾命众将迎 敌，未见交令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。四文堂、四大铠、四两段头、马岱、王平、魏延、关兴、姜维同上，同挖门。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "将魏将押在后营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、四两段头自两边分下。"
        },
        {
          "character": "姜维、马岱、王平、魏延、关兴",
          "type": "同白",
          "text": "禀丞相：末将等擒得魏将三人，请令定夺。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吓，擒来三将？"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔唔，绑上来。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "吓，下面听者：丞相有令，魏营三将绑上来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四两段头押戴凌、张虎、乐琳同上。"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "同白",
          "text": "呔，诸葛亮，既将我等擒住为何不杀？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哈哈，擒尔等何足为奇，就是擒你主将，有如囊中取物，你们且通名姓，我有 恩典于你。"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "同白",
          "text": "若问我等，某乃司马元帅麾下大将军——"
        },
        {
          "character": "戴凌",
          "type": "白",
          "text": "戴凌。"
        },
        {
          "character": "张虎",
          "type": "白",
          "text": "张虎。"
        },
        {
          "character": "乐琳",
          "type": "白",
          "text": "乐琳。"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "同白",
          "text": "你问我等则甚？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "我看你们，皆是无用之辈，谅也不能成其大事，吾发恻隐之心，放尔等回去， 可叫司马懿再读兵书，重观战策。我兵屯扎在此，叫他前来，决个雌雄。"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "同白",
          "text": "既肯释放，怎不将我等松绑？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "且慢，吾今饶你性命，当留军器战马。 众将官，将他三人，就在帐前松绑，黑墨涂脸，脱了男装，即将女裙衫与他们 更换。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "姜维、马岱、王平、魏延、关兴同推戴凌、张虎、乐琳换女衣衫。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "哈哈哈，你们也有今日了。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "汉丞相用兵法神鬼难解， 司马懿何敢称将中大才。 你叫他来我营屈膝跪拜， 如不然终难免刀剑之灾。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "叉出帐去。"
        },
        {
          "character": "戴凌",
          "type": "白",
          "text": "哎呀可恼可恼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戴凌、张虎、乐琳同下。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "羞辱他已妆成妇人体态， 从今后此三将再不敢来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "禀丞相：都尉苟安解粮到。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吓，苟安解粮到了？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "大开辕门。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "大开辕门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。〖大吹打〗。诸葛亮上高台，坐。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "传苟安进帐。"
        },
        {
          "character": "姜维、马岱、王平、魏延、关兴",
          "type": "同白",
          "text": "苟安进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苟安上。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "禀丞相：末将解粮十万，已在外营，听候查点。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "住了！万军之中，粮草乃是大事，违误三天，罪该处斩。你今误了十日，其罪 难饶。 左右，将他推去斩了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠押苟安同下。杨仪上。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "刀下留人！启丞相：苟安乃李严用人，又兼钱粮多出于西川。若杀此人，后来 无人敢送粮草。求丞相宽免死罪。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "也罢，传令放回。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "谢丞相。 将苟安放回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠押苟安同上。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "谢丞相不斩之恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "住了，虽不斩于你，念在长史杨仪讲情，死罪已免，活罪难饶。 传牢子手进帐。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "牢子手进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四牢子自两边分上。"
        },
        {
          "character": "四牢子",
          "type": "同白",
          "text": "牢子手叩头。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "将苟安捆打八十。"
        },
        {
          "character": "四牢子",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "你可知吾军法。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "自古言兵未动粮草先行，"
        },
        {
          "character": "四牢子",
          "type": "同白",
          "text": "一十。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "一路上贪花酒故意癫狂。 军无粮怎能去交锋打仗。 起毒心要绝我将士身亡。 蛇蝎心竟被我早已所谅， 你纵有千张口难辩短长。 睁狗眼可识我诸葛丞相， 今打你八十棍叉出营房。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "叉出帐去，掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人自两边分下。"
        },
        {
          "character": "苟安",
          "type": "唱",
          "text": "倚仗他势力大兵权执掌， 捆打我八十棍痛苦难当。 今要杀诸葛亮无计可想，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四长枪手自两边分上。"
        },
        {
          "character": "四长枪手",
          "type": "同白",
          "text": "吓，将军为何这等模样？"
        },
        {
          "character": "苟安",
          "type": "唱",
          "text": "你老爷平白的受此灾殃。"
        },
        {
          "character": "四长枪手",
          "type": "同白",
          "text": "请问什么灾殃？"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "孔明道我解粮来迟，将我推去处斩，多亏杨仪讲情，免了死罪，捆打八十军棍， 叉出营来。哎哟痛杀我也。"
        },
        {
          "character": "四长枪手",
          "type": "同白",
          "text": "既然受了打，请将军转回长安。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "咳，我如今不回长安了。"
        },
        {
          "character": "四长枪手",
          "type": "同白",
          "text": "不回长安，哪里去呢？"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "你们随我投奔魏营，寻个机会，就好报今日之仇了。"
        },
        {
          "character": "四长枪手",
          "type": "同白",
          "text": "如此小人们情愿跟随。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "好好，有义气。 孔明啊孔明，我进了魏营，若不杀你枉为人也！"
        },
        {
          "character": "苟安",
          "type": "唱",
          "text": "大丈夫不报仇枉生世上， 我要杀诸葛亮须投魏王。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "走吓，收拾去。哎哟，可恼可恼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四大铠、司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "诸葛亮出祁山兵多将广， 取天水收服了姜维投降。 在阵前辱舌斗骂死王朗， 一书简送曹真命见无常。 某屡次去交锋难打胜仗， 擒去我三员将某险丧疆场。 到如今扎渭滨聚齐勇将， 既为国又何惜阵前身亡。 羡孔明果称得兴周吕尚， 三国中又出了再世张良。 愧无能扶曹魏与他对抗， 俺一片忠义胆可对上苍。"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "内同白",
          "text": "走吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。戴凌、张虎、乐琳同上。"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "同白",
          "text": "参见元帅。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，你三人为何这等模样？"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "内同白",
          "text": "哎呀元帅，末将等被他擒去，将我三人盔甲军器留下，换了女装黑墨涂脸释放 回营，他叫元帅再读兵书，重观战策，他在祁山等候，分个雌雄。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，这是孔明说的么？"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "内同白",
          "text": "是他说的。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哎呀，可恼可恼。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "诸葛亮耻笑我无能为将， 羞得我脸惭愧虎目无光。 军胜败古常有人心难谅，"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "唔，孔明孔明！"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "俺若不生擒你枉为栋梁。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "你三人后帐歇息，本帅自有妙计，收服孔明。"
        },
        {
          "character": "戴凌、张虎、乐琳",
          "type": "内同白",
          "text": "多谢元帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "戴凌、张虎、乐琳同下。报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：门外来了主仆五人，口称蜀将苟安来投麾下，候令传见。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，可有兵器？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "没有。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "唔，纵是孔明派来奸细，只有五人，谅他也不能成其大事。 传苟安一人进帐。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "苟安一人进帐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。苟安上。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "来了。"
        },
        {
          "character": "苟安",
          "type": "念",
          "text": "蜀营得活命，立志辅魏王。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "吓，元帅在上，永安城李严麾下都尉苟安叩见元帅。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓起来。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "谢元帅。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "你既是李严之将，为何反来投我？"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "因为解粮来迟，孔明定要将我处斩，多亏杨仪讲情，留了首级，打我八十军棍， 叉出营来，怨恨难消，为此投拜帐下，寻计报仇，望乞元帅收留。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "你莫非来献苦肉之计么。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "哎呀元帅，苟安死里逃生，焉敢欺瞒，可怜我体无完肤，疼痛难忍，只求元帅 收留杀得孔明，情愿执鞭坠镫。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "唔，虽然如此，但是孔明多有谋略，你言难信，若是与我干得一件大功，本帅 表奏天子，保你为上将。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "但不知元帅有甚大事，末将即当效力。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "可不惜辛苦，奔回成都，散布流言，就说孔明有怨上之意，早晚必将称帝，使 你主召回孔明，即汝之功也。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "既是元帅重用于我，散布流言，有何难处，末将马到成功。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "也罢，你即速回成都，本帅听你好音。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "凡事须要多斟酌。"
        },
        {
          "character": "苟安",
          "type": "念",
          "text": "管叫孔明回成都。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苟安下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哈哈，苟安回到成都，散布流言，孔明退兵，某也罢息干戈了。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "他未必学黄盖苦肉一样， 未必是反奸计诓虎离岗。 在渭滨多操练强兵勇将， 孔明退某收兵保守魏邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四长枪手、车夫、司马昭骑马同上。"
        },
        {
          "character": "司马昭",
          "type": "念",
          "text": "将军功劳成画饼，黄金难买寸光阴。"
        },
        {
          "character": "司马昭",
          "type": "白",
          "text": "俺司马昭，只因大司马病丧军营，今将灵柩装载兵车，送回长安。 众军士，催趱前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬上。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "走吓。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "耳闻得家丁报使我愁闷， 诸葛亮未必忘先帝厚恩。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "下官蒋琬。静坐府中，家丁报说满街人言纷纷，诸葛丞相兵扎祁山，有怨上之 意，早晚欲称为帝。吾主出旨命人召他回朝，削其兵权。我想此事，定是佞臣 散布流言，待我上殿谏奏便了。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "想必是奸谗臣心怀不正， 散流言要断送汉室乾坤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、刘禅同上。"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "高祖兴汉业建刘感天运， 至孝平王莽纂一十八春。 光武兴为东汉社稷重整， 四百年终于献国出谗臣。 恨董卓欺君上朝纲不振， 后又出奸曹操狼虎羊群。 孟德死子曹丕为恶更胜， 在禅台逼献帝汉室侵吞。 魏蜀吴争汉鼎各占州郡， 号三国俱心想独霸为君。 我父王坐西川成都永镇， 白帝城王宴驾孤承父恩。 诸葛亮伐中原阵阵得胜， 今又要为天子自立称尊。 国之患不早诛无所逃遁， 王出旨即召他转回都门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬上。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "召丞相回都门是何人上本？ 流言计请问君哪个贼臣？"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "臣蒋琬见驾，愿主千岁。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "有何本奏？"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "诸葛丞相自出师以来，屡建大功，何故宣回成都。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "这……朕有机密大事，与丞相商议。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "主公分明听了佞臣流言，故召丞相回还，倘若魏兵伐蜀，何人抵敌？望君停旨， 免使丞相撤兵。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤王要召相父回朝，另有国事，况且旨已去了，不必阻谏，下殿去吧。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "吓，圣旨去了，待臣快马将圣旨追回。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "哎呀，卿去也无益，下殿去吧。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "陛下。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "老丞相兴汉室匡扶国政， 蒙先帝托孤重他岂忘恩！ 平南蛮征孟获坐立未稳， 又请旨伐中原不畏顷身。 主休听流言计召回原郡， 那时节魏兵到玉石俱焚。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "咳卿家吓！"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "孤不是商纣王酒色迷混， 孤不是周幽王误放烟墩。 孤待那诸葛亮父子之论， 他为何仗权势欺压寡人？ 今欲要为天子负恩太甚， 他为君将孤王置于何存？ 召回都削兵权自必安分， 常言道患不除终是祸根。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孤王不准，卿且下殿。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "我一番金石言龙心不准， 眼见得汉基业一统难成。 恐折了擎天柱无人扶正，"
        },
        {
          "character": "费祎",
          "type": "内白",
          "text": "大人等着。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "吓，好了！"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "费侍中一定是为国谏君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "费祎上。"
        },
        {
          "character": "费祎",
          "type": "白",
          "text": "走吓！"
        },
        {
          "character": "费祎",
          "type": "唱",
          "text": "汉刘王无圣才年幼性昏， 我不尽忠言谏枉为功勋。"
        },
        {
          "character": "费祎",
          "type": "白",
          "text": "吓，大人。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "大人入朝何事？"
        },
        {
          "character": "费祎",
          "type": "白",
          "text": "吾闻家丁报道，满街之上人言纷纷，道诸葛丞相兵扎祁山，欲称帝号，主公要 召丞相回朝，我想此事定是奸人散布流言，为此上殿谏奏，阻挡圣旨。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "下官也曾奏过，陛下道圣旨已往祁山去了。"
        },
        {
          "character": "费祎",
          "type": "白",
          "text": "吓，圣旨去了，大人怎不启奏陛下，将旨赶回？"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "陛下不准。"
        },
        {
          "character": "费祎",
          "type": "白",
          "text": "不准赶回？咳，主公听信奸言，汉室休矣！啊，大人再随我上殿启奏，你我赶 至祁山追回圣旨，以免丞相撤兵。"
        },
        {
          "character": "蒋琬",
          "type": "白",
          "text": "好，一同上殿。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "食王禄须当把国事理正。"
        },
        {
          "character": "费祎",
          "type": "唱",
          "text": "为大臣岂惧怕碎骨粉身！"
        },
        {
          "character": "蒋琬、费祎",
          "type": "同白",
          "text": "启陛下：还要将圣旨赶回，以免丞相撤兵。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "诸葛亮欲称帝号，当召回削去兵权，二卿为何阻挡朕意。况且圣旨早已去了， 何必赶回，孤王不准。"
        },
        {
          "character": "蒋琬、费祎",
          "type": "同白",
          "text": "启陛下：若召丞相回朝，司马懿必来伐蜀，那时何人抵敌？"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "孔明削去兵权，若是司马懿领兵前来，孤调倾国人马，何虑不胜？二卿下殿去 吧。"
        },
        {
          "character": "蒋琬、费祎",
          "type": "同白",
          "text": "哎呀陛下，诸葛丞相，受先帝遗诏，辅助汉室，竭心秉力，岂有称帝之理？主 公休听流言。"
        },
        {
          "character": "刘禅",
          "type": "白",
          "text": "二卿苦苦谏奏，不要孤王召回孔明，削其兵权，莫非你二人是孔明内应么？"
        },
        {
          "character": "蒋琬、费祎",
          "type": "同白",
          "text": "哎呀，屈杀臣也！"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "有异心臣应该身为齑粉，"
        },
        {
          "character": "费祎",
          "type": "唱",
          "text": "无一日不思报陛下龙恩。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "为国家岂可把朝事高枕？"
        },
        {
          "character": "费祎",
          "type": "白",
          "text": "陛下！"
        },
        {
          "character": "费祎",
          "type": "唱",
          "text": "断不可召丞相班师回军。"
        },
        {
          "character": "刘禅",
          "type": "唱",
          "text": "子承父基业理正言顺， 诸葛亮要为帝何德何能？ 召回都削兵权龙岗守困， 再谪贬蜀国内奸党一群。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘禅、四太监自两边分下。"
        },
        {
          "character": "蒋琬、费祎",
          "type": "同白",
          "text": "哎呀。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "空负了先帝爷数年劳困，"
        },
        {
          "character": "费祎",
          "type": "唱",
          "text": "得疆土全亏了诸葛先生。"
        },
        {
          "character": "蒋琬",
          "type": "唱",
          "text": "君定要削兵权令人心冷，"
        },
        {
          "character": "费祎",
          "type": "白",
          "text": "大人吓！"
        },
        {
          "character": "费祎",
          "type": "唱",
          "text": "进忠言保家邦尽化烟云。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蒋琬、费祎同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": "苟安",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。苟安上。"
        },
        {
          "character": "苟安",
          "type": "念",
          "text": "人行千里苦，马过万山河。"
        },
        {
          "character": "苟安",
          "type": "白",
          "text": "哈哈，我苟安，且喜散了流言，后主也曾出旨召宣孔明回朝，我急急回到司马 元帅台前报功讨赏。马上加鞭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖合头〗。苟安下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、四大铠、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "引子",
          "text": "奉命代天行，指日里，长安可进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨仪上。"
        },
        {
          "character": "杨仪",
          "type": "念",
          "text": "适才得一信，忽闻御诏临。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "禀丞相，主公旨意到。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吓，旨意到了？"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "旨意此来，必有原故。香案接旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。四校尉、蜀使同上。"
        },
        {
          "character": "蜀使",
          "type": "白",
          "text": "圣旨下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "蜀使",
          "type": "白",
          "text": "听宣诏曰：丞相自出祁山，屡建功劳多受辛苦，寡人有旨，宣卿即速班师回都， 另有国事商议。旨意读罢，望旨谢恩。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "千千岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "请在后帐，暂为歇马，吾即班师同行。"
        },
        {
          "character": "蜀使",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "蜀使",
          "type": "念",
          "text": "军令催急休迟慢，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蜀使下。"
        },
        {
          "character": "诸葛亮",
          "type": "念",
          "text": "顷刻班师离祁山。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "咳，此乃天命也！"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "吓，丞相为何自叹？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主上年幼，必有佞臣在侧，吾欲建立功劳，何故取回，若不罢兵，乃是欺主， 若是奉命而退，日后再难得此机会也。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "吓，丞相，我营兵马即回成都，倘若司马懿乘势掩杀，当复如何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "唔唔唔，吾今退军，可分五路而退，今日先退此营，内兵一千，却掘二千灶， 今日三千灶，明日四千灶，每日退军添灶而行。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "昔日孙膑擒庞涓用添兵减灶之法，丞相今日退兵，何故增灶，是何意也？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "那司马懿惯会用兵，知吾兵退，必然追赶；心中疑我，恐有埋伏，又见每日增 灶，又不知我兵退与不退，心中猜疑又不敢追，吾兵徐徐而退，自无损兵之患 了。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "丞相机谋难测也。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军士们传吾将令，吩咐众将，照计而行。"
        },
        {
          "character": "四大铠、四文堂",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠、四文堂自两边分下。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "吓，杨仪，吾兵归去，那司马懿，只落一场空叹也。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "哦哦哦。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "增灶计退大兵叫人难量， 猜不透我人马何处隐藏。 欲追赶又疑我埋伏兵将，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "杨仪，"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "我教他脸含羞暗撤营房。"
        },
        {
          "character": "杨仪",
          "type": "白",
          "text": "妙计妙计。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮、杨仪同下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "土神上。"
        },
        {
          "character": "土神",
          "type": "念",
          "text": "中央戊己土为尊，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水神上。"
        },
        {
          "character": "水神",
          "type": "念",
          "text": "北方壬癸水金生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "灶神上。"
        },
        {
          "character": "灶神",
          "type": "念",
          "text": "武侯奇门会遁甲，退兵之计请灶君。"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "请了，今诸葛武侯全军撤回成都，各营具要添灶，你我在此听候。头柱香必请 的是我。"
        },
        {
          "character": "水神、灶神",
          "type": "同白",
          "text": "吓，怎么先请你呢？"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "我是中央戊己土，没有土怎么成灶？"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "依我说头柱香该我受。"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "吓，怎么该着你受？"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "我是北方壬癸水，无水不成灶。岂不该我受头柱香么？"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "咳，老四，你还早。"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "吓，我又没有与你拈香拜把子，怎么叫我老四？"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "你算东方甲乙木，南方丙丁火，西方更辛金，北方壬癸水，你不是老四是什么？"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "呵，这等说，你是我兄弟老五。"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "我是中央戊己土，万物皆从土内生，该我居长。我是你二人的长辈，可该我受 头柱香。"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "不错，头柱香该你，二柱香该是我的。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "你二人不要争，武侯原是增灶，不是增土、增水，头柱香该我。"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "无土不成灶。"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "无水不成灶。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "我原砖炷土砖灶，也是土烧成的。"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "也是水和成的，有了水土，用不着你。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "用不着我也罢，你我三人各用诗一首，谁的才学高，就让谁受头柱香。"
        },
        {
          "character": "水神、土神",
          "type": "同白",
          "text": "好好好，吟诗谁吟起呢？"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "让你土神吟起。"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "让我。吓，有了。"
        },
        {
          "character": "土神",
          "type": "念",
          "text": "土能生百福，地可纳千祥。四季皆兴旺，中央我为王。"
        },
        {
          "character": "灶神、水神",
          "type": "同白",
          "text": "吓，怎么“我为王”？"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "我是中央一位，称不得王么？"
        },
        {
          "character": "灶神、水神",
          "type": "同白",
          "text": "称得，称得。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "该你水神说。"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "该我，哎，也有了。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "有什么？"
        },
        {
          "character": "水神",
          "type": "念",
          "text": "有恙休来洗，年高莫入堂。银包交柜上，洗澡脱衣裳。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "哎，不像话，不像话！"
        },
        {
          "character": "水神",
          "type": "白",
          "text": "怎么不像话？你洗澡不脱衣裳么？"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "算得么？"
        },
        {
          "character": "土神",
          "type": "白",
          "text": "算得，该你来。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "我现成的。"
        },
        {
          "character": "土神、水神",
          "type": "同白",
          "text": "考考你的才学。"
        },
        {
          "character": "灶神",
          "type": "念",
          "text": "上天言好事，回宫纳吉祥。喜煞丙丁旺，怕的李三娘。"
        },
        {
          "character": "土神、水神",
          "type": "同白",
          "text": "怕的什么李三娘？"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "就是李氏三春，她要分家，天天打我，我怕的就是她。"
        },
        {
          "character": "土神、水神",
          "type": "同白",
          "text": "还是算你不中用。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "不中用倒也罢了，可惜我这三个才子埋没了。"
        },
        {
          "character": "土神、水神",
          "type": "同念",
          "text": "水土灶神同一处。"
        },
        {
          "character": "灶神",
          "type": "白",
          "text": "真是桃李入公门。"
        },
        {
          "character": "灶神",
          "type": "同白",
          "text": "请吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土神、水神、灶神同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "搭高台，香烛。"
        },
        {
          "character": "诸葛亮",
          "type": "内二黄导板",
          "text": "按奇门兴遁甲差神遣将，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮披发仗剑上。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "为的是托孤重汉室家邦。 黄石翁三略法六韬吕望， 三国中谁敢比再世子房。 孙伯陵减灶计庞涓误闯， 诸葛亮今增灶扭转阴阳。 请中央戊己土众神下降，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水神、土神、灶神同上。"
        },
        {
          "character": "水神、土神、灶神",
          "type": "同白",
          "text": "有何法旨？"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "仗众神兴刘汉共灭魏王。 吾近日回都城俱撤营帐， 司马懿必领兵乘势逞强。 各营内俱增灶让我兵往， 诓哄那司马懿难测难防。 撤一军增一灶休要违抗， 按金木水火土切莫张皇。"
        },
        {
          "character": "土神、水神、灶神",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土神、水神、灶神同下。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "知兵法方能把万兵执掌， 司马懿是魏邦驾海金梁。 在祁山今遇我诸葛丞相， 看一看用兵计谁弱谁强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "诸葛亮下。〖大吹打〗。四大铠、四文堂、四段头、四校尉、杨仪、蜀使、旗夫、车夫、诸葛亮同上。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "众将官缓缓而行。"
        },
        {
          "character": "诸葛亮",
          "type": "唱",
          "text": "撤大营并不是凯歌齐唱， 君命召是不敢违背君王。 我去后司马懿定来探访， 中我计管叫他无趣还乡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四下手、四段头、四大铠、司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "蒙魏王赐节钺提兵调将， 扎祁山要收伏孔明投降。 又谁知那孔明兵多将广， 某屡次败阵回脸上无光。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哈哈哈哈，且喜苟安之计成功，候蜀兵退时，一齐追杀，大功可成也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "禀元帅：蜀寨人马皆无，俱已弃寨走了。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，蜀兵俱已弃营走了？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哎呀，苟安果有舌辩之能，流言散布，刘禅竟将孔明将士人等召回成都去了。 待某带兵追赶孔明，生擒蜀将，岂不一战成功？ 众将官，催动人马。 哎呀且慢，那孔明足智多谋，神鬼难测，若是追杀前去，恐中他计，乃是自投 罗网，若不追赶，恐生后患。也罢，待我带领百骑，悄悄查看。 众将官，前往蜀营去者。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "俺带领兵百人孔明难挡， 逃脱我司马懿方算计强。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。四龙套、四马甲、四大铠、姜维同上。"
        },
        {
          "character": "姜维",
          "type": "唱",
          "text": "古今来用兵法惟我丞相， 退兵将又增灶司马难防。 各带领本部兵分路前往， 这内中必有个玄机隐藏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "水神、土神、灶神、司马懿、四下手、四段头、四大铠同上，同挖门。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "众将官暂勒马休把营闯， 要防他又设计反把自伤。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "来此蜀营。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "进营观看，可有蜀兵在内？"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "吓，并无一人。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "并无一人？待某进营观看。 吓，果然并无一人在内。 众将官点灶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠自两边分下，自两边分上。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "此营二千余灶。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，有二千余灶？ 哎呀，可见孔明兵将不少，此是空营，孔明人马已去，待某前去追赶。哎，恐 他人马埋伏别营，也未可知。 众将官，再去查看一营，也好追赶。众将官再往左右二营查看。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "要想个凌烟阁姓名标上， 须兴国建奇功才算栋梁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 17,
      "name": "第十七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大吹打〗。四马甲、四龙套、四大铠、魏延同上。"
        },
        {
          "character": "魏延",
          "type": "唱",
          "text": "俺正要擒司马鞭敲镫响， 我丞相要遵旨撤退营房。 今不伐中原地后悔已晚， 怕的是汉基业尽付魏王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 18,
      "name": "第十八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "水神、土神、灶神、司马懿、四下手、四段头、四大铠同上。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "密层层尽都是蜀军营帐， 但不知诸葛亮何处隐藏。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "来此蜀营。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "进去查看。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同冲进。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "并无蜀兵，乃是空营。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "点灶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四大铠同冲下，同上。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "并无兵将，共有三千余灶。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "有三千余灶？ 吓，兵将全无，灶又增多，孔明人马隐藏何处去了？吓，孔明能会奇门遁甲之 法，若是追赶前去恐有兵将埋伏，哎，不要中了他计。 众将官，你们轮流点灶，待本帅差人打听明白，再去追赶，悄悄收兵吓。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "俺自幼读兵书非自夸奖， 扶魏王也算得盖世无双。 今日里遇孔明屡次上当， 总是我学不精让他癫狂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 19,
      "name": "第十九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四马甲、四大铠、马岱同上。"
        },
        {
          "character": "马岱",
          "type": "唱",
          "text": "奉将令离祁山五路分往， 汉字旗摆甬道遮日无光。 司马懿如犬羊难挡狮象， 哪知道我丞相八卦阴阳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 20,
      "name": "第二十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "司马懿、四下手、四段头、四大铠同上，挖门。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "下雕鞍进虎帐暗暗思想， 猜不透诸葛亮埋伏何方。"
        },
        {
          "character": "司马懿",
          "type": "念",
          "text": "欲追诸葛亮，恐中计笼牢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "孔明五座营盘，又添了数千余灶。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，又添了数千余灶。再探。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，某在蜀营查看，并无兵将，为何又添数千余灶，这又是何人所增？吓，是 了，想是孔明大兵已去，留下数万人马，在此埋伏，以防我兵攻打他营，幸喜 本帅未曾追赶，若是追杀前去，蜀兵四下围攻，吾命休矣。哈哈，诸葛亮啊， 孔明，任你妙算如神，某家偏偏不中你计。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "启元帅：孔明全军俱回成都去了。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "吓，孔明全军俱回成都去了，你可曾打听明白？"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "亲眼见他全军过去。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "众将官，起兵追赶。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "哎呀元帅，孔明人马将近蜀地赶不上了。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "下去。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子下。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "这探子报道，叫人好不明白，既是孔明全军已退，那数千灶，又是何人所增？ 吓是了，想是孔明能会差鬼遣神，此事无疑了。欲去追杀，又赶他不上，夺他 营盘内面，俱是土灶，不但无用，惟恐神兵杀来，难以抵敌呢。你就差鬼遣神， 想我中计，万万不能。 吓，众将官，且喜孔明人马已退，吩咐即日班师转回长安。"
        },
        {
          "character": "四大铠",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "司马懿看。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "咳，孔明今效虞诩之法，瞒过吾也。此等谋略，我不如他。咳，诸葛亮啊，孔 明，我司马懿拜服你了。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "诸葛亮真能会差神遣将， 不见兵只增灶难测难防。 欲追赶我怕他后有兵挡，"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "罢了！"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "掩旌旗息战鼓悄悄还乡。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "唔，只怕中了他计吓。哎，某今日偏偏不中他这一计。 众将官一齐追赶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖风入松〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 21,
      "name": "第二十一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四上手、四文堂、四大铠、王平、魏延、关兴、马岱、姜维同上。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "众位将军请了，司马懿只带兵百十余人，前来追赶，你我奉丞相将令，拦路截 杀。 众将官，就此埋伏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。司马懿、四下手、四段头、四大铠同上。〖牌子〗。众人同挖门。内喊声。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哎呀，哪里人马呐喊？吓，探子报道，孔明全军已回，这人马又是哪里来的？ 吓，想是孔明暗有埋伏，我只有兵丁百人，如何抵敌，只怕中他之计了。"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "诸葛亮好一似仙人下降， 用兵计胜过了吕望、张良。 我只有百十人怎能抵挡？"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "司马懿",
          "type": "唱",
          "text": "拚性命奋余勇且战一场。 （四上手、四文堂、四大铠、王平、魏延、关兴、马岱、姜维自下场门同上，会阵，同杀。众人自两边分下。 姜维、司马懿同杀，姜维下，司马懿接王平、魏延、关兴、马岱。姜维上，司马懿杀下，姜维追下。四下 手同上，打下，司马懿上，打总攒，司马懿、姜维同追下，四下手同上，打下。姜维、众人追司马懿过合同 下。姜维、众人自两边分上。）"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "司马懿逃走。"
        },
        {
          "character": "姜维",
          "type": "白",
          "text": "不必追赶，回营交令。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。众人领司马懿同上。"
        },
        {
          "character": "司马懿",
          "type": "白",
          "text": "哎呀，诸葛亮真乃神人也。埋伏人马，将我杀得大败，这便怎么处？哎呀，也 罢，不免回朝请兵，再擒孔明。 众将官收兵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖尾声〗。众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
