{
  "script_id": "02001048",
  "title": "五雷阵",
  "alias": [],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "毛蕡",
      "hangdang": "净"
    },
    {
      "name": "孙燕",
      "hangdang": "小生"
    },
    {
      "name": "王翦",
      "hangdang": "净"
    }
  ],
  "plot": "此剧系出列国，秦始皇遣王翦并吞六国之时，从妖道毛蕡助王翦攻齐起，其大概为孙膑侄为毛蕡所败，孙膑\n亲自出阵杀退毛蕡，不意被毛蕡败回作法，设下五雷阵，将孙膑魂摄入，将殛死之。幸孙膑道数高，真元不\n动，卒破毛蕡阵，用鬼谷师所遗太极图击死毛蕡云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四兵卒引王翦同上。"
        },
        {
          "character": "王翦",
          "type": "念",
          "text": "可恨燕孙膑，私下天台山。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "报子上。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "报！启元帅：垂莲洞毛道仙求见。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "摆队相迎。"
        },
        {
          "character": "报子",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。王翦、四兵卒同下。毛蕡上，王翦、四兵卒同上。"
        },
        {
          "character": "王翦、毛蕡",
          "type": "同笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王翦、毛蕡同下，四兵卒同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王翦、毛蕡同上。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "师兄下山，小弟失迎，多有慢待，师兄恕罪。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "岂敢。但不知因何免战高悬？"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "师弟被孙膑，杀得大败，因此免战高悬。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "待师兄出马，与师弟报仇。"
        },
        {
          "character": "王翦",
          "type": "白",
          "text": "孙膑法力高强，恐怕难以取胜。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "师弟呀！"
        },
        {
          "character": "毛蕡",
          "type": "唱",
          "text": "师弟休要小看咱， 师父赐宝来下山。 此去若遇燕孙膑， 叫他一命丧黄泉。 辞别贤弟去交战，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡下。"
        },
        {
          "character": "王翦",
          "type": "唱",
          "text": "等候师兄得胜还。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王翦下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "孙燕上。"
        },
        {
          "character": "孙燕",
          "type": "唱",
          "text": "领了军令到阵前，"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "俺，孙燕。奉了三叔将令，前到秦营讨战，探看敌人动静，就此马上加鞭。"
        },
        {
          "character": "孙燕",
          "type": "唱",
          "text": "杀却王翦报仇冤。 中国京剧戏考 《五雷阵》【二本】 2 一马来在战场上， 那旁来了将一员。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡上。"
        },
        {
          "character": "毛蕡",
          "type": "唱",
          "text": "催马坐骑紧加鞭， 又见娃娃到阵前。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "马前来的小将，通上名来，好在你道爷剑下做鬼！"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "妖道听者：你少爷名唤孙燕。你这野道，快快通名受死！"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "呀，这就是孙燕，倒要小心他些。 娃娃，你也不必问你道爷名姓。山人不忍伤你，快快回营，叫那瘸夫孙膑，出 营受死！"
        },
        {
          "character": "孙燕",
          "type": "白",
          "text": "休发朗言大话，看枪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙燕、毛蕡开打，毛蕡败下，孙燕追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡上。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "这娃娃枪法厉害，他若来时，用混元锤伤他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙燕上。毛蕡用锤打孙燕，青龙上，孙燕败下，青龙下。"
        },
        {
          "character": "毛蕡",
          "type": "白",
          "text": "且住。你看青龙出现，果应师父之言，饶他去罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "毛蕡下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}