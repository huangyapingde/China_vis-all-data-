{
  "script_id": "02011041",
  "title": "宁武关",
  "alias": [
    "别母·乱箭"
  ],
  "source": "《国剧大成》",
  "characters": [
    {
      "name": "周遇吉",
      "hangdang": "老生"
    },
    {
      "name": "周母",
      "hangdang": "老旦"
    },
    {
      "name": "周妻",
      "hangdang": "旦"
    },
    {
      "name": "周子",
      "hangdang": "小生"
    },
    {
      "name": "家将",
      "hangdang": "末"
    },
    {
      "name": "李自成",
      "hangdang": "净"
    },
    {
      "name": "一支虎",
      "hangdang": "副净"
    }
  ],
  "plot": "总兵周遇吉，虽擒诛李闯义子李洪基，卒因寡不敌众，难当闯贼攻势，代州乃陷，不得已退守宁武关。周母\n及妻若子均在关内，周遇吉返关之日，适逢母寿，周遇吉介寿称觞，自度孤城无援，旦夕必破，面带忧容。\n拟遣将护母外避，己则与守土共存亡。周母深明大义，不欲偷生，遂举火自焚，以绝其子内顾之忧，全其捐\n躯成仁之志。而其妻子奴仆家将，亦均自尽殉国。周遇吉终亦浴血奋战，被箭自刎而亡。一门忠烈，千秋足\n式矣。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、四上手、众闯将、一支虎引李自成同上。"
        },
        {
          "character": null,
          "type": "text",
          "text": "中国京剧戏考 《宁武关》【三、四本】 5"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "孤，李自成。 御弟，你看周遇吉越杀越勇，伤了无数大将，不免弃了此关，攻打别处，再来 招安便了。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "周遇吉虽然英勇，到底寡不敌众。兄王带领弓箭手，埋伏前面山谷之中，待小 弟引他到来，乱箭齐发，不怕他飞上天去！"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "有理！"
        },
        {
          "character": "李自成",
          "type": "念",
          "text": "挽弓需挽强，"
        },
        {
          "character": "一支虎",
          "type": "念",
          "text": "用箭须用长。"
        },
        {
          "character": "李自成",
          "type": "念",
          "text": "射人先射马，"
        },
        {
          "character": "一支虎",
          "type": "念",
          "text": "擒贼先擒王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉上。"
        },
        {
          "character": "周遇吉",
          "type": "采芙蓉",
          "text": "战场黯黯阵云黄， 浮云雾惨苍茫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎上，见。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "周遇吉，敢与俺斗几百回合么？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "呔！贼子！"
        },
        {
          "character": "周遇吉",
          "type": "采芙蓉",
          "text": "看俺枪尖动处， 便披靡奔逃亡！"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "放马过来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎败下，周遇吉追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李自成、众弓箭手同上，同站高处。一支虎上，周遇吉追上。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "众将放箭！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉带箭下。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "周遇吉已中乱箭。"
        },
        {
          "character": "李自成",
          "type": "采芙蓉",
          "text": "雕弓遍张， 似飞蝗骤雨难遮挡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉上。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "杀败了啊杀败了！不想我误入罗网身被重伤，虽然杀出重围，今番性命休矣！"
        },
        {
          "character": "周遇吉",
          "type": "唱",
          "text": "悲怏身未死，忠魂先飏， 心已碎，丹心犹壮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎上。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "周遇吉，还能战么？"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "不怕死得来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉杀，打一支虎一鞭，一支虎下。"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "圣上啊，圣上！臣力已尽，不能保你社稷了！"
        },
        {
          "character": "周遇吉",
          "type": "唱",
          "text": "出师未捷身先丧， 赢得英雄泪两行。"
        },
        {
          "character": "众闯将",
          "type": "内同白",
          "text": "你还不降顺么！"
        },
        {
          "character": "周遇吉",
          "type": "白",
          "text": "呔，尔等谁敢来！"
        },
        {
          "character": "周遇吉",
          "type": "唱",
          "text": "休无状！ 望龙庭稽颡， 好从容结缨， 中国京剧戏考 《宁武关》【三、四本】 6 谈笑饮干将！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周遇吉自刎。李自成、众闯将同上。"
        },
        {
          "character": "众闯将",
          "type": "同白",
          "text": "周遇吉自刎了。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "可惜周遇吉，恁般英勇，自刎而亡，深为可怜。若是明朝将官个个如此，孤家 焉能到此。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎上。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "哎哟哟！"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "御弟怎么了？"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "方才被周遇吉打了一鞭，啊呀疼杀我也！"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "请到后宫调养。"
        },
        {
          "character": "一支虎",
          "type": "白",
          "text": "这是周遇吉尸首，待俺砍他几百刀！"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "住了！他也是各为其主，请到后营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一支虎下。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "将校们，将周将军尸首，抬到高埠之处埋葬，不要伤损。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众闯将同应。"
        },
        {
          "character": "李自成",
          "type": "白",
          "text": "大队人马，直奔燕京！"
        },
        {
          "character": "李自成",
          "type": "朱奴儿",
          "text": "蟠螭旗云中摇漾， 虎豹旌风外飘飏。 虎将狰狞豪气旺， 马如龙掣断丝缰。 遥望五云帝乡， 指日里归吾掌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}