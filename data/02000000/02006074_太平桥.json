      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李克用上，史敬思随上。"
        },
        {
          "character": "李克用",
          "type": "白",
          "text": "看四面俱是兵将，城门紧闭，你我父子怎生逃脱？"
