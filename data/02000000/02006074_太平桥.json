          "type": "西皮导板",
          "text": "耳边厢又听得有人呼唤，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史敬思起，看。"
        },
        {
          "character": "史敬思",
          "type": "白",
          "text": "父王吓……"
        },
        {
          "character": "史敬思",
          "type": "西皮摇板",
          "text": "中了奸贼巧机关。 扯开战甲将伤掩，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史敬思包胸。"
        },
        {
          "character": "史敬思",
          "type": "西皮摇板",
          "text": "又见人马到桥前。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手引卞金遂同上，架枪。"
        },
        {
          "character": "史敬思",
