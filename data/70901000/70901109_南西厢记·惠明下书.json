{
  "script_id": "70901109",
  "title": "南西厢记·惠明下书",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "惠明",
      "hangdang": "净"
    },
    {
      "name": "张生",
      "hangdang": "小生"
    },
    {
      "name": "长老",
      "hangdang": "老生"
    },
    {
      "name": "崔莺莺",
      "hangdang": "旦"
    },
    {
      "name": "红娘",
      "hangdang": "贴旦"
    },
    {
      "name": "崔母",
      "hangdang": "老旦"
    }
  ],
  "plot": "草寇孙飞虎带领五千人马，围住相国寺寺院，要强虏崔莺莺做押寨夫人。崔母情急无奈，声言“有能退得贼\n兵者，愿将小女妻之”。此时张珙亦在寺中，闻此言，急修书给故友白马将军杜确，以求解围。为遣送此信，\n寺中和尚惠明，自愿前往。遂单身闯出重围，直奔蒲关白马将军处下书求救。",
  "notes": "《惠明下书》为《南西厢记》第十一出。\n《南西厢记》，明李日华撰。全三十六出。是以元王实甫《北西厢》为基础，加以增饰，改编而成。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "崔莺莺上。"
        },
        {
          "character": "崔莺莺",
          "type": "六字调淘金令",
          "text": "恹恹瘦损， 那值春光尽。 罗衣宽褪，早是神劳顿， 能消几度黄昏。 目断行云， 奈人远天涯近。"
        },
        {
          "character": "崔莺莺",
          "type": "夹白",
          "text": "呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "红娘暗上。"
        },
        {
          "character": "崔莺莺",
          "type": "六字调淘金令",
          "text": "只索要自温存惮出闺门，"
        },
        {
          "character": "崔莺莺",
          "type": "夹白",
          "text": "可恨红娘，"
        },
        {
          "character": "崔莺莺",
          "type": "六字调淘金令",
          "text": "她影儿般不离身。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "吓小姐。"
        },
        {
          "character": "崔莺莺、红娘",
          "type": "同白",
          "text": "（红娘）（瞒着什么娘）？"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "你几时来的？"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "红娘么，是“影儿般不离身”来的。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "红娘，我也瞒你不得了。"
        },
        {
          "character": "崔莺莺",
          "type": "六字调淘金令",
          "text": "我从见了那个人， 兜的便可亲。 咏月吟诗，依着前时韵。"
        },
        {
          "character": "众喽啰",
          "type": "内同白",
          "text": "杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "崔母上。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "啊呀不好了！"
        },
        {
          "character": "崔母",
          "type": "念",
          "text": "闭门家中坐，祸从天上来。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "啊呀我的儿哪里？"
        },
        {
          "character": "崔莺莺、红娘",
          "type": "同白",
          "text": "（母亲）（老夫人）。"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "为何这等慌张？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "那孙飞虎带领五千人马，围住庙门，要掳你去做押寨夫人，这便怎么处？"
        },
        {
          "character": "崔莺莺",
          "type": "白",
          "text": "吓，有这等事，啊呀！兀的不痛煞人也。"
        },
        {
          "character": "崔母、红娘",
          "type": "同白",
          "text": "啊呀（我儿）（小姐）醒来。"
        },
        {
          "character": "崔莺莺",
          "type": "红衫儿",
          "text": "听罢伊言，心不忍。 此祸临身。 苦教人进退无门， 如今怎生把袖梢儿揾不住啼痕。"
        },
        {
          "character": "众喽啰",
          "type": "内同白",
          "text": "杀呀！"
        },
        {
          "character": "崔莺莺",
          "type": "红衫儿",
          "text": "听喊杀声怎禁。"
        },
        {
          "character": "崔莺莺",
          "type": "夹白",
          "text": "娘呀！"
        },
        {
          "character": "崔莺莺",
          "type": "红衫儿",
          "text": "休得要爱惜莺莺，我甘心自殒。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "儿吓！"
        },
        {
          "character": "崔母",
          "type": "东瓯令",
          "text": "那厮如狼虎，尽胡行， 道你莲脸生春眉黛颦。 更有倾城倾国杨妃貌，多姣俊， 恣情劫掠要成亲，教我泪盈盈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "长老上。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "啊呀不好了！"
        },
        {
          "character": "长老",
          "type": "念",
          "text": "灾来怎躲，祸至难逃。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "啊呀老夫人在哪里？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "长老，贼势如何了？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "那孙飞虎带领五千人马，围住寺院，要掳小姐去做押寨夫人，这便怎么处？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "长老，事已急了，你到两廊下去说：不论士庶人等有能退得贼兵者，愿将莺莺 小姐妻之，决不食言。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "是。待贫僧去问。 喂，两廊下听者。"
        },
        {
          "character": "众僧人",
          "type": "内同白",
          "text": "吓。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "老夫人有言，不论士庶人等，有能退得贼兵者，愿将小姐妻之，决不食言。可 有？"
        },
        {
          "character": "众僧人",
          "type": "内同白",
          "text": "没有。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "呀！没有。待我倒那边去。 喂……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张生上。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "呀，长老！长老！"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "吓，啊呀，原来是张相公。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "长老，我有退兵之策，何不早来说。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "呀，张相公有退兵之策？"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "请稍待。 吓，老夫人。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "长老。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "此间，张相公有退兵之策。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "如此，请进来。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "吓，张相公，老夫人相请。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "是。 吓，老夫人。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "先生。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "小姐。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "小姐免见。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "礼不可缺。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "先生，计将安出？"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "老夫人，重赏之下，必有勇夫。赏罚分明，其计必成。倘退了贼兵，老夫人便 怎么？"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "方才与长老讲过的，不论士庶人等，有退得贼兵者，愿将小女妻之，决不食言。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "如此，请了，浑家进去。"
        },
        {
          "character": "崔母",
          "type": "白",
          "text": "我儿随我进来。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "张先生，你是清早进午膳，尚早哩。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "红娘姐，你是一脚跌在炉坑里。"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "怎讲？"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "你倒是饱温了，哈……"
        },
        {
          "character": "红娘",
          "type": "白",
          "text": "呀啐！"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "哟……这时候还要取笑么？"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "长老，我如今用着你了。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "贫僧又不会相持厮杀，要我何用？"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "哪个要你相持厮杀，只要你与贼人答话。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "讲说什么？"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "待我教导于你。你就说，老夫人有言：本当将小姐送到阵前与将军成亲。一来 丧服在身，二来惟恐将军不利。将军休得鸣锣击鼓，惊坏小姐岂不可惜。请将 军把人马暂退一箭之地，待等过了三日，功德完备，脱去孝服，换上喜衣，送 到阵前，与将军成亲如何？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "是，是，是。待我再来。 喂，将军答话。"
        },
        {
          "character": "孙飞虎",
          "type": "内白",
          "text": "怎么讲？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "老夫人有言。"
        },
        {
          "character": "孙飞虎",
          "type": "内白",
          "text": "吓。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "本欲将小姐送到阵前，与将军成亲。一来孝服在身，二来惟恐将军不利。将军 休得鸣锣击鼓。"
        },
        {
          "character": "孙飞虎",
          "type": "内白",
          "text": "唔。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "倘惊坏小姐岂不可惜。请将军把人马暂退一箭之地，待等过了三日，功德完备， 脱去孝服，换上喜衣，送到阵前，与将军成亲如何？"
        },
        {
          "character": "孙飞虎",
          "type": "内白",
          "text": "过了三日若不送回成亲呢？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "张先生，过了三日若不送出去呢？那还了得。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "任凭将军处置。"
        },
        {
          "character": "孙飞虎",
          "type": "内白",
          "text": "既如此，众喽啰将人马退回一箭之地者。"
        },
        {
          "character": "众喽啰",
          "type": "内同白",
          "text": "吓。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "哈……倒是你们读书人。三言两语，就把贼人退了。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "长老，这是小生初出茅庐第一功也。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "张先生，你先不要报功，过了三日，若不送出去，那还了得。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "长老，我有一故友，此人姓杜名确，号为白马将军，现在蒲关镇守，待我修书 一封，请他前来，擒拿贼子，如同探囊取物耳！"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "既如此，就请张先生修书。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "待我修书一封。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "如此，待贫僧磨墨。"
        },
        {
          "character": "张生",
          "type": "干念一封书",
          "text": "洛生珙拜兄， 今日何期遇难中。 孙飞虎，逞凶， 劫掠民财强聚众。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "长老，哪个为媒？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "贫僧为媒。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "和尚为媒，极妙的了。"
        },
        {
          "character": "张生",
          "type": "干念一封书",
          "text": "崔相国家并仆等， 一旦如鱼困釜中。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "退了贼兵就要成亲的呢。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "只怕来不及。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "吓，来不及么，哎！不写了。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "吓，吓，就成亲如何？"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "啊呀妙吓。"
        },
        {
          "character": "张生",
          "type": "干念一封书",
          "text": "仗威风，破群凶， 颠沛来缄恕不恭。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "书已写完，差哪个前去？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "我有一个徒弟名唤惠明，此人心粗胆大，他倒去得。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "唤他来。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "张先生，此人性如烈火，等他来时，须要用言语激发于他，方可去得。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "是，我已记下。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "待我去唤他。 惠明哪里？惠明快来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "惠明上。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "来也。"
        },
        {
          "character": "惠明",
          "type": "上字调粉蝶儿",
          "text": "听得——"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "嗨！"
        },
        {
          "character": "惠明",
          "type": "上字调粉蝶儿",
          "text": "传呼。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "惠明，那孙飞虎带领五千人马，围住寺门，你还要这么慢慢腾腾的么？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "咳！"
        },
        {
          "character": "惠明",
          "type": "上字调粉蝶儿",
          "text": "不觉得心头起火。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "师父。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "惠明拜。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "罢了，过来见了张相公。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "张相公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张生作打量。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "咳！阿弥陀佛。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "长老，就是此人么？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "就是此人。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "我看他，人不出众，貌不惊人，他如何去得？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "待老僧去说。 惠明，有封书信，命你下到蒲关白马将军处投递，你可愿去？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "拿来！"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "道你人不出众，貌不惊人，你如何去得？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "谁说？"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "张先生。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "俺偏要去！"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "去不得，回避了。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "呔！俺如今是偏要去！"
        },
        {
          "character": "惠明",
          "type": "端正好",
          "text": "不念法华经， 不礼那梁皇忏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "惠明走圆场。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "我撇下这僧伽帽。"
        },
        {
          "character": "惠明",
          "type": "端正好",
          "text": "我脱下了，这偏衫， 只我这杀人心，逗起英雄胆。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "只我这两只手。"
        },
        {
          "character": "惠明",
          "type": "端正好",
          "text": "把那乌龙尾钢椽揝。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "惠明，敢是你贪？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "非是俺贪。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "莫不是你敢？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "也不是俺敢。"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "我知他们，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "怎生唤做，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "打参。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "我大踏步，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "直杀入虎穴龙潭。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "惠明，敢是你搀？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "非是俺搀。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "敢是你揽？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "也不是俺揽。"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "这些时，吃几个菜馒头委实价口淡。 俺将那五千人，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "也不索，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "炙爆个煎爁。 腔子里热血权消渴， 肺腑内生心且解馋。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "好一腌臜和尚。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "唔……"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "有甚腌臜。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "惠明，那孙飞虎有五千人马，将寺院团团围住，你可敢去不敢？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "师父，你那里问小僧敢也不敢。"
        },
        {
          "character": "惠明",
          "type": "倘秀才",
          "text": "我这里，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "启大师，用咱……"
        },
        {
          "character": "惠明",
          "type": "倘秀才",
          "text": "也不用咱， 飞虎将声名播斗南。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "那厮能淫欲，"
        },
        {
          "character": "惠明",
          "type": "倘秀才",
          "text": "会贪婪，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "诚何——"
        },
        {
          "character": "惠明",
          "type": "倘秀才",
          "text": "以堪。"
        },
        {
          "character": "长老",
          "type": "夹白",
          "text": "为何不念经文？"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "我的经文也不会谈， 那逃禅也懒去参。"
        },
        {
          "character": "长老",
          "type": "夹白",
          "text": "逃禅呢？"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "只我这戒刀头。"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "近新来将钢蘸，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "铁棒上，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "没半星儿土渍尘缄。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "别的来，僧不僧，俗不俗，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "女不女，男不男。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "他则会斋的饱，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "向那僧房中胡渰。那里怕焚烧了"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "兜率，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "似伽蓝。 则为那善文能武人千里，"
        },
        {
          "character": "张生",
          "type": "夹白",
          "text": "此有书信，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "凭着这，"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "济困扶危书缄。"
        },
        {
          "character": "张生",
          "type": "夹白",
          "text": "有勇无惭。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "嘿！"
        },
        {
          "character": "惠明",
          "type": "滚绣球",
          "text": "有勇无惭。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "惠明，他若放你过去还好。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "师父，他放咱过去便罢。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "若不放呢？"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "他若不放，哎呀师父吓！"
        },
        {
          "character": "惠明",
          "type": "白鹤子",
          "text": "着几个小沙弥，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "将幢幡和那宝盖擎，壮行者，将杆棒镬杈担。师父，你与俺排阵脚，将众僧安， 俺撞钉子——"
        },
        {
          "character": "惠明",
          "type": "白鹤子",
          "text": "要把贼兵探。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "远的破开步，将铁棒撇，近的顺着手把戒刀钐。小的提起来把脚尖跺，大的板 下来将骷髅勘。我只瞅一瞅！"
        },
        {
          "character": "惠明",
          "type": "白鹤子",
          "text": "古嘟嘟翻了海波；"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "我晃一晃，"
        },
        {
          "character": "惠明",
          "type": "白鹤子",
          "text": "厮琅狼震动了山岩。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "我脚踹地，"
        },
        {
          "character": "惠明",
          "type": "白鹤子",
          "text": "卒律律地轴摇，我手板着忽剌剌天关撼。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "惠明此去必然成功。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "正是。张先生请到后面用茶。"
        },
        {
          "character": "张生",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张生下。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "师父，与俺助威风擂一阵鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内擂鼓。"
        },
        {
          "character": "长老",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "仗佛力——"
        },
        {
          "character": "惠明",
          "type": "煞尾",
          "text": "呐一声喊，"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "绣幡下，"
        },
        {
          "character": "惠明",
          "type": "煞尾",
          "text": "遥见英雄俺。"
        },
        {
          "character": "惠明",
          "type": "夹白",
          "text": "俺教那半万贼兵，"
        },
        {
          "character": "惠明",
          "type": "煞尾",
          "text": "就吓，吓破他的胆。"
        },
        {
          "character": "惠明",
          "type": "白",
          "text": "走！走！走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "惠明下，长老随下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}