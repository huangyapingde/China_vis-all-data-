    }
  ],
  "plot": "一黑驴三扣开封府，包公知其必有奇案，命衙役跟随黑驴来到荒郊，发现女尸一具。从此寻踪觅迹，细察范\n仲虞一家冤情。",
  "notes": "《阳审》为《琼林宴》之一折。\n《琼林宴》清无名氏撰。故事写汴京开科选仕，穷生范仲虞卖驴做盘费，携带家人去汴京应试。行至中途，\n遇猛虎，一家人逃散。其子范锦被舅舅陆荣所救，其妻玉贞被太尉葛登云抢入府中。汴京试毕。范仲虞得知\n妻子已被葛登云抢去府中，赶去讨还妻子。葛登云谎言抵赖，诓骗范留宿府中。乘夜派人把范仲虞用棍打死，\n装在箱内，弃之荒野。范仲虞未死，但已疯癫。陆玉贞被锁在府中，葛登云妻女同情陆玉贞将其放走。葛\n登云派家丁追寻，将陆玉贞中途杀死，此时，恰好黑驴毕见。驴即三扣开封府，替主鸣冤。最后，包拯详查\n细访，真相大白，救活了陆玉贞，范仲虞疯癫亦愈。一家人重又团圆，葛登云被处斩。\n朝廷举行琼林宴，范仲虞遇害前，已状元及第。此时冤情昭雪，正好举行琼林宴，故以《琼林宴》标名。\n《琼林宴》又称作《黑驴告状》，民间流传甚广，但至今未见传本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉、众衙役引包拯同上。土地跪门。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "禀爷，有一老头跪门。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "带进来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "放彩火。土地下。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "禀爷，老头儿逃去了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "给你一块火签，赶上拿回！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝允，下。吴氏、范锦同上上。"
        },
        {
          "character": "吴氏、范锦",
          "type": "同白",
          "text": "冤枉啊爷爷！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴氏、范锦同哭。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "禀爷，有一老婆儿喊冤。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "带进来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉引吴氏、范锦同进见，同跪。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "禀爷，老婆儿告进。 老婆儿当面。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "讫过。那一老婆儿家住哪里，姓甚名谁？你丈夫在日曾授何职，有何冤枉同这 小孩儿前来告状？讲！"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "老身陆门吴氏，先夫在日，曾授武卫将军之职。所生一女，名唤陆玉贞，许配 陕西延安府范生为妻。次子陆荣，曾与葛登云宦门结亲，那日葛登云寿诞之日， 我孩儿备的寿礼与他前去祝寿，他认下也罢，不认下也罢，将我孩儿问成盗 案了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴氏哭。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你孩儿既不为盗，不该招认才是。"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "哎呀爷爷呀！"
        },
        {
          "character": "吴氏",
          "type": "唱",
          "text": "自古道人心似铁非似铁， 官法如炉果如炉。⑴"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "见爹行，"
        },
        {
          "character": "范锦",
          "type": "唱",
          "text": "吓得我魂飘荡。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "住了！这一小孩子，为何抱着疯魔汉子啼哭，他是你什么人？"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "他是我的爹爹呀爷爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吓！是你的父亲呢。"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "家住哪里？姓甚名谁？有何冤枉同着老婆儿前来告状？讲！"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "生员范锦，乃陕西延安府人氏。我父子二人进京应试，求取功名。路上失去盘 费，我父归路寻找。我母子二人在彼悬望，忽然见跳出一只猛虎呵！"
        },
        {
          "character": "范锦",
          "type": "唱",
          "text": "我命丧须臾，丧须臾， 我母舅从天降。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "嗯！你被虎伤，是你母舅将你救下的？"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "是呀，爷爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你母舅叫什么名子？"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "叫陆荣。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哦，陆荣。不用说了，告状的老婆一定是你的外婆了？"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "是啊，爷爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你父平素间就有疯癫之病症吗？"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "喂呀爷爷呀！"
        },
        {
          "character": "范锦",
          "type": "唱",
          "text": "他平日里体健康， 路途上受灾殃， 望爷爷作主张。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "我且问你，你父亲叫什么名子？"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "范仲虞。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哪里人氏？"
        },
        {
          "character": "范锦",
          "type": "白",
          "text": "陕西延安府人氏。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "呜呼呀！奇哉呀奇哉。新科状元范仲虞他乃陕西延安府人氏，只因探花病故， 状元无踪，如今这琼林宴也未曾赴得。 马汉，过来！将这一疯癫汉子，带到太医院，用药调治，待他病好，再来听审。 你二人暂且下去。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉下。王朝上。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "王朝告进。领了老爷火签，追赶那一老头儿。赶到城南五里，有一土地祠，老 头儿入祠不见了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "敢是你卖法了？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "小人不敢。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "起过。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑驴上，众人同轰黑驴。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "住了！这黑驴三扣开封，其中必有无头冤枉。 王朝、马汉，拿我火签，速跟黑驴，拿他主人晚堂听审。快去！"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "快去！"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "快去！"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。"
        },
        {
          "character": "王朝",
          "type": "念",
          "text": "奉命差遣，"
        },
        {
          "character": "马汉",
          "type": "念",
          "text": "概不由己。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "你我奉包大人之命，速跟黑驴，拿他主人晚堂听审。我想驴子乃是个哑巴畜牲， 你我怎样去拿法？"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "我倒有一计。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "有何妙计？"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "将驴子拉将出来，驴子走在哪里，我们跟在哪里，岂不是好？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "这倒是好计。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "拉驴子去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝拉黑驴。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "驴子，我对你说：我奉包大人之命，拿你主人晚堂听审。你走到哪里，我们跟 在哪里。走啊，走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黑驴走圆场，黑驴刨土。"
        },
        {
          "character": "王朝、马汉",
          "type": "同唱",
          "text": "因甚的掷双蹄把土来跐， 掷双蹄把土来跐。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "唉伙计！你瞧这驴子乱刨乱叫，其中必有缘故，你我掘开一看。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "驴子闪开了！"
        },
        {
          "character": "马汉",
          "type": "唱",
          "text": "忙掘起莫待迟，"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "咦！"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "见娇娇滴滴一死尸。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "伙计，这一死尸，一定是驴子的主母了。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "着啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马汉唱。⑵"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "你看这一妇人尸首冲天冲地，不大稳便，你我仍旧埋上。 驴子闪开！"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "我说驴子，谁人害了你家主母，你就往谁家跑。走啊，走啊！"
        },
        {
          "character": "马汉",
          "type": "唱",
          "text": "竖双耳引卫士，⑶ 奉公差谁敢辞， 奉公差怎敢辞。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "唉哟，驴子跑这家去了。出来个人哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆伦上。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "唉哟，小黑驴跑回来了。"
        },
        {
          "character": "穆伦",
          "type": "念",
          "text": "活该不破财，驴子转家来。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "穆忠宝，喂上咱们的小黑驴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆忠宝内允。"
        },
        {
          "character": "马汉、王朝",
          "type": "同白",
          "text": "出来个人哪！"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "哦，二位。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "请问大哥上姓啊？"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "我叫穆伦哪。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "叫什么名字？"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "我叫穆伦哪，你们二位是干什么的？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "我们是行路的。我们的小黑驴跑到你们家去了，牵出来，我们还要赶路哪！"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "怎么，是你们的驴子？这是我们的驴。我打发小孩到大道沿上放脚去，后来这 驴子溜了缰了，跑了好几天没回来。今天回来了，怎么是你们的驴子！"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "唉！你不要着急，我们这一驴子有一暗号。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "有什么暗号啊？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "脊背上有撮白毛。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "巧了，我那驴子是混铁枪，一抹黑。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "你把驴子牵出来，有白毛的是我们的，没有白毛的是你们的，牵出来！"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "穆忠宝呀，别喂了！有了蒙驴的了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆忠宝牵驴上。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "你们看看哪有白毛啊？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "哦，这驴子当真是你的。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "当真是我的。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "你近前来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝打穆伦，马汉锁穆伦。"
        },
        {
          "character": "王朝",
          "type": "念",
          "text": "你强盗杀人最不屈。"
        },
        {
          "character": "穆伦",
          "type": "念",
          "text": "驴子溜缰是所无。"
        },
        {
          "character": "王朝",
          "type": "念",
          "text": "踏破铁鞋无觅处，"
        },
        {
          "character": "马汉",
          "type": "念",
          "text": "得来全不费功夫。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "打官司去吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉带穆伦同下。众衙役引包拯同上。"
        },
        {
          "character": "包拯",
          "type": "念",
          "text": "头戴乌纱持牙笏，身穿王莽紫罗襕。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "王朝告进，王朝叩头。奉老爷火签，速跟黑驴，拿他主人晚堂听审。行到半路 途中，驴子乱刨乱叫。我二人掘开一看，原来是一妇人尸首。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "怎样死的？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "勒死的。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "啊！勒死的，往下讲。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "我二人仍旧埋上，驴子又行至一家，此人姓穆名伦，已经带到。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "带上来。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "带上来。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "报！穆伦告进，穆伦当面。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "启刑！"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "当堂启刑！"
        },
        {
          "character": "众衙役",
          "type": "同白",
          "text": "跪下，跪下！"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "跪下就跪下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "那汉子，你可叫穆伦？"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "不错，我叫穆伦哪！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "人间致死人命，事犯公堂，还不招认！"
        },
        {
          "character": "众衙役",
          "type": "同白",
          "text": "招！"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "什么？杀了人啦！我不瞒老爷说，我是天底下，地上头，忠实有余的大老实人。 且慢说杀人，我是吃饭不知饥饱，睡觉不知颠倒。且慢说杀人，就是鸡、猫、 狗，连个臭虫我都不敢碾呀，怎么敢杀人！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "人命重情，不打不招，扯下去重打四十！"
        },
        {
          "character": "众衙役",
          "type": "同白",
          "text": "一十，二十，三十，四十，打完！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "叫他招！"
        },
        {
          "character": "众衙役",
          "type": "同白",
          "text": "招！"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "我无有什么招的。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "左右，看大刑伺候！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "哎呀！老爷别动大刑，我有招了，老爷容禀。"
        },
        {
          "character": "众衙役",
          "type": "同白",
          "text": "老爷容禀。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "非是我贪美事，见财起义，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哦！你见那一妇人，身边有些财物，故此将她勒死？埋在荒郊。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "唉哟！怎么跑出一妇人来了？我杀的不是个妇人，我杀的是个男的。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "哈！你又杀了哪一个？"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "老爷别着急，我慢慢的告诉你。我们那儿有一上林村，有一陆老太太，她有个 家人，名叫卢可夫，我杀的是他。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "过来，将那告状的老婆儿和那小孩儿叫来听审。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "领命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "穆伦。"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "你与那人有何仇恨？为何将他杀死？"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "我们俩没有仇，也没有恨，我们路遇，他从陕西贸易而归，我打陕西探亲而归。 我们俩路遇，路过我家。我见他行囊沉重，将他让到我家，用好酒、好饭， 将他灌了个沉沉大醉，躺在我们的小炕上他就睡着了。我找了把切菜刀，我就 磨呀，磨了个锋霜快。我就轻轻地，慢慢地，照着他的脑袋我就一刀，就把他 刀啦！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "如此说来，你是图财害命！"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "我冤枉呀老爷……"
        },
        {
          "character": "穆伦",
          "type": "念",
          "text": "望老爷恕奴才，持斋把素永不开，持斋把素永不开。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "起去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "穆伦允，跪旁。王朝押吴氏、范锦同上。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "禀爷，老婆子、小儿带到。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "带上来。 那一老婆儿可是吴氏？"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "是啊爷爷。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "吴氏，你家可有个老苍头？"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "有个老苍头。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "往哪里去了？"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "出外贸易，三载未归。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "下面问那人便知明白。"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "唉哟！这不是穆伦，穆大哥么，啊！你可曾见我家老苍头？"
        },
        {
          "character": "穆伦",
          "type": "白",
          "text": "你家老苍头啊？我把他杀啦。"
        },
        {
          "character": "吴氏",
          "type": "白",
          "text": "啊！你怎么把他杀了！着打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴氏欲打穆伦，众衙役同拦。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "下去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴氏哭下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "穆伦图财害命，实实可恨。 刀斧手，斩首报来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刀斧手押穆伦同下，捧首级上。"
        },
        {
          "character": "刀斧手",
          "type": "白",
          "text": "献首级。"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": "交令了。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "穆伦图财害命，公案已结。只是那一妇人不知被何人勒死，埋在荒郊。前者有 一老头儿跪门，命人赶去，赶到城南五里，有一土地祠，老头儿入祠不见了。 王朝马汉，拿我火签，捉拿土地，晚堂听审。快去！快去！"
        },
        {
          "character": "王朝、马汉",
          "type": "同白",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同下。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯下。王朝、马汉同上。"
        },
        {
          "character": "王朝",
          "type": "念",
          "text": "奉命差遣，"
        },
        {
          "character": "马汉",
          "type": "念",
          "text": "概不由己。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "伙计请了。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "你我奉包大人之命，捉拿土地晚堂听审，我想土地乃是个泥胎，你我怎样的拿 法？"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "我倒有个主意。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "什么主意？"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "你我到在那里，把签票搁在那里，去也在他，不去也在他。"
        },
        {
          "character": "马汉",
          "type": "念",
          "text": "去去行行，行行去去。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "来到了。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "咱们见个礼。 土地公公，土地婆婆，我二人奉包大人之命，拿你二人听审。这是火签搁在这 里，票也搁在这里。你去还则罢了，你若不去呀，百家姓上一句。"
        },
        {
          "character": "马汉",
          "type": "白",
          "text": "哪一句呀？"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "你要不去，烧你个乌焦巴龚。 伙计，你看土地公公年岁大，土地婆婆年岁轻，他们两人不般配，咱俩给他彩 画彩画。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同画。"
        },
        {
          "character": "王朝",
          "type": "白",
          "text": "这回般配了，咱们交差去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王朝、马汉同下。土地、土地婆同上。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "你看看你那样子吧！我说那妇人留不得，你一定要留下。你瞧见没有啊，火签 也搁在这啦，票也搁在这啦！包公拿我晚堂听审。你去，我不去。"
        },
        {
          "character": "土地婆",
          "type": "白",
          "text": "你去我不去。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "你去，我不去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地婆打土地。"
        },
        {
          "character": "土地婆",
          "type": "白",
          "text": "你去不去，你去不去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地跪。"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "我去，我去。"
        },
        {
          "character": "土地婆",
          "type": "白",
          "text": "你敢不去！"
        },
        {
          "character": "土地",
          "type": "白",
          "text": "好生厉害。待我换了衣服，去见包公。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "土地、土地婆同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "土地",
          "type": "stage",
          "text": "—————————— ⑴曲牌名不详。另，《阳审》唱腔均为弋腔。 ⑵此段唱词唱腔皆不详。 ⑶此句唱词不确。"
        }
      ]
    }
  ]
}