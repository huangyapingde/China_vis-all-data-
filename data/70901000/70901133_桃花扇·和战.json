{
  "script_id": "70901133",
  "title": "桃花扇·和战",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "侯方域",
      "hangdang": "冠生"
    },
    {
      "name": "黄德功",
      "hangdang": "净"
    },
    {
      "name": "刘泽清",
      "hangdang": "丑"
    },
    {
      "name": "刘良佐",
      "hangdang": "净"
    },
    {
      "name": "高杰",
      "hangdang": "副净"
    }
  ],
  "plot": "靖安侯黄德功、东平侯刘泽清和广昌侯刘良佐，三镇诸侯，联合起来，与兴平侯高杰展开争斗厮杀。",
  "notes": "《和战》即《桃花扇》之第十九出。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "黄德功、刘良佐、刘泽清戎装随军校、众兵执旗帜、器械呐喊同上。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "俺庐、和、镇守史，靖安侯黄德功。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "俺淮、徐、镇守史，东平侯刘泽清。"
        },
        {
          "character": "刘良佐",
          "type": "白",
          "text": "俺凤、泗、镇守史，广昌侯刘良佐。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "二位贤弟请传令。闻得高杰在黄金坝上，点齐人马预备迎敌。我们分做三队人 马，依次前进。"
        },
        {
          "character": "刘良佐",
          "type": "白",
          "text": "俺带的人马原少。俺前去挑战，二位兄长与我接应便了。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "我的田雄不曾来，我做第二队，总叫河洲哥哥压哨便了。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "既如此，一同杀上前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。众人同下。〖急急风〗。高杰引众兵卒同上。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "俺乃扬州镇守史兴平侯高杰是也。闻得三镇前来征讨。 三军！摆开阵势，准备迎敌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同允。刘良佐上。"
        },
        {
          "character": "刘良佐",
          "type": "白",
          "text": "呔！高杰，快快出来争个谁大谁小。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "啊！你花马刘是咱小兄弟，你还敢如此。"
        },
        {
          "character": "刘良佐",
          "type": "白",
          "text": "你满口胡说，撒马过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘良佐、高杰同战，刘良佐败下。〖急急风〗。黄德功持双鞭上。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "高杰，我黄闯子的本领你是晓得的，快快磕头，饶你不死。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄得功、高杰同战，高杰示意众兵卒混战。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "呔！高杰！向来兵对兵，将对将。如要混战，到底你是无理贼子，今日且输与 你一阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄德功败下，刘泽清持双刀上。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "呔！高杰，你休要逞强，来，来，来！我与你横战也可，竖战也可，你可晓得 我翻天鹞子不怕人的么。来，来，来！我与你杀！杀！杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘泽清、高杰同战。侯方域上，摇令旗。刘泽清、高杰同住战。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "阁部大元帅有令，四镇作反，皆督师之过。请先到帅府杀了元帅，再到南京抢 了宫阙，不必在此混战，骚害平民。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "朝廷是我们立的，哎唷，元帅是朝廷派的，要不给元帅留个面子。我们本不曾 作反。只是高杰无礼，混乱座次。我们争个明白，好参谒元帅。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "俺高杰乃本部先锋，怎敢作反。他们领兵来杀，只得迎敌。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "不奉军令，妄行厮杀，都是反贼。明日奏闻朝廷，你们自己去分辩吧。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "朝廷是我们立的，元帅是朝廷派的。我们违了军令，便是叛了朝廷，如何使得？ 情愿束手待罪，只求元帅饶恕。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "高将军，你如何说？"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "我高杰是元帅犬马，犯了军法，只听元帅处分。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "既如此说，速传黄、刘二镇回赴辕门，央求元帅。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "二镇败走，各回汛地去了。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "你淮、扬两镇，唇齿之邦，又无宿嫌，为何听人指使？快快前去，候元帅发落。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众兵卒同下，侯方域下高台。高杰、刘泽清同至辕门。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "已到辕门了。两位将军在外等候，待俺传进去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯方域进。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "元帅有令，四镇擅相争夺，皆当军法从事。但高将军不知礼体，挑嫌起衅，罪 有所归。着与三镇服礼，俟解和之日再行处分。"
        },
        {
          "character": "侯方域",
          "type": "香柳娘",
          "text": "劝将军自思，劝将军自思， 祸来难救，负荆早向辕门叩。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高杰恼。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "俺高杰，乃元帅标下先锋。元帅不加护庇，倒叫与三镇服礼，可不羞死人也。 罢，罢，罢！看来元帅也不能用俺了。不免领兵渡江，另做事业去吧。"
        },
        {
          "character": "高杰",
          "type": "香柳娘",
          "text": "这屈辱怎当，这屈辱怎当， 渡过大江头，事业从新做。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "三军快来，随俺前去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众兵卒同上，呐喊摇旗同下。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "啊呀呀！高杰竟要过江了。想江南有他的党羽，不日要领来与俺厮闹。俺也早 去约会黄、刘二镇，多带人马，到此迎敌。"
        },
        {
          "character": "刘泽清",
          "type": "香柳娘",
          "text": "笑力穷远走，笑力穷远走， 长江洗羞，防他重来作寇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘泽清下。侯方域呆。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "不料局势如此，教俺怎生收救。"
        },
        {
          "character": "侯方域",
          "type": "香柳娘",
          "text": "恨山河半倾，恨山河半倾， 怎能重构；人心瓦解忘恩旧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯方域向南望。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "那高杰竟是反了。"
        },
        {
          "character": "侯方域",
          "type": "香柳娘",
          "text": "看扬扬渡江，看扬扬渡江， 旗帜乱中流，直入南徐口。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯方域向北望。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "那刘泽清也急忙北去，要约会三镇人马，全来迎敌。"
        },
        {
          "character": "侯方域",
          "type": "香柳娘",
          "text": "这烟尘偏有，这烟尘偏有， 好叫俺元帅搔头，参谋搓手。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "且回复了阁部，再作计较。正是："
        },
        {
          "character": "侯方域",
          "type": "念",
          "text": "堂堂开府辖通侯，江北淮南数上游。只恐楼船与铁马，一时都羡好扬州。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯方域下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}