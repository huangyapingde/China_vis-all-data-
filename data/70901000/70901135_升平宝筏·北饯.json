{
  "script_id": "70901135",
  "title": "升平宝筏·北饯",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "尉迟恭",
      "hangdang": "净"
    },
    {
      "name": "唐僧",
      "hangdang": "老生"
    },
    {
      "name": "徐绩",
      "hangdang": "老生"
    },
    {
      "name": "杜如晦",
      "hangdang": "老生"
    },
    {
      "name": "殷开山",
      "hangdang": "小生"
    },
    {
      "name": "程咬金",
      "hangdang": "丑"
    }
  ],
  "plot": "唐天子命大唐一十八路总管为唐三藏西天取经饯行。尉迟恭年老功高，乃向唐三藏及众人讲述御果园单鞭救\n唐王的经过。",
  "notes": "《北饯》即《升平宝筏》第四十出。原题：“饯送郊关开觉路”。\n《升平宝筏》清张照撰。全十本，共二百四十出。据《西游记》唐三藏西天取经故事改编而成。为清宫承应\n传奇巨制之一。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "徐绩、杜如晦、殷开山、程咬金同上。"
        },
        {
          "character": "徐绩",
          "type": "念",
          "text": "七寸潇湘管，"
        },
        {
          "character": "杜如晦",
          "type": "念",
          "text": "三分玉兔毫。"
        },
        {
          "character": "殷开山",
          "type": "念",
          "text": "落在文臣手，"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "安帮定圣朝。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "某，徐绩。"
        },
        {
          "character": "杜如晦",
          "type": "白",
          "text": "杜如晦。"
        },
        {
          "character": "殷开山",
          "type": "白",
          "text": "殷开山。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "程咬金。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "今有大唐师父往西天竺印度求取大藏真经，奉圣人命，着俺唐家一十八路总管， 都在那十里长亭饯行发路。怎么这般时候还不见尉迟老将军到来？"
        },
        {
          "character": "杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "想必就来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭嗽上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "某，复姓尉迟，名恭字敬德。朔州善阳人也。今有大唐师父往西天竺印度求取 大藏真经。奉圣人命，着俺唐家一十八路总管都在那十里长亭饯行发路，须索 走遭也。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "吓，老将军请了。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "列位请了。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "老将军为何来迟？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "列位。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "老将军。"
        },
        {
          "character": "尉迟恭",
          "type": "点绛唇",
          "text": "一来为帝主亲差，"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同夹白",
          "text": "二来呢？"
        },
        {
          "character": "尉迟恭",
          "type": "点绛唇",
          "text": "二来为老夫年迈，"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同夹白",
          "text": "持斋戒。"
        },
        {
          "character": "尉迟恭",
          "type": "点绛唇",
          "text": "持斋戒，哎则，则将这香火安排。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同点绛唇",
          "text": "送师父，临郊外。"
        },
        {
          "character": "唐僧",
          "type": "内白",
          "text": "阿弥陀佛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖万年欢〗，〖吹打住〗。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "远远望见幢幡宝盖，大唐师父来也。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "尉迟恭",
          "type": "混江龙",
          "text": "遥望着，幢幡和那宝盖， 见军民，百姓们多也闹咳咳，"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同夹白",
          "text": "军民百姓好不热闹也。"
        },
        {
          "character": "尉迟恭",
          "type": "混江龙",
          "text": "引领着一行儿侍从， 也荡散了满面尘埃， 坐下马，如同滴溜溜水急， 俺心里，恁似朔风来。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同夹白",
          "text": "按袱头。"
        },
        {
          "character": "尉迟恭",
          "type": "混江龙",
          "text": "俺这里——"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同混江龙",
          "text": "挪玉带， 见师父禅心儿己定。 师父将慧眼，落得个忙开。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "执事太监擎幢幡宝盖引唐僧同上。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "唐僧",
          "type": "念",
          "text": "口吃千家饭，身穿百纳衣。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "贫僧有何德能。敢劳众公卿远远相送。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金、尉迟恭",
          "type": "同白",
          "text": "不敢。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "列位请升界，请。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金、尉迟恭",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "请问列位尊姓大名？"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "徐绩。"
        },
        {
          "character": "杜如晦",
          "type": "白",
          "text": "杜如晦。"
        },
        {
          "character": "殷开山",
          "type": "白",
          "text": "殷开山。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "程咬金。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "唔……"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "丹墀下不为言者，莫非是尉迟老将军么？"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "咦，哈哈……不敢啊是不敢。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "久闻老将军南征北讨，东荡西驰。边扫六十四处烟尘，擅改一十八家年号，贫 僧只是耳闻，今日天色尚早，请老将军细说一遍，贫僧洗耳恭听。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "师父若不嫌絮烦，待某试说一遍。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "愿闻。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": "尉迟恭",
          "type": "油葫芦",
          "text": "十八处都将，年号改， 某扶立起唐世界。"
        },
        {
          "character": "唐僧",
          "type": "夹白",
          "text": "可不杀生害命？"
        },
        {
          "character": "尉迟恭",
          "type": "油葫芦",
          "text": "师父道俺杀生害命， 也罪何该。 想当日尉迟恭， 怎想到今日持斋戒， 今日个谢吾师， 恁便超度了俺这唐十宰。 俺这里便整顿了宫袍， 拂了土垓。 就在这尘埃地中展脚， 可便舒腰拜。 望师父特地请取一个法名来"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "要贫僧取法名么？"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "正是。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "就取：慧仁，慧义，慧理，慧智，慧信。念你孩儿尉迟宝林……待贫僧取得真 经回来，望空中念一声南无……"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同天下乐",
          "text": "救度俺这众生的们， 可便离了苦海。"
        },
        {
          "character": "尉迟恭",
          "type": "天下乐",
          "text": "师父那片虔也么心， 我可也无挂碍。 正按着救苦救难得这观自在，"
        },
        {
          "character": "唐僧",
          "type": "夹白",
          "text": "参的透。"
        },
        {
          "character": "尉迟恭",
          "type": "天下乐",
          "text": "参得透，色即是空，"
        },
        {
          "character": "唐僧",
          "type": "夹白",
          "text": "参不透。"
        },
        {
          "character": "尉迟恭",
          "type": "天下乐",
          "text": "参不透，空即是色， 师父那片修行的心， 某可也有甚么的歹。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "久闻得老将军，在南御园，小交锋，单鞭救主。贫僧只有耳闻，不曾目睹。再 请老将军试说一遍。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "师父若不嫌絮烦，待某家手舞足蹈，试说一遍。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "如此甚好。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "师父，此一节不为别的而起。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "端为谁来？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吖哈喏。"
        },
        {
          "character": "尉迟恭",
          "type": "后庭花",
          "text": "都只为病秦琼他太厉害， 皆因是，尉迟恭年老迈。"
        },
        {
          "character": "尉迟恭",
          "type": "夹白",
          "text": "嗯！"
        },
        {
          "character": "尉迟恭",
          "type": "后庭花",
          "text": "我想那一日相约定，那一日相约定， 尽都是杜如晦使的计策。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "老夫闻言听罢。哇呀……"
        },
        {
          "character": "尉迟恭",
          "type": "后庭花",
          "text": "怒气可也满胸怀， 这都是唐家，唐家的十宰， 那一日，鼓不擂，锣不筛，箭不发，甲怎生披， 只听得，耳边厢人报来。 御果园暗计排， 御果园暗计排。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同青哥儿",
          "text": "可恨他无知， 无知的波赖。 见一人倒在， 倒在尘埃。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "倒在尘埃者是谁？那年是何月日？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "那年五月五日，蕤宾佳节，将那南御园，改为御果园，他弟兄三人要做个金钱 插柳会。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "哪三人？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "第一建成。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "第二？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "元吉。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "第三？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "乃是吾主。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "绕着那御果园连转三遭，离百步之内，竖一高竿，高竿之上悬挂一枚金钱，他 弟兄三人要射那金钱之眼。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "哪个当先？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "先是建成，元吉，先射未中。那时我主，也不慌，也不忙，在飞鱼袋内挽一张 鞘不长，靶不短，拽得硬，射得远，背阔弦粗，铜胎铁靶宝雕弓。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "好弓也！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "又在走兽壶中抽一枝，捻一捻转千遭，水银灌杆，叮叮当当百步穿杨枣齿狼牙 箭。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "好箭也。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "扭入朱红扣，搭上紫金鈚，左手推靶，右手兜弦。左手推靶似挞檀台，右手兜 弦似抱婴孩。弓开如满轮秋月，箭发似一点寒星。箭无不发，发无不中。中无 不倒，倒无不死。只听得飕、飕、飕，连射三箭。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "可曾射中？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "正中那金钱的眼儿。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "好神箭也。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "那时吾主扭项回头，看他二人卖弄哪家的武艺。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "卖弄哪家武艺？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊呀不好！谁想建成那厮，起了不良之心，他要掣剑来伤吾主。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "可曾伤着？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "不想那剑有些恋鞘，元吉搬弓这样的打——"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "可曾打中？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "又被那花枝儿抓住了弓梢。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "唐僧",
          "type": "念",
          "text": "圣天子百灵相助，"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同念",
          "text": "大将军八面威风。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "不敢吓不敢。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "那时老将军在于何处？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "那时某在澄清涧洗马。吖呵，忽有军师来报。说主公在御果园有难，速去救驾。 那时吓得某，人披不及甲，马也备不及鞍，只得骣马单鞭，赶哪——"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "赶到哪里？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "赶到御果园。被某厉声高叫，呀呔！你们休伤吾主，是休伤吾主。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "那厮见了老将军便怎么样？"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "那建成、元吉，见了某就哈哈，吓慌了。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "他见老将军这等威严，也不怕他不慌。"
        },
        {
          "character": "敬德",
          "type": "白",
          "text": "有诗为证。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同白",
          "text": "怎道？"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "建成、元吉使双锋，倾刻英雄一梦中。若非敬德鞭在手，"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金",
          "type": "同念",
          "text": "谁人搭救圣明公。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "不敢，不敢。那时被某抢上一趷蹬步，走上前，抓住那厮狮蛮带，将他滴溜扑 掉下马来。"
        },
        {
          "character": "尉迟恭",
          "type": "青哥儿",
          "text": "我脚，脚踹住他胸怀， 脚踹住他胸怀。 只教他怎生样的挣扎， 叵耐寒才，使的计策。 便把那人杀害， 怒气可也满胸怀。 老微臣，忽喇喇一骑马儿赶将过来。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "被某一鞭。"
        },
        {
          "character": "尉迟恭",
          "type": "青哥儿",
          "text": "打碎那厮天灵盖。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "这场功劳古今罕有，天色已晚，贫僧趱路去也。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金、尉迟恭",
          "type": "同白",
          "text": "我等再送师父一程。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "不消。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金、尉迟恭",
          "type": "同煞尾",
          "text": "百忙里修行大， 禅性儿分毫不改。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金、尉迟恭",
          "type": "同白",
          "text": "愿师父把金经来取。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金、尉迟恭",
          "type": "同白",
          "text": "愿师父疾疾而去，早早地归来。"
        },
        {
          "character": "唐僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": "徐绩、杜如晦、殷开山、程咬金、尉迟恭",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
