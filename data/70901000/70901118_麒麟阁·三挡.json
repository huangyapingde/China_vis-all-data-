        {
          "character": null,
          "type": "stage",
          "text": "刮地风"
        },
        {
          "character": "兵甲",
          "type": "白",
          "text": " 𠮾才才得个逍遥云际。 呀！ 早来到，玉关岩、铁索围。 关上有人么？ 什么人？ 原来是太保，这身披挂要向何往？ 奉大王将令，要出潼关公干的。 可有令箭！ 有。 呈上来。 啊，妙啊！ 果然有大王令箭，开关，请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "兵甲下。"
        },
        {
          "character": "兵甲",
          "type": "stage",
          "text": "秦琼"
        },
        {
          "character": "兵甲",
          "type": "白",
          "text": "啊，哈哈……且喜被俺赚出关来也，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刮地风"
        },
        {
          "character": "兵甲",
          "type": "stage",
          "text": "好一似他乡遇故知。 𠮾呵痛慈亲珠泪垂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。杨林、众兵同上。"
        },
        {
          "character": "杨林",
          "type": "念",
          "text": "雄关暗袭，窃符虎帐如姬急。 偷过函关，商君殛，超海威，拔山力，垂天翼。 貔貅勇猛罹锋镝，山川搜索穷南北。 军威振，声名赫。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨林、众兵同下。秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "四门子",
          "text": ""
        },
        {
          "character": null,
          "type": "stage",
          "text": "夹白"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四门子"
        },
        {
          "character": "秦琼",
          "type": "stage",
          "text": "看、看、看连天展羽麾。 听、听、听、听喧天鼓角来何地？ 𠮾呀！这、这的是老大王带马追。 休比那等闲间看花游嬉。 呀！ 忙整顿冲天壮气。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨林、众兵同上。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "秦琼哪里走？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "大王，俺秦琼并无过犯，为何提兵追赶？"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "勾引响马，大反山东、火烧仓库，还说无罪，看枪！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "老大王，那都是贺方谗言，与俺秦琼何干？"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "盗孤令箭、杀孤爱姬，私出潼关，还说无罪，看枪！"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "老大王，你再三逼迫，秦琼无义了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、杨林同战，秦琼败下。"
        },
        {
          "character": "秦琼",
          "type": "stage",
          "text": "众兵"
        },
        {
          "character": "秦琼",
          "type": "同白",
          "text": "秦琼败下。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "追"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨林、众兵同下。程咬金上。"
        },
        {
          "character": "杨林",
          "type": "stage",
          "text": "程咬金"
        },
        {
          "character": "杨林",
          "type": "念",
          "text": "髫龄识、髫龄识，念患难同今昔。云天谊、云天谊，念生死同休戚。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "咱程咬金。奉了徐大哥之令，前来接应秦二哥。一路行来，闻得二哥与杨林这 老儿战了一日一夜，追至石龙桥，我此时不去接应，更待何时？"
        },
        {
          "character": "杨林",
          "type": "念",
          "text": "合兵敌、势男力，捐躯报效，敢惮荆棘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨林、秦琼同杀上，程咬金接战。"
        },
        {
          "character": "杨林",
          "type": "stage",
          "text": "程咬金"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "呔！杨林哪里走！"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "杀了半日，杀出一伙毛贼来了。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "什么毛贼不毛贼，放马过来。"
        },
        {
          "character": "杨林",
          "type": "白",
          "text": "饶你们这伙毛贼去吧。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "去你的吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨林败下。秦琼上。"
        },
        {
          "character": "程咬金",
          "type": "stage",
          "text": "程咬金"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "二哥，兄弟程咬金在此。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "原来是兄弟，亏你助力了。哈哈……"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "秦二哥，做的什么官，还是当强盗的好。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "咳，罢了是罢了。"
        },
        {
          "character": "秦琼",
          "type": "尾声",
          "text": "权向山林学避世， 论英雄，怎做得束手攒眉。 程咬金"
        },
        {
          "character": "秦琼",
          "type": "尾声",
          "text": "早打点，揭地掀天，"
        },
        {
