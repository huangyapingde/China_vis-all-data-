  "plot": "唐初高祖李渊病重将亡，乃令其三子：李建成、李元吉、李世民于御果园内箭射金钱，射中者方能继位。李\n建成、李元吉遂勾结单通，劫杀李世民以夺取王位。正于危急时刻，尉迟恭（敬德）闻讯赶到并打死了单通，\n李世民方得脱险。",
  "notes": "《御果园》又称《御科园》，为《兴唐传》之一折。\n《兴唐传》清升平署有抄本，作者不详。全十八本，其中第六本为《御园救驾》，全四出，无标题，故事情\n节与《御果园》相仿，但所用曲牌、戏文等，则完全不同。此外，元无名氏撰有《尉迟恭单鞭夺槊》杂剧；\n元尚仲贤撰有《尉迟恭三夺槊》杂剧。两杂剧皆以表现尉迟恭为主，故事情节并不相同。《兴唐传》之《御\n园救驾》当源出于此并加以改编而成。又清升平署有抄本《御果园》总本一册，不分出、有宾白、唱词、无\n工尺、不分曲牌，可能为“杂曲”之类。故事是写尉迟恭二次御果园救李世民的故事，与侯玉山今传《御果\n园》不符。当另有传本，惜今未见。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众将官引单通同上。"
        },
        {
          "character": "单通",
          "type": "点绛唇",
          "text": "执掌兵权，貔貅百万。"
        },
        {
          "character": "单通",
          "type": "念",
          "text": "身披铠甲透玲珑，匹马大槊逞英雄。忆昔当年放响马、反隋主，曾作南朝驸马 公。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "俺，单通，今有建成、元吉书信到来，命俺到御果园劫杀二主唐童。今乃黄道 吉日，正好发兵。 众将官！"
        },
        {
          "character": "众将官",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "兵发御果园！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将官同应。〖二犯江儿水〗。众人同下。〖吹住〗。"
        },
        {
          "character": "门官甲、门官乙",
          "type": "内同白",
          "text": "啊咳……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官甲、门官乙同上。"
        },
        {
          "character": "门官甲",
          "type": "念",
          "text": "家里打车。"
        },
        {
          "character": "门官乙",
          "type": "念",
          "text": "外头合辙。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "下官，官是也。"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "下官，也是官。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "官请了。"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "请了官。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "哎呀官吓！"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "哎呀官！"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "你我奉了二位千岁之命，看守御果园，说有一个单通在此经过，你我伺候他过 去，就交了差了。"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "我不认得他？"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "等他来了，我说与你就是了。"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "你我打坐等着他。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "等着他"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单通领众将官同上。〖江儿水〗。"
        },
        {
          "character": "众将官",
          "type": "同白",
          "text": "已到御果园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹住〗。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "埋伏了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单通下。"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "哎呀官哪！你看见了没有？一个菠菜糖手里拿大菜瓜过去啦。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "得啦，那就是单通。"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "那就是单通？"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "嗳。"
        },
        {
          "character": "门官乙",
          "type": "白",
          "text": "你我算交差啦。"
        },
        {
          "character": "门官甲",
          "type": "白",
          "text": "你我后面饮酒去。走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "门官甲、门官乙同下。秦琼、谢映登、程咬金同上。"
        },
        {
          "character": "秦琼",
          "type": "念",
          "text": "手持双锏坐黄骠，"
        },
        {
          "character": "谢映登",
          "type": "念",
          "text": "白马银枪逞英豪。"
        },
        {
          "character": "程咬金",
          "type": "念",
          "text": "上阵全凭加钢斧，"
        },
        {
          "character": "秦琼、谢映登、程咬金",
          "type": "同念",
          "text": "赤胆忠心保唐朝。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺秦琼。"
        },
        {
          "character": "谢映登",
          "type": "白",
          "text": "俺谢映登。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "俺程咬金。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "众家弟兄请了。"
        },
        {
          "character": "谢映登、程咬金",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "今有老主染病在床，命三位殿下在御果园箭射金钱，只用文官，不用武将，不 知所为何事？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "秦二哥，这样大事，你都不晓得？"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "不晓得。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "附耳过来。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "讲说什么？"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "连我也不晓得。"
        },
        {
          "character": "谢映登",
          "type": "白",
          "text": "且到临时再做道理。正是："
        },
        {
          "character": "谢映登",
          "type": "念",
          "text": "丹心扶社稷，"
        },
        {
          "character": "秦琼、程咬金",
          "type": "同念",
          "text": "赤胆保明君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼、谢映登、程咬金同下。徐绩上。"
        },
        {
          "character": "徐绩",
          "type": "念",
          "text": "一片丹心扶社稷，两条眉锁庙堂忧。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "下官徐绩，今有老主染病在床，命三位殿下在御果园，箭射金钱，哪家射得， 即登大宝。"
        },
        {
          "character": "太监",
          "type": "内白",
          "text": "道言未了，三家殿下来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李建成、李元吉、李世民同上。"
        },
        {
          "character": "李建成、李元吉、李世民",
          "type": "同引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": "李建成、李元吉、李世民",
          "type": "同念",
          "text": "万国衣冠祝圣明，四海宁靖庆生平。清香一炷朝天地，文武百官赞此行。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "本御建成。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "本御世民。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "本御元吉。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "今日父王染病在床，命我弟兄三人去到御果园，箭射金钱，哪家射得，即登大 宝。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "嘿！皇兄，还是你我射中方好。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "这个自然。 军师。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "车马可曾齐备？"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "齐备多时了。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "吩咐起驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监应。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "起驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖玉芙蓉〗。众人同下。花神上。"
        },
        {
          "character": "花神",
          "type": "白",
          "text": "吾乃花神是也。今有二主御果园有难，不免差二鬼前去护救。 二鬼何在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小鬼同上。"
        },
        {
          "character": "花神",
          "type": "白",
          "text": "今有二主御果园有难，命你二人前去护救，不得有误。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二小鬼同应，花神、二小鬼同下。太监领李建成、李元吉、李世民、徐绩同上。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "来此已是御果园，哪家御弟先请。"
        },
        {
          "character": "李世民、李元吉",
          "type": "同白",
          "text": "还是皇兄先请。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "呀。还是我先射，如此看弓来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖片子〗。李建成射箭。"
        },
        {
          "character": "李世民、李元吉",
          "type": "同白",
          "text": "皇兄怎么样了？"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "弓不曾拉开，我小肠串气疼。我不行！看你们的吧！"
        },
        {
          "character": "李世民、李元吉",
          "type": "同白",
          "text": "没你的天份。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "皇兄请。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "我想，有兄就有弟，御弟请。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "如此，看弓箭来。哎呀！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "御弟怎么样了？"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "我弓不曾拉开，掰了我的膀子。"
        },
        {
          "character": "李世民、李建成",
          "type": "同白",
          "text": "没有你的天份。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "皇兄请！"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "皇兄，御弟都不曾射着，小弟不射也就罢了。"
        },
        {
          "character": "李元吉、李建成",
          "type": "同白",
          "text": "哪有不射之理？"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "既如此，看弓箭过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民将金钱射掉。单通上。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "皇兄。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "御弟。"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "单通杀红了眼了，连你我全杀起来了。"
        },
        {
          "character": "李建成",
          "type": "白",
          "text": "你我到哪里藏躲？"
        },
        {
          "character": "李元吉",
          "type": "白",
          "text": "后宫里跑吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李建成、李元吉同下，李世民追单通同上，单通用槊打李世民，二小鬼同上抱住槊。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "单通慢动手！"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "什么人拉住俺单通？"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "下官徐绩。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "当初降唐，为何不用俺单通。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "念结拜之情。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "呀，念结拜之情？也罢，俺与你割袍断义！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单通下。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "哎呀！看单通这厮与我割袍断义，这便如何是好？待俺袖占一课…… 吖哈有了，今有敬德在澄澄涧洗马，俺不免急急赶上前去，命他救驾便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐绩下。李世民上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "哎呀不好！看单通这厮追俺正紧，这便如何是好？吖呵也罢！不免下得马去， 藏在花棵之下便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李世民下，单通上。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "哎呀！看唐童这厮藏在花棵之下，俺不免下得马去，卸了铠甲，擒他便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "单通下。尉迟恭上。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "啊哈……"
        },
        {
          "character": "尉迟恭",
          "type": "醉花阴",
          "text": "统领貔貅提鞭叫， 我恨、恨乌鸦疆场也那乱扰； 恨罗成小儿曹， 两军前鞭枪齐搅。 有一日金镫鞭敲， 方显得英雄年少。"
        },
        {
          "character": "尉迟恭",
          "type": "念",
          "text": "金叶乌甲黑幞头，当初扶保刘武周。大战罗成回来路，难免敬德脸面羞。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "俺，尉迟敬德。我与军师赌头争印，大战罗成。我若胜得罗成，他将军师牌印， 输与俺掌管。若俺胜不得罗成，将俺项上人头就输与他！哎！偏偏败下阵来， 无有颜面去见军师。今当五月五日，乃是息兵的日期，俺不免去澄清涧洗马 一回。呀！来此已是澄清涧，好一片清泉，待俺洗马一回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖工尺上〗。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "吖呵马呀！当年扶保刘武周，跳红尾涧的时节，你那威风劲往哪里去了？我与 军师赌头争印，大战罗成，偏偏的你就败下阵来。我对你说，再要上得阵去， 将你那口张的大大的，你那么一口，叨下他马来。赢了军师牌印，挂在你的胸 前，你也威风、威风，煞气、煞气！记住了，记住了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖马叫声〗。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀，看这孽畜也使起性儿来了。"
        },
        {
          "character": "尉迟恭",
          "type": "喜迁莺",
          "text": "这马儿心中焦躁， 乍鬃尾，如狼似豹。 哮也么哮。 这畜生，也有性知闹， 好叫俺，怒发冲霄。 擒罗成，全仗于汝， 方显得，赌赛功高。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "看天气炎热，不免把俺的身体也沐浴沐浴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖工尺上〗。徐绩上。〖吹住〗。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "敬德，敬德！"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀！什么人大胆，叫我一声敬德，待我看来。 吖！原来是军师，你到此何事？"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "二主御果园有难，命你前去救驾。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你把此话来哄谁，分明把俺诓上岸去，想要这个买卖儿，那是万万的不能。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "你若不信，这有军令状。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "待我与你扯碎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "徐绩撕碎军令状，下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哇呀……哎呀！二主有难，俺不免前去救驾便了！我赶，赶！赶！"
        },
        {
          "character": "尉迟恭",
          "type": "水仙子",
          "text": "赶那厮无处逃， 怎、怎、怎，怎把那军状撕碎了。 只、只、只，只得把我主洪恩报， 快、快、快，快去救驾莫迟疑。 我戴、戴、戴，戴不稳这项幞头帽， 备、备、备，备不上乌骓马鞍桥。 恨、恨、恨，恨不能早把御园到， 这、这、这，这的是韂马单鞭救驾走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。秦琼上。"
        },
        {
          "character": "秦琼",
          "type": "白",
          "text": "俺秦琼。二主御果园有难，赶上前去救驾便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "秦琼下。单通追李世民同上，尉迟恭上，将单通打下。谢映登上。"
        },
        {
          "character": "谢映登",
          "type": "白",
          "text": "二主有难，赶去救驾便了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "谢映登下。单通追李世民同上。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "单通，饶恕孤家，封你为段国公。"
        },
        {
          "character": "单通",
          "type": "白",
          "text": "长国公也不饶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭上，将单通打下。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "哎呀！你看单通这厮，我家千岁封他为段国公，他听到哪里去了，说什么长国 公也不饶。呔！单通啊单通，你黑爷爷将你赶上，打你个长短不齐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭下。程咬金上。"
        },
        {
          "character": "程咬金",
          "type": "白",
          "text": "俺程咬金救驾哟！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "程咬金下。尉迟恭追单通同上，将单通打死。李世民、秦琼、谢映登、程咬金、徐绩同上。"
        },
        {
          "character": "秦琼、谢映登、程咬金、徐绩",
          "type": "同白",
          "text": "主公醒来，主公醒来。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "何人救驾？"
        },
        {
          "character": "秦琼、谢映登、程咬金、徐绩",
          "type": "同白",
          "text": "敬德。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "命他见孤。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "敬德快来。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "来了，来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "尉迟恭遮脸。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "千岁命你见驾。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "军师，你看我赤身露体难以见驾。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "待我与你去奏。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "你就去奏，见不得驾。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "启千岁：敬德赤身露体，难以见驾。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "也罢，将孤家龙袍赏与他遮盖身体。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "拿过来。 唔！军师，千岁爷，龙袍小咱的身体大。顾了上半截顾不了下半截。"
        },
        {
          "character": "徐绩",
          "type": "白",
          "text": "遮了下半截见驾要紧。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "军师前行。嘿！遮下半截见驾要紧。 敬德见驾来迟，愿我主千岁，千千岁。"
        },
        {
          "character": "李世民",
          "type": "白",
          "text": "救孤功劳不小，封你为一字降唐鄂国公。"
        },
        {
          "character": "尉迟恭",
          "type": "白",
          "text": "多谢万岁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}