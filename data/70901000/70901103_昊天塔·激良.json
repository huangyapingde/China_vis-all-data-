{
  "script_id": "70901103",
  "title": "昊天塔·激良",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "孟良",
      "hangdang": "净"
    },
    {
      "name": "杨延昭",
      "hangdang": "武生"
    },
    {
      "name": "岳胜",
      "hangdang": "武生"
    }
  ],
  "plot": "《激良》即《昊天塔》之第二折。写杨继业被番兵困在两狼山虎口交牙峪，后撞李陵碑而死，幽魂乃托梦于\n其子六郎杨延昭。杨延昭惊醒后，将梦中之事向排军岳胜诉说，并用激将法激恼孟良。二人遂同闯敌阵，去\n昊天塔盗取杨继业骨殖。",
  "notes": "《昊天塔》杂剧，正名《昊天塔孟良盗骨殖》，全四折。元朱凯（一曰无名氏）撰。取材于宋代杨家将故事。\n写宋、辽交兵之际，老将杨继业被辽兵围困，撞死在李陵碑下，杨七郎亦阵亡。杨继业尸身被吊在昊天寺\n塔尖上，每日一百个辽兵，轮番射三箭。杨继业及七郎二人魂灵不散，托梦给杨延昭以夺回骨殖。后六郎用\n激将法激恼孟良去盗骨。于归途中被追兵冲散，六郎逃到五台山，巧遇在此出家的杨五郎，兄弟难中相遇，\n悲痛万分。六郎将盗取父亲骨殖之事细诉一遍，五郎愤极，此时，追兵已到，二人合力击退了辽兵。六郎归\n去，五郎仍留五台山为僧。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。四龙套、中军引杨延昭同上。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "昨夜分明见严亲，休言梦里是非真。我今不把冤仇报，枉为英雄一世人。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "岳胜告进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳胜上。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "元帅在上，岳胜打恭。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟免礼，请坐。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "谢坐。元帅，今日为何开门恁早？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟有所不知，昨夜梦见老父托梦于我，对俺说，被番兵困在虎口交牙峪，内 无粮草，外无救兵。我父差七郎兄弟前去雄关搬兵求救，不想被潘仁美乱箭射 死。那时，我父盼兵不到，盼子不归，万般无奈，碰死在李陵碑下。尸首被番 兵盗去，吊在幽州昊天塔上，每日用一百个小番各射一箭，名曰百箭会。那时 我父幽魂疼痛难忍，来在三关渡口，托梦于我，叫我盗取爹爹骨殖而归，无计 可施，故此伤感。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "吓元帅，既如此，何不领兵前去，抢回老元帅骨殖，有何不可？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟，若统大兵，番兵必然有所准备，怎得骨殖到手？此乃悄悄地行动，方能 成功。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "待小弟同哥哥去。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "俱个去不得。惟有孟良兄弟方能成功。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "元帅。只是孟良是个倔强性儿，使他去，他倒不去，不使他去，他偏要去。唯 有用言语激发于他，方能前去。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "既如此，待我吩咐。 中军过来。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "辕门把守，待孟良回来，就说元帅与将军议论紧急军情，用他不着，叫他回避。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。孟良上。"
        },
        {
          "character": "孟良",
          "type": "念",
          "text": "伽山太保显英豪，昼夜巡边不惮劳。饶尔番兵千百万，撞着咱，胆战魂魄消。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "俺孟良，奉着哥哥将令，巡察界河，一路平安无事，不免回复哥哥将令，须索 走遭也。"
        },
        {
          "character": "孟良",
          "type": "粉蝶儿",
          "text": "这些时无处征伐， 俺在那界河边，恰才巡罢。 撞俺的一个个活捉生拿， 涌彪躯舒猿臂，肝横胆乍。 也不用将武艺盘咱， 回头儿只看咱全身披挂。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "来此已是辕门，为何这等静悄悄地？ 呔！里面哪个小校在？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "孟将军回来了，巡查界河多有辛苦。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "小校，禀知元帅，说俺孟良巡查界河一路平安无事，俺今特来交令。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "元帅与岳将军在后帐议论紧急军情，用你不着，叫你回避。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "用哪个不着？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "用你不着。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "叫哪个回避？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "叫你回避。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "呔！小校吃我一斧！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "请元帅，啊呀杀人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、岳胜同上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哪个在此杀人？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哇呀……"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "岂敢无礼！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哇呀…… 恁兄弟奉着哥哥将令，巡查界河，一路平安无事，俺今特来交令。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟多有辛苦。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "好说。方才那一小校说，元帅与岳将军在后帐议论紧急军情，用俺不着，叫俺 回避，俺故此吓他。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "此话是我对他说的。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "果有此话。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "啊呀，果有此话？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟，我这里用你不着，你自回避。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "用哪个不着？"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "用你不着。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "叫哪个回避？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "叫你回避。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "啊呀，哥呀！你今番就是杀了俺，也是偏不回避的。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "岳贤弟，你看孟良哪知我的心事来。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孟良",
          "type": "红绣鞋",
          "text": "往常时，无我来不喜欢说话， 今日个，见俺来便低着头无语使这嗟呀！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哥！"
        },
        {
          "character": "孟良",
          "type": "红绣鞋",
          "text": "有甚么机密事， 对孟良也合知么。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳胜与杨延昭耳语。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孟良",
          "type": "红绣鞋",
          "text": "一个儿眼角觑，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "他哪里知道？"
        },
        {
          "character": "孟良",
          "type": "红绣鞋",
          "text": "一个儿脚尖踏。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "噫！"
        },
        {
          "character": "孟良",
          "type": "红绣鞋",
          "text": "好教俺半合儿傒幸杀。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "孟贤弟，元帅有件心事命你猜来，猜着用你，猜不着你自回避。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "元帅有心事，命俺猜来？"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "嗨！待俺猜来，待俺猜来，待俺猜来，俺今番猜着了。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "猜着何来？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "吖呵喏！"
        },
        {
          "character": "孟良",
          "type": "石榴花",
          "text": "莫不是大辽兵马前来蹅踏， 俺与你火速地便去争杀。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "不是。"
        },
        {
          "character": "孟良",
          "type": "石榴花",
          "text": "莫不是王枢密搬弄着、搬弄着宋官家， 俺与你急忙备马便去京华。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "不是。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "啊呀是了。"
        },
        {
          "character": "孟良",
          "type": "石榴花",
          "text": "莫不是佘太君定有人便相欺压，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孟贤弟，我的老母谁敢欺压！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "吖咳，着啊！量他们确也不敢！"
        },
        {
          "character": "孟良",
          "type": "石榴花",
          "text": "则除非赵玄坛威力无加， 才敢把虎头儿须来抓。 俺与你亲自把贼拿。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孟贤弟，我要取一物，他那里兵多将广，只怕你一人取他不来。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "那厮他！"
        },
        {
          "character": "孟良",
          "type": "斗鹌鹑",
          "text": "又不是布雾的蚩尤， 又不是飞天、飞天的夜叉。 那厮便躲在云中， 藏在了藏在了地下。 俺可也翻过了乾坤， 若见他，说那厮能变化。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "吼一吼！"
        },
        {
          "character": "孟良",
          "type": "斗鹌鹑",
          "text": "骨碌碌海沸山崩， 觑一觑，觑一觑天摧地塌。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孟贤弟，量你也猜不着。待愚兄对你说了吧。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我的哥，请讲，请讲！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "昨夜偶得一梦，梦得我父老元戎托梦于我，说被番兵困在虎口交牙峪，只困得 内无粮草，外无救兵，我父差七郎兄弟前到雄关搬兵求救，不想被潘仁美乱箭 射死！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哇呀……我的哥，请讲，请讲！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那时我父盼兵不到，盼子不归，无奈碰死在李陵碑下。尸骨被番兵盗去，吊在 幽州昊天塔上，每日用一百个小番，各射一箭，名曰百箭会。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哇呀……请讲，请讲！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那时我父幽魂疼痛难忍，来在三关渡口，托我一梦，叫我盗取爹爹骨殖而归。 是我无计可施，故此伤感吓。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我的哥，我想这件事，别人去不得，恁兄弟我倒也去得。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你去不得。你……"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "啊……"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "不能！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "孟良",
          "type": "上小楼",
          "text": "凭着俺烧天火把， 说什么经忏佛法。 大踏步踹入僧房， 拿住和尚，揝定袈裟。 性气差，忿怒发，拖离禅榻，"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "滴溜溜噗！"
        },
        {
          "character": "孟良",
          "type": "上小楼",
          "text": "脑袋儿殿前阶下。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孟贤弟，你若拿住那厮便怎样？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我若拿住他！"
        },
        {
          "character": "孟良",
          "type": "上小楼",
          "text": "胸脯上脚去蹬， 面门上把来抓。 凭着俺腰下宣斧， 乞抽扢叉、斫他鼻凹。 恶菩萨、狠那吒，金刚答话， 我直着释迦佛也整理不下。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "贤弟执意要去，可带多少人马？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我的哥。"
        },
        {
          "character": "孟良",
          "type": "尾声",
          "text": "凭着俺火轮儿左手拿， 宣花斧右手杀。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "摇一摇，晃一晃，震动了千层琉璃瓦！"
        },
        {
          "character": "孟良",
          "type": "尾声",
          "text": "俺可也推倒玲珑舍利塔！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "我的哥请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良下。"
        },
        {
          "character": "岳胜",
          "type": "白",
          "text": "孟良此去必然成功。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "岳贤弟紧守营盘，"
        },
        {
          "character": "岳胜",
          "type": "念",
          "text": "孟火星谁敢挡拦。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "众头领休离汛地，"
        },
        {
          "character": "岳胜、杨延昭",
          "type": "同念",
          "text": "取骨殖早回三关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "岳胜、杨延昭同下。"
        },
