{
  "script_id": "70901105",
  "title": "义侠记·打虎",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "武松",
      "hangdang": "武生"
    },
    {
      "name": "酒保",
      "hangdang": "丑"
    }
  ],
  "plot": "武松酒醉后，在景阳岗上只身打死猛虎。本折刻画了武松勇敢顽强的英雄性格。",
  "notes": "《打虎》原名《除凶》，即《义侠记》第四折。《义侠记》明沈璟撰，共三十六折。取材于《水浒传》好汉\n武松的故事，以武松“义”而“侠”得名。全剧从景阳岗打虎开始至梁山招安结束，并添有武松之妻崔氏同\n母亲寻访武松，路遇孙二娘等情节。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "虎上，虎跳，四猎户同上。"
        },
        {
          "character": "四猎户",
          "type": "同上小楼",
          "text": "大家要抖擞精神， 大家要抖擞精神， 不要那猛虎伤人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猎户下。酒保上。"
        },
        {
          "character": "酒保",
          "type": "念",
          "text": "隔壁三家醉，开坛十里香。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我酒保的便是，在景阳岗边开了个小小的酒铺，看天气晴和，不免将幌儿挂出 去，有吃酒的来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保下。武松上。"
        },
        {
          "character": "武松",
          "type": "念",
          "text": "道旁车马日缤纷，行路悠悠何足云。未知肝胆向谁是，今人却忆平原君。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "俺武松，久住在柴皇亲庄上，一路探听宋兄消息。是俺别了柴大官人，去到阳 谷县访俺的兄长，就此走遭也。"
        },
        {
          "character": "武松",
          "type": "新水令",
          "text": "老天何苦困英雄， 二十年一场春梦。 不能够奋云程九万里， 只落得沸尘海，数千重。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "想俺武松呵！"
        },
        {
          "character": "武松",
          "type": "新水令",
          "text": "嗳好，好一似浪迹浮踪， 任乌兔闯荡搬弄。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哎呀且住！来此已是景阳岗，待俺沽饮几壶再走。啊呀！你看那酒幌之上写着 “三碗不过岗”确是为何？我且吃酒不要管他。 酒家！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "酒保上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官要喝酒吗？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "如此，请里面坐。待我抹过桌儿，去取酒来。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "转来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "唉，客官怎么说？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "我来问你，那酒幌上写着“三碗不过岗”，却是为何？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官，我这里造的酒甚高，有人吃了三碗，喏、喏、喏，可就过不去前面景阳 岗了。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呵，待我吃上他十来碗，看过得此岗，过不得此岗。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "喔哟，好大话！待我将酒取一壶来。 伙计们，将酒取一壶来。 客官酒到。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "斟上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏饮酒乐回回曲。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "干！好酒。斟上！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松饮酒。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "干！斟上！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是啦。吓客官，净吃酒吗？不用什么菜淡淡您那口么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹住。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "酒家！"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "又何须炮凤烹龙。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏饮酒乐回回曲，吹住。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "干！斟上！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哦，斟上。没有啦！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "啊？怎么才吃就无有了？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官有所不知，我这壶酒只盛得三碗，多一滴也是盛不下的。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "什么三碗、五碗，有酒只管取来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "我那里边还有小小一坛。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好！快去取来。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是啦！ 喂，伙计们，拿坛好酒来！ 客官酒到。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "打去泥头。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是。乒乓噗！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "蠢才！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "迷武松眼，武松揉眼。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "光棍眼里着不下沙子。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "斟上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "唉！客官，你看我这酒犹如琥珀一般。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "妙啊！"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "鹦鹉杯浮琥珀光浓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏饮酒乐回回曲。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "斟上！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官，方才三碗，如今两碗，共合五碗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹住。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "酒家！"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "却不道这五斗消醒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏饮酒乐回回曲。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "干！斟上！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哎，斟上。客官，方才三碗，如今有三碗，共凑六碗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹住。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "酒家！"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "三杯何道，俺自有神功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏饮酒乐回回曲。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "看仔细些。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "斟上。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是，斟上。客官，这酒不是什么好东西，吃得下去便吃，吃不下去，不要强吃。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹住。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呔！酒保，你这个人好碎嘴，想俺在此吃酒呵！"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "何劳你偏虚担怕恐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "奏饮酒乐回回曲。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "斟上！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官，这酒也剩不多了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹住。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松捧坛喝，掷坛。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "果然好酒。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "呵……哇，喔哟！险些砸碎了我的坛子，客官还喝不喝？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "不用了，算账！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "算账。先是一壶，后是一坛，一坛一壶，一壶一坛，共合银子三钱四分五厘六 毫半。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "多少？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "三钱四分五厘六毫半。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哎呀且住！多蒙柴大官人送俺的盘费，一路用来，剩也剩不多了。啊酒保，我 这包里三四分银子拿去！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "什么？这三四分银子不够哇。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "怎么不够？也罢，将这包儿留下，改日再取。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哦。客官敢是要留当头的意思么？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "如此……我上账去。客官贵姓？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "姓武。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "姓鲁？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "姓武。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "哦，姓卜。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呔！俺姓武。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "是啦，姓武。听错了。 喂伙计们，上了武客官的账！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伙计内应。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "咳！好羞惭人也。"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "好叫俺羞杀囊空。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "看天色已晚，不免上岗趱路。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "吓，客官，您要往哪里去呀？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "上岗趱路。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "您来得去不得了！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "怎么说，来得去不得？"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官有所不知，我们景阳岗，出了一只吊睛白额虎，拦路伤人，来往客商，不 知被它害了多少。故此，官府写下榜文，不许客人单身行走，倘若前去，被衔 去一口，岂不痛苦哀哉！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呔！不提起猛虎便也罢了，若提起猛虎恼得俺精神抖擞，头发欲竖，俺如今偏 要去！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "去不得！"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "按不住怒气冲冲，行色匆匆。"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "去不得！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "放手！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "客官，当真去不得！"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "谁要你多管！"
        },
        {
          "character": "酒保",
          "type": "白",
          "text": "不管就不管。"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "趁着这落日熹微，似俺这醉眼朦胧。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "呔！虎在哪里！虎在哪里！呀呸！哪里来的虎，你看官府榜文，也是无用了。 一路上岗，酒也涌上来了。呀！看那边有块大石，俺不免打一盹睡，起来再走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎啸，跳上。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好大风，好大风！呔！果然一只大虫来也！"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "我觑，觑着这破毛团虎势凶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。武松、虎同打。"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "狼牙棒先催进。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。"
        },
        {
          "character": "武松",
          "type": "折桂令",
          "text": "俺这里前退后忙， 这孽畜舞爪张牙横。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虎扑，武松躲。"
        },
        {
          "character": "武松",
          "type": "得胜令",
          "text": "呀！哎呀闪、闪得它回身扑着空， 转眼处乱着踪。 这的是虎有伤人意， 因此上冤家对面逢。 再显神通， 怎知俺力有千斤重。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "虎啊虎，今番遇俺武松呵！"
        },
        {
          "character": "武松",
          "type": "得胜令",
          "text": "途穷， 管教你花开没有百日红， 花开无有百日红。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松将虎打死。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "这只大虫，被俺打了几下，竟自死了。将它扔下岗去。下岗趱路，下岗趱路。 呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众猎户同上。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "看那边又有两只大虫来也！"
        },
        {
          "character": "武松",
          "type": "沽美酒",
          "text": "须索要， 逞余威斗晚风， 逞余威斗晚风。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "不是虎，"
        },
        {
          "character": "武松",
          "type": "沽美酒",
          "text": "只见它双挪踪。"
        },
        {
          "character": "众猎户",
          "type": "同白",
          "text": "什么人？"
        },
        {
          "character": "武松",
          "type": "沽美酒",
          "text": "俺，俺本是盖世英雄， 唤武松。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "你是武松，可见那只猛虎？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "虎在那里！"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "看枪！果然将猛虎打死。你是怎样将猛虎打死？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "听者。"
        },
        {
          "character": "武松",
          "type": "太平令",
          "text": "试言它凶猛， 负虎恁威风。 身一扑山来般重； 尾一剪钢刀般横； 数步远众生哀痛。 俺呵！ 恁着俺胆雄气雄， 空拳儿结果了大虫。 呀！教众口将咱称颂。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "那只猛虎被你打死，我等不信。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": "武松",
          "type": "鸳鸯煞",
          "text": "早难道， 岩前虎兽雄心横。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "虎在哪里？虎在哪里？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "那不是虎！"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "看枪！果然一只大虫被他空拳打死，就是卞庄、存孝也不如你。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "武松",
          "type": "鸳鸯煞",
          "text": "俺笑那卞庄、存孝全无用。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "下岗趱路。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "且慢！来得去不得。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "怎么去不得？"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "随我们到县上请功受赏。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "请功受赏？"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "武松",
          "type": "鸳鸯煞",
          "text": "俺本是逆旅经商，谁承望奏捷陈功。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "吓，列位，俺去只去。只是一件。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "哪一件？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "列位。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "壮士！"
        },
        {
          "character": "武松",
          "type": "鸳鸯煞",
          "text": "我怕， 怕只怕六巷三街，"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "前遮、"
        },
        {
          "character": "武松",
          "type": "鸳鸯煞",
          "text": "后拥，沸沸扬扬。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "沸沸扬扬怎么样？"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "你们阳谷县的虎，被俺清河县人打死！"
        },
        {
          "character": "武松",
          "type": "鸳鸯煞",
          "text": "怕恁那阳谷县的人讥讽。"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "壮士随我们到县上，叫那满城百姓，认认你是打虎的好汉。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "怎么，一定要去？"
        },
        {
          "character": "猎户",
          "type": "白",
          "text": "一定要去。"
        },
        {
          "character": "武松",
          "type": "白",
          "text": "好，将虎扛起来！"
        },
        {
          "character": "武松",
          "type": "鸳鸯煞",
          "text": "怎当他们把俺来恁趋奉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武松、众猎户同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}