{
  "script_id": "70901134",
  "title": "升平宝筏·擒猴",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "李靖",
      "hangdang": "净"
    },
    {
      "name": "孙悟空",
      "hangdang": "武生"
    }
  ],
  "plot": "玉皇大帝派众天兵天将到花果山擒拿孙悟空，孙悟空领众小猴奋力厮杀，众天将败下。后二郎神出战，擒住\n孙悟空，交与太上老君装进八卦炉，以炼取金丹。",
  "notes": "《擒猴》即《升平宝筏》第十六出，原题：“营开细柳专征讨”。\n《升平宝筏》清张照撰。全十本，共二百四十出。据《西游记》唐三藏西天取经故事改编而成。为清宫承应\n传奇巨制之一。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李靖上。"
        },
        {
          "character": "李靖",
          "type": "唱",
          "text": "统领熊貔，军威严厉，尊天帝，剿灭渠魁，扫尽妖魔辈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众天将同上。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "众天将打躬。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "站在两厢。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "李靖",
          "type": "念",
          "text": "大将威威出玉庭，神兵十万列连营。天罗地网安排定，管取妖猴一命倾。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "某，托塔天王李靖。可恨妖猴大闹蟠桃会，私窃老君金丹。玉帝大怒，命俺统 领天兵十万，二十八宿曜星君，十二元辰，四大天王，东西南北星斗，丧门地 煞，风雨雷电，计都罗猴，桑门吊客，六丁六甲，哪吒、巨灵，灌口二郎神， 齐到花果山、水帘洞擒拿妖猴，扫清洞府。 众天将！"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "吓。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "吾奉玉帝敕旨，花果山去者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。〖三枪唢呐〗。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "已到花果山。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "撒下天罗地网。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "俺这里神通奇异， 妖氛不许踏先飞， 俺这里祥云露露， 他那里冷雾凄凄； 俺这里一片雄心，多智谋， 他那里千般魔力少神机。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "马天君。"
        },
        {
          "character": "马天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "命你带领计都星呵！"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "恁在那山前迎战施法力。"
        },
        {
          "character": "马天君",
          "type": "白",
          "text": "尊旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马天君下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "赵天君。"
        },
        {
          "character": "赵天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "命你带领罗猴星呵！"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "恁在那山后边运动神机，"
        },
        {
          "character": "赵天君",
          "type": "白",
          "text": "尊法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵天君下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "温天君。"
        },
        {
          "character": "温天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "命你带领月孛星君呵！"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "恁在那山左接战。"
        },
        {
          "character": "温天君",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "温天君下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "刘天君。"
        },
        {
          "character": "刘天君",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "命你带领丧门星呵。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "恁在那山右边，将他魂魄追随。"
        },
        {
          "character": "刘天君",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘天君下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "巨灵神。"
        },
        {
          "character": "巨灵神",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你为前部先锋，带领风雨雷电呵。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "惩将他巢穴倾倒。"
        },
        {
          "character": "巨灵神",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "巨灵神下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "哪吒。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你为都接应，带领六丁六甲呵。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "务必要剿灭渠魁。"
        },
        {
          "character": "哪吒",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "哪吒下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "二郎神！"
        },
        {
          "character": "二郎神",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "你为万部总先锋，带领二十八宿，十二元辰。今日之战，全仗于你，你可将妖 猴紧紧追赶。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "见妖猴紧追紧赶， 休得要半步相离。"
        },
        {
          "character": "二郎神",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二郎神下。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "俺这里天兵天将施威武。"
        },
        {
          "character": "李靖",
          "type": "混江龙",
          "text": "他那里，猴卒妖兵乱逞威。 只杀得愁云惨淡，只杀得，星斗依稀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "我把泼猴呵！"
        },
        {
          "character": "李靖",
          "type": "油葫芦",
          "text": "只见他雄威纠纠勇如貔， 不枉了号天齐， 只见他往来南北， 冲突东西， 他那里，奔驰一似也那如儿戏， 俺这里，神通广大可也难逃避。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。"
        },
        {
          "character": "李靖",
          "type": "油葫芦",
          "text": "俺与他这回较辨个高低， 昏惨惨，四壁征云起， 闹垓垓，几处军声沸。 恰便似，平地上起一个轰雷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。"
        },
        {
          "character": "李靖",
          "type": "天下乐",
          "text": "只见那，魔怪山魈也那挂铁衣， 摇也么旗，俺可也助军威。 可怜那无知亡命好痴迷。 一任恁排成阵，一任恁合作围。 怎当俺法力大，可也尽披靡。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。"
        },
        {
          "character": "李靖",
          "type": "哪叱令",
          "text": "小妖们遍山岭， 沿堤奔腾也那似飞， 有的妖把角吹， 有的妖把鼓擂。 老妖们头顶盔， 小妖们摩着旗。 这山坡聚聚堆， 那山坡聚聚堆， 笑他们，闹嚷嚷意欲何为？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。"
        },
        {
          "character": "李靖",
          "type": "鹊踏枝",
          "text": "满山林云雾黑， 四下里刀枪密， 眼见得地惨天昏， 耳边厢鬼哭神啼， 大地里山崩海沸。 他们只杀得紫微垣斗转星移。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。"
        },
        {
          "character": "李靖",
          "type": "胜葫芦",
          "text": "这妖猴法力有精奇， 不能够把他欺， 又只见狰狞相貌多奇异， 恁就是铜筋铁骨，吼一声好似霹雳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，二郎神上。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "杀了半日，未曾问你名姓，你且通上名来。"
        },
        {
          "character": "二郎神",
          "type": "白",
          "text": "妖猴听者。"
        },
        {
          "character": "二郎神",
          "type": "念",
          "text": "清虚妙道二郎神，赫赫威名天地间。灵霄宝殿为上将，特来擒你泼猴狲。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "呔！你这话只可对别人去讲，在孙爷面前岂是卖弄得的。你且站稳了，听你孙 爷爷道来。"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "天地初分育我身，参禅学道拜昆仑。神通广大超三界，俺上灵霄做帝君。"
        },
        {
          "character": "二郎神",
          "type": "白",
          "text": "休得胡说，看刀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空、二郎神同开打。"
        },
        {
          "character": "李靖",
          "type": "幺篇",
          "text": "俺只见六丁六甲显神威， 四面列重围， 恁就是三头六臂登时毙， 怎当俺舞枪抡剑逞矛戟， 一队队跃武扬威紧相随。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "妖猴被擒。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "猴头吓猴头！"
        },
        {
          "character": "李靖",
          "type": "煞尾",
          "text": "你只夸神通广， 怎敌俺法力威， 总是你自作孽怨着谁？"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "准备着斩仙台上标名姓，可怜你，"
        },
        {
          "character": "李靖",
          "type": "煞尾",
          "text": "一灵儿何处追随。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "众天将，好生看守妖猴，待我请旨定夺。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李靖下。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "杀了半日，反上了狗的当了。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "猴头吓猴头！"
        },
        {
          "character": "众天将",
          "type": "同千秋岁",
          "text": "你犯天条， 自作休烦恼。 顷刻间， 首身难保。 大圣齐天，大圣齐天。 尚不是心中又起波涛。 名和利，逐水飘。 风中絮，霜栖草。 一霎时魂飘渺， 可恨伊从前枉费辛劳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李靖上。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "玉帝有旨，将猴头呵！"
        },
        {
          "character": "李靖",
          "type": "红绣鞋",
          "text": "将妖猴万剐千刀，千刀， 筋骨零落荒郊，荒郊。 纷纷上，动枪刀。 请世人，看猴妖。 粉身碎骨不留毛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太上老君上。"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "天王请了。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "老君到此何事？"
        },
        {
          "character": "太上老君",
          "type": "白",
          "text": "可恨猴头将我金丹偷吃，所以刀枪不入。我将他投入八卦炉中，炼出金丹，管 叫他化为灰烬矣。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "如此，就请老君带去。 众天将。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "将妖猴送至兜率天宫者。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "领法旨。"
        },
        {
          "character": "李靖",
          "type": "白",
          "text": "众天将，就此回复玉旨。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": "众天将",
          "type": "同尾声",
          "text": "猴头造孽非轻小， 触犯天条动灵霄。"
        },
        {
          "character": "众天将",
          "type": "同白",
          "text": "猴头吓猴头！"
        },
        {
          "character": "众天将",
          "type": "同尾声",
          "text": "管教他魄散魂飞难恕饶。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}