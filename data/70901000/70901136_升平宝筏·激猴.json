{
  "script_id": "70901136",
  "title": "升平宝筏·激猴",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "孙悟空",
      "hangdang": "武生"
    },
    {
      "name": "猪八戒",
      "hangdang": "净"
    }
  ],
  "plot": "孙悟空重回花果山后，猪八戒和沙僧保护唐三藏继续往西天取经，路经碗子山波月洞，遇黄袍妖，三人被难。\n力战不过，猪八戒逃出，直奔花果山，以诓言激怒孙悟空，并引孙悟空赶到碗子山波月洞，搭救师父唐三\n藏。",
  "notes": "《激猴》亦称《请猴》，即《升平宝筏》第九十八出。原题：“美猴王激怒下山”。\n《升平宝筏》清张照撰。全十本，共二百四十出。据《西游记》唐三藏西天取经故事改编而成。为清宫承应\n传奇巨制之一。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "通臂猿上。"
        },
        {
          "character": "通臂猿",
          "type": "念",
          "text": "人说仙家日月迟，仙家日月快如斯。遥遥百岁人间事，只换山中一局棋。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "俺，齐天大圣总部先锋通臂猿。俺主自从大闹天宫，至今五百馀年，今日重整 花果山，复兴水帘洞。你看花果山，峭壁萦青，猿啼鹤唳。正是："
        },
        {
          "character": "通臂猿",
          "type": "念",
          "text": "洞天福地人间有，金阙银宫世上稀。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "俺在此伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒上。"
        },
        {
          "character": "猪八戒",
          "type": "念",
          "text": "时辰三两个，肚里有点饿。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "走了多少山，也不知哪是花果山，走了多少洞，也不知哪是水帘洞。来此，哎 呀！那边有个小猴儿，待我逗逗他。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "啊，你是哪来的野人？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "你睁眼吧，我是家人哪。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "你敢是奸细？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我还是团细哪，我说小猴儿，这是花果山吗？"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "正是花果山。你是什么人？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我告诉你说，我是你们大王的兄弟，二大王猪八爷。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "哦，你就是那猪八戒吗？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "猪八爷！"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "猪八戒！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "就算是猪八戒。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "我们大王时常想你。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "哥儿们有交情嘛。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "恨入其骨！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "方才说常常思念，怎么又恨入其骨哪？哎，思念也罢，恨入其骨也罢，小猴， 你怎样带我见见你们大王啊？"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "要见大王不难，就让你混进阵去，将你拿住，岂不就见了我们大王吗？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "好，就这么办吧。小猴儿，我没有来过这儿，你先领我逛逛山景。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "随我来。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "这儿树真不少，这是什么树？"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "桃树、杏树、梨树、枣树、核桃树、栗子树……"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "什么树都有？有鸡蛋树吗？"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "没有鸡蛋树，是白果树。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖鼓声〗。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "大王升帐，随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒、通臂猿同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖唢呐吹打工尺上〗。跳猴。猴朝官领孙悟空同上。〖吹打住〗。"
        },
        {
          "character": "孙悟空",
          "type": "新水令",
          "text": "花果山，重建旧基开。 水帘洞，近在东洋大海。 杏黄旗，高飘在云霄外。 半山麓，建一座九亭台。 明朝儿，演武升台。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "好男儿。"
        },
        {
          "character": "孙悟空",
          "type": "新水令",
          "text": "到此地方为快。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖唢呐吹打工尺上〗。孙悟空上高台。〖吹打住〗。"
        },
        {
          "character": "孙悟空",
          "type": "念",
          "text": "云高四起莽寒烟，举目苍翠海山连。东海若似平铺地，一轮明月照垂天。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "俺悟空。自从师父逐回，重整花果山，复兴水帘洞，好不洒乐俺也。"
        },
        {
          "character": "孙悟空",
          "type": "驻马听",
          "text": "牙将分排，牙将分排。 大圣齐天，威名在。 抓耳挠腮，抓耳挠腮。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "咦……"
        },
        {
          "character": "孙悟空",
          "type": "驻马听",
          "text": "一个个，躜山跳涧奔驰快。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "通臂猿，将猴兵操演一番。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "吓！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "操演者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖击鼓三通〗。"
        },
        {
          "character": "孙悟空",
          "type": "驻马听",
          "text": "三通战鼓震云开， 一声炮响惊天外。 胜韩侯，拜将登台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒溜上偷望。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "咦！"
        },
        {
          "character": "孙悟空",
          "type": "驻马听",
          "text": "却原来是一个替屠狗的猪八戒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒下。摆阵。通臂猿擒猪八戒。"
        },
        {
          "character": "通臂猿",
          "type": "白",
          "text": "拿住奸细了！"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "擒住奸细！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "绑来面向外跪。 唗！你是什么人，乱了俺的军纪阵法？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "为什么乱了军纪阵法？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "什么叫军纪呀？什么叫阵法呀！得啦，我看你们是吃饱了耍猴儿玩呢！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "孙悟空",
          "type": "折桂令",
          "text": "也是你时衰运乖， 营伍内恁自招灾。"
        },
        {
          "character": "孙悟空",
          "type": "夹白",
          "text": "掌嘴！"
        },
        {
          "character": "孙悟空",
          "type": "折桂令",
          "text": "俺今日操兵练卒， 谁似你冒充宾客， 不由俺，怒满胸怀。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "与我打一百二十个背花。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "慢着，慢着，为什么打我？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "你走错了阵法。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我走错了就打一百二十个背花，你们大王唱的荒腔走板该怎么办哪？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "孙悟空",
          "type": "折桂令",
          "text": "谁叫你戏耍军情，你便惹祸灾。 丑痴呆！怎提防，风波也那不测。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "与我杀！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "慢着，瞧我大老远的来看你，也不问我吃饭了没有，喝水了没有，不是打就是 杀，这算什么师兄弟呐？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "他与大王称兄弟？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你是什么东西，敢与俺称兄道弟！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "你瞧瞧啊，你现在穿着黄袍子，戴着翎帽子，坐在高台上，你才唱呗！你还不 认得我这大乖乖吗？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "原来是八戒贤弟到了，松绑、松绑，受惊了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空下高台。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "哎呀贤弟。"
        },
        {
          "character": "孙悟空",
          "type": "雁儿落",
          "text": "甚风儿吹送你此地来？"
        },
        {
          "character": "猪八戒",
          "type": "夹白",
          "text": "特来拜望你。"
        },
        {
          "character": "孙悟空",
          "type": "雁儿落",
          "text": "说什么特地将咱拜， 莫不是中途路上惹祸灾，"
        },
        {
          "character": "猪八戒",
          "type": "夹白",
          "text": "我是忠厚老实人，岂敢惹祸。"
        },
        {
          "character": "孙悟空",
          "type": "雁儿落",
          "text": "莫不是老和尚将你怪。"
        },
        {
          "character": "孙悟空",
          "type": "得胜令",
          "text": "呀你与我从头说明白，"
        },
        {
          "character": "猪八戒",
          "type": "夹白",
          "text": "自古朋友面前莫说假，又岂敢欺侮哉。"
        },
        {
          "character": "孙悟空",
          "type": "得胜令",
          "text": "你休得之乎者也矣焉哉。 提起那老和尚心太狠，"
        },
        {
          "character": "猪八戒",
          "type": "夹白",
          "text": "沙兄弟多多致意你。"
        },
        {
          "character": "孙悟空",
          "type": "得胜令",
          "text": "堪笑那沙兄弟他会卖乖。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "什么是沙兄弟会卖乖，他自幼儿就是那么个赖怠脾气，自从师父将你逐回，我 们一路西行，师父也不知是渴了，还是饿了，他就叫徒弟、徒弟，连叫了几声。 猴哥啊，你知道我的耳朵是背的。沙兄弟听见了，他故意装听不见。咱师父 可就恼了，说：我把你们这两个呆子……要有你们大师兄在此，问一答十，多 释而广记。猴哥，你还是回去保护师父求取真经吧，我的猴哥呀。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "贤弟，俺在此逍遥自在，取什么经，成什么果？！"
        },
        {
          "character": "孙悟空",
          "type": "得胜令",
          "text": "俺真个舒怀， 风不吹日不晒实实的逍遥哉，"
        },
        {
          "character": "猪八戒",
          "type": "夹白",
          "text": "好是好，到底有些妖气。"
        },
        {
          "character": "孙悟空",
          "type": "得胜令",
          "text": "天不遣，地不差，天不遣，地不差。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "你坐在这逍遥自在，风不吹，日不晒，一事无成两鬓白了，我的猴哥！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "哎呀贤弟呀……"
        },
        {
          "character": "孙悟空",
          "type": "挂玉钩",
          "text": "恁道俺一事无成两鬓白， 闹哄哄在此，俺可也为将帅。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你今来此我晓得了。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "晓得什么？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "哼！"
        },
        {
          "character": "孙悟空",
          "type": "挂玉钩",
          "text": "莫不是老和尚遭惊骇？"
        },
        {
          "character": "猪八戒",
          "type": "夹白",
          "text": "没相干。"
        },
        {
          "character": "孙悟空",
          "type": "挂玉钩",
          "text": "既不为此来，因甚么临吾寨？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "什么临寨不临寨呀，你随我保护师父要紧。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "哎呀贤弟呀！"
        },
        {
          "character": "孙悟空",
          "type": "挂玉钩",
          "text": "恁叫俺保护师父， 除非是三岁的婴孩。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "什么三岁婴孩呀！你跟我嘎起典来啦。猴哥，师父想你啦！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "八戒，你告诉那唐僧，他既逐俺，就不要想俺了。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "看你的意思是不回去了？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "不去！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我岂不是白来一趟？告辞了。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "不去的了。 小的们，送客。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "好家伙，说声不去，街坊的鸡轰出来啦，交谁也别交猴，它最没有良心。我得 骂他几句出出气。你是死猴，懒猴，猴崽子。猴拉稀坏肠子……"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "他背地里骂大王呢！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "抓回来！ 我好意放你回去，为何背地里骂俺？！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我没敢骂，我哪敢骂师兄啊，我要骂你，叫小猴嘴上长痔疮。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "孙悟空",
          "type": "川拨棹",
          "text": "骂猪呆，你比古人坏，你比庞涓心还歹。"
        },
        {
          "character": "孙悟空",
          "type": "夹白",
          "text": "小的们！"
        },
        {
          "character": "孙悟空",
          "type": "川拨棹",
          "text": "你与我先打猪乖后割双腮，"
        },
        {
          "character": "猪八戒",
          "type": "夹白",
          "text": "割了腮我怎么吃饭呀？还是打吧。"
        },
        {
          "character": "孙悟空",
          "type": "夹白",
          "text": "小的们！"
        },
        {
          "character": "孙悟空",
          "type": "川拨棹",
          "text": "快快的烧起水来，"
        },
        {
          "character": "众猴",
          "type": "同夹白",
          "text": "大王烧水何用？"
        },
        {
          "character": "孙悟空",
          "type": "川拨棹",
          "text": "俺今日要开斋将他宰！"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "杀猪！杀猪！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "猴哥，饶了我吧，看师父的面上，饶了我吧。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "不饶！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "不看僧面看佛面哪。"
        },
        {
          "character": "孙悟空",
          "type": "七弟兄",
          "text": "你是个老浅⑴前来卖乖，犹兀自乱胡柴。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "囊糠⑵。"
        },
        {
          "character": "孙悟空",
          "type": "七弟兄",
          "text": "俺念你同门兄弟高看待， 你怎肯把俺杂念歪。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "猴哥饶了我吧。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "咦，哈……叫我饶你，这也不难。吓呵……"
        },
        {
          "character": "孙悟空",
          "type": "七弟兄",
          "text": "快说出师尊马匹今何在。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "猴哥，你叫我说实话，就捆着说吗？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "与他松绑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒乱跑。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "我把你这个呆子！我好意将你松绑，你要往哪儿跑？"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我看阵势厉害，想寻个洞钻进去，好跑。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "呆子，你走三天三夜，俺老孙也抓你回来！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我忘了，猴哥会筋斗云，我跑到哪儿去，他一个筋斗云，就把我抓回来了。我 不走了，就在这混吧。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "快说实话！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "你就叫我跪着说呀？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "起去。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "你就叫我站着说嘛？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "与他看座。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "捆着、跪着、站着、坐着，这真不错。 猴哥，从你走后，我师徒三人往西行，碰见一个妖怪，叫什么白眼狼啊。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "想是那魁目狼！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "他遇见师父，一口邪气将师父擒住。沙兄弟上前解救，也被妖怪擒去了，我不 服气，整整帽子，提提靴子，手持九齿耙，一扒就爬到这儿来了。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "你提起俺，那妖怪就不敢了。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我告个便。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒背语。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我说出他的名字，妖怪就不敢了。有了，遣将不如激将能，我来智激美猴王呗， 好哩，我就假说妖怪骂他来着，他一生气，就跟我下山了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "猪八戒转身。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "猴哥，我提了您了。我说：妖怪你欺侮我们师徒三人不打紧，要有我们大师兄 在此，你惹得起他吗？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "讲得好！"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我讲得好，妖怪讲得更好。妖怪大肚一腆，大刀一戳，说我把你这个猪的八个 的。动不动就提你们大师兄，他是谁呀？我说，我师兄五百年前大闹天官，齐 天大圣，谁人不知，哪个不晓哇？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "讲得好。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "那妖怪讲都更好。说猪的六个的，给我减了两点。妖怪说，他是什么出身呐？ 我说，你说他是什么出身呐？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "呀，呀……"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "你说他是什么出身呐？妖怪说，把你这猪的四个的。又抽了两点。你那猴哥， 他是我手心里的一个死猴，懒猴，猴崽子……他算什么东西！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "呀！我本不愿去，那妖怪欺人太甚。 八戒，你稍等，我去去就来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空下。"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "二大王给说个笑话吧。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "别说笑话啦，说说我们取经的事吧。我师徒三人走着、走着，忽然一阵旋风， 从东边刮来，你们猜什么风？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众猴同猜不着。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "红风。又从西边来一阵风，你们猜什么风？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "红风，红风。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "不对，是白风。又从南边来一阵风，你们猜什么风？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "白风。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "不对，是黑风，又从北边来一阵风，你们猜是什么风？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "黑风。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "不对，是蓝风。又从天上来了一阵风，你们猜是什么风？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "黑风，红风，白风，蓝风。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "不对，不对。是黄风。这五阵风凝在一块，变了个妖怪，顶天立地，胳膊像房 梁那么粗，手像磨盘那么大。你们猜那脑袋有多大？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "有芭斗那么大。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "不对，那脑袋就像鸡蛋那么大。这是个小脑袋妖怪。他跟我大战，我用大耙扒 不过他，我就跑，他就追，我反头来一耙，你们猜谁胜了？"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "二大王胜了。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "我倒搂一耙，这有个名堂。叫猪八戒败阵倒打一耙么，我就爬到这儿来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙悟空上，众猴同不舍，同央求。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "小的们！好生看守山寨，唤尔等即来。俺就此降妖去者！"
        },
        {
          "character": "众猴",
          "type": "同白",
          "text": "送大王！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "免！"
        },
        {
          "character": "孙悟空",
          "type": "鸳鸯煞",
          "text": "令人堪笑猪八戒，"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "要吾行，那妖怪神通广大。"
        },
        {
          "character": "猪八戒",
          "type": "鸳鸯煞",
          "text": "也是师尊命活该，"
        },
        {
          "character": "孙悟空",
          "type": "鸳鸯煞",
          "text": "堪笑猪呆，"
        },
        {
          "character": "猪八戒",
          "type": "鸳鸯煞",
          "text": "我也不呆，一事无成两鬓白，"
        },
        {
          "character": "孙悟空",
          "type": "鸳鸯煞",
          "text": "你激吾行把家业卖， 猛回头，家乡何在！"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "望见云山霭霭。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "猴哥，不要走了，来到洞门口了。"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "贤弟，先把守洞门。"
        },
        {
          "character": "猪八戒",
          "type": "白",
          "text": "你呢？"
        },
        {
          "character": "孙悟空",
          "type": "白",
          "text": "吖呵喏！"
        },
        {
          "character": "孙悟空",
          "type": "鸳鸯煞",
          "text": "俺把那紫袈裟扶上了九莲台。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "开打。孙悟空、猪八戒同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "孙悟空",
          "type": "stage",
          "text": "—————————— ⑴ 方言俗语，呆傻的意思。 ⑵ 方言俗语，废物的意思。"
        }
      ]
    }
  ]
}