{
  "script_id": "70901101",
  "title": "单刀会·训子",
  "alias": [
    "训平"
  ],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红净"
    },
    {
      "name": "关平",
      "hangdang": "武小生"
    },
    {
      "name": "周仓",
      "hangdang": "副净"
    },
    {
      "name": "黄文",
      "hangdang": "丑"
    }
  ],
  "plot": "《训子》也叫《训平》，是较典型的红净唱工戏，为本戏《关大王独赴单刀会》第三折。写关羽赴鲁肃宴请\n之前，对义子关平的一番教诲。表述了汉室创业，刘、关、张结义等往事；并识破鲁肃宴请用意做下了周密\n安排。这一折为全剧的高潮《单刀会》作了铺垫。",
  "notes": "《关大王独赴单刀会》杂剧，元关汉卿撰，全四折（无楔子）。以三国故事敷演而成。通过鲁肃向刘备索还\n荆州，设计欲迫使荆州守将关羽归还等情节的描写，生动地塑造了关羽大义凛然，忠贞不屈的英雄形象。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "关平上。"
        },
        {
          "character": "关平",
          "type": "念",
          "text": "身披铠甲逞英雄，小将原来有父风。却喜趋庭承亲训，须知子孝与臣忠。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "小将关平，今日父王升座，只得在此伺侯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽内嗽。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "道犹未了，父王出堂来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "器宇昂昂志气舒，指天化日定规模。荆州久镇无人犯，认取须眉大丈夫。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "父王在上，臣儿打恭。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我儿免礼，坐了。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "谢坐。请问父王，当今天下鼎足三分，臣儿不知，请父王试说一遍，臣儿洗耳 恭听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我儿听者。当今天下鼎足三分，曹操占据中原，孙权霸住江东，你伯父首尊西 蜀，这都是汉家天下也。"
        },
        {
          "character": "关羽",
          "type": "粉蝶儿",
          "text": "那其间，楚汉争强， 叹周秦早属刘项。 分君臣，先到咸阳。 一个儿拔山力， 一个儿量宽容海。 他两个，一时开剏， 想当日，黄阁乌江。 一个儿，用了三杰， 一个儿立诛八将。"
        },
        {
          "character": "关羽",
          "type": "沉醉东风",
          "text": "一个在短剑下身亡， 一个儿听静鞭三下响。 这的是祖宗传位与儿孙， 到今日只落得享、享。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "献帝——"
        },
        {
          "character": "关羽",
          "type": "沉醉东风",
          "text": "他无靠无依， 董卓不仁不义；"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吕布——"
        },
        {
          "character": "关羽",
          "type": "沉醉东风",
          "text": "一冲一撞。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "请问父王，当初桃园结义之事，臣儿不知，请父王试说一遍。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吾儿听者。当初桃园结义之时，宰白马祭天，杀乌牛祭地。不求同日生，只愿 同日死，一在三在，一亡三亡。"
        },
        {
          "character": "关羽",
          "type": "十二月",
          "text": "想当日，兄弟在范阳， 兄长在楼桑； 俺关某在蒲州解良； 更有那，诸葛在南阳。 煞时间，英雄出四方。 结义了皇叔与关张，"
        },
        {
          "character": "关羽",
          "type": "尧民歌",
          "text": "其年三谒卧龙岗， 已料定，鼎足三分，汉家邦。 俺哥哥，称孤道寡世无双。 俺关某，匹马单刀镇荆襄。 长也么江，今经几战场。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "却正是后浪——"
        },
        {
          "character": "关羽",
          "type": "尧民歌",
          "text": "催前浪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "念",
          "text": "猛虎台前出入，貔貅帐内传宣。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "中军叩头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "中军。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "无有某家将令，为何私离汛地？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "东吴鲁大夫差人下书。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那下书人呢？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "现在帐外。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "与我搜检明白，抓他进来，"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "领命。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "传鼓开门。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "传鼓开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。关羽归大座。中军领黄文同上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "下书人当面。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "下书人与爷叩头。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "下书人，你叫什么名字？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "我叫大胆黄文。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你的胆有多大？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "有巴斗大。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "剖腹看者！"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "啊呀爷呀，我的胆没那么大，有荠莱仔那么大。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "为何能大能小？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "啊呀，能强能弱我的爷。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "收！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周仓收刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "可有书信？"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "书信呈上。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "原来是鲁大夫请某过江赴会。俺这里修书不及，原书发回。回去奏明你家爷， 说某本月十三日亲自过江赴会。放他出去。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "出去！"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "黄文",
          "type": "念",
          "text": "今日吓破黄文胆，再也不做下书人。"
        },
        {
          "character": "黄文",
          "type": "白",
          "text": "好怕，好怕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄文下。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大开门〗。四龙套自两边分下，关羽转小座。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "父王，那书信上写的什么言语，说与臣儿知道。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "我儿听者。"
        },
        {
          "character": "关羽",
          "type": "石榴花",
          "text": "上写着，两朝相隔汉阳江。 又写着，鲁肃请云长。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "安排什么来？"
        },
        {
          "character": "关羽",
          "type": "石榴花",
          "text": "安排下筵宴不寻常， 再休想，画堂别是风光。 哪里有凤凰杯满捧葡萄酿， 尽都是巴豆共着砒霜。 玳宴前摆列着尽都是英雄将， 再休想，开宴出红妆。"
        },
        {
          "character": "关羽",
          "type": "斗鹌鹁",
          "text": "安排下，打凤的牢笼。 准备着天罗地网。 哪里有待客的筵席？ 分明是杀人、杀人的战场。 再休想重意诚心， 全不怕后人来讲。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "古来筵无好筵，会无好会，还是不去的是。"
        },
        {
          "character": "关羽",
          "type": "斗鹌鹑",
          "text": "既然他谨谨的相邀，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "来，周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "关羽",
          "type": "斗鹌鹑",
          "text": "望和恁便亲身前往。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "他那里兵多将广。"
        },
        {
          "character": "关羽",
          "type": "上小楼",
          "text": "恁道他，兵多将广，"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "他那里人强马壮。"
        },
        {
          "character": "关羽",
          "type": "上小楼",
          "text": "人强马壮。 大丈夫奋勇当先， 一人拼命，万夫难挡。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "大江遥远，恐难接应。"
        },
        {
          "character": "关羽",
          "type": "上下楼",
          "text": "恁道是，隔大江起战场， 都急难亲傍。 着那厮鞠躬身， 送某到船上。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "还是先下手为强。"
        },
        {
          "character": "关羽",
          "type": "么篇",
          "text": "恁道是先下手强， 后下手殃。 一只手揪住他宝带， 臂转猿猱，剑掣秋霜。 他那里暗暗藏， 俺这里紧紧防。 都是些狐朋狗党。 俺可也，千里独行五关斩将。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "关平，明日驾定小舟，江口伺候。"
        },
        {
          "character": "关平",
          "type": "白",
          "text": "领命。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "明日随某赴会者。"
        },
        {
          "character": "关羽",
          "type": "尾声",
          "text": "虽不比，临潼会上秦穆公， 那里有宴鸿门楚霸王。 满眼前，折磨了英雄将。 小可的，百万军中，斩颜良，那一场嚷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}