{
  "script_id": "70901104",
  "title": "昊天塔·会兄",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "杨延德",
      "hangdang": "净"
    },
    {
      "name": "杨延昭",
      "hangdang": "武生"
    },
    {
      "name": "老僧",
      "hangdang": "末"
    },
    {
      "name": "萧天佐",
      "hangdang": "丑"
    }
  ],
  "plot": "杨延昭与孟良盗得杨继业骨殖，正待急急赶回，后面追兵已到。杨延昭身背骨匣，孟良在后御敌，慌忙中二\n人走散。杨延昭夜宿于五台山兴国寺，巧遇在此出家的杨延德。难中相遇，悲痛万状。此时追兵已围住寺院，\n兄弟二人合力击退众兵。后杨延昭归家，杨延德仍留五台山为僧。",
  "notes": "《会兄》即《昊天塔》第四折。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "呔！休赶哪休赶。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "踹破玉笼飞彩凤，顿断金锁走蛟龙。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "俺杨延昭，奉母亲之命，到幽州昊天塔上盗取爹爹骨殖而归。看天色已晚，来 此已是五台山，在此借宿一夜。 师父开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧上。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "来了，来了！"
        },
        {
          "character": "老僧",
          "type": "念",
          "text": "扫地休伤蝼蚁命，爱惜飞蛾纱罩灯。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "是哪一个？ 原来是一位客官，从哪里来的？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我是远方来的。天色已晚，借宿一夜，明日早行，望师父行一方便。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "我出家人慈悲为本，方便为门，哪有不留之理，客官请进。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "将马拴在廊下。就在此处安歇如何？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "倒也使得。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "客官，我有一徒弟，此人性如烈火。若他来时，不要睬他。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "是，我记下了，师父请便。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧下。杨延昭哭。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哎呀，爹爹呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭睡，杨五郎带酒上。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "嘿，好酒，好酒！吃的来好不爽快也！呣……"
        },
        {
          "character": "杨延德",
          "type": "新水令",
          "text": "归来余醉未曾醒， 撞着俺五爷爷无些干净。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呜呀！"
        },
        {
          "character": "杨延德",
          "type": "新水令",
          "text": "莫不是山中老树怪， 莫不是潭底毒龙精。 他待要显圣通灵， 只俺这道高的鬼神敬。"
        },
        {
          "character": "杨延昭",
          "type": "哭",
          "text": "爹爹呀！"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杨延德",
          "type": "驻马听",
          "text": "只听得噎噎哽哽， 只听得噎噎哽哽， 搅乱俺，无是无非廊下僧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭哭。"
        },
        {
          "character": "杨延德",
          "type": "驻马听",
          "text": "呜他，他哭的孤苦伶仃。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "莫不是着枪带箭，"
        },
        {
          "character": "杨延德",
          "type": "驻马听",
          "text": "那些败残兵。 靠三门倚定价壁儿听， 耸双肩手抵着牙儿定，"
        },
        {
          "character": "杨延昭",
          "type": "哭",
          "text": "哎呀爹爹呀！"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杨延德",
          "type": "驻马听",
          "text": "叫的俺沸沸腾腾，沸沸腾腾， 看绿荫满地禅房静。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "来此已是山门，呔，开门来，开门来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧上。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "来了！ 想是徒弟回来了，待我与你开门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨五郎进门，吐。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "哎呀，哪里吃的这般大醉回来？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "师父，弟子未曾吃酒，山下那些烧刀子烂狗肉的，啊……吃的倒也爽快。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "那些腌臜东西，岂是你我出家人用的！罪过，罪过。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "弟子改过。师父，什么人在这里啼哭？"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "没有人。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "徒弟上山来，明明听得有人在此啼哭，怎么说没有？"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "你听见了？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "听见了。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "有一远方来的客官，只因天色已晚，在此借住一宿，明日早行。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "这样来路不明之人，留他做甚！待我打发他出去。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "住了。你不要生事，不要闯祸。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "师父，徒弟不生事，不闯祸。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "来，来，来，与我安歇了吧。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呔！这等唠唠叼叼的。"
        },
        {
          "character": "老僧",
          "type": "白",
          "text": "阿弥陀佛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "老僧下。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "哈……这等样来路不明之人，留他做甚。待我打发他出去。 喂！那汉子醒来，你是哪里来的？喂，那汉子醒来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭醒，拔剑。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "咱家不生事，咱不闯祸。收拾了你这个买卖吧！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "好一个莽撞和尚。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "好一个狠汉子。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "那汉子，你是哪里来的？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我是来处来的。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "你往哪里去？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "我要往去处去。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "杨延德",
          "type": "步步娇",
          "text": "莫不是负屈衔冤，恁可也通名姓。 莫不是，远方来，探望你那爹娘病。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "不是。"
        },
        {
          "character": "杨延德",
          "type": "步步娇",
          "text": "莫不是犯法违条，你的罪不轻。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "俺也不犯谁的法。"
        },
        {
          "character": "杨延德",
          "type": "步步娇",
          "text": "莫不是打担推车，恁撞着那伙贼兵，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "那伙贼兵也不是俺的对手！"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "杨延德",
          "type": "步步娇",
          "text": "俺这里，连问你那两三声， 恁那里，并无有半句话儿来答应。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "俺不答应你便怎样？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "俺这里厉害！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "厉害，你敢打人骂人不成？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "听者。"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "俺这里，便打了人，也无争竞，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "敢骂人吗？"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "俺这里便骂了人也不回应。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "敢劫人吗？"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "俺这里便劫了人也无个罪名，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "敢杀人吗？"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "俺这里便杀了人也不偿命。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你说便这等说，我是不信的。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "杨延德",
          "type": "水仙子",
          "text": "烟腾腾火烧人肉喷鼻腥，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "可不道为惜飞蛾罩灯？"
        },
        {
          "character": "杨延德",
          "type": "水仙子",
          "text": "哪里管惜飞蛾纱罩灯！ 不杀生有甚么轮回证， 念几声观自在超度他的经。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "想你也不是自幼出家。"
        },
        {
          "character": "杨延德",
          "type": "水仙子",
          "text": "吓呀客官吓，细说个分明。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "自幼年间，"
        },
        {
          "character": "杨延德",
          "type": "水仙子",
          "text": "曾杀的番兵怕。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "客官，"
        },
        {
          "character": "杨延德",
          "type": "水仙子",
          "text": "几时儿有信士请？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "到中年落发，"
        },
        {
          "character": "杨延德",
          "type": "水仙子",
          "text": "在此为僧。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "听他之言，倒是一个好和尚。待俺对他说了吧。 那和尚，俺是大宋来的。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "怎么讲？你是大宋来的？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "俺要盘你一盘？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你盘俺哪一家？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "就是那大……大……大……大宋！"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "有一个使金刀杨令公他手段能，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "他家还有何人？"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "他家有七个儿子心肠硬。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "母亲是谁？"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "母亲是佘太君， 敕赐的天波楼无邪佞。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "他弟兄们可都有哩？"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "啊呀客官吓！ 可怜他弟兄们多死少波生， 只俺在五台山又为僧。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "还有何人？"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "还有个六郎镇守在三关上，"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你可认得他哩？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "客官。"
        },
        {
          "character": "杨延德",
          "type": "雁儿落",
          "text": "咱和他一爹娘亲弟兄。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "听他之言，好象我五郎哥哥。是也不是，我应他一声。 那和尚，你敢是我五郎哥哥？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "你是何人？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "小弟延昭在此。"
        },
        {
          "character": "杨延德",
          "type": "得胜令",
          "text": "吓呀贤弟呀！ 相逢，这会合真侥幸。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "贤弟到此何事？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "奉母亲之命，到幽州昊天塔上盗取爹爹骨殖而回。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "爹爹骨殖在哪里？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "在哪里，哇呀……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德接匣悲。"
        },
        {
          "character": "杨延德",
          "type": "得胜令",
          "text": "呜呀爹爹呀！ 好伤情。把幽魂陷虏城把幽魂陷虏城。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德跪拜。番兵内追喊。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "哥哥，番兵追来，如何是好！"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "贤弟，你在后面，咱一同打发他回去。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德、杨延昭同下。萧天佐上。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "啊咳！"
        },
        {
          "character": "萧天佐",
          "type": "念",
          "text": "我做大将胆子大，出战发兵我不怕。忽听大炮一声响，吓得我八天没说话。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "俺萧天佐。奉太后密旨，追赶南蛮盗骨之人，追到此处不见了。来此已是五台 山，想必藏在这里，待我下马问问和尚。 呔！和尚开门来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德上，开门。杨延德、萧天佐对打。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呔！"
        },
        {
          "character": "杨延德",
          "type": "川拨棹",
          "text": "这厮呵待蒙挣， 那厮呵待蒙挣。 闹得俺心头火噗噔噔， 待杀官兵，扑杀苍蝇。 我打，打你个小头也那官兵。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "我打！"
        },
        {
          "character": "杨延德",
          "type": "七弟兄",
          "text": "这厮呵带鞓， 可搭的揝定， 摔你个满天星。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧天佐跪架铲。"
        },
        {
          "character": "萧天佐",
          "type": "白",
          "text": "你们出家人连个慈悲心也没有吗？"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "咦，哈……"
        },
        {
          "character": "杨延德",
          "type": "七弟兄",
          "text": "哎休，休道俺出家人并无个慈悲性， 怒轰轰恶向胆边生。 恁且来、来、来，好好还俺杨令公爹爹命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德杀萧天佐，萧天佐下。杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "番兵已退，哥哥随小弟回家见母亲一面。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "贤弟，俺既出了家，还回家做甚？贤弟与我多多拜上老母便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭允。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "贤弟请乘骑。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "待愚兄步送一程者。"
        },
        {
          "character": "杨延德",
          "type": "清江引",
          "text": "番兵个个皆逃遁， 杀得他无踪影堪叫那番兵， 死在俺手中。 方显得老杨家有后生。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "杨延德",
          "type": "白",
          "text": "呔！你们谁敢来，你们谁敢来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延德、杨延昭同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}