{
  "script_id": "70901132",
  "title": "桃花扇·争座",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "史可法",
      "hangdang": "外"
    },
    {
      "name": "侯方域",
      "hangdang": "冠生"
    },
    {
      "name": "高杰",
      "hangdang": "副净"
    },
    {
      "name": "黄德功",
      "hangdang": "净"
    },
    {
      "name": "刘良佐",
      "hangdang": "净"
    },
    {
      "name": "刘泽清",
      "hangdang": "丑"
    }
  ],
  "plot": "河南总兵许定国因抵挡不住闯王的进攻，向阁部元帅史可法告急求援。史可法乃邀集四镇诸侯，共商救援之\n策。四镇诸侯因座次而争，引起一场内讧。",
  "notes": "《争座》为清传奇《桃花扇》第十八出。原题《争位》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "侯方域上。"
        },
        {
          "character": "侯方域",
          "type": "念",
          "text": "无定输赢似奕棋，书空殷浩欲何为？长江不限天南北，击楫中流看誓师。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "小生侯方域。前日替史公修书，一时激烈，有“三大罪，五不可立”之议。不 料福王今已登极，马士英竟入阁办事，把那些迎驾之臣，皆录功补用。史公虽 亦入阁，又令督师江北，这分明有外之之意了。史公却全不介意，反以操兵剿 贼为喜，如此忠肝义胆，人所难能也。现在开府扬州，命俺参其军事，约定今 日齐集四镇，共商防河之计，不免上前一问。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯方域至书房坐。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "管家那里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "书童上。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "侯爷来了，待我通报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法上。"
        },
        {
          "character": "史可法",
          "type": "北点绛唇",
          "text": "持节江皋，龙骧虎啸。忧国事，不顾残躯，双鬓苍白了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法见侯方域。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "世兄，可知今日四镇齐集，共商大事，今日整师誓旅，雪君父之仇了。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "如此甚妙，只有一件，高杰镇守扬通，兵骄将傲，那黄刘三镇，每发不平之恨。 今日相见，大费调停，万一兄弟不和，岂不为敌人之利乎。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "所说极是。今日相见，俺自有一番劝慰之言。"
        },
        {
          "character": "书童",
          "type": "白",
          "text": "辕门传鼓，说四镇到齐，伺候参谒。 （侯方域下，史可法升帐。吹打〖大开门〗。仪卫排左右，高杰、黄德功、刘泽清、刘良佐穿甲胄同上。吹 打住。）"
        },
        {
          "character": "高杰、黄德功、刘泽清、刘良佐",
          "type": "同念",
          "text": "只恨燕京无乐毅，谁知江左有夷吾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高杰、黄德功、刘泽清、刘良佐同见。"
        },
        {
          "character": "高杰、黄德功、刘泽清、刘良佐",
          "type": "同白",
          "text": "四镇小将叩谒阁部大元帅。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高杰、黄德功、刘泽清、刘良佐同拜，史可法拱手立。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "列位请起。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高杰、黄德功、刘泽清、刘良佐同排立。"
        },
        {
          "character": "高杰、黄德功、刘泽清、刘良佐",
          "type": "同白",
          "text": "听候元帅将令。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "本帅，以阁部皆师，君命隆重，大小将士俱在指挥之下。"
        },
        {
          "character": "高杰、黄德功、刘泽清、刘良佐",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "四镇乃堂堂列侯，不比寻常武弁。屈尊伺坐，共议军情。"
        },
        {
          "character": "高杰、黄德功、刘泽清、刘良佐",
          "type": "同白",
          "text": "岂敢。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "本帅命坐，便如军令一般，不可推辞。"
        },
        {
          "character": "高杰、黄德功、刘泽清、刘良佐",
          "type": "同白",
          "text": "是。告坐了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高杰首座，黄德功、刘泽清、刘良佐依次坐，黄德功怒视高杰。"
        },
        {
          "character": "史可法",
          "type": "混江龙",
          "text": "淮南险要， 江河保障势滔滔。 一带奇云结阵， 满目细柳垂条。 铁马嘶风先突塞， 犀军放弩早惊潮。 说甚么徐、常、沐、邓， 比得上绛、灌、萧、曹。 同心共把乾坤造。 看古来功臣阁丹青图画， 似今日列侯公剑佩弓刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄德功怒。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "元帅在上，小将本不该争论。这高杰乃投诚草寇，有何战功？今日公然坐俺三 镇之上，俨然以副帅自居，是何道理？"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "我投诚最早，年齿又尊，岂肯居尔等之下。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "我想此处是你的汛地，我们到此都是客宾，你连宾主之礼都不晓得，还要统兵？"
        },
        {
          "character": "刘良佐",
          "type": "白",
          "text": "他在扬州享受繁华，尊大惯了，今日也该让咱们享享。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "你们哪个敢来，我就奉让。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "两位刘兄同我出来，即刻与那厮见个高低。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄德功、刘泽清、刘良佐同怒下，史可法向高杰。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "他们讲的有道理，你还该谦让他们才是。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "小将宁死不肯相让！"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "你这就大错了。"
        },
        {
          "character": "史可法",
          "type": "油葫芦",
          "text": "四镇堂堂气象豪， 倚仗着恢复北朝。 看您挨肩雁序， 恰似好同胞。 为甚的争座位， 失了同心好，斗齿牙，变了协恭貌。 一个儿，眼睁睁同室操戈盾； 一个儿，怒冲冲平地起波涛。 没见阵上逞威风， 早已窝里相争闹。 笑中兴， 封了一伙小儿曹。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "不料四镇英雄，可笑如此。老夫一天高兴，却早灰冷一半也。没奈何，且出张 告示，晓谕三镇，叫他各回汛地听候调遣。你既驻扎本境，就在本帅标下做个 先锋，各有执掌，他们也不敢来争闹了。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "多谢元帅。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "待老夫写起告示来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "史可法写，内呐喊。黄德功、刘泽清、刘良佐持刀同上。"
        },
        {
          "character": "黄德功、刘泽清、刘良佐",
          "type": "同白",
          "text": "高杰快快出来！"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "青天白日持刀呐喊，竟是反了。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "我们为什么反？只要杀你这个无礼贼子！"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "你们敢在帅府门前如此放肆，难道不是无礼贼子吗？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄德功、刘泽清、刘良佐同追杀高杰，高杰入辕门叫。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "阁部大老爷，救命呀！黄、刘三贼杀入帅府来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄德功、刘泽清、刘良佐同外骂，史可法惊立。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "史可法",
          "type": "天下乐",
          "text": "俺只道， 塞马南来把战挑。 杀声渐高， 却是咱兵自鏖。 这时协力同仇还愁少， 怎当的阋墙鼓噪，起了离间根苗。 这才是将难调，北贼易讨。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "快请侯相公出来。"
        },
        {
          "character": "龙套",
          "type": "白",
          "text": "侯爷有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯方域急上。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "晚生已听得明白了。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "借重高才，传俺帅令，安抚乱军。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "如何安抚？"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "老夫有告示一纸，快去晓谕他们便了。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侯方域接告示，见。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "列侯请了！小弟乃本府参谋，奉阁部大元帅之命，晓谕三镇知悉：恭逢新主中 兴，闯贼未讨，正我辈枕戈待旦，立功报效之时，不宜怀挟小忿，致乱大谋。 俟收复中原，太平赐宴，论功叙坐，自有朝仪。目下军容匆遽，凡事权宜，皆 当相谅，无失旧好。兴平侯高，原镇扬、通，今即留在本帅标下，委作先锋。 靖安侯黄，仍回庐和。东平侯刘，仍回淮徐。广昌侯刘，仍回凤、泗。静听调 遣，勿得违抗。军法凛然，本帅不能容情也。特谕。"
        },
        {
          "character": "黄德功",
          "type": "白",
          "text": "我们只要杀死无礼贼子，怎敢犯元帅军法。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "目今辕门截杀，这就是军法难容的了。"
        },
        {
          "character": "刘泽清",
          "type": "白",
          "text": "既是这等，不要惊着元帅，大家且散。"
        },
        {
          "character": "刘良佐",
          "type": "白",
          "text": "明日杀到高杰家里去罢。正是："
        },
        {
          "character": "刘良佐",
          "type": "念",
          "text": "国仇犹可恕，私恨最难消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "黄德功、刘泽清、刘良佐同下，侯方域入见史可法。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "三镇闻令，暂且退散去，明日还要厮杀哩。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "这便怎么处？"
        },
        {
          "character": "史可法",
          "type": "后庭花",
          "text": "高将军，你横将仇衅招， 为甚的不谦恭，妄自骄； 坐了个首席乡三老， 惹动他诸侯五路刀。 凭仪秦一番舌战巧， 也不过息兵半晌饶。 费调停，干焦躁。 难消释，空懊恼。 这情形何待瞧， 那事业全去了。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "元帅不必着急，明日和他见个输赢，把三镇人马并俺一处，随着元帅恢复中原， 却亦不难也。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "你说的是哪里话，现今流寇北来，将渡黄河。总兵许定国，不能阻挡，连夜告 急；正要与四镇商议，发兵防河。今日一动争端，误俺大事，岂不可忧！"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "他三镇也不为别的，只因扬州繁华，要来夺取，俺怎肯让他。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "这话益发可笑了。"
        },
        {
          "character": "史可法",
          "type": "煞尾",
          "text": "引领着一支兵，和他三家傲， 似垒卵泰山压倒。 你占住繁华二十四桥， 竹西明月夜吹箫， 他也想隋堤柳下安营巢， 不教你蕃鳌观独琼花少。 谁不羡扬州鹤背飘，"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "妒杀你腰缠十万好。"
        },
        {
          "character": "史可法",
          "type": "煞尾",
          "text": "怕明日，杀声咽断广陵涛。"
        },
        {
          "character": "史可法",
          "type": "白",
          "text": "罢，罢，罢！老夫已拚一死，更无他法。侯兄大才，只索凭你筹划了。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "且看局势，再做商量。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗，〖大开门〗。"
        },
        {
          "character": "侯方域",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下，史可法，侯方域同下，高杰吊场。"
        },
        {
          "character": "高杰",
          "type": "白",
          "text": "俺高杰也是一条好汉，难道坐以待毙不成。明早黄金坝上，点齐人马，排下阵 势，等他来时，迎敌便了。正是："
        },
        {
          "character": "高杰",
          "type": "念",
          "text": "龙争虎斗逞雄豪，杯酒筵边动剑刀。刘项何须成败论，将军头断不降曹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "高杰下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}