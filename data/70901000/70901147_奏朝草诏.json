{
  "script_id": "70901147",
  "title": "奏朝草诏",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "方孝孺",
      "hangdang": "外"
    },
    {
      "name": "朱棣",
      "hangdang": "末"
    },
    {
      "name": "陈瑛",
      "hangdang": "丑"
    },
    {
      "name": "齐泰",
      "hangdang": "老生"
    },
    {
      "name": "黄子澄",
      "hangdang": "老生"
    }
  ],
  "plot": "燕王朱棣篡位后，尽戮贤臣，残害忠良。为草写诏书，宣令方孝孺上殿。方孝孺秉忠义之节，拒不草诏。燕\n王大怒，命武士将其敲牙割舌。方孝孺痛斥昏王无道，直至遭鱼鳞细剐而死。",
  "notes": "据传《草诏》本戏为《千忠戮》，经查校，《千忠戮》实无此书。\n清李渔撰有《千忠戮》传奇。全剧以（明）燕王追杀建文帝（朱允炆）为背景，描写程济保护建文帝一路逃\n亡，直至出家为僧一段史实。剧中顺带有方孝孺殉节事。又清叶时章（雉斐）撰有《千钟禄》传奇二十五出，\n经查校亦无《奏朝》、《草诏》两出。\n又北京图书馆藏有手抄本《琉璃塔》昆曲四出，作者不详。写燕王朱棣谋反，攻陷京城，建文帝（朱允炆）\n跟随程济等人逃亡的故事。未见有《奏朝》、《草诏》二出。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "陈瑛上。"
        },
        {
          "character": "陈瑛",
          "type": "念",
          "text": "只道终身葬九渊，忽然沧海变桑田。百年富贵从新起，一品高官我占先。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "我陈瑛。被史仲彬这狗头，道俺创议让位，将我当朝凌辱，必欲置于死地，立 时削职监禁天牢。只道这颗头儿毕竟放不牢在颈上。谁想燕王来的甚快，谷王 献了镜川门。北兵直入，宫内火起，建文帝投火身亡。燕王就登宝位，改元永 乐元年。第一道新旨就赦我出狱，复我原官。想万岁念我北平旧功，又晓得我 廷杖受辱，定然爱我，怜我，敬我，信我。哈哈……此后言听计从，封王拜相， 决不待言。这两日万岁已将齐泰、黄子澄这几个叛逆大臣，一个个全家抄没， 极刑拷打。御史景清入朝行刺，已经剥皮楦草。闻得今日传旨去召方孝孺， 此老到来，必然倔强。不免入朝面圣，先放他一把火儿，除得一个是一个。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟响。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "呀！听景阳钟响，万岁爷升殿了。不免速速入朝。正是："
        },
        {
          "character": "陈瑛",
          "type": "念",
          "text": "全凭三寸如刀舌，惹起千秋四海愁。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈瑛下，太监引朱棣同上。"
        },
        {
          "character": "朱棣",
          "type": "点绛唇",
          "text": "天挺龙标，身膺大宝，非轻渺，继统临朝，好修着，一纸郊天诏。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。朱棣归大座。"
        },
        {
          "character": "朱棣",
          "type": "念",
          "text": "唐虞揖让三杯酒，汤武征诛一局棋。当年玄武开唐室，今日金川创帝基。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "寡人躬承嫡续，位居燕藩。叵耐群奸计图削夺，遂而靖难以问罪。二三奸党尚 未尽正厥辜。近须一诏郊天颁行天下，必得方孝孺执笔，才得人心倾服。我命 陈瑛宣他两次，怎的不见回旨？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈瑛上。"
        },
        {
          "character": "陈瑛",
          "type": "念",
          "text": "萧曹扶汉日，尉秦坐唐尧。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "陈瑛见驾，愿吾皇万岁，万万岁。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "陈瑛，我命你宣方孝孺上殿，陈卿不召而来，有何奏启？"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "那方孝孺穿了崭衰麻衣，日夜啼哭，宣上殿来，恐怕与君不利。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "寡人临行之时，姚广孝再三嘱咐，不叫寡人杀害方孝孺，留他读书种子。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "齐、黄二犯已经拿下，候我主定夺。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "齐、黄二逆，朕心大怒，将他二人绑在雨花台，鱼鳞细剐。再将景清尸首剥皮 楦草，领旨下殿。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "领旨。"
        },
        {
          "character": "陈瑛",
          "type": "念",
          "text": "一朝权在手，便把令来行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈瑛下。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "内臣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监同上，见。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "宣方孝孺上殿，寡人在谨身殿里等候。"
        },
        {
          "character": "二太监",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二太监同下。"
        },
        {
          "character": "朱棣",
          "type": "念",
          "text": "靖难扫清匡社稷，承先整顿旧乾坤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。〖小开门〗。太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "方相国请快行一步。"
        },
        {
          "character": "方孝孺",
          "type": "内白",
          "text": "啊呀！圣上啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方孝孺上。"
        },
        {
          "character": "方孝孺",
          "type": "一枝花",
          "text": "嗟哉我，凄风带怨号。 兀的不，惨雾和愁罩。 痛煞那，苍天含泪浇。 望不见，白日吐光照。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "方相国请行，万岁爷在金殿候久了。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "你们奉谁的旨来？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "当今万岁爷。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "啊吔！"
        },
        {
          "character": "方孝孺",
          "type": "一枝花",
          "text": "他是个藩服臣僚， 怎生个万岁声声叫！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "老相国，你这孝服不便入朝面君，请换了冠服相见。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "君父之丧岂容易改，"
        },
        {
          "character": "方孝孺",
          "type": "一枝花",
          "text": "俺把那纲常一担挑。 骨粼粼是再世夷齐， 吓呀！看，看不得恶狠狠当年莽曹！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刽子手绑齐泰、黄子澄同上，见。"
        },
        {
          "character": "齐泰、黄子澄",
          "type": "同白",
          "text": "老相国请了。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "请！哈哈……原来是齐、黄二位先生。"
        },
        {
          "character": "齐泰、黄子澄",
          "type": "同白",
          "text": "老相国，我二人与君长别了。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "好！二位先生死的好，死的倒也干净。二位先生请先行，俺孝孺随后就到。请！"
        },
        {
          "character": "齐泰、黄子澄",
          "type": "同白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刽子手绑齐泰、黄子澄同下。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "哈哈……好两个大忠臣也。"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "他不负，读圣书彝伦名教。 受皇恩，地厚天高。 他，他、他，张牙怒目向云阳道。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "赛过那渐离击筑，"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "赛过那博浪槌敲，"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "赛过那长山舌骂，"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "赛过豫让衣枭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刽子手抬景清尸首同上。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "啊呀！这是御史的尸首，竟自把他行刑过了，怎么又剥皮楦草！这厮好狠哪！"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "他、他、他，好男儿义薄云霄。 吓呀大，大忠臣命丧鸿毛。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "俺，俺，俺！"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "羡恁个，着绯衣行刺当朝； 羡恁个赤身躯剥皮楦草；"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "羡恁个闪英灵，"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "厉鬼咆哮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈瑛上。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "方老先生，请了！"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "请！哈哈……陈瑛你做得好官哪！"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "方相国，此乃是圣上龙恩，与你何功之有？"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "好贼臣哪！"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "看你乌帽朱袍，传呼拥导。 喜孜孜，承恩新官诰。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "方老先生，新君登基，满朝文武都去朝贺，唯有先生穿了崭衰麻衣，日夜啼哭， 是何理也？"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "你全不念邦家痛，"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "君王悼，一味地弄妖魔，逞桀傲。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "方孝孺，看看你死在临头，还这么倔强吗？"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "呀呀呸！"
        },
        {
          "character": "方孝孺",
          "type": "梁州第七",
          "text": "我骂，骂煞恁叛逆鸱鸮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方孝孺举哭丧棒打陈瑛。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "方老先生快行几步。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方孝孺下。"
        },
        {
          "character": "陈瑛",
          "type": "白",
          "text": "啊呀！这是哪里说起，平白由他一短好骂。笑骂由他笑骂，好官我自为之。 左右，打道。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈瑛、众人同下。朱棣、二太监、校尉同上。〖吹打〗。"
        },
        {
          "character": "朱棣",
          "type": "念",
          "text": "金殿云烟浮罘扆，玉阶日月丽旌旗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监上。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启万岁：方孝孺宣到。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "宣他上殿。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "方孝孺穿了崭衰麻衣，宣上殿来，恐与君不利。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "且带他去来。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "方相国，万岁有宣。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方孝孺上。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "啊呀，圣上啊！"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "方老先生请了。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "请！哈哈……"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "请了！"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "寡人应天正位，群臣尽皆朝贺，先生何故服此不祥之衣来见寡人？"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "子服亲丧，臣服君丧，古礼昭昭，岂容易改！"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "律设大法，礼顺人情，独尔不能为新君一转移乎？"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "天无二日，民无二主。孝孺唯知有故主，不知有你这样的新君哪！"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "咳！先生，寡人此来，权法周公辅成王耳。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "如今成王安在？"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "他自己焚火身亡，非寡人加害。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "成王即死，何不立成王之子？"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "他儿幼小，焉能掌国家大事。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "何不立成王之弟？"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "这个，这个……"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "什么？哈哈……"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "方先生，此乃寡人家事，先生不必多言。况寡人系高皇帝嫡子，继高皇帝大统， 亦复何辞？"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "可怜我那建文皇帝呵！"
        },
        {
          "character": "方孝孺",
          "type": "四块玉",
          "text": "他、他、他，四载受艰劳， 普天下称仁孝。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "殿下，当初李景隆临行时谆谆嘱咐，说道：毋使朕负杀叔父之名儿——"
        },
        {
          "character": "方孝孺",
          "type": "四块玉",
          "text": "美意儿生全，叔父语叨叨， 到头来送入红炉窖。 兀的不思忖量；兀的不添悲悼； 兀的不颜面无处逃。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "方老先生，别的话儿不必讲了。寡人今日只要先生草写诏书，上告天地，下颁 四海。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "你原来要俺草诏么？"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "然。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "听者。"
        },
        {
          "character": "方孝孺",
          "type": "哭皇天",
          "text": "俺不是李家儿惯修降表； 俺不是侍多君，冯道羞包。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "俺不是射君钩，管仲与齐伯，"
        },
        {
          "character": "方孝孺",
          "type": "哭皇天",
          "text": "俺不是魏征易主，佐唐朝。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "你不学，待学谁来？"
        },
        {
          "character": "方孝孺",
          "type": "哭皇天",
          "text": "俺只是，学龙蓬黄泉含笑。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "方老先生，你若草了诏，寡人定当授你职居宰辅，也好荫及子孙。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "你纵有那三公爵显。"
        },
        {
          "character": "方孝孺",
          "type": "哭皇天",
          "text": "九锡荣褒，恩荫儿曹，"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "封王带砺。"
        },
        {
          "character": "方孝孺",
          "type": "哭皇天",
          "text": "博不得彤管一挥毫。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "方孝孺，你若不草诏，莫道寡人宝剑不利乎。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "啊呀，你纵有千言万语！"
        },
        {
          "character": "方孝孺",
          "type": "哭皇天",
          "text": "俺甘伏你万剐千刀。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "啊呀！这老儿实实的倔强，可恼！可恼！叫摆下文房四宝，偏叫这老儿与我写！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "校尉摆文房四宝。"
        },
        {
          "character": "校尉",
          "type": "白",
          "text": "写！"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "写！"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "要俺写什么？要写就写。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方孝孺写。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "拿去看！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱棣看。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "篡、篡、篡、啊呀！这老儿实实可恼，可恨！ 武士的，将这老儿与我拿下了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众武士将方孝孺绑。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "哈哈……高皇帝建文帝，你在天之灵，怎知老臣方孝孺今日里呵。"
        },
        {
          "character": "方孝孺",
          "type": "鸟夜啼",
          "text": "拜别了高皇，高皇帝圣考， 拜别了先王魂飘。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "武士的，将他老妻拿下了！"
        },
        {
          "character": "方孝孺",
          "type": "鸟夜啼",
          "text": "啊呀老妻呀！一任你死蓬蒿。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "武士的，将他的儿孙都拿下了！"
        },
        {
          "character": "方孝孺",
          "type": "鸟夜啼",
          "text": "啊呀儿孙吓！顾不得宗支杳。 俺如今拼却生身，完却臣操。 急急的趱阴魂，历历地诉青霄，历历的诉青霄。 少不得，天心炯炯分白皂！"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "你这老儿，死在头上还分什么白皂？！"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "凭着你拧着天谴，凭着俺千寻正气！"
        },
        {
          "character": "方孝孺",
          "type": "鸟夜啼",
          "text": "到底个叛字儿难饶。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "你若不草诏，你就不怕灭你的九族吗？"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "你就灭俺十族又有何妨！只为俺阴灵不散，"
        },
        {
          "character": "方孝孺",
          "type": "鸟夜啼",
          "text": "管什么十族全枭。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "啊呀！叫武士的，把着老贼敲牙割舌。可恼！可恼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "武士给方孝孺敲牙，割舌，方孝孺痛滚。"
        },
        {
          "character": "方孝孺",
          "type": "煞尾",
          "text": "一任你，敲牙割舌刑千套。 俺只是痛骂千声五岳摇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "方孝孺喷血。朱棣拂袖。"
        },
        {
          "character": "朱棣",
          "type": "白",
          "text": "啊呀！这老儿将寡人龙袍玷污了。 武士的，快把这老贼绑了，押赴雨花台，鱼鳞细剐，妻子对面受刑。砍的砍， 剐的剐，我就灭你十族，又有何妨！绑！绑！绑下殿去！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "朱棣下。"
        },
        {
          "character": "众武士",
          "type": "同白",
          "text": "领旨。"
        },
        {
          "character": "方孝孺",
          "type": "白",
          "text": "血喷腥红难洗濯。"
        },
        {
          "character": "方孝孺",
          "type": "煞尾",
          "text": "受万苦，孤臣粉身碎脑， 啊呀这，这的是领袖千忠，一身儿今古少。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众武士抬方孝孺同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}