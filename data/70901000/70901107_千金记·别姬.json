{
  "script_id": "70901107",
  "title": "千金记·别姬",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "项羽",
      "hangdang": "净"
    },
    {
      "name": "虞姬",
      "hangdang": "旦"
    },
    {
      "name": "韩信",
      "hangdang": "老生"
    },
    {
      "name": "钟离昧",
      "hangdang": "武生"
    }
  ],
  "plot": "韩信统领汉军十万人马，把楚王项羽围于垓下，项羽爱妾虞姬，知大势已去，乞项羽赐死以报，项羽痛不忍\n舍。悲泣之间，汉兵已潮涌而至，杀声震天，虞姬终于自刎而死。",
  "notes": "《别姬》为《千金记》第三十七出。\n《千金记》明沈采撰。以韩信和他的妻子为主要线索，写楚汉相争故事。包括漂母进食、胯下受辱、鸿门宴、\n追韩信、登坛拜将、灭项羽、封齐王等情节，共五十出。有关项羽各出，刻画了项羽勇而无谋、刚愎自用\n的性格。“追信”一出袭用了元杂剧《萧何月下追韩信》第三折的曲词。“追信”、“别姬”、“埋伏”各\n出，昆曲演出较多。韩信被封为齐王，衣锦还乡，亲奉千金给漂母，以谢昔日赠饭之恩，故此剧以《千金记》\n命名。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "虞姬上。"
        },
        {
          "character": "虞姬",
          "type": "引子",
          "text": "一身曾沐君恩宠，暖帐亲承奉。"
        },
        {
          "character": "虞姬",
          "type": "念",
          "text": "玉容未必倾城国，椒房宠爱君恩极。海棠睡起春正娇，莫把金珠污颜色。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "妾乃虞姬也。自配楚王，指望江山一统，岂知天不遂志，瓦解冰消。目下四处 歌声骤起，楚军尽皆逃散，妾身急往叩报。怎奈大王全不运筹善策，只在帐内 长叹。看看汉兵已至，眼看大势去也。"
        },
        {
          "character": "项羽",
          "type": "内白",
          "text": "哇呀……"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "言之未已，大王升帐来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "项羽上。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "咳，嘿！"
        },
        {
          "character": "项羽",
          "type": "引子",
          "text": "盖世英雄，"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "项羽呀项羽！"
        },
        {
          "character": "项羽",
          "type": "引子",
          "text": "始信短如春梦。"
        },
        {
          "character": "项羽",
          "type": "念",
          "text": "力拔山兮气盖世，时不利兮骓不逝。骓不逝兮可奈何……"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "虞姬接驾。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "哇呀……"
        },
        {
          "character": "项羽",
          "type": "念",
          "text": "虞兮、虞兮奈若何！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "吓，大王为何发此长叹？"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "虞姬，美人。孤家行兵五载，身经七十余战，未曾有败。如今，天亡我楚，岂 不可叹。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "虞姬",
          "type": "念",
          "text": "汉兵已掠地，四下楚歌声。大王意气尽，贱妾何聊生。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "啊呀美人哪！我霸业——"
        },
        {
          "character": "项羽",
          "type": "唱",
          "text": "已成灰。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩信领兵同上，同走圆场，同下。"
        },
        {
          "character": "项羽",
          "type": "泣颜回",
          "text": "论英雄，盖世无敌， 时遇折挫，到如今枉自迟疑。 思之就里，悔当初不听鸿门计， 把孤身冒镝。 当锋时不利，岂知今日。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "项羽、虞姬同下。韩信领兵同上。"
        },
        {
          "character": "韩信",
          "type": "白",
          "text": "众将官！"
        },
        {
          "character": "韩信",
          "type": "青天歌",
          "text": "前队两边分，前队两边分， 前摧马，后摧军。 把都门，势摆一个常山阵。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众兵同摆阵，韩信领众兵同下。虞姬、项羽同上。"
        },
        {
          "character": "项羽",
          "type": "泣颜回",
          "text": "我腰间仗剑吐虹霓， 空自有拔山之力。 天亡吾楚，看看食尽兵疲。 听歌声四起汉兵围， 吹散了八千队。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "美人！"
        },
        {
          "character": "项羽",
          "type": "泣颜回",
          "text": "我和你难免分离， 禁不住两行珠泪。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟离昧上。"
        },
        {
          "character": "钟离昧",
          "type": "不是路",
          "text": "垓下重围， 帐里将军知也未？"
        },
        {
          "character": "钟离昧",
          "type": "白",
          "text": "报，大王不好了！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "为何的？"
        },
        {
          "character": "钟离昧",
          "type": "白",
          "text": "大王，那韩信统兵十万众，围住垓下，事在危急了！"
        },
        {
          "character": "钟离昧",
          "type": "不是路",
          "text": "四下里，腾腾横杀气。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "有这等事！起过了。 啊呀美人吓！我英雄志，当初指望造鸿基。"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "项羽",
          "type": "唱",
          "text": "到如今，"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "一旦成虚废！我项羽此行，那韩信纵有十万之众，孤家何足惧哉！只是行军之 际，怎生带得你行。也罢！我闻汉王乃好色之徒，你可好生扶侍他去吧！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "大王说哪里话来，自古忠臣不事二君，烈女不嫁二夫。大王欲图天下大事，岂 可以贱妾为累，愿以此身报大王之恩也。"
        },
        {
          "character": "虞姬",
          "type": "唱",
          "text": "不须疑，"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "大王！"
        },
        {
          "character": "虞姬",
          "type": "唱",
          "text": "赐我三尺青锋先刎死。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "啊呀美人，你果有此心？"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "果有此心。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "你实有此意？"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "实有此意。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "罢，罢，罢！我项羽就死在九泉之下，也得瞑目矣！啊呀美人，只是孤家舍你 不得！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "大王舍了吧！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "舍不得！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "大王舍了吧！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "舍不得！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "汉兵围得紧了。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "闪开了！哇呀……嘿！罢，罢，罢！我就把青锋付与伊。 呣，老亚夫啊老亚夫！"
        },
        {
          "character": "虞姬",
          "type": "白",
          "text": "大王请上，妾身有一拜。"
        },
        {
          "character": "虞姬",
          "type": "唱",
          "text": "分别去，除非梦里重相会。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "虞姬自刎，下。"
        },
        {
          "character": "钟离昧",
          "type": "白",
          "text": "大王，虞娘娘自刎了！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "怎、怎、怎么说？"
        },
        {
          "character": "钟离昧",
          "type": "白",
          "text": "虞娘娘自刎了！"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "啊！啊呀美人吓！看看粉消玉碎，粉消玉碎！"
        },
        {
          "character": "项羽",
          "type": "扑灯蛾",
          "text": "可怜一妇人，可怜一妇人， 激烈男儿志。 甘自把身躯须臾丧我龙泉也。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "啊呀美人吓！"
        },
        {
          "character": "项羽",
          "type": "扑灯蛾",
          "text": "魂飞魄散，好叫我一身无计。 到如今，怎生区处，只恐汉兵又来至。"
        },
        {
          "character": "钟离昧",
          "type": "扑灯蛾",
          "text": "大王休迟滞，大王休迟滞。 顷刻汉兵至， 若还不出战，及早收兵回避也。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "闪开了！ 虞姬，美人……我就把……哇呀……青锋取首级。 马来！"
        },
        {
          "character": "钟离昧",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "项羽",
          "type": "扑灯蛾",
          "text": "且将来，马上悬之。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "虞姬……美人！"
        },
        {
          "character": "项羽",
          "type": "扑灯蛾",
          "text": "愿生死同归一处， 管叫恁，名登青史，留下好名儿。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "啊呀美人！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "项羽抛尸。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "看铊！"
        },
        {
          "character": "钟离昧",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "项羽上马。"
        },
        {
          "character": "项羽",
          "type": "白",
          "text": "刘邦啊刘邦，我若拿住你的时节呵！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖急急风〗。项羽、钟离昧同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}