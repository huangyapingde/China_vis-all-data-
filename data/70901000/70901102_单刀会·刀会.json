{
  "script_id": "70901102",
  "title": "单刀会·刀会",
  "alias": [],
  "source": "侯玉山剧本选",
  "characters": [
    {
      "name": "关羽",
      "hangdang": "红净"
    },
    {
      "name": "鲁肃",
      "hangdang": "外"
    },
    {
      "name": "周仓",
      "hangdang": "副净"
    }
  ],
  "plot": "鲁肃为索取荆州，暗定计谋，邀请荆州守将关羽前来赴宴。关羽单刀匹马而往。在设有埋伏的筵席上，据理\n以争，大义凛然。本折刻画了关羽英勇无畏，忠贞不屈的英雄形象。",
  "notes": "《刀会》为《关大王独赴单刀会》第四折。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周仓执大刀上。"
        },
        {
          "character": "周仓",
          "type": "念",
          "text": "志气凌云贯九霄，周仓今日显英豪。父王独赴单刀会，全仗青龙偃月刀。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "某周仓是也。今日鲁大夫请俺父王赴宴，为此驾舟前往。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽内嗽。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "道言未了，父王出舱来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽上。〖吹打〗。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "波涛滚滚渡江东，独赴单刀孰与同？片帆瞬息西风力，鲁肃今日认关公。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓，"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "船行至哪里？"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "大江。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吩咐水手，风帆不用扯满，把船缓缓而行！某家好观江景。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓！ 呔！水手听者，父王有令：风帆不用扯满，把船缓缓而行，父王要观江景。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "果然一派好江景也。"
        },
        {
          "character": "关羽",
          "type": "新水令",
          "text": "大江东去浪千叠， 趁西风驾着这小舟一叶。 才离了九重龙凤阙， 早来到千丈虎狼穴。 大丈夫心烈，大丈夫心烈， 觑着那单刀会，赛村社。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "看这边厢，天连着水，那边厢水连着山。想某二十年前隔江斗智，曹兵八十三 万人马，屯于赤壁之间。那时，只听兵马之声，不见山水之形，今日里呵。"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "依旧的水涌山叠， 依旧的，水涌山叠。 好一个年少的周郎，恁在何处也？ 不觉的灰飞烟灭。 可怜黄盖暗伤嗟。 破曹樯橹，恰又早一时绝。 赤壁鏖兵，江水犹然热，好教俺心惨切。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内水声。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "好水，好水！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这不是水！"
        },
        {
          "character": "关羽",
          "type": "驻马听",
          "text": "这是那，二十年流不尽的英雄血。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鲁肃、二中军同上。〖吹打〗。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "请爷。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "军侯过江。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吩咐打了扶手。 早知君侯光临，鲁肃只合远迎，接待不周，望勿见罪。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某有何德能，敢劳大夫置酒张筵。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "酒非洞府之长春，乐乃人间之菲艺，鲁肃有何德能，敢劳君侯屈高就下，降尊 临卑，实鲁肃之万幸也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢！贱足踹贵地。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "贵足踹贱地。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "一路江风寒冷，请君先饮三杯御寒。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "看酒。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "头杯奉敬君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，可知主不饮……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "客不宁。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哈……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哈……"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "验杯。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "干！酒来，二杯奉敬君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "酒不饮单。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "色不侵二。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哈，哈……"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哈，哈……"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "验杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹打住。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "干。酒来，三杯奉敬君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，可知某的刀，也会饮酒？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "名将必有宝刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀来。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "刀吓刀！想你在百万军中，取上将的首级，如探囊取物一般。今日鲁大夫请某 饮酒，席上若有不明之事，少不得劳你一劳，先饮上一杯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。关羽将酒倒刀上。吹打住。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯，你我哪里一别，直至如今？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你我当阳一别直至如今。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吓，当阳一别，直至如今，好吓，真乃光阴似骏马加鞭，日月如落花流水，去 得好疾也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "果然去得好疾也。"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "想古今立勋业，"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "舜有五人，汉有三杰。"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "哪里有舜五人汉三杰。 两朝相隔只这数年别， 不复能够会也。 恰又早这般老也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯不老，鲁肃倒也苍了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "皆然。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请君侯开怀畅饮。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "使得。"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "开怀来饮数杯。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯！"
        },
        {
          "character": "鲁肃",
          "type": "胡十八",
          "text": "请开怀饮数杯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫！"
        },
        {
          "character": "关羽",
          "type": "胡十八",
          "text": "某只待要尽心儿可便醉也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吹酒令。关羽将髯蘸酒试刀。吹打住。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问君侯，昔日辞曹归汉，弃印封金，五关斩将，千里独行，这些事，下官鲁 肃只是耳闻，未曾目睹，请君侯试说一遍，鲁肃洗耳恭听。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，想这节事，只可耳闻，不可目睹。闻者寻常，见者却也惊人。大夫若不 嫌絮烦，待某家出得席去，卸了袍服，手舞足蹈，试说一遍。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "愿闻。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "卸袍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。关羽卸袍。吹打住。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那日辞曹归汉，弃印封金，出得城来，那日色刚刚乍午。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "只听得韵悠悠画角绝， 韵悠悠画角绝。 昏惨惨日得这西斜。 曹丞相满捧着香醪， 他自将来，某只在这马上接。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯马上，那时赠君侯何物？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "赠某红锦战袍，要赚关某下马。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯可曾下马？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某在马上一躬说道，丞相，恕关某不下马来者！"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "某就卒律律， 刀挑了锦征袍，某只待去也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯行至哪里？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "行至三里桥。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯又见些什么来？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时关某扭项回头，只见曹兵如潮水一般，涌将上来。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯便怎么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某家在马上陡生一计。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "生何计策？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "见路旁有棵柳树，有如许之大，被某提起青龙偃月刀，将此树，喀咤一声分为 两段。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯好宝刀。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某家又出一令。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "出得何令？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "也呔！曹兵听者，有人过此桥者，即按柳树为号！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯出得好严令吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "某只此一句。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "某就吓得他吓得他马怯惊， 人似痴呆，早晚间不分一个明夜。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "不分明夜，君侯又行至哪里？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "行至古城。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "令兄，令弟，自然是相会得了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥、三弟俱站在城楼之上。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时玄德公曹讲些什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥乃仁德之君，一言不发。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "令弟三将军呢。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟是员虎将，他说道：呀呔！我把你这红脸的！你既降曹，又来则甚？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯便怎样？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某家，百般样分说，他只是不信。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "吓呀大夫，好教某浑身是口怎样分说？ 脑背后将军猛烈。 那素白旗上，他就明明将这标写。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那白旗上写些什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "蔡阳。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "他与君侯无仇吓？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "只为某在东岭关，斩了他外甥秦琪，故此提兵前来报仇。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "原来如此。那时三将军便怎样？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时三弟道：“呔！红脸的！你既不降曹，为何有曹兵接至？”"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "三将军疑的是。那时君侯便怎样？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某家说：三弟快把城门打开，将二位皇嫂车辆接进城去，助俺一支人马， 待俺立斩蔡阳！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那三将军可曾应否？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟道：啊吓，你把谎话来哄谁？俺把城门开了，岂不被你杀个里应外合。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "三将军疑的是。那时君侯便怎样？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时，那时怒恼某家性儿，说道：那城门不用你开，人马也不用你助，可念桃 园结义份上，助俺三通战鼓，待俺立斩蔡阳！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时令弟三将军可曾应允？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟乃是粗中有细之人，他就拍掌呵呵大笑，说这个使得。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "那时君侯便怎样？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "那时某家，将二位皇嫂车辆，我就撵、撵在一旁，说道：三弟擂鼓者！"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "只听得扑通通鼓声儿未绝， 忽喇喇，征鞍儿骤也， 卒律律，过处似雪，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "喀咤！"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "人头儿落也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "斩了蔡阳，令兄，令弟自然是相会得了。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺三弟将城门打开，将二位皇嫂车辆接进城去，俺弟兄三人，挽手而行。大夫。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯。"
        },
        {
          "character": "关羽",
          "type": "沽美酒",
          "text": "才得个兄弟哥哥便欢悦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖节节高〗。关羽归大座。吹打住。关羽、鲁肃对笑。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "请问君侯，方才这节事，叫做什么？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "这叫做以德报德，以直报怨。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "吓！好个以德报德，以直报怨。我想，借物不还，谓之怨也；想君侯熟读春秋 左传，通练兵书，匡扶社稷，救困扶危，谓之仁也；想君侯待令兄玄德公如同 骨肉，视曹操如寇仇，谓之义也；君侯辞曹归汉，弃印封金，五关斩将，千里 独行，谓之礼也；坐缚于禁，水淹七军，谓之智也；我想君侯，仁，义，礼， 智四字俱全，只是缺少一个信字。惜乎吓惜乎！若得信字完全，真乃五常之将， 盖世英雄，无出君侯之右也。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺关某从不曾失信与人。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯不曾失信于人，令兄玄德公曾失信于下官。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "俺大哥乃仁德之君，岂肯失信与你？！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "听者。昔日贤昆仲兵败当阳，身无所归，那时孔明兄与下官同见吾主，暂借荆 州，以为养兵之策。如今数载未还，是何理也？那时吾主屡屡归罪于下官，鲁 肃低情屈意。暂将荆州归还吾主，待等仓廪丰盈，再献与君侯掌管。下官不敢 自专，伏乞君侯台鉴。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，今日是请某饮酒，还是索取荆州？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "这酒也要饮，荆州也要还。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "少讲！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "我把你真心儿待， 恁将那筵宴来设。 攀今吊古，分什么枝叶， 在某跟前使不得之乎者也，诗云和那子曰。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "荆州乃是我主的，是要还的。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "再开言只教你剜口截舌。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "孙刘结亲，乃为两国和好。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "却又来。"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "有义，孙刘，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "目下。"
        },
        {
          "character": "关羽",
          "type": "庆东原",
          "text": "反成做吴越。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "什么响？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "剑响！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "主何吉凶？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "人头落地！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "几次了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "三次了！"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第一？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "文丑。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第二？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "蔡阳。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "第三呢？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "莫非轮着大夫了？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯言重了，下官与它无仇吓。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "听者。"
        },
        {
          "character": "关羽",
          "type": "念",
          "text": "此剑神威不可挡，庙堂之器岂寻常。席前索取荆州事，一剑赏你子敬亡！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽抓鲁肃袍，周仓举刀欲杀。"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "凭着你三寸不烂舌， 休挡俺三尺无情铁。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "此剑。"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "饥餐上将头，渴饮仇人血。 龙在鞘中蛰， 虎向坐间歇。 今日个故友们重相见， 休教俺弟兄们相间别。 子敬听者， 心下休惊怯， 畅好是随邪。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯莫非醉了？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "周仓！"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "吾当醉也。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "君侯果然醉了。 众将官，依计而行。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "有埋伏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "抓回来！可有埋伏？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "并无埋伏。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "你。"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "却怎生闹吵吵把三军列， 谁敢挡拦者。 挡着俺呵，管叫你剑下身亡， 目前见血。 你纵有张仪口蒯通舌，"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "哪里去躲藏？"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "哪里去？"
        },
        {
          "character": "关羽",
          "type": "雁儿落带得胜令",
          "text": "恁且来，来、来、好好送俺到船上，和你慢慢别。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "请大夫过船谢宴。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "下官不过船去了。"
        },
        {
          "character": "周仓",
          "type": "白",
          "text": "谅你也不敢。 斩缆开船！"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大夫，受惊了。"
        },
        {
          "character": "鲁肃",
          "type": "白",
          "text": "好说，好说。"
        },
        {
          "character": "关羽",
          "type": "煞尾",
          "text": "承款待多多承谢。 某这两句话儿，也要你也牢牢记者。 百忙里称不得老兄心， 急切里，夺不得汉家的基业！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、周仓同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}