  "plot": "春秋时，楚国有一白猿，棋艺非凡，人莫能敌。楚王便假借邀请齐王夫妇与白猿下棋为名，想乘机要挟齐国，\n进而达到消灭齐国的目的。齐王妻子钟无盐，智勇双全，以智谋赢了白猿，并带领齐国兵将冲出埋伏，击\n溃了楚兵的追杀，保护齐王返回齐国。",
  "notes": "《棋盘会》取材于《列国志传》，清升平署有抄本《棋盘会》，共六出。第一出《无盐点将》、第二出《下\n棋除猴》、第三出《齐王突围》、第四出《壶公下凡》、第五出《芦苇撇子》、第六出《大战柳盖》。今侯\n玉山先生所传《棋盘会》，即抄本《棋盘会》的前三出。故事情节、人物、曲牌、唱词等，基本相符。\n《棋盘会》之本戏，据传为《列国传》，惜未见传本。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "【第一场：点将】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田昆上。"
        },
        {
          "character": "田昆",
          "type": "点绛唇",
          "text": "整顿熊罴，刀枪锐利，三军集，谁敢轻敌，到处降书递。"
        },
        {
          "character": "田昆",
          "type": "念",
          "text": "军马交驰日色黄，披星戴月渡严疆。君臣迢递来荆楚，回望临淄是故乡。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "小将田昆是也，国母登台点将，只得在此伺候。正是："
        },
        {
          "character": "田昆",
          "type": "念",
          "text": "令行山岳动，言出鬼神惊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廉赛花、四女兵、四大刀手引钟无盐同上。田昆下。"
        },
        {
          "character": "钟无盐",
          "type": "北端正好",
          "text": "没来由离临淄， 急忙忙，催趱征驹， 总只是，未定俺东齐。 楚王何事把人欺， 未审他行何计。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗。钟无盐上高台，田昆上。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "国母在上，田昆打躬。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "一旁伺立。"
        },
        {
          "character": "钟无盐",
          "type": "念",
          "text": "宝剑霜威纠纠雄，霓旌齐卷海天空。一声长啸貔貅肃，云乌奔腾碧玉骢。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "哀家乃齐邦钟无盐。自从井底降妖，幸得梨山圣母垂怜，一换容颜，幸去头上 三角，喜得邦清国泰。不料楚王设下棋盘大会，邀请吾主前去赴会。我想此去， 定有一番波涛也。为此，今日点齐众将，专候吾主起行。 田昆听令。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "吩咐军政司，众将，披挂整齐，擂鼓三通，都到将台听点。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "呔！众将听者，国母有令，众将披挂整齐，擂鼓三通，都到将台听点。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同应。〖内擂鼓〗。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "钟无盐",
          "type": "滚绣球",
          "text": "鼓渊渊声乍起， 振戎行东与西。 振行起三军的刚毅， 兼能够，整饬了戈戟旌旗。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田常、田玉同上。"
        },
        {
          "character": "田常",
          "type": "白",
          "text": "俺田常。"
        },
        {
          "character": "田玉",
          "type": "白",
          "text": "田玉。"
        },
        {
          "character": "田常、田玉",
          "type": "同白",
          "text": "国母擂鼓聚将，急速上前。 众将官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同应。"
        },
        {
          "character": "田常、田玉",
          "type": "同白",
          "text": "催马！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田常、田玉同下。〖内擂鼓〗。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "钟无盐",
          "type": "滚绣球",
          "text": "但只见月光寒，杀恶气， 又听得，惨悲风，战马嘶。 一个个，握刀张旗， 那些军和将，也兵法神奇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖擂鼓〗。田能、管和同上。"
        },
        {
          "character": "田能、管和",
          "type": "同白",
          "text": "俺（田能）（管和）。请了，国母擂鼓聚将，急速上前。 众将官，催马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人内同应。田能、管和同下。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "楚王吓楚王！"
        },
        {
          "character": "钟无盐",
          "type": "滚绣球",
          "text": "恁纵有万马千军勇， 知己知人俺自宜， 料定幽微。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田能、管和、田常、田玉同上。"
        },
        {
          "character": "田能、管和、田常、田玉",
          "type": "同白",
          "text": "国母在上，众将打躬。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "两旁侍立。"
        },
        {
          "character": "田能、管和、田常、田玉",
          "type": "同白",
          "text": "国母，今日擂鼓聚将，有何差遣？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "今有楚王在望江楼设摆棋盘大会，邀请吾主前去赴会。我想此去，干系非小， 倘遇风波颠险，皆赖尔等之力也。"
        },
        {
          "character": "田能、管和、田常、田玉",
          "type": "同白",
          "text": "臣等仗国母威灵，敢不竭忠尽力，以报主上、国母殊恩。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "好！帐下听我道来。"
        },
        {
          "character": "钟无盐",
          "type": "叨叨令",
          "text": "凭着他重重的罗网奇， 俺如今到此也难回避。 往棋盘会去，怎好推干系， 恨无知荆楚未审怀何意。 兀的不恨杀人也么哥， 兀的不恼杀人也么哥。 告诸臣，应须提起精忠义。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "国母，兵扎何处？与儿臣说，也好准备。"
        },
        {
          "character": "廉赛花",
          "type": "白",
          "text": "国母，想那小小楚国，何足惧哉。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "虽然如此，也要提防一二。"
        },
        {
          "character": "田能、管和、田常、田玉",
          "type": "同白",
          "text": "国母，量他有百万之众，臣等自能杀也。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "好！今日登台点将，原为此事。 田昆听令。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "命你带领本部人马，随主公到望江楼下，守好鞍马器械。一等动手，送来接应。 违反者斩！"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "廉赛花听令。"
        },
        {
          "character": "廉赛花",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "命你保护主公赴会。会中有诈，急忙保护主公下楼，不得有误。"
        },
        {
          "character": "廉赛花",
          "type": "白",
          "text": "得令。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "田常、田玉听令。"
        },
        {
          "character": "田常、田玉",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "命你二人带领五百人马，在望江楼西北埋伏，等会中有诈，急忙杀来，不得有 误。"
        },
        {
          "character": "田常、田玉",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "田能、管和听令。"
        },
        {
          "character": "田能、管和",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "命你二人带领五百弓箭手，在丹凤岭埋伏，专候楚国追兵，以便接应。"
        },
        {
          "character": "田能、管和",
          "type": "同白",
          "text": "得令。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "安排已定，尔等小心伺候。分列两旁，听我道来。"
        },
        {
          "character": "钟无盐",
          "type": "上小楼",
          "text": "这的是交相为倚， 兵家深奇。 这其间自有藏机， 运用帷幄莫待狐疑。 正与奇，细与微， 相为卒励， 到头来须知道，有功应记。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖工尺上〗。"
        },
        {
          "character": "齐王",
          "type": "内白",
          "text": "驾到。"
        },
        {
          "character": "田能、管和、田常、田玉",
          "type": "同白",
          "text": "主公驾到。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "随我接驾。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监引齐王同上。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "御妻。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "我等接驾。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐王归大座。〖吹打住〗。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "御妻，人马怎生调遣？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "人马俱已点齐，请吾主起驾。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "这等，田昆听令。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "吩咐大队人马兵发楚国。"
        },
        {
          "character": "田昆",
          "type": "白",
          "text": "得令。 众将官，兵发楚国。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田能、管和、田常、田玉同应。众人同上马。"
        },
        {
          "character": "田能、管和、田常、田玉",
          "type": "尾声",
          "text": "动三军举义旗， 日光寒驱万骑。 这一番去赴棋盘会， 管教那楚国郊原定有兵刀起。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同领下。"
        },
        {
          "character": "田能、管和、田常、田玉",
          "type": "stage",
          "text": "【第二场：诈会】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴英上，起霸。"
        },
        {
          "character": "吴英",
          "type": "念",
          "text": "今日江楼会两君，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳盖上。"
        },
        {
          "character": "柳盖",
          "type": "念",
          "text": "故将棋会漫敷陈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦奎上。"
        },
        {
          "character": "焦奎",
          "type": "念",
          "text": "欲知楚国神威震，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "韩士隆、柏忠同上。"
        },
        {
          "character": "韩士隆、柏忠",
          "type": "同念",
          "text": "今日席前宾主分。"
        },
        {
          "character": "吴英",
          "type": "白",
          "text": "俺吴英。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "柳盖。"
        },
        {
          "character": "焦奎",
          "type": "白",
          "text": "焦奎。"
        },
        {
          "character": "韩士隆",
          "type": "白",
          "text": "韩式隆。"
        },
        {
          "character": "柏忠",
          "type": "白",
          "text": "柏忠。"
        },
        {
          "character": "吴英",
          "type": "白",
          "text": "列位将军请了。"
        },
        {
          "character": "柳盖、焦奎、韩士隆、柏忠",
          "type": "同白",
          "text": "请了。"
        },
        {
          "character": "吴英",
          "type": "白",
          "text": "今有咱家主公，在望江楼上设下棋盘大会，请齐王夫妇饮宴，咱家主公迎接他 君臣去了。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "吓呀！列位将军！少时齐王夫妇到来，你我一起动手便了。"
        },
        {
          "character": "吴英、柳盖、焦奎、韩士隆、柏忠",
          "type": "同白",
          "text": "正是："
        },
        {
          "character": "吴英、柳盖、焦奎、韩士隆、柏忠",
          "type": "念",
          "text": "江楼设摆棋盘会，安排香饵钓金鳌。 （吴英、柳盖、焦奎、韩士隆、柏忠同下。〖工尺上〗。四太监引楚王同上，四女兵引齐王同上，楚王、齐 王同见，四女兵、齐王同下。廉赛花耍刀花上，进城，下。钟无盐上，与楚王见，钟无盐、楚王同下，田昆 带兵同上，同走圆场，同翻下。齐王、钟无盐、楚王、廉赛花、田昆同上。）"
        },
        {
          "character": "楚王",
          "type": "白",
          "text": "不知皇兄皇嫂驾到，未曾远迎，当面恕罪。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "好说，敝处东齐，足贱德薄。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "治国无能，贻笑邻邦。"
        },
        {
          "character": "楚王",
          "type": "白",
          "text": "小王设宴在望江楼上，请皇兄、皇嫂登楼畅饮，请。"
        },
        {
          "character": "齐王、钟无盐",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同上楼。〖工尺上〗。楚王、齐王、钟无盐互相敬酒。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "闻知贵国有一白猿，善能着棋。"
        },
        {
          "character": "楚王",
          "type": "白",
          "text": "我国有一白猿，虽为畜类，小王封他为宰相了。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "畜类封为宰相，哈哈……倒也可笑。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "渴求一见。"
        },
        {
          "character": "楚王",
          "type": "白",
          "text": "命柳盖上楼。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳盖上楼。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "来了！ 参见主公。"
        },
        {
          "character": "楚王",
          "type": "白",
          "text": "见过国王、国母。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "吓，国王、国母。"
        },
        {
          "character": "齐王、钟无盐",
          "type": "同白",
          "text": "将军免礼。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "吓！有何差遣？"
        },
        {
          "character": "楚王",
          "type": "白",
          "text": "命丞相来见。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "呔！丞相上楼来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白猿上。〖上猴儿〗。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "呀！看这猴头生得诡计多端，少时与他着棋，若输与他，起不被他邦耻笑于我！ 我自有道理。 我奉梨山老母之命，值日公曹速降。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "公曹上。"
        },
        {
          "character": "公曹",
          "type": "白",
          "text": "来也！ 有何法旨？"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "少时我与猴头着棋，命你取些酸果抛下，混乱一番，不得有误！"
        },
        {
          "character": "公曹",
          "type": "白",
          "text": "领法旨。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "丞相请过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白猿应。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "闻得你善能着棋……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "白猿叫。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "敢与哀家下？"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "国母今日着棋，须要赌下礼物才是。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "赌何礼物？"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "我国丞相输了，黄金千两，年年进贡，岁岁称臣，国母输了也是照样。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "将军不要如此，俺要输了，我国即为下邦就是。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "好！既如此，摆下棋盘。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "丞相请。"
        },
        {
          "character": "钟无盐",
          "type": "醉扶归",
          "text": "两国相争分棋式， 一番车马皆围绕。 忙将士相安排着， 炮打当头将军定。"
        },
        {
          "character": "齐王",
          "type": "夹白",
          "text": "丞相输了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐王、廉赛花同暗下。"
        },
        {
          "character": "钟无盐",
          "type": "醉扶归",
          "text": "今日里士马卧槽， 管教你奔走无处逃，奔走无处逃。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "丞相输了。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "请国母再下一盘。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "一盘为定，何必再下。"
        },
        {
          "character": "柳盖",
          "type": "白",
          "text": "众将官放箭！"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "看剑！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "钟无盐杀死白猿。"
        },
        {
          "character": "钟无盐",
          "type": "白",
          "text": "哎呀不好！楼下乱箭齐发，侍女们舍命跳楼。 （钟无盐、侍女同下，众楚兵同追下。廉赛花引齐王同出城，同下。钟无盐上，钟无盐、田昆同开打，同下， 众齐兵、众楚兵同上，同开打，众楚兵追众齐兵同下。） 【第三场：败齐】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "廉赛花引齐王同上。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "哎……好也呀是好也！"
        },
        {
          "character": "齐王",
          "type": "新水令",
          "text": "行行渐到楚荒郊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内呐喊声〗。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "呀。"
        },
        {
          "character": "齐王",
          "type": "新水令",
          "text": "听军声观来之鸟，⑴ 悲风天日惨， 杀气阵云高。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "适才寡人在望江楼上饮宴，望见火炮连天，自忖不能走脱，若非赛花保驾，险 些一命而亡。呀！看看杀出重围来也。"
        },
        {
          "character": "齐王",
          "type": "新水令",
          "text": "途路迢遥， 想归来，齐疆杳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦奎上。"
        },
        {
          "character": "焦奎",
          "type": "白",
          "text": "呔！齐王哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐王慌下，廉赛花、焦奎同战。焦奎败下，廉赛花追下。齐王上。"
        },
        {
          "character": "齐王",
          "type": "驻马听",
          "text": "急走忙逃，急走忙逃， 怎顾荒原低与高。 惊惶非小。 这兵马骤相交， 俺则见，两国尽待把兵鏖。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内呐喊声〗。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "齐王",
          "type": "驻马听",
          "text": "又只见，旗靡辙乱征云绕， 两相争逞英豪， 这其间，怎把那敌兵扫！"
        },
        {
          "character": "吴英",
          "type": "内白",
          "text": "齐王哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "吴英上，齐王慌下，廉赛花、吴英同战，吴英败下，廉赛花追下。齐王上。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "啊呀！"
        },
        {
          "character": "齐王",
          "type": "沉醉东风",
          "text": "是将军追来气豪， 催战马突阵咆啸。 好一个赛花幼女猛， 猛可也敌阵云高， 又只见两骑相交， 恶狠狠耀月枪刀。 震着山，把地摇。"
        },
        {
          "character": "齐王",
          "type": "夹白",
          "text": "杀！"
        },
        {
          "character": "齐王",
          "type": "沉醉东风",
          "text": "窣地里，惊回也那飞鸟。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "齐王下，廉赛花、楚将同开打下。〖水底鱼〗。田常、田玉带大刀同上。"
        },
        {
          "character": "田常",
          "type": "白",
          "text": "俺田常。"
        },
        {
          "character": "田玉",
          "type": "白",
          "text": "田玉。奉国母之命，带领人马在望江楼西北埋伏，以为接应。 众将官！"
        },
        {
          "character": "众齐兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "田玉",
          "type": "白",
          "text": "就此埋伏！"
        },
        {
          "character": "众齐兵",
          "type": "同白",
          "text": "吓！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。田常、田玉同下。齐王上。"
        },
        {
          "character": "齐王",
          "type": "雁儿落",
          "text": "眼见那楚兵追，有几遭， 好叫俺道途间惊非小。 纵有女将军胆略高， 挡不得楚兵重围绕。 一会价无计把兵消。 他那里雄纠纠恶似枭。 迢遥，怎能够众齐军救这遭，众齐军救这遭！ （齐王下。吴英、焦奎、柏忠追廉赛花同上，同开打，廉赛花败下。田常、田玉带众齐兵同上，接战，同败 下，众人同追下。〖水底鱼〗。田能、管和带四弓箭手同上。）"
        },
        {
          "character": "呀！你看那杀气贯青宵、俺这里马如眠人将倦、今朝，一煞时流落在他乡道、管和",
          "type": "白",
          "text": "俺管和。"
        },
        {
          "character": "田能",
          "type": "白",
          "text": "田能。奉国母之命，带领五百弓箭手，在丹凤岭埋伏，专候楚国追兵，以便接 应。就此埋伏者。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖水底鱼〗。田能、管和、四弓箭手同下。齐王上。"
        },
        {
          "character": "齐王",
          "type": "挂玉钩",
          "text": " 俺这是，急急抽身紧勒骠紧趭，⑵ 纵有那征𩣵駣， 好叫俺，尽自把愁肠绞。 反被那邻邦笑。 俺怎惯奔走荒郊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖内呐喊声〗。"
        },
        {
          "character": "齐王",
          "type": "殿前欢",
          "text": "猛听得喊声高， 这一回分明吓破胆魂消。 则索要奔走荒郊。 这的是魂消。 则看那军士无辜也那餐刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众楚兵、众齐兵同开战，众楚将同败下。齐王、田常、田玉、田能、管和同上。"
        },
        {
          "character": "田常、田玉、田能、管和",
          "type": "同白",
          "text": "楚国大败。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "国母哪里去了？"
        },
        {
          "character": "田常、田玉、田能、管和",
          "type": "同白",
          "text": "吾主不必忧虑，有大将田昆护驾，料也无妨。请主公按辔缓行，且道前途候便 了。"
        },
        {
          "character": "齐王",
          "type": "白",
          "text": "众将言之有里，回銮。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "田常、田玉、田能、管和同应。"
        },
        {
          "character": "齐王",
          "type": "煞尾",
          "text": "江楼赴宴遭围套， 两国相争把兵交。 从今后，整顿军威图报早。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "齐王",
          "type": "stage",
          "text": "—————————— ⑴原文此处作“hōng lái zhī biáo”，根据《怡志楼曲谱》补全。 ⑵原文此处作“jǐn jiào”，根据上下文补全。"
        }
      ]
    }
  ]
}