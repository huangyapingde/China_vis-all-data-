{
  "script_id": "70401104",
  "title": "青梅煮酒论英雄",
  "alias": [],
  "source": "郝寿臣剧本选",
  "characters": [
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "刘备",
      "hangdang": "老生"
    }
  ],
  "plot": "汉献帝时，曹操为相，阴谋篡位，欲观群臣动静，强迫献帝往许田射猎。曹操射死一鹿，僭立献帝之前，昂\n然受贺，群臣见状，甚为不满。献帝密召国舅董承，授以衣带血诏；董承约合刘备等人，共立盟状，相机灭\n曹。刘备恐曹操生疑，佯为灌园种菜，不问天下大事。曹操闻知，以青梅初放，煮酒邀饮，席间畅论天下英\n雄以试探刘备，并谓：“天下英雄，惟使君与操耳。”刘备闻言大惊，杯箸落地，时雷雨大作，乃借胆小怕\n雷以掩饰之，曹操不疑。忽报袁术假道徐州，欲投袁绍。刘备遂乘机请领一军，前往截击，以图脱身。去后，\n曹操甚悔，急命许褚阻止，但刘备终脱身离去。",
  "notes": "本剧1922年首演于北京。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小锣帽儿头〗。刘备上。小锣归位。"
        },
        {
          "character": "刘备",
          "type": "引子",
          "text": "为了衣带诏，昼夜把心焦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣归位。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "曹操专权势位高，欺君罔上压群僚。立志要除朝廷害，一片丹心佐汉朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣二击。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "孤家、刘备。前因徐州失守，权依曹操帐下，蒙圣恩，封为左将军之职。这且 不言。今有曹操，心怀篡逆，挟制天子，邀往许田行围，不料奸贼侥幸，误射 一鹿，受文武山呼万岁；天子被欺不过，在内廷命董承受下衣带血诏，意欲扫 除汉贼。怎奈曹瞒，势位过大，只可待时而动。吾今设一诡计，在后园浇水种 菜，以释曹操之疑也。"
        },
        {
          "character": "刘备",
          "type": "二黄慢三眼",
          "text": "恨奸雄怀篡逆欺君过甚， 有二弟秉忠心心怀不平。 食君禄报君恩为臣分定， 有曹瞒掌兵符势位权衡。 董国舅受血诏忠心耿耿， 回府去会合了义士七名。 但愿得成大事早除奸佞， 必须要多谨慎待机而行。"
        },
        {
          "character": "张辽、许褚",
          "type": "内同白",
          "text": "走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣五击。张辽，许褚同上。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "奉了丞相命，"
        },
        {
          "character": "许褚",
          "type": "念",
          "text": "特邀刘使君。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣三击。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "来此已是馆驿门首。门上有人么？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣五击。院子上。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "什么人？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子出门。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "原来是张、许二位将军到此，有何公干？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "我二人奉了丞相钧旨，来请皇叔，过府一叙。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "稍待，我去通禀。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "慢着，不用通报，吾二人面请便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冲头。许褚、张辽、院子同进门。"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "使君请了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "原来是张、许二位将军到此，有何见谕？"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "我二人奉了丞相严命，请使君便行。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "呜呼呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣一击。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二位将军，丞相相召，不知有何钧旨？"
        },
        {
          "character": "许褚",
          "type": "白",
          "text": "不知有何紧急之事，特命吾二人，前来相召，就此同行。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "既然如此，二位将军先行，备随后就来。"
        },
        {
          "character": "张辽、许褚",
          "type": "同白",
          "text": "速速快来，不可耽误时刻，吾二人吃罪不起。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "是是是！备随后就来。"
        },
        {
          "character": "张辽、许褚",
          "type": "同白",
          "text": "就要来的。请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣三击。"
        },
        {
          "character": "张辽",
          "type": "念",
          "text": "不辱丞相命，"
        },
        {
          "character": "许褚",
          "type": "念",
          "text": "能传使君言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冲头。张辽、许褚同下。"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "且住！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣五击。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你看他二人匆匆而去，曹操无故相召，必有缘故。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小锣一击。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦呵是了，莫非为董国舅奉血诏讨贼，我七人共主义状，被曹贼看破行藏，前 来相召？"
        },
        {
          "character": "刘备",
          "type": "叫头",
          "text": "哎呀苍天哪，苍天！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "果然如此，量刘备插翅难逃，此番性命休矣！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣紧锤。"
        },
        {
          "character": "刘备",
          "type": "西皮快板",
          "text": "曹孟德无故的前来相召， 想必是董国舅做事不牢。 若被他看破了牢笼计套， 我七人准备着项上餐刀。 那奸贼做事狠性情骄傲， 此一去必须要谨防祸苗。 细想起这件事吉凶难保， 在矮檐须低头去走一遭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "一击，冲头。刘备下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣圆场〗。四龙套上。〖四击头〗。曹操上。长尖归位。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "志量如天高，效周公，独掌皇朝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "圆场归位。曹操坐外座。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "忆昔当年刺董卓，除奸去害定朝歌。许田射鹿受呼贺，文武百官莫奈何。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "归位。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫、曹操。自许田射鹿回来，人心不服。众官不放心上，惟有刘备，内怀奸 诈之心，外做仁义之事，又有关、张相助，况天子认为皇叔，倘与同谋，则为 害不浅。前番有人报道，刘备在馆驿后园，浇水种菜。吾看此人，平素气概轩 昂，今日为何做此卑鄙之事？真叫老夫好难解也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖闪锤〗。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "刘玄德他为人多行诡道， 为什么学种菜做事不高。 命许褚和张辽将他请到， 那时节看动静再作笼牢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "冲头。张辽引刘备同上。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣五击。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "启丞相：皇叔到。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "说我出迎。"
        },
        {
          "character": "张辽",
          "type": "白",
          "text": "丞相出迎。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣五击。曹操出门迎刘备，张辽、四龙套同暗下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊丞相！"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "啊哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊皇叔，在家做的好大事啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。刘备惊。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备……备在家不曾做什么大事啊！"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔在馆驿后园，浇水种菜，此乃小人之事，非大丈夫所为。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "这个……备无事，不过借此以消遣耳。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "即如此，皇叔请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣圆场〗。曹操、刘备同进门。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "有坐。丞相相邀，不知有何台谕？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫并无别故，适见青梅，开得茂盛，忽然想起去年征张绣之时，路上缺水， 军士们口渴，老夫心生一计，鞭梢一指，说道：前面不远，就是梅林。军士们 闻听，个个口生津液，由是不渴。啊，使君！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吾想，人生在世，犹如白驹过隙，大丈夫当及时行乐。你看梅子青青，结蕊成 实，芳华可爱，又值煮酒初熟，醇醪适口，故特邀使君前来，小亭一会。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备有何德能，多蒙丞相错爱！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔不可忒谦。来！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "酒宴可齐？"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "吩咐摆设花亭。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "院子下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、刘备同离位，同出门。"
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "转过玉砌雕栏，"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "去到百花亭上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣圆场〗。曹操、刘备同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖小开门〗。院子上，摆酒。场上正面单桌直摆，左右分设两椅。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有请丞相！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、刘备同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "来此已是。皇叔请坐！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备谢坐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操、刘备分宾主落座。小开门牌住。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔请！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "请！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖慢长锤〗。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "花亭上摆酒宴共同欢笑， 观花景赏青梅美酒佳肴。 汉天子坐江山群僚不扰， 我也曾统貔貅费尽辛劳。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "老丞相扶社稷功劳不小， 讨董卓灭吕布麟阁名标。 但愿得干戈静狼烟熄了， 保我主坐龙庭要比唐尧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "水声。四云童、四水卒引龙形同上，站下场门前。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊，使君！你看黑雾弥漫，阴云密布，想必天要降雨呀！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相，你我一同出席看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣五击。刘备、曹操同出席离位，同看天。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "丞相，西北“龙挂”出现。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操看。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊，果然是“龙挂”。 啊使君，可知神龙的变化？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备才疏学浅，未知其详，愿领丞相赐教。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔不知，听道——"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备愿闻。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "龙，能大能小，能升能隐，大则兴云吐雾，小则敛迹藏形，升则飞腾宇宙之间， 隐则潜伏波涛之内。譬如为人，能屈能伸，能刚能柔，屈则隐居幽僻，伸则 得仕朝堂。能刚可以纵横天下，能柔可以制伏强歆。龙之为物，好比世之英雄。 玄德公久历四方，必知天下英雄，请道其详，操愿听耳。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备肉眼无珠，天下英雄，实为不晓。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔不识其面，也闻其名。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "备今失言一番，丞相谅之。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "请讲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣慢长锤。四云童、四水卒、龙形同下。曹操、刘备同归座。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "袁公路大志威名甚好， 在淮南亦聚着文武群僚。 有纪灵和张勋亚赛虎豹， 兵又精粮又足可算英豪。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "那袁术窃玉玺僭称帝号， 他好比秦朝中奸相赵高。 冢中骨无能为如同蒿草， 不久的管叫他命赴阴曹。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊丞相！河北袁绍，四世三公，门多故吏，在冀州地面，龙骧虎踞。文有田丰、 沮受，奇计良谋；武有颜良、文丑，武艺高强。因董卓作乱，天下诸侯推为 盟主，亦曾报效朝廷。丞相，这可算是得一个大大的英雄。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "哎！袁绍色厉胆小，好谋无断；干大事而惜身，见小利而忘命，文有谋不从， 武有勇不用，碌碌的庸才，非英雄也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊丞相！备还闻名一人，不知可中丞相钧意否？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔请讲。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相啊！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "闻听刘表广略韬， 名称八俊志气豪。 胸藏锦绣多奥妙， 吟诗作赋笔如刀。"
        },
        {
          "character": "曹操",
          "type": "西皮原板",
          "text": "虚名无实非正道， 建功立业无一毫。 蔡瑁、张允将他保， 难出老夫计一条。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖闪锤〗。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "伯符孙策武艺好， 威镇九州立功劳。 血气方刚韬略妙， 江东领袖算他高。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣凤点头。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "虚名无实不足表， 有勇无谋算什么英豪！ 任他雪山万丈高， 太阳出来自化消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣紧锤三击。"
        },
        {
          "character": "刘备",
          "type": "西皮快板",
          "text": "益州刘璋谁不晓？ 能守能为任逍遥。 多行仁义无强暴， 西蜀一带民富饶。"
        },
        {
          "character": "曹操",
          "type": "西皮快板",
          "text": "使君把话错讲了， 守户之犬见人嚎。 有朝一日大兵到， 管叫他锦绣华夷一旦抛。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣住头。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊丞相！备举此数人，皆不中钧意，现今汉中张鲁、宛城张绣、西凉韩遂、河 北公孙瓒等，啊丞相以为如何？"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "啊哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "撕边大锣一击。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此等碌碌小人，何足挂齿呀！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "除此以外，备实不知，望丞相台谕。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "夫大英雄，胸有大志，腹有良谋，有包藏宇宙之机，吞吐天地之志，上知天文， 下晓地理，战无不胜，攻无不克，运筹帷幄之中，决胜千里之外，有此等的 能为，方可算得英雄。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哎呀，如此看来，谁能当得起！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "嗯——目今天下英雄惟使君与操耳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "雷声，刘备故意惊怕，失箸落杯。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "皇叔为何这等模样？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "吓死我也，吓死我也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣夺头。刘备离座。"
        },
        {
          "character": "刘备",
          "type": "西皮二六板",
          "text": "曹操为人多奸狡， 说破英雄把祸招。 趁此机会生计巧，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备向曹操。"
        },
        {
          "character": "刘备",
          "type": "西皮二六板",
          "text": "丞相前来听根苗： 雷声大作吓一跳， 险些刘备魂魄消。 偶然失手把箸掉， 望丞相宽洪大量休挂心梢。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖闪锤〗。曹操离座。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "玄德公怕雷声可发一笑， 我看他空有志怎能扶朝？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操向刘备。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "你也曾百万军经历多少， 大丈夫创事业身要胆包。 （曹操入座。大锣〖水底鱼〗。关羽、张飞同上，同闯进亭内，同站刘备侧。曹操暗惊，二目瞠视关羽、张 飞。〖大锣一击〗。）"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "大哥，丞相好意相请，小亭筵宴，酒要少饮，休要失了礼貌。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操目不转睛，仍瞠视关羽、张飞。〖大锣一击〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你二人从何至此？"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "吾二人闻听兄长和丞相小亭饮酒，特来舞剑，以助——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣二击。关羽、张飞同拔剑，曹操探身瞠视剑柄。"
        },
        {
          "character": "关羽",
          "type": "白",
          "text": "一笑。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操佯笑。"
        },
        {
          "character": "曹操",
          "type": "笑",
          "text": "哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "此非鸿门设宴，安用项庄、项——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操双手拢水袖。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "伯——"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操手背朝外一崩水袖。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "乎！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操双手自然地落于膝上。冷锤。曹操坐实，二目睨视关羽、张飞，面带讽笑。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "丞相，二弟来得鲁莽，休要见怪。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好弟兄，情深意重，令人可敬。 来！"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫赐宴，与二樊哙压惊，带下去。"
        },
        {
          "character": "院子",
          "type": "白",
          "text": "是。 这里来。"
        },
        {
          "character": "关羽、张飞",
          "type": "同白",
          "text": "谢丞相！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关羽、张飞随院子同下。大锣三击。满宠上。"
        },
        {
          "character": "满庞",
          "type": "念",
          "text": "忙将阃外事，报与丞相知。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大锣住头。"
        },
        {
          "character": "满庞",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "罢了。命你打听袁绍消息，如何？"
        },
        {
          "character": "满宠",
          "type": "白",
          "text": "丞相容禀：今有袁绍，带领人马与公孙瓒交战，屡战屡胜。瓒势孤难敌，差人 赴许都求救，不料中途被绍军所获，退守城中。袁绍又使一计，挖地入城，放 起火来，将瓒全家烧坏，公孙瓒自缢而死。现今袁绍兵势甚大，意欲扰乱中原， 特来禀报。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "袁绍如此猖狂！传令下去：命曹洪挂帅，许褚为前站先行，带领三万人马，前 去征讨，不得有误！"
        },
        {
          "character": "满宠",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣一击〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊丞相，那袁绍不过疥癣之疾，何劳大队人马！备愿统一旅之师，前去劝降。 丞相以为如何？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好，如此前令追回。请皇叔带领五万人马，前去征剿，不得有误。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。满宠随下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖闪锤〗。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "今朝脱离天罗网， 虎落平阳想山岗。 三十六计走为上，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖快长锤〗。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "久居虎口定有伤。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖大锣圆场〗。刘备下。"
        }
      ]
    },
    {
