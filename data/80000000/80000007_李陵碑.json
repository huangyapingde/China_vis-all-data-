{
  "script_id": "80000007",
  "title": "李陵碑",
  "alias": [
    "两狼山；一名：苏武庙"
  ],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "杨继业",
      "hangdang": "老生"
    },
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "苏隐士",
      "hangdang": "老生"
    },
    {
      "name": "韩延寿",
      "hangdang": "净"
    }
  ],
  "plot": "宋辽失和，使杨继业征之。杨继业兵困两狼山，遣子七郎求救于元帅潘洪。潘洪不发一兵，且杀七郎以报私\n仇。杨继业久困无援，夜梦七郎冤魂，醒后大疑。使子六郎突围出，己则单身杀至苏武庙，气力不加，见李\n陵碑，大骂一场，竟撞碑死。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "杨继业",
          "type": "内二黄导板",
          "text": "金乌坠玉兔升黄昏时候，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "回龙",
          "text": "盼姣儿不由人珠泪双流。"
        },
        {
          "character": "杨继业",
          "type": "二黄快三眼",
          "text": "七郎儿回雁门搬兵求救， 为什么此一去不见回头？ 唯恐那潘仁美记起前扣， 怕的是我的儿一命罢休。 含悲泪进大营双眉愁皱， 腹内饥身寒冷遍体飕飕。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业睡。杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "二黄原板",
          "text": "听谯楼打罢了二更时分， 杨延昭倒作了巡夜之人。 迈虎步且把那大营来进， 又只见老爹爹瞌睡沉沉。 我这里用袍服与父遮冷， 等候了我七弟搬兵回营。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭睡。"
        },
        {
          "character": "杨继业",
          "type": "二黄导板",
          "text": "我方才蒙胧将养静，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业醒。"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "又只见六郎儿瞌睡沉沉。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "我儿醒来！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "方才一梦得唤醒，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭醒。"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "只见爹爹面前存。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "哎呀，儿啊！你七弟回转雁门，搬取救应，如今杳无音信。为父放心不下，我 儿快快杀出重围，探听你七弟下落，为父的也好放心哪！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿不去！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "为何不去？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹年迈，无人侍奉。孩儿不去！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "为父的么？为父虽老，有道是：虎老雄心在。儿只管前去。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "孩儿不去！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "当真不去？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "当真不去！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿啊，为父倒有父子之情，难道我儿，就无有手足之义了么？"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹不必如此，孩儿愿去就是。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "好，快快上马去罢！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹呀！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "倘若胡儿来骂阵， 紧守大营莫出兵。 辞别爹爹足踏蹬， 探听七弟走一程。"
        },
        {
          "character": "杨继业、杨延昭",
          "type": "同白",
          "text": "（六郎）（爹爹），（延昭）（我父）！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "爹爹呀！罢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        },
        {
          "character": "杨继业",
          "type": "哭头",
          "text": "啊！我的儿啊！"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "见姣儿上了马能行， 指着潘洪发恨声。 我儿若有好和歹，"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "潘洪啊，贼！"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "定把老命与尔拚！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四番兵引韩延寿同上。"
        },
        {
          "character": "韩延寿",
          "type": "念",
          "text": "奉了太后旨，把守在雁门。"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "某，韩延寿。奉了太后旨意，把守雁门关。儿郎的，"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "雁门关去者。"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。会阵。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "何人挡住俺的去路？"
        },
        {
          "character": "韩延寿",
          "type": "白",
          "text": "韩延寿要尔的狗命！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "一派胡言，放马过来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭、韩延寿同开打，杨延昭下。韩延寿、四番兵同追下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "叫头",
          "text": "休赶哪，休赶！"
        },
        {
          "character": "杨延昭",
          "type": "二黄散板",
          "text": "打破玉笼飞彩凤， 顿断金锁走蛟龙！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四老军扛弓刀引杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "反二黄慢板",
          "text": "叹杨家秉忠心大宋扶保， 到如今只落得兵败荒郊。 恨北国萧营中打来战表， 擅抢夺我主爷的锦绣龙朝。 贼潘洪在金殿帅印挂了， 我父子倒作了马前的英豪。 金沙滩双龙会一阵败了， 只杀得血成河鬼哭神嚎。 我的大郎儿替宋王把忠尽了， 二郎儿短剑下命赴阴曹； 杨三郎被马踏尸首不晓， 四八郎失番邦无有下梢； 杨五郎在五台学禅修道， 七郎儿被潘洪箭射花标。 只落得杨延昭随营征剿， 可怜他尽得忠，又尽孝，血染沙场、马不停蹄，为国辛劳。 可怜我八个子把四子丧了，把四子丧了，我的儿啊！"
        },
        {
          "character": "杨继业",
          "type": "反二黄原板",
          "text": "可怜我一家人无有下梢。 魍魉臣与潘洪又生计巧， 请我主到五台快乐逍遥。 又谁知中了那奸贼笼套， 四下里众番儿犹如海潮。 多亏了杨延昭一马来到， 一杆枪保圣驾闯出笼牢。 有老夫二次里又闯贼道， 害得我东西杀砍、左冲右突、虎撞羊群，被困在两狼山，里无有粮，外无有草， 盼兵不到，眼见得我这老残生就难以还朝！ 我的儿啊！"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "饿呀！"
        },
        {
          "character": "杨继业",
          "type": "反二黄原板",
          "text": "饥饿了就该把战马宰了，"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "冷呀！"
        },
        {
          "character": "杨继业",
          "type": "反二黄原板",
          "text": "身寒冷就该把大营焚烧。"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "雁来了。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "四老军",
          "type": "同白",
          "text": "雁来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业持弓搭箭，弦断。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "宝雕弓打不着空中飞鸟， 弓炸弦断就为的是哪条？"
        },
        {
          "character": "探子",
          "type": "内白",
          "text": "报！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子上。"
        },
        {
          "character": "探子",
          "type": "白",
          "text": "石虎将爷战马绞倒。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "不、不、不、不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "探子下。"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "恨石虎把我的战马绞倒， 为大将无良骑怎把战交？ 抬过了定宋刀爷把路找，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四老军同下。"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "寻一个避风所再作计较。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "苏隐士上。"
        },
        {
          "character": "苏隐士",
          "type": "二黄摇板",
          "text": "天下荒荒刀兵乱， 黎民涂炭不得安。"
        },
        {
          "character": "苏隐士",
          "type": "白",
          "text": "老汉，苏隐士，乃南朝人也。当年大战北国，流落在此，每日在这海上牧羊度 日。闻听南朝差来大将杨继业，被番兵杀得大败，被困在这两狼山下，内无粮 草，外无救兵，倘若被番兵擒去，可叹他一世的忠良付与流水。是老汉在苏武 庙前、李陵碑下刻下诗句一首，激他之怒，盗去宝刀，成全他一世英名也。"
        },
        {
          "character": "苏隐士",
          "type": "二黄摇板",
          "text": "可叹忠良遭大难， 那旁来了一将官。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "当年保驾五台山， 智空长老对我言： 他道我后来遭大难， 到如今果应那智空言。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "来此不知什么所在？"
        },
        {
          "character": "苏隐士",
          "type": "白",
          "text": "嗯哼！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "那厢有一老丈，向前问来。 啊，老丈请了。"
        },
        {
          "character": "苏隐士",
          "type": "白",
          "text": "请了。这位将军，敢么失迷路途么？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "请问老丈，此处什么所在？"
        },
        {
          "character": "苏隐士",
          "type": "白",
          "text": "你来看："
        },
        {
          "character": "苏隐士",
          "type": "念",
          "text": "此处是两狼，前面摆战场。到此有埋伏，犯者一命亡。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "请问老丈，在此作甚？"
        },
        {
          "character": "苏隐士",
          "type": "白",
          "text": "在此牧羊。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "这样兵荒马乱，你还牧的什么羊啊？"
        },
        {
          "character": "苏隐士",
          "type": "白",
          "text": "兵荒不兵荒，与我实无妨。老汉无别干，在此牧老羊。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "难道这老羊还有什么贵处么？"
        },
        {
          "character": "苏隐士",
          "type": "念",
          "text": "提起此羊有贵处，他的名儿万古扬。生下几个羊羔子，烈烈轰轰在世上。 前者几个死，今日一个亡。逃生是忘想，今日死老羊。"
        },
        {
          "character": "苏隐士",
          "type": "白",
          "text": "老羊与我死！"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "老丈说话理不通， 分明道我杨令公！ 定宋宝刀将你砍，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苏隐士收刀，下。"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "霎时不见我的护身龙。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "且住。老丈将我的宝刀收去。为大将者，宁舍千军，不舍寸铁。待我赶上前去。 “苏武庙”，进庙走走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业进庙。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "那厢有一碑碣，向前看来。 “李陵碑”，呀呀呸！汉室李陵，乃是大大的奸佞，不知何人与他立的什么碑 碣！上面还有几行小字，待我仔细看来："
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "庙是苏武庙，碑是李陵碑，令公来到此，卸甲又丢盔！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业丢盔弃甲。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "且住！老夫被困在两狼山，盼兵兵不到，望子子不归，白日受饥饿，夜晚被风 吹。也罢，不免拜谢宋王爵禄之恩，我就碰死在李陵碑下！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业碰碑，死。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}