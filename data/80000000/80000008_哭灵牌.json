{
  "script_id": "80000008",
  "title": "哭灵牌",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    }
  ],
  "plot": "刘备率蜀兵、蛮兵在猇亭大败吴兵，沙摩柯射死甘宁，江南大震。孙权遣诸葛瑾押解范疆、张达及张飞首级\n往蜀营求和，刘备不允。乃设位哭祭关、张，斩杀范、张及傅士仁、糜芳，誓必灭吴。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内西皮导板",
          "text": "白盔白甲白旗号，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、关兴、张苞引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "二弟呀，三弟呀！"
        },
        {
          "character": "刘备",
          "type": "回龙",
          "text": "孤的好兄弟！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "孤王心恸哭嚎啕。 决意兴兵把仇报， 扫平了东吴恨方消。 请过了灵牌王怀抱，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴取灵牌，跪。刘备坐，接灵牌。"
        },
        {
          "character": "刘备",
          "type": "反西皮二六",
          "text": "点点珠泪往下抛。 当年桃园结义好， 胜似那骨肉亲同胞。 不幸今朝分别了， 眼望黄泉去路遥。 徐州遭离乱，愚兄我暂栖河北投袁绍， 你身在曹营念故交。 上马金，下马银，富贵你不要， 挂印封金辞奸曹。 匹马单刀保皇嫂， 过五关斩六将，擂鼓三通把蔡阳的首级枭，可算得盖世的英豪！ 恼恨东吴行奸巧， 害孤的二弟归天曹。 此仇此恨怎能够不报，怎能不报！"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "二弟呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴起，接灵牌。刘备起。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "踏平东吴恨方消！"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "伯父！"
        },
        {
          "character": "关兴",
          "type": "西皮摇板",
          "text": "伯父不必痛哀悼， 珍重天年春秋高。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "非是为伯珠泪掉， 孤与尔父生死交。 哭罢了二弟把三弟叫，"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "翼德啊，三弟啊！啊！难得见的好兄弟啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苞取灵牌，跪。刘备坐，接灵牌。"
        },
        {
          "character": "刘备",
          "type": "反西皮二六",
          "text": "哭声三弟泪洒在白袍。 当年同把董卓讨， 弟兄们阵前显英豪。 虎牢关曾把吕布的发冠挑， 长坂坡前喝断了当阳桥。 夜战马超胆气豪， 义收严颜颇有略韬。"
        },
        {
          "character": "刘备",
          "type": "快西皮二六板",
          "text": "恼恨那范疆张达两个贼强盗， 害孤三弟，二贼脱逃。 如今犯人俱解到， 纵然我手刃狂徒难把恨消。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张苞接灵牌，起。刘备起。"
        },
        {
          "character": "刘备",
          "type": "快西皮二六板",
          "text": "越思越想心头恼， 这血海深仇，"
        },
        {
          "character": "刘备",
          "type": "西皮快板",
          "text": "东吴是根苗。 今日兴兵把仇报， 不杀孙权不还朝。"
        },
        {
          "character": "刘备",
          "type": "西皮摇板",
          "text": "一片忠诚天可表，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备接灵牌。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二弟，三弟，"
        },
        {
          "character": "刘备",
          "type": "哭头",
          "text": "好兄弟呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备递灵牌。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "完恩义拼一个海沸山摇！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "看酒来。"
        },
        {
          "character": "关兴",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴递酒。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "待为伯祭奠。"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "儿臣代祭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "关兴、张苞同祭奠。"
        },
        {
          "character": "刘备",
          "type": "哭",
          "text": "唉，贤弟吓……"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "关兴、张苞！"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "将一干人犯一齐开刀！"
        },
        {
          "character": "关兴、张苞",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "刘备",
          "type": "念",
          "text": "满怀仇恨冲霄汉，要把吴狗踏平川！"
        },
        {
          "character": "刘备",
          "type": "哭",
          "text": "唉，兄弟吓……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备下。关兴、张苞同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}