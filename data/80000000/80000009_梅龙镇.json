{
  "script_id": "80000009",
  "title": "梅龙镇",
  "alias": [
    "游龙戏凤；一名：下江南"
  ],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "正德帝",
      "hangdang": "老生"
    },
    {
      "name": "李凤姐",
      "hangdang": "旦"
    }
  ],
  "plot": "明武宗私游大同，过李龙酒店，见李龙之妹李凤姐美，乃加调戏。后实告以皇帝身份，封李凤姐为妃。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "正德帝作军家打扮上。"
        },
        {
          "character": "正德帝",
          "type": "内内",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "小毛锣，正德帝上。"
        },
        {
          "character": "正德帝",
          "type": "引子",
          "text": "离金阙暗藏珠宝，游天下访察民情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝归大座。"
        },
        {
          "character": "正德帝",
          "type": "念",
          "text": "大明一统锦山河，龙凤车辇多快乐。孤王离了燕京地，梅龙镇上景致多。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "孤，大明天子国号正德。自登基以来风调雨顺国泰民安。昨日改装出宫，住在 梅龙镇上，那店主东巡更作扑去了。临行言道：要茶要酒，只用木马儿一响便 有人来。孤王独坐店中，闷煞人也！"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "有寡人离了燕京地， 梅龙镇上且散心。 将玉玺交与龙国太， 朝中大事托付了众卿。 孤忙将木马儿一声响， 唤出提茶送酒的人。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保！"
        },
        {
          "character": "李凤姐",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐托酒盘上。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "自幼儿生长在梅龙镇， 兄妹卖酒度光阴。 我哥他巡更去守夜， 他言道前堂有一位军人。 将茶放置在桌案上，"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀啐！"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "紧忙回转绣房门，啊……绣房门。 （李凤姐的腰巾拖在地上，才拾起来。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀呀啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐自上场门下。正德帝笑。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "好花儿生在深山内， 美女生在这小地名。 孤忙将木马儿一声响，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐上。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "后面来了卖酒的人。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保！酒保！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "酒保无有，有个酒大姐在此啊。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好好，酒大姐，酒大姐！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "唤我何事？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我且问你，那个巡更作扑的人是你何人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他是我家哥哥。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他叫李龙。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我哇，我是无有名字的。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嗳！人生天地之间，岂无名字的道理，叫什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "名字倒有，说出来怕军爷你叫。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的不叫。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怎么，军爷不叫？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不叫。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我叫……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "叫什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我叫……噢，我姓李吆。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嗳！我晓得你姓李。叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我叫……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐贴近耳边，小声。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "李凤姐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "嗬，好一个李凤姐吆！呵呵！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "拿名字来还我！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "话出如风，怎么还你呀？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "方才军爷说不叫，怎么又叫起来了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的乃是顺口答应。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "下次不可！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "下次不叫也就是了。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "唤我何事呀？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我且问你，你们这里卖的都是什么酒饭？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们这里有三等样酒饭。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪三等？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "上中下三等。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "上等的卖于是什么人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "来往官员。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "中等的？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "买卖客商。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "下等的？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这下等的么……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "正是！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不说也罢。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为何不说？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "恐怕军爷你着恼。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的不恼。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷不恼？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不恼。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "就是你们这些吃粮当军人所用。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "啊呀，且住！想为军之人有这样的苦处！哎！也罢，待孤王回转朝中，发饷银 十万犒赏他们。 啊，酒大姐，我与你商量商量。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "商量什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你将那上等的酒饭摆来我用。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怎么？军爷要用上等的酒饭么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "打个哑谜，你可知道？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "略知一二。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有道是：坐船？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "要船钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "住店？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "要店钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这吃酒呢？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，酒后……"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀啐！酒钱都不会说，说什么酒后！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么？你还要钱吗？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我倒不要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪一个要钱？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我哥哥回来，向我要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好哇，既是要钱就好办事了。你将这帘儿卷呐起！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "好一个乖巧李凤姐， 她与孤王要酒钱。 用手儿忙把银来取， 九龙袋取出了一锭银。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "拿去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "放下。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "放在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "放在桌儿上。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这银子是光的，桌儿是滑的，要掉在地下呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "掉在地下有我去拣呐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕呀。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你怕什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕闪了大姐你的腰哇！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎！闪了我的腰，与你什么相干？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的心疼哪。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我自己不心疼，要你来心疼？放下！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦，放下就放下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝用扇遮银子。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀！军爷你敢是舍不得么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我倒舍得。只怕你呀……呵呵，舍不得。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啊呀，且住！看这军爷有些不老成，待我哄他一哄。 啊，军爷，你进得我们店来，可曾看见一幅古画？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你家有个古画，在哪里呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐拿银子。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在这里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎呀！被她哄了去了哇。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "用巧计诓过银一锭， 问声军爷几个人？"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "为军的一人一骑马，"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "一人用不了许多的银。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "银子多了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "人的酒饭，马的草料。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，人的草料，马的酒饭。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃！人的酒饭，马的草料。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "还多呢。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "还多，哦，也罢，剩下那就送与大姐你买花儿戴呀。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "多谢军爷。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不承一谢。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啊，军爷请哪！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "请到哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "请到客堂。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我正要到你的卧房。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎！客堂吆！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝学李凤姐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎！客堂吆！"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "掌灯！ 这是何人的房子啊？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这是我哥哥的卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦。这个呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这是我的卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦。我倒要看上一看。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎！慢来慢来！你可知道男女有别呀？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎呀呀！这个小丫头她也晓得男女有别呀，哈哈哈。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "龙行虎步客堂进，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，开开呀"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "门不开了！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "啊呀呀！这梅龙镇上好紧的门那！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们这里遇见你们这样人，这门户是不得不紧呐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呵呵……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝自下场门下。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "用手儿关上两扇门，啊啊啊，啊，掸一掸灰尘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "行弦，李凤姐摆酒。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "我这里酒席来摆定， 请出军爷饮杯巡。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啊，军爷请出来用酒哇，哎，军爷请出来用酒呀！哎呀呀，你看这个人，叫他 出来，他又不出来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐洗手，正德帝暗上，抱李凤姐。李凤姐挣脱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，好高的房子喔！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "房子，房子，我打你一盘子。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，怎么打起为军的来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "看你这人进得店来，上也瞧瞧下也看看。我们女儿家有什么好看？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不是啊。大姐你长得好看，为军的我喜看！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怎么？你喜看？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "爱瞧。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你爱瞧？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "爱瞧。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "好！如此你就请看。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "倒要瞻仰瞻仰。好！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你再看看！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "再看看，就看看。越看越好。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "还要你看看！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我不看了。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怎么不看了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我看饱了哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哼！我若不看你是我这店里的客人，我就要骂你！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么？你要骂我？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我不但要骂你，我还要打你！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "啊呀呀！为军的从来不曾叫人家打过。今日叫大姐打上几下，又待何妨！来来 来，请打！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝手掌心朝上。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷叫我打？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "叫你打。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，我就……哎呀呀！不打了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么不打了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怕军爷着恼。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的不恼。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷不恼？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不恼。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，我就打打打，呀啐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐自上场门下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝笑。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "这酒席摆的多齐整， 缺少龙心与凤肝。 孤再将木马儿连声响，"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "想是茶寒酒又凉。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保，酒保！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "来了，军爷，敢是茶寒了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "茶不寒。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "酒凉了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒也不曾凉。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这茶也不寒，酒也不凉，你将我们这张桌儿这么敲敲打打，打坏了是要你赔的！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "慢说是你这张桌儿，就是你我也赔……"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "赔你这张桌儿呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "说话要明白些。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的说话最是明白的。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "唤我何事？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我且问你，这酒席是哪一个摆的？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是我摆的。可好？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "摆的倒好。缺少两样。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哪两样？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "红裙系着双罗步，月里天仙美嫦娥。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，军爷说的红白萝卜，我们这里是不上席的。军爷要用，待我与你取来。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，回来，回来！什么红白萝卜！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是什么东西？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "就是那穿红着绿的姐儿们哪！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，先前倒有。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "如今呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "被官府查禁了。慢说无有，就是有，这夜半三更，叫我们女儿家往哪里去寻？ 哪里去找？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这也说的是。酒大姐，我与你商量商量。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "商量什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这是为军的酒，大姐你的手，斟上一杯酒，吃了我就走。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们只管卖酒，不管斟酒。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你斟也不斟？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不斟。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不斟？好，拿银子来还我！我别处去吃！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "待我取来。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "呃，回来回来！哎呀，你真是个呆傻子啊！你这酒席被我吃残了，你哥哥回来 问你要钱，你拿何言答对呀？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎呀！是啊，这酒被他吃残，银子被他拿去，等我哥哥回来问我要钱，我是何 言答对呀？我再哄他一哄。 啊，军爷，你们那里老鼠儿是什么颜色的？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "老鼠么，是灰色的呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们这里是白的。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦，白老鼠？在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎呀，它出来了！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐连忙将酒斟好。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷，在这里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这酒是哪一个斟的？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是我斟的，可好哇？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎，慢说是这一杯，就是十杯八杯也说不了什么呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，你要怎样的斟法呢？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "要你斟上酒，你的手递在我的手，我的手付于我的口，那才算得呢。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此说来，我手上有糖？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "无糖。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有蜜？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "无蜜。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "无糖，无蜜，为何要我来斟酒？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的我喜爱这个调调儿。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我恼的就是这个调调儿。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你是斟也不斟？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不斟。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不斟，拿银子来还我！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "待我与你取来。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "回来！你可晓得我那银子是怎么来的？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "打抢来的不成？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "正是做响马打抢来的。不犯事便罢。若是犯了事，我就说你兄妹二人是窝主， 银子我不要了，酒我也不吃了，我走了。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷回来！商量商量。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你哪一个商量？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我……心与口商量。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "快去商量，我还等着吃酒呢。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎呀，且住！想他这银子乃是打抢来的。若不犯事便罢。倘若犯了事，将我兄 妹二人攀连在内，这便如何是好？哥哥呀，哥哥，今日也卖酒，明日也卖酒， 这就是卖酒的下场哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐斟酒。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "无奈何斟上酒一杯， 叫声军爷饮杯巡。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "吃酒时将她来戏一戏， 看她知呃情不知情。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "干！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝戏搔挠李凤姐手心。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "干你娘的心肝！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎！这个丫头怎么骂起人来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你为何将我手着了一下？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎呀，不错，为军的这几日不曾跑马射箭，指甲长长了，着了大姐一下，也是 不为紧要哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们女儿家指甲也是长的，怎么着不着你呀？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哦！大姐你是爱小便宜呀。好好好，为军的一双粗手，任凭大姐着上几下，来， 请着！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷叫我着？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "叫你着！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此我就……不着了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么不着了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你将手放平些！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好好好，放平些，放平些。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，我就着着着。"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈哈……"
        },
        {
          "character": "李凤姐",
          "type": "西皮流水板",
          "text": "月儿弯弯照天下， 问声军爷你哪里有家？"
        },
        {
          "character": "正德帝",
          "type": "西皮流水板",
          "text": "大姐不必盘问咱， 为军的住在这天底下。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "住了！一个人不住在天底下，难道说还住在天上不成？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我那个住处与旁人大不相同。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怎么不同？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在紫禁城内那个黄圈圈里面呐。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哦，我认得你呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你认得我？认得我是谁？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你是我哥哥的……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "大舅子呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "胡说！"
        },
        {
          "character": "李凤姐",
          "type": "西皮流水板",
          "text": "军爷做事理太差， 不该调戏我们好人家。"
        },
        {
          "character": "正德帝",
          "type": "西皮流水板",
          "text": "好人家，歹人家， 不该斜插这海棠花。 扭扭捏，捏捏扭，十分俊雅， 风流就在这朵海棠花。"
        },
        {
          "character": "李凤姐",
          "type": "西皮流水板",
          "text": "海棠花来海棠花， 反被军爷取笑咱。 我这里将花丢地下， 从今后不戴这朵海棠花。"
        },
        {
          "character": "正德帝",
          "type": "西皮流水板",
          "text": "李凤姐做事差， 不该将花丢在地下。 为军的将花这忙拾起， 李凤姐来来来，我与你插啊……插啊，插上这朵海棠花。"
        },
        {
          "character": "李凤姐",
          "type": "西皮流水板",
          "text": "军爷百般来戏咱， 去到后面我躲避了他。"
