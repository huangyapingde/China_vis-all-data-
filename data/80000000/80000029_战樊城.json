{
  "script_id": "80000029",
  "title": "战樊城",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "伍尚",
      "hangdang": "老生"
    },
    {
      "name": "费无极",
      "hangdang": "净"
    },
    {
      "name": "伍奢",
      "hangdang": "老生"
    },
    {
      "name": "鄢将师",
      "hangdang": "丑"
    },
    {
      "name": "武城黑",
      "hangdang": "武净"
    },
    {
      "name": "家将",
      "hangdang": "小生"
    },
    {
      "name": "家院",
      "hangdang": "外"
    }
  ],
  "plot": "楚平王听信费无极谗言，囚伍奢，并命伍奢修书召其子伍尚、伍员进京，欲一并杀之。镇守樊城的伍尚、伍\n员见信后，伍员心生疑心，劝伍尚不要前往。伍尚不听，进京见父被抓，与父亲同时遇害。楚平王又命武城\n黑领兵至樊城捉拿伍员。伍员不敌，弃城逃走。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "伍尚、伍员",
          "type": "内同白",
          "text": "嗯哼！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚、伍员上。"
        },
        {
          "character": "伍尚",
          "type": "念",
          "text": "边外狼烟靖，"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "共享太平春。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院暗上。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "啊，兄长，自到樊城，为何终日愁闷？"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "啊，贤弟，你我弟兄镇守樊城，不知爹娘在京可安泰否？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "吉人自有天相，兄长何必挂怀？"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "伺候了。"
        },
        {
          "character": "鄢将师",
          "type": "内白",
          "text": "马来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师上。"
        },
        {
          "character": "鄢将师",
          "type": "念",
          "text": "离了京城地，来此是樊城。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "门上哪位听事？"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "做什么的？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "下书人求见。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "启禀二位老爷：下书人求见。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "吩咐书先进，人落后。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "来人的，书先进，人落后。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师暗下。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "二位老爷请看。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "爹娘有书信到来，贤弟请看。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长请看。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "同拆同观。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "爹娘在上，恕孩儿不孝之罪。"
        },
        {
          "character": "伍尚",
          "type": "西皮原板",
          "text": "未曾拆书泪先淋， 书上相逢父子情。 平王思念临潼会， 加封犒赏有功臣。 外加走“之”书后存， 骏马“十匹”少留停。 看罢了书信喜自胜，"
        },
        {
          "character": "伍尚",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "伍员心中自沉吟！"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "贤弟请看。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "小弟不必看书，此乃“逃走”二字。兄长可解？"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "愚兄不解。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "既是爹娘书信，为何有“逃走”二字？只恐此事有诈。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "唤下书人一问便知明白。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唤下书人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师暗上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "是。 下书人！"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "里面唤你，随我进来。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "是。 参见二位老爷。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "小人名叫鄢将师。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "新进相府，久在相府？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "久在相府。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "太老爷可好？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "安泰。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "太夫人呢？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "福寿康宁。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "调我弟兄进京何事？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "这个？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "讲！"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "加官授爵。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "嘿嘿嘿！好一个加官授爵。外厢伺候。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "啊，贤弟，听下书人之言，一定是加官授爵的了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "有道是将在外，君命有所不受。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "唉，贤弟呀！"
        },
        {
          "character": "伍尚",
          "type": "西皮原板",
          "text": "贤弟说话太烈性， 有辈古人将你明： 昔日里有个文王君， 囚系南牢整七春。 长子伯邑救父命， 至今留名万古存。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长！"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "兄长说话欠思论， 休把今人比古人。 文王被囚天注定， 伯邑考焚身命里生成。 既是平王"
        },
        {
          "character": "伍员",
          "type": "转西皮二六板",
          "text": "加官赠， 就该有圣旨到樊城。 若是爹娘修书信， 为什么有“逃走”二字在书后存？ 怕的是失足履陷阱， 那时节插翅也难腾。 我一心坐定樊城镇， 愿做个不忠不孝的人。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "听他言来自沉吟， 背转身来暗思忖： 长子须要遵父命， 是好是歹走一程。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "听贤弟之言，是不进京的了？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "小弟看来，不进京为上策。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "也罢，待兄一人进京。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "兄长一人进京，小弟放心不下，必须命家将跟随，一路之上，也好侍奉鞍马。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "但凭贤弟。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唤家将。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "家将走上。"
        },
        {
          "character": "家将",
          "type": "内白",
          "text": "来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将上。"
        },
        {
          "character": "家将",
          "type": "念",
          "text": "俺本英雄好汉，侍奉帅府门前。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "参见二位老爷。"
        },
        {
          "character": "伍尚、伍员",
          "type": "同白",
          "text": "罢了。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "唤小人前来，有何差遣？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "大老爷一人进京，命你跟随，一路之上，侍奉鞍马。倘有不测，速报我知。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "遵命。但不知大老爷几时起程？"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "即刻起程。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "外厢备马伺候。"
        },
        {
          "character": "家将",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "伍尚",
          "type": "白",
          "text": "看衣更换。"
        },
        {
          "character": "伍尚",
          "type": "西皮原板",
          "text": "在头上取下了乌纱顶， 紫罗蓝衫离了身。 叫家将备马府外等， 等候了你老爷就要登程。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家将下。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "看酒！"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "一封书信到樊城， 拆散我弟兄两离分。 叫家院看过酒一樽，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师、家将暗同上。"
        },
        {
          "character": "伍员",
          "type": "西皮原板",
          "text": "弟与兄长"
        },
        {
          "character": "伍员",
          "type": "转西皮二六板",
          "text": "来饯行。 登山涉水多安稳， 披星戴月奔都城。 若是合家同欢庆， 在那爹娘台前问安宁。 倘若是家门遭不幸， 报仇之事有弟伍员。 非是小弟不从命， 为的是那“逃走”二字解不明。 兄长饮干杯中酒， 一路平安早到京。"
        },
        {
          "character": "伍尚",
          "type": "西皮快板",
          "text": "用手接过酒一樽， 背转身来谢神灵。 回头我对贤弟论， 愚兄言来听分明： 但愿得家门多吉庆， 爹娘台前问安宁。 倘若家门遭不幸， 你就是伍家报仇人！"
        },
        {
          "character": "伍尚",
          "type": "西皮摇板",
          "text": "辞别贤弟跨金镫，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师、家将同下。"
        },
        {
          "character": "伍尚",
          "type": "西皮摇板",
          "text": "披星戴月奔家门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍尚下。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "兄长上马两泪淋， 叫人难舍又难分。 流泪眼观流泪眼， 断肠人送断肠人。 倘若是家门遭不幸， 杀上天子午朝门！ 吉凶二字难测定， 闷坐在樊城等信音。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员、家院同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师、家将、伍尚同上。"
        },
        {
          "character": "伍尚",
          "type": "西皮流水板",
          "text": "青山绿水分得清， 行走哪怕路不平。 吾今懒观路旁景，"
        },
        {
          "character": "伍尚",
          "type": "西皮摇板",
          "text": "急速回家奉双亲。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师、家将、伍尚同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "四校尉",
          "type": "内同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、费无极同上。"
        },
        {
          "character": "费无极",
          "type": "念",
          "text": "眉头一皱计千条，舌尖杀人不用刀。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师上。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "参见大人。小人交差。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "樊城下书，怎么样了？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "伍尚一人进京，伍员镇守樊城。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "伍尚既然进京，他往哪里去了？"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "监中探父去了。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "好，赏假一月，下面歇息。"
        },
        {
          "character": "鄢将师",
          "type": "白",
          "text": "多谢大人。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "鄢将师下。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "且住！今有伍尚，私自进京，监中探父。趁此机会，参他一本。 校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "顺轿上朝。"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四校尉、费无极同走圆场。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "臣费无极见驾，吾皇万岁。"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "卿家上殿，有何本奏？"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "今有伍尚私自进京，监中探父，请主定夺。"
        },
        {
          "character": "楚平王",
          "type": "内白",
          "text": "将他父子，斩首金阶。领旨下殿。"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "领旨！ 校尉的！"
        },
        {
          "character": "四校尉",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "费无极",
          "type": "白",
          "text": "打道法场。"
        },
