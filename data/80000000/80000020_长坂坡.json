          "text": "丞相升帐，我等两厢伺候，"
        },
        {
          "character": "曹洪、李典、文聘、夏侯惇、许褚、乐进、张辽",
          "type": "同白",
          "text": "请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众将分站两边，四红文堂、四大铠引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "铺天翳日，建奇勋，四海扬德政，独力扶乾坤，用兵机，券操必胜。"
        },
        {
          "character": "曹洪、李典、文聘、夏侯惇、许褚、乐进、张郃、张辽",
          "type": "同白",
          "text": "参见丞相！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "站立两厢。"
        },
        {
          "character": "曹洪、李典、文聘、夏侯惇、许褚、乐进、张郃、张辽",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "长眉细眼气昂藏，指日中兴日月光。眼看汉家气数尽，吾今要学周文王。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫，曹操。汉室为臣，自起义兵扫荡群雄，诸侯闻风归顺。唯大耳刘备，占 据新野，实乃心腹大患。今遣徐庶说降，又被诸葛阻止，不肯来降。适才闻报， 大耳刘备弃新野，走樊城，带领数万百姓，日行数里。为此老夫点动大军亲 自追赶，眼见得生擒在迩。 张郃听令，"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "在！"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "传吾将令：大队人马，不分昼夜，追赶刘备去者！"
        },
        {
          "character": "张郃",
          "type": "白",
          "text": "得令！ 令出。下面听者，丞相有令：大队人马，不分昼夜，追赶刘备去者！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同唱泣颜回牌。众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内西皮导板",
          "text": "离了新野忙逃亡，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四下手、简雍、甘夫人、糜夫人、赵云、糜竺、糜芳、两车夫、两马童，两纛旗引刘备同上。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "十数万百姓们相随跟。 桃园弟兄秉忠正， 治国安民破黄巾。 指望治乱多嘉庆， 谁知曹贼多专横。 徐元直打马，"
        },
        {
          "character": "刘备",
          "type": "西皮流水板",
          "text": "许昌奔， 三顾茅庐访孔明。 眼看至此珠泪滚，"
        },
