      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "众百姓、甘夫人、糜夫人同上。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": "赵云",
          "type": "内白",
          "text": "马来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "西皮散板",
          "text": "黑夜之间破曹阵， 主公不见已天明。"
        },
        {
          "character": "赵云",
          "type": "白",
