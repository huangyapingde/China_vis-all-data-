        },
        {
          "character": "赵云",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "三弟一同挡曹兵。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "喳喳喳！得令！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "同下。"
        }
      ]
    },
    {
