          "text": "归降！"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "拚命逃出天罗网，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四上手引张飞同上。"
        },
        {
          "character": "张飞",
