          "type": "内同白",
          "text": "有。"
        },
        {
          "character": "张飞",
          "type": "内白",
          "text": "休得落后，趱行哪！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张飞、众百姓同上，过场，同下。"
        },
        {
          "character": "刘备",
          "type": "西皮散板",
          "text": "再与先生说分明。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "先生，"
        },
        {
          "character": "简雍",
          "type": "白",
          "text": "主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "今日在此安宿一宵，明晨早行，"
        },
        {
          "character": "简雍",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟，"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你看秋末冬初，凉风透体，好不凄凉人也！"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公且免愁肠，保重要紧。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "大家席地而坐，待到天明便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同坐。〖起初更鼓〗。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "寒风透体夜已深， 满天星斗起浮云。 莫不是孤刘备无福分？ 思来叫人珠泪淋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同西皮原板",
          "text": "夜静更深天寒冷， 点点珠泪洒衣襟。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "甘夫人、糜夫人",
          "type": "同西皮原板",
          "text": "阿斗怀中睡不稳， 令人坐卧不安宁。"
        },
        {
          "character": "刘备",
          "type": "西皮原板",
          "text": "未曾睡着复又醒，"
