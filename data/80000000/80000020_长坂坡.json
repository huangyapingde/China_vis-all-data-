      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹洪追糜芳上，糜芳中枪倒地，曹洪下。"
        },
        {
          "character": "赵云",
          "type": "内白",
          "text": "来呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马童引赵云上，过场，下。"
        },
        {
          "character": "糜芳",
          "type": "白",
          "text": "哎呀！且住！被曹营将官射了一箭，好不痛煞我也！哎呀！且住！看那赵云勒 转马头，直奔西北而去，想是降曹去了。待我报与主公知道便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "糜芳下。"
        }
      ]
    },
