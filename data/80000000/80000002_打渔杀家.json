{
  "script_id": "80000002",
  "title": "打渔杀家",
  "alias": [
    "庆顶珠；一名：讨鱼税"
  ],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "萧恩",
      "hangdang": "老生"
    },
    {
      "name": "萧桂英",
      "hangdang": "旦"
    },
    {
      "name": "大教师",
      "hangdang": "丑"
    }
  ],
  "plot": "宋，梁山泊宋江投顺后，阮小七不愿招安，仍以捕鱼为业。所生一女，许于花荣之子，以庆顶珠为定物。阮\n氏父女二人，一叶扁舟，烟蓑雨笠，悠然自适。有土豪丁某，向阮小七需索陋规，阮小七不与。丁某遣教师\n率家丁往捕阮小七。阮小七举手一挥，众皆倾跌，负创而回。丁某嘱县官逮阮小七，责以四十六板，阮小七\n出而大愤，率女儿杀至丁府，残其全家而逃隐焉。",
  "notes": "剧本中以阮小七为萧恩，或系阮小七之隐名。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "萧桂英",
          "type": "内西皮导板",
          "text": "白浪滔滔海水发，"
        },
        {
          "character": "萧恩",
          "type": "内白",
          "text": "开船呐！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧桂英、萧恩上。"
        },
        {
          "character": "萧桂英",
          "type": "西皮快板",
          "text": "江边俱是打鱼家。 青山绿水难描画， 树直哪怕日影斜。"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "儿啊。"
        },
        {
          "character": "萧恩",
          "type": "西皮散板",
          "text": "父女打鱼在河下， 家贫哪怕人笑咱。 桂英儿掌舟舵父把网撒， 可怜我年迈苍苍气力不佳。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "爹爹年迈，这河下生意不作也罢！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "本当不作河下生意，怎奈你我父女拿什么度日呀？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "不要啼哭，将船栓在柳荫之下为父要凉爽凉爽啊。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "儿遵命！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "啊，二位贤弟慢走，愚兄不远送了！这才是我的好朋友！哈哈！"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "爹爹上船来吧！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "哦，来了。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "啊，爹爹，此二位叔叔他是甚等样人？"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "哦，儿问的是他？儿呀！"
        },
        {
          "character": "萧恩",
          "type": "西皮摇板",
          "text": "忆昔当年擒方腊， 倪荣、李俊二豪侠。 蟒袍玉带不愿挂， 弟兄们双双走天涯。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "萧桂英",
          "type": "西皮摇板",
          "text": "昔日有个俞伯牙， 千里迢迢访豪家。 知心人儿说的是知心话，"
        },
        {
          "character": "萧恩",
          "type": "西皮散板",
          "text": "猛抬头见红日坠落西斜。"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "啊，儿啊，你看天色不早，你我父女回去吧。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "回去吧。"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "哎，待我收拾收拾。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "萧恩",
          "type": "念",
          "text": "父女打鱼在江下，"
        },
        {
          "character": "萧桂英",
          "type": "念",
          "text": "家贫哪怕人笑咱。"
        },
        {
          "character": "萧恩",
          "type": "念",
          "text": "看看不觉红日落，"
        },
        {
          "character": "萧桂英",
          "type": "念",
          "text": "一轮明月照芦花。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧恩、萧桂英同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "萧恩上。"
        },
        {
          "character": "萧恩",
          "type": "西皮原板",
          "text": "昨夜晚吃酒醉和衣而卧， 稼场鸡惊醒了梦里南柯。 二贤弟在河下相劝与我， 他劝我把打鱼的事一旦丢却。 我本当不打鱼关门闲坐， 怎奈我家贫穷无计奈何。 清晨起开柴扉乌鸦叫过， 飞过来叫过去却是为何。"
        },
        {
          "character": "萧恩",
          "type": "西皮二六板",
          "text": "将身儿来至在草堂打坐， 桂英儿捧茶来为父解渴。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧桂英上。"
        },
        {
          "character": "萧桂英",
          "type": "西皮摇板",
          "text": "遭不幸我的母早年亡故， 撇下了桂英儿受尽折磨。 清晨起我的父呼唤于我， 我这里捧香茶与父解渴。"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "爹爹请来用茶。"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "为父不叫你渔家打扮，怎么还是这样的渔家的打扮呐？"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "啊，爹爹，女儿生在渔家，长在渔船。不叫女儿渔家打扮，是要怎样的打扮呢？"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "嗯。不听教训就是不孝哇！"
        },
        {
          "character": "萧桂英",
          "type": "白",
          "text": "啊，爹爹，不必生气，女儿改过就是！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "这便才是啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大教师、家丁同上。"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "走哇。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "走哇。"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "别走啦！到了！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "就这儿？我去瞧瞧去。 走吧。咱们回去吧！他没在家。"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "怎么没在家呀？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "关着门呢。"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "诶，关着门是在家呢！锁着门才没在家呢！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "这叫去吧！"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "叫门我们不会，瞧您的！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "这也得瞧我的？ 萧恩呐！萧恩！"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "使点劲呐！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "使劲不让他听见了吗！"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "为的是要他听见！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "哦，为的是叫他听见？等我脱了衣裳啊。瞅见没有？这叫门得有个架势，这叫 拦门式。他不出来便罢，他若出来，上头一拳，底下一脚，他就得躺下。这叫： “金风未动蝉见觉，暗算无常死不知”。 呔！萧恩！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧桂英下。萧恩开门，推大教师倒地。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "呵，这是谁泼的水啊？滑了我一个跟头啊。"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "得啦！萧恩出来啦！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "萧恩出来啦？我瞧瞧去哦！哟呵，糟老头子！咱们跟他横着点！ 是我，是我！是嘚儿我！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "哦，你是哪里来的？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "我们是丁府上来的。"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "原来是丁府上的教师爷。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "罢啦。"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "哎，这老头子会两下子啊。"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "到此作甚？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "我们给请安来啦！问好来啦！催讨渔税银子地来啦！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "原来为此。你来看，这几日天旱水浅，鱼不上网。改日有了银钱，送上府去， 何必你来？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "怎么着？你说什么这两天天旱水浅，鱼不上网。改日有了银钱，给我们爷们儿 送上府去。要是别人来啦，你拿这两句话给他打发走啦！今儿教师爷我来啦， 任凭你怎样说，排派你怎么说，上回书，算你白说！你得拿渔税银子来！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "旁人来啦，倒还罢了，今日教师爷你来了么？哈哈哈！越发的无有！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "照我看呐，要钱没有。你认识这个不认识？"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "朝廷王法，要它何用？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "什么朝廷王法，这是你姥姥怕你活的不长远，给你打的百家锁！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "放屁！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "哎，没打着，锁上，拉着就走啊！萧恩呐！要钱没有，教师爷我要锁你！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "啊？尔要讲锁？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "要讲锁！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "好！你就与我锁锁锁！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大教师以锁链套萧恩，反被萧恩兜回套住脖子。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "得啦！锁他拉着走。怎么锁我也拉着走啊！"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "拉错了。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "又拉错啦！来，拿着，用不着这个！ 哎！我说萧恩老头儿！我们爷们啊，是奉命差遣，概不由己，这么办，你跟我 们辛苦一趟，到趟丁府，要不要在他，给不给在您，我们爷们儿就交代差使啦！ 您瞧怎么样？"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "话倒是两句好话，可惜你二大爷无有工夫啊。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "二大爷啦啊？跟你要钱，你是没有，让你跟我们走，你又不走。教师爷带的人 多，我要讲打！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "啊？尔要讲打么？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "要讲打！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "唉！老汉幼年之间，听见“打架”二字，好象似小孩子盼新年穿新鞋的一般。 如今呐，我老了，打不动了啊。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "这呀撇鞋，你说什么你幼年间听说打架如同那小孩子穿新鞋过新年的一般？教 师爷我听说打架，好有一比！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "比作何来？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "好比那耗子舔猫的鼻梁骨——我要作死！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "啊？听你之言，敢莫是当真讲打？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "要打！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "果然讲打？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "果然讲打！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "娃娃！待老汉将衣帽丢在家中，打个样儿与你们见识见识！"
        },
        {
          "character": "萧恩",
          "type": "西皮导板",
          "text": "听一言气得我七孔冒火！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "听一言气得你七孔冒火！今儿教师爷我打你个八处生烟！"
        },
        {
          "character": "萧恩",
          "type": "西皮摇板",
          "text": "只气得年迈人咬碎牙窝。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧恩打家丁。"
        },
        {
          "character": "萧恩",
          "type": "西皮摇板",
          "text": "在江湖叫萧恩不才是我！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "怎么的？在江湖叫萧恩不才是你？教师爷我也有个名有个姓！"
        },
        {
          "character": "萧恩",
          "type": "白",
          "text": "尔叫什么东西？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "人嘛！怎么东西！我叫“左铜锤”！哎呀，锤上喽！"
        },
        {
          "character": "萧恩",
          "type": "西皮摇板",
          "text": "大战场小战场见过许多。 我本是出山虎独自一个！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧恩打家丁。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "你说什么？你好比出山虎独自一个？教师爷我好比那打猎的，单打你这个出山 虎！哎！打呀！"
        },
        {
          "character": "萧恩",
          "type": "西皮摇板",
          "text": "尔好比看家犬一群一窝。"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "哎！怎么揪我的耳朵呀！"
        },
        {
          "character": "萧恩",
          "type": "西皮散板",
          "text": "你本是奴下奴敢来欺我？"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "打呀！"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "别打啦！人家骂啦！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "骂什么呀？"
        },
        {
          "character": "家丁",
          "type": "白",
          "text": "骂你一人儿奴下奴！没有我们四个人儿什么事情！"
        },
        {
          "character": "大教师",
          "type": "白",
          "text": "有的，你们四个人倒摘得挺干净呐。我问问他去！ 你骂我们爷们儿奴下奴，不错！我们是奴，我是丁家门儿奴，不是你萧家门儿 奴！这么办，经得住教师爷三羊头，鱼税银子不要，带领徒弟一走，你瞧怎么 样？"
        },
        {
          "character": "萧恩",
