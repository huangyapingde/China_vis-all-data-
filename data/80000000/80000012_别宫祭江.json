          "character": "大太监",
          "type": "白",
          "text": "祭礼摆下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖哭皇天〗。四小太监、四宫女、二大太监同设香案，孙尚香焚香祭奠。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "两厢退下了。"
