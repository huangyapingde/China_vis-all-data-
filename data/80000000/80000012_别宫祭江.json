        },
        {
          "character": null,
          "type": "stage",
          "text": "四小太监、四宫女、二大太监自两边分下。"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "设祭长江岸，举目望西川。梦魂何日见，空叫泪不干。"
        },
        {
          "character": "孙尚香",
          "type": "二黄导板",
          "text": "在江边只哭得泪流不尽，"
        },
        {
          "character": "孙尚香",
          "type": "叫头",
          "text": "皇叔，我夫，唉，喂呀！"
        },
        {
          "character": "孙尚香",
          "type": "回龙",
          "text": "尊一声汉皇叔在天上灵："
        },
        {
          "character": "孙尚香",
          "type": "反二黄慢板",
          "text": "好夫妻恶姻缘前生造定， 又谁知半途中两下离分。 可叹你大英雄出世被困， 可叹你结桃园誓死同生； 可叹你破黄巾功劳被隐， 可叹你入虎穴东吴招亲； 好容易战荆襄身立未稳， 偏遇着讨荆州火烧连营。 辜负了小阿斗少年情性， 辜负了诸葛亮赤胆忠心。 在江边只哭得声嘶哑紧， 倒不如投江死万世留名。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖反哭皇天〗。孙尚香再祭。"
