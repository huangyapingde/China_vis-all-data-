{
  "script_id": "80000012",
  "title": "别宫祭江",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "孙尚香",
      "hangdang": "正旦"
    },
    {
      "name": "吴国太",
      "hangdang": "老旦"
    },
    {
      "name": "孙权",
      "hangdang": "净"
    }
  ],
  "plot": "三国，东吴孙权之妹孙尚香惊闻夫君刘备晏驾白帝城，欲赴西川奔丧吊祭。孙权则拟趁妹入川奔丧之际，以\n派兵护送为名暗袭西川。事为孙尚香识破，怨恨兄长多次将自己作为其成王霸业的诱饵。为免吴蜀两地生灵\n惨遭涂炭，乃进宫辞别母后，藉口前往江边祭奠。奠毕，投江自尽，以死来挫败孙权的诡计。",
  "notes": "《别皇宫》（一名《别宫》）和《祭江》（一名《祭长江》）是两个剧情相连而又可以单独演出的剧目。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫女引孙尚香同上。"
        },
        {
          "character": "孙尚香",
          "type": "引子",
          "text": "吴蜀两地，动刀兵，何日太平？"
        },
        {
          "character": "孙尚香",
          "type": "念",
          "text": "别君常挂念，难忘故日情。虽无千丈锦，万里系人心。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "我，孙尚香。配夫刘玄德，西蜀为君。只因周瑜在世之时，假报母病，将我诓 回东吴，不放回去，我与皇叔天南地北，音信渺茫，思想起来好不伤感人也。"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "恨兄长行巧计居心太恶， 隔断了织女星难渡银河。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大太监引孙权同上。"
        },
        {
          "character": "孙权",
          "type": "西皮摇板",
          "text": "袖内机关安排定， 进宫诓骗同胞人。 内待摆驾宫院进， 见了贤妹说分明。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "啊呀，贤妹，大事不好了！"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "何事惊慌？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "只因刘皇叔，为报关羽之仇，被大都督陆逊火烧连营，在白帝城丧命了。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "你在怎讲？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "在白帝城丧命了。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香昏倒。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "贤妹醒来！"
        },
        {
          "character": "孙尚香",
          "type": "西皮导板",
          "text": "听说是汉皇叔白帝丧命，"
        },
        {
          "character": "孙尚香",
          "type": "叫头",
          "text": "皇叔，我夫，唉，喂呀！"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "好一似万把刀刺在我心。 可叹你为报仇反送性命，"
        },
        {
          "character": "孙尚香",
          "type": "哭头",
          "text": "皇叔哇！啊！"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "撇下了未亡人何以为情？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "兄长啊！皇叔已死，我有意回转西川，前去奔丧吊祭，不知兄长意下如何？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "哦，怎么你要人川奔丧吊祭么？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "夫妻一场，理应如此，贤妹速速准备。待为兄派兵护送贤妹入川奔丧就是。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "多谢兄长。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "愚兄告辞了。"
        },
        {
          "character": "孙权",
          "type": "西皮摇板",
          "text": "想人生必须要礼义为本， 为江山那顾得手足之情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权下。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢参见郡主。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "进宫何事？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "启禀郡主：奴婢有话不知当讲不当讲？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "有话快些讲来。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "方才银安殿上，吕范定计：借郡主入川奔丧吊祭为名，主公统领大兵，明为护 送，暗则夺取西川，那时灵堂变成战场，郡主可要留心一二啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香惊慌。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "这……我来问你，可是真情？"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢亲耳听见，不敢慌报。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "起过了。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "咋。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "哎呀且住，想当年只为荆州九郡，将我用作美人之计，得配皇叔；如今皇叔已 死，又要借我奔丧吊祭为名，夺取西川，两地军民岂不又遭涂炭，这便如何是 好！有了，我不免假意去往江边祭奠，投江一死，免得再被兄长陷害了。 内待过来！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "速备祭礼，江边伺候。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "待我去到后宫，辞别母后便了。"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "侍儿们备素服随我祭奠， 到后宫别母后再去江边。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第三场",
      "utterances": [
        {
          "character": "吴国太",
          "type": "内西皮导板",
          "text": "一日清闲一日安，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二大太监引吴国太同上。"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "转眼不觉有几年。 可恨曹丕把位篡， 东吴大事属孙权。 将身且坐皇宫院，"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "等候皇儿把驾参。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香上。"
        },
        {
          "character": "孙尚香",
          "type": "西皮散板",
          "text": "可叹皇叔把驾晏， 离鸾别鹄有谁怜？ 侍儿引路养老院， 母后驾前儿问安。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "儿臣见驾，母后千岁。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "皇儿平身，赐坐。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "谢母后。"
        },
        {
          "character": "孙尚香",
          "type": "哭",
          "text": "喂呀……"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "啊！我儿身穿素服，两眼落泪，为了何事？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "启禀母后，适才我兄长进宫言道，刘皇叔在白帝城晏驾了。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "哦！刘皇叔晏驾了？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "唉！皇叔哇！"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "听说皇叔把驾晏， 怎不叫人心痛酸。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后不必悲泪，想皇叔已死，儿臣有意去往江边，望空一祭，特来辞别母后。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "想你兄长与刘皇叔，有敌国之仇，况且人死不能复生，你还祭他则甚？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "儿与皇叔，夫妻一场，未曾亲视晏驾，心中甚是不安。儿臣去心已定，望求母 后恩准。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "我儿不必如此，为娘有一言儿且听了。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后请讲。"
        },
        {
          "character": "吴国太",
          "type": "西皮原板",
          "text": "母女们对坐皇宫院， 为娘言来听根源： 皇叔已然把驾晏， 我儿何必礼周全？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "母后！"
        },
        {
          "character": "孙尚香",
          "type": "西皮原板",
          "text": "母后说话言语颠， 细听儿臣把话言： 只因周郎心地险， 定下美人之计得配娇鸾。 夫妻奉命，"
        },
        {
          "character": "孙尚香",
          "type": "西皮快板",
          "text": "荆州转， 假报母病接儿还。 如今皇叔把驾晏， 未曾见面心痛酸。 儿到江边去祭奠， 纵死在黄泉我就也安然。"
        },
        {
          "character": "吴国太",
          "type": "西皮快板",
          "text": "我的儿说话理不端， 人死哪能又复还？ 江边祭奠空祭奠， 一滴何曾到九泉？"
        },
        {
          "character": "孙尚香",
          "type": "西皮快板",
          "text": "母后说话理太偏， 往日贤来今不贤。 说什么祭奠空祭奠， 一滴何曾到九泉。 老母空把那弥陀念， 从前的事儿你想一番。"
        },
        {
          "character": "吴国大",
          "type": "西皮快板",
          "text": "我儿休要将娘怨， 开口反道娘不贤。 任你讲得天花现， 为娘不准也枉然。"
        },
        {
          "character": "孙尚香",
          "type": "西皮快板",
          "text": "儿嫁刘备娘情愿， 夫妻恩爱重如山。 今日不容儿祭奠，喂呀，儿的娘， 当初何必就结良缘？"
        },
        {
          "character": "吴国太",
          "type": "西皮快板",
          "text": "一见奴才把脸变， 气得老身怒冲冠， 为娘驾坐皇宫院， 哪一个大胆到江边？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "母后不容我祭奠，"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "也罢！"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "不如碰死在娘面前。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "儿啊！"
        },
        {
          "character": "吴国太",
          "type": "西皮散板",
          "text": "我儿不必行短见， 为娘陪儿到江边。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "我儿不必如此，为娘陪儿前去就是。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "且慢，母后年迈，江风甚大，还是儿臣自已前去罢。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "如此为娘赐儿半副鸾驾，须要早去早回。"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "多谢母后。啊，母后请上，受儿臣大礼参拜。"
        },
        {
          "character": "吴国大",
          "type": "白",
          "text": "啊？去去就回，何必行此大礼？"
        },
        {
          "character": "孙尚香",
          "type": "白",
          "text": "这个……唉，娘啊！"
        },
        {
          "character": "孙尚香",
          "type": "西皮二六板",
          "text": "虽然暂别皇宫院， 为人须要礼当先。 儿愿母后身康健， 儿愿母后福寿全。 辞别母后出宫院，"
        },
        {
          "character": "孙尚香",
          "type": "西皮摇板",
          "text": "生离死别好不惨然。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙尚香下。"
        },
        {
          "character": "吴国太",
          "type": "西皮摇板",
          "text": "我儿出宫把脸变， 倒叫老身心不安。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "内侍！"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "奴婢在。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "二千岁进宫。"
        },
        {
          "character": "大太监",
          "type": "白",
          "text": "国太有旨，二千岁进宫啊！"
        },
        {
          "character": "孙权",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权上。"
        },
        {
          "character": "孙权",
          "type": "念",
          "text": "忽听母后宣，进宫把驾参。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "儿臣见驾，母后千岁！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "千千岁！"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "赐座。"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "谢坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孙权坐。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "唉！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "母后为何这样唉声叹气？"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "刘皇叔殡天，你还不知吗？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "孩儿早已知道，有意带兵，护送我胞妹入川奔丧，乘他丧乱之时，儿要暗取他 的成都，西川岂不唾手可得？母后何必长叹。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "怎么，儿要借你胞妹，奔丧之时，暗取西川么？"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "我把你这无谋无用的小奴才！想皇叔虽死，那诸葛亮现在成都，焉能不加防备。 你若带兵夺取西川，那汉贼曹丕，必然趁机来伐东吴，像你这样三番两次， 利用胞妹，以为交锋之兵刃，枉为九郡八十一州之主！怪不得你妹，进宫请命， 去往江边祭奠。出宫之时，变脸变色，想是她看破儿的奸计。命你速速将她 赶回，倘有差错，是定不与你干休，你、你、你快去！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "母后不必动怒，儿臣即刻前去就是。"
        },
        {
          "character": "吴国太",
          "type": "白",
          "text": "快去！"
        },
        {
          "character": "孙权",
          "type": "白",
          "text": "遵命！正是："
