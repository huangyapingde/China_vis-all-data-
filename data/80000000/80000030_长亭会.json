{
  "script_id": "80000030",
  "title": "长亭会",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "申包胥",
      "hangdang": "净"
    }
  ],
  "plot": "伍员弃樊城逃走后，途中遇好友申包胥催贡回朝。伍员向申包胥备诉冤情，立誓雪恨。申包胥劝伍员回朝，\n伍员执意不肯，必往吴国借兵伐楚。申包胥声言：你若灭楚，我必复楚。于是放伍员逃往吴国。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、中军、申包胥同上。"
        },
        {
          "character": "申包胥",
          "type": "点绛唇",
          "text": "将士英豪，儿郎虎豹，军威浩，地动山摇，要把狼烟扫。"
        },
        {
          "character": "申包胥",
          "type": "念",
          "text": "腰挂三尺剑，替主扫狼烟。各国催贡转，把本奏龙颜。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "本帅，申包胥。奉了平王旨意，去往各国催贡。且喜贡件催齐，正好回朝交旨。 中军。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "人马可齐？"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "俱已齐备。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "吩咐班师回朝。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "众将官。"
        },
        {
          "character": "八龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "班师回朝。"
        },
        {
          "character": "八龙套",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、中军、申包胥同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "且住！幸喜逃出樊城，看前旌旗之上，有一斗大“申”字，想是包胥贤弟班师 还朝。等他到来，将我血海冤仇细说一遍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "八龙套、中军、申包胥同上。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "前道为何不行？"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "伍将军挡道。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "人马列开！"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "申包胥",
          "type": "白",
          "text": "仁兄因何这等模样？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "贤弟呀！"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "恨平王无道贪色酒， 父纳子妻礼不周。 我父谏奏反斩首， 一家满门刀割头。 这样的冤仇怎撒手， 不杀平王誓不休！"
        },
        {
          "character": "申包胥",
          "type": "西皮快板",
          "text": "仁兄不必两泪流， 小弟言来听从头： 相国夫人遭毒手， 定是奸贼用计谋。 得放手，且放手， 得罢休来且罢休。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "贤弟把话错出口， 愚兄言来听从头： 君不正，臣逃走， 父不正来子外游。 誓到吴国借兵就， 要杀平王报冤仇。 贤弟回朝莫泄漏， 念在金兰义气投。"
        },
        {
          "character": "申包胥",
          "type": "西皮快板",
          "text": "仁兄已经把誓咒， 小弟不敢来强留。 你若是兴兵来伐楚， 临潼的名儿枉空留。 仁兄打马你阳关走， 急忙快奔吴国投。"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "申包胥与我把志斗， 背转身来反加愁。 贤弟请上兄叩首，"
        },
        {
          "character": "伍员",
          "type": "西皮快板",
          "text": "多谢你放我往东流。 你兴楚来我灭楚， 你为忠来我为仇。 辞别贤弟跨走兽，"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "扬鞭打马往吴国投。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员下。"
        },
        {
          "character": "申包胥",
          "type": "西皮快板",
          "text": "一见仁兄跨走兽， 大小三军听从头： 尔等回朝休泄漏， 泄漏机关斩人头。 人来与爷带走兽，"
        },
        {
          "character": "申包胥",
          "type": "西皮散板",
          "text": "回朝把本奏龙楼。"
        },
        {
          "character": "众人",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}