{
  "script_id": "80000003",
  "title": "打龙袍",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "李后",
      "hangdang": "老旦"
    },
    {
      "name": "包拯",
      "hangdang": "净"
    },
    {
      "name": "宋仁宗",
      "hangdang": "小生"
    },
    {
      "name": "灯官",
      "hangdang": "丑"
    },
    {
      "name": "王延龄",
      "hangdang": "老生"
    },
    {
      "name": "陈琳",
      "hangdang": "丑"
    }
  ],
  "plot": "包拯识出李后，回京，借元宵节，请宋仁宗（赵禛）观灯于午门，故以雷殛张继宝灯戏演出。赵禛问包拯，\n包拯答帝亦不孝。赵禛怒以为谤己，欲斩。首相王延龄求免，请老太监陈琳说破当年狸猫换太子，刘后害李\n后事，赵禛悟，立赦包拯，斩郭槐，并亲迎李后还朝，请罪。李后命包拯行罚，包拯乃脱赵禛龙袍，打袍以\n代。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗上，太监上。"
        },
        {
          "character": "宋仁宗",
          "type": "引子",
          "text": "凤阁龙楼，万古千秋。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "臣，王延龄见驾，吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "念",
          "text": "平顶冠上九龙头，太阳一出照九洲。蓝田玉带朝北斗，万国衣冠拜冕旒。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "寡人，大宋天子赵祯。自登基以来风调雨顺，国泰民安。唯有陈州干旱三载， 孤命包拯前去放粮，未见回朝交旨。王卿,"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "有本早奏，无本退班。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "臣启万岁：今有包拯放粮回朝，已在午门候旨。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家替孤传旨，宣包拯上殿。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "领旨！ 万岁有旨：包拯上殿。"
        },
        {
          "character": "包拯",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮流水板",
          "text": "忽听万岁宣包拯， 陈州来了放粮臣。 撩袍端带了我就上龙廷。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "品级台前臣见君。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣包拯见驾，愿吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "平身。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "将陈州放粮之事一一奏与朕知。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "修下本章，我主龙目御览。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "呈上龙书案。"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "唔呼呀，真乃卿家之功也！内侍，命光禄寺大摆筵宴，与包卿贺功。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "为何拦阻？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣在午门以外设摆花灯大会，请我主龙驾观灯。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家先行，寡人御驾随后。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣领旨！"
        },
        {
          "character": "包拯",
          "type": "西皮流水板",
          "text": "万岁爷准了为臣本， 也免得国太受苦情。 午门巧摆花灯彩，"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "暗地里打动了有道的君。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "内侍摆驾下龙廷， 午门以外观花灯。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "灯官上。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "嗯哼！"
        },
        {
          "character": "灯官",
          "type": "念",
          "text": "君乐臣乐民安乐，五谷丰登大有年。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "我乃灯官是也，奉包相之命巧扮花灯，俱已齐备，在此侍候。"
        },
        {
          "character": "包拯",
          "type": "内白",
          "text": "摆驾！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监、宋仁宗、包拯、王延龄同上。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "灯官，将灯名报上来。"
        },
        {
          "character": "灯官",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "灯官",
          "type": "数板",
          "text": "尊万岁在上听，细听我灯官报花灯： 一团和气灯，和合二圣灯，三羊开泰灯，四季平安灯，五子捉魁灯，六国封相 灯，七子八婿灯，八仙过海灯，九子十成灯，十面埋伏灯。这些个灯，那些个 灯，往后瞧又一层，吕布戏貂蝉，大闹凤仪亭。瞧罢了一篇又一篇，昭君打马 和北番。不好了，不妙了，天雷打死张继保。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "众人",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "将扮灯人拿下！"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "为何拦阻？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "为何将扮灯人拿下？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "这样不忠不孝之灯，要它何用？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "慢说不忠不孝之灯，就是不忠不孝之人臣朝现有。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "当殿奏来，寡人将他治罪。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "若论不孝，就是万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "内臣摆驾回龙廷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "宋仁宗下。"
        },
        {
          "character": "王延龄",
          "type": "西皮摇板",
          "text": "回头埋怨小包文。 有本就该当殿奏， 不该午门藐视君。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "恩师！"
        },
        {
          "character": "包拯",
          "type": "西皮流水板",
          "text": "老恩师不必胆怕惊， 学生言来听分明： 既做忠臣不怕死， 怕死焉能奉当今！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "包拯、王延龄同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四太监、宋仁宗同上。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮流水板",
          "text": "适才午门观花灯， 竟出不忠不孝的人。 借题发挥实可恨， 看来有意藐视君。 怒气不息金殿进。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮摇板",
          "text": "快快宣上王延龄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王延龄上。"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "臣启万岁，包拯拿到。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押上殿来！"
        },
        {
          "character": "王延龄",
          "type": "白",
          "text": "押上殿来！"
        },
        {
          "character": "众人",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监同上，包拯上。"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "忽听万岁押包拯， 午门来了惹祸人。 放心大胆我把龙廷进。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "问我一言答一声。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮快板",
          "text": "开言便把包拯问： 为何午门藐视君？"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "在陈州放粮转回京， 赵州桥下遇冤情。 口口声声龙国太， 倒把为臣吃一惊。 放着亲娘子不认， 外国闻知了你是无道的君。"
        },
        {
          "character": "宋仁宗",
          "type": "西皮快板",
          "text": "包拯得了疯魔症， 敢在金殿你乱胡云。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "包拯",
          "type": "西皮快板",
          "text": "休道臣得下疯魔的病， 国太的言词记在心。 千言万语主不信， 景阳宫问一问那二十年前的老陈琳。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "押下殿去！"
        },
        {
          "character": "众人",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四太监押包拯同下。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "内侍。"
        },
        {
          "character": "众人",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "金牌宣，银牌诏，宣亚父陈琳上殿。"
        },
        {
          "character": "内侍",
          "type": "白",
          "text": "万岁有旨：亚父陈琳上殿呐！"
        },
        {
          "character": "陈琳",
          "type": "内白",
          "text": "领旨！"
        },
        {
          "character": "陈琳",
          "type": "内西皮导板",
          "text": "金牌宣来银牌诏定，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "陈琳上。"
        },
        {
          "character": "陈琳",
          "type": "西皮流水板",
          "text": "景阳宫来了老陈琳。 听说是正宫国母有音信， 那时节我老陈琳上金殿，把本一本一本往上升。 是与不是龙廷进。"
        },
        {
          "character": "陈琳",
          "type": "西皮摇板",
          "text": "品级台前见当今。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "臣，奴婢陈琳见驾，愿吾皇万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "亚父平身！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "万万岁！"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "赐坐！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "谢座。二十余载未曾宣召奴婢，今日宣召奴婢，不知有何国事议论？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "寡人有一事不明，要在亚父台前领教。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "有何事不明，何言“领教”二字？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "寡人是哪宫所生，何宫所养？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "我主乃是李后所生，狄娘娘抚养。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "奏来！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏：只因癸未年间，李后身怀六甲，宫中有一刘妃，她与内侍郭槐乃是姑表 之亲，在老王驾前讨下收生代劳旨意。是日临盆，她用金丝狸猫剥去皮尾，抵 换我主龙体，道李后产生妖怪。老王大怒，推出午门以外就要斩首，多亏满朝 文武保奏，将李后打入冷宫。那奸妃一计不成又生二计，道李后冷宫不清。约 定八月十五火焚冷宫。不知李后生死存亡。算来也有二十余载，为何今日问起 奴婢来了？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "今有包拯还朝，言道国太还在。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "既是国太还在，当年老王游逛御花园，赐她黄绫诗帕，上面有寇准的诗句为证。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "卿家可曾全记？"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "奴婢全记。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "奏来。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "容奏："
        },
        {
          "character": "陈琳",
          "type": "念",
          "text": "春风得意花千里，秋月阳晖桂一枝。天降紫薇接宋后，一对行龙并雌雄。"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "包拯既然还朝，不在金殿奉君，万岁差他哪里公干去了？"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "只因他在午门巧扮花灯，藐视寡人，将他问斩！"
        },
        {
          "character": "陈琳",
          "type": "白",
          "text": "万岁呀！"
        },
        {
          "character": "陈琳",
          "type": "西皮摇板",
          "text": "万岁要斩将奴婢斩， 快快赦回小包拯。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "将包拯赦回。"
        },
        {
          "character": "包拯",
          "type": "西皮摇板",
          "text": "百尺高竿得活命， 鬼门关前又复生。"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "谢万岁不斩之恩。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "包卿，"
        },
        {
          "character": "包拯",
          "type": "白",
          "text": "臣。"
        },
        {
          "character": "宋仁宗",
          "type": "白",
          "text": "你道国太还在，有何为证？"
        },
        {
          "character": "包拯",
          "type": "白",
