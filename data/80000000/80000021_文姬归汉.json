{
  "script_id": "80000021",
  "title": "文姬归汉",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "蔡琰",
      "hangdang": "正旦"
    },
    {
      "name": "周近",
      "hangdang": "老生"
    },
    {
      "name": "左贤王",
      "hangdang": "小生"
    },
    {
      "name": "曹操",
      "hangdang": "净"
    },
    {
      "name": "单于",
      "hangdang": "净"
    },
    {
      "name": "侍琴",
      "hangdang": "旦"
    },
    {
      "name": "李成",
      "hangdang": "丑"
    },
    {
      "name": "张四",
      "hangdang": "丑"
    }
  ],
  "plot": "李榷、郭汜与杨奉争劫汉献帝刘协，南匈奴王乘乱遣左贤王会同白波帅攻侵汉河内地。中郎蔡邕之女蔡琰逃\n难，为左贤王掳入匈奴，纳为妃，生二子。十二年后为汉相曹操得知，乃遣使周近持金璧至匈奴，赎蔡琰回\n国。蔡琰与二子诀别，又哭拜昭君之墓，随周近回汉。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "侍琴引蔡琰同上。"
        },
        {
          "character": "蔡琰",
          "type": "引子",
          "text": "才华空把青春误，薄命难赓白首吟。"
        },
        {
          "character": "蔡琰",
          "type": "念",
          "text": "镜鸾孤掩已成尘，念乱忧家更痛心。自古文章难赎命，可怜身做未亡人。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "奴家蔡琰字文姬，陈留圉人也。我父在日，官拜左中郎将，封高阳乡侯。奴家 幼侍卫仲道，只因夫亡无子，只得归宁在家。幸有我父留下满架图书，堪以日 常消遣。今日闲暇无事，我不免将焦尾琴抚弄一回，也好解除愁闷。 侍琴，"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "取焦尾琴过来。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侍琴取琴。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "小姐，瑶琴在此。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "放下。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "待我抚弄一回便了。"
        },
        {
          "character": "蔡琰",
          "type": "南梆子",
          "text": "日长时怎解我心中烦闷？ 见瑶琴不由我睹物思人。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "想我父以抚弄传名，今已成《广陵绝调》了。"
        },
        {
          "character": "蔡琰",
          "type": "南梆子",
          "text": "好比那寡女丝弦清调冷， 又好比别鹤吟动魄凄心。"
        },
        {
          "character": "蔡琰",
          "type": "西皮摇板",
          "text": "在家中从未见捕蝉奇景， 却缘何带有那杀伐之声？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "苍头上。"
        },
        {
          "character": "苍头",
          "type": "白",
          "text": "启禀小姐：大事不好了！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "何事惊慌？快快讲来！"
        },
        {
          "character": "苍头",
          "type": "白",
          "text": "今有匈奴国造反，逢州抢州，遇县夺县，看看杀到我们这里来了哇！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "这便如何是好哇？"
        },
        {
          "character": "苍头",
          "type": "白",
          "text": "小姐就该寻个安静所在，躲避躲避。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "事已至此，也只好暂且逃生。苍头，"
        },
        {
          "character": "苍头",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你在我家多年，家中之事，只好奉托与你。别是物件都不要紧，唯有老爷留下 满架图书，你须要小心保护。 侍琴，"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "将焦尾琴带好，同我逃生去吧。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": "蔡琰",
          "type": "西皮摇板",
          "text": "没奈何我只得仓皇逃命， 留下了老苍头看守门庭。"
        },
        {
          "character": "苍头",
          "type": "白",
          "text": "哦，是是是。"
        },
        {
          "character": "蔡琰",
          "type": "西皮摇板",
          "text": "家中事还望你多多地照应，"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "小姐，咱们可快点儿走吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "李榷、四兵丁同上。"
        },
        {
          "character": "李榷",
          "type": "白",
          "text": "俺，大司马李榷。适才探马报道，言道左贤王统兵前来，岂肯容他张狂？ 众将官！"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "李榷",
          "type": "白",
          "text": "阵前去者！"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": "蔡琰",
          "type": "内西皮导板",
          "text": "登山涉水争逃命，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡琰、侍琴同上。"
        },
        {
          "character": "蔡琰",
          "type": "西皮快板",
          "text": "女哭男号不忍闻。 胡兵满野追呼近， 哪晓今朝是死生？ 举目看，旌旗影， 侧耳听，刀剑声。 我呼天，天不应， 我待入地地无门。 没奈何我只得奔波前进，"
        },
        {
          "character": "蔡琰",
          "type": "西皮散板",
          "text": "乱哄哄后边来万马千军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二番将、四番兵同上。"
        },
        {
          "character": "二番将",
          "type": "同白",
          "text": "哎！你们是做什么的？"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "你管我们哪！我们是逃难的！"
        },
        {
          "character": "二番将",
          "type": "同白",
          "text": "哪里是逃难的，分明是奸细！巴图鲁！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "二番将",
          "type": "同白",
          "text": "拿下了！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二番将、四番兵擒蔡琰、侍琴同下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "左贤王、四番兵同上。"
        },
        {
          "character": "左贤王",
          "type": "西皮摇板",
          "text": "此次行军多不利，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军上。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "拿住奸细！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "怎么？奸细？押了上来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。 将奸细押了上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵押蔡琰、侍琴同上。"
        },
        {
          "character": "蔡琰",
          "type": "西皮摇板",
          "text": "听传唤想必是凶多吉少， 一霎时怕就要玉殒香消。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "看这二人，好像好人家女子。 左右！"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "与她二人松绑。"
        },
        {
          "character": "四番兵",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四番兵同与蔡琰、侍琴松绑。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "你们家住哪里？姓字名谁？不要害怕，慢慢地讲来。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "容禀："
        },
        {
          "character": "蔡琰",
          "type": "西皮摇板",
          "text": "我本是汉通儒蔡中郎女， 妾名字叫文姬通晓诗书。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "哦！你乃蔡中郎之女，文姬姑娘么？失敬得很。 来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "与蔡小姐看座。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "谢座！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡琰坐。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "你乃聪明女子，若是服从本帅，同享荣华富贵。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "我乃名父之女，岂肯充人下陈？国破家亡，无心求活。若蒙见杀，妾之惠也。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "哎！小姐！别这么样说话呀！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "你如此激烈，本帅决不难为于你。 来，将蔡小姐带到馆驿，好生款待。若有怠慢，定责不贷！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "啊，蔡小姐，安歇去吧。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "小姐，咱们走吧，小姐，走吧，走吧，咱们……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡琰、侍琴同下。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "将王妃官服备好，鼓乐送到馆驿。要好言相劝，不要怠慢，违令者斩！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "遵命！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "左贤王",
          "type": "念",
          "text": "难得相逢遇才女，忙将天书叩单于。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 5,
      "name": "第五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同上，中军引曹操同上。"
        },
        {
          "character": "曹操",
          "type": "引子",
          "text": "队伍神威，气轩昂，统三军，剿灭他邦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众曹将同上。"
        },
        {
          "character": "曹操",
          "type": "念",
          "text": "堂堂将才恃英武，威威虎将镇帝都。纷纷剑戟如霜雪，个个儿郎胆气足。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫，曹操。自讨灭群雄，迁都许昌，自为首相，这且不言。今日故旧凋零复 痛，桥公之墓。最可叹者，蔡中郎伯喈与我十分交好，又无子嗣。闻得他女文 姬，流落南匈奴，为左贤王匹配。此女才学，颇有父风。老夫准备厚礼，赎她 回国。使蔡中郎有后，以继香烟。想周近熟悉胡情，不免命他前往。 来！"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "周近进帐。"
        },
        {
          "character": "中军",
          "type": "白",
          "text": "是。 周大夫进帐！"
        },
        {
          "character": "周近",
          "type": "内白",
          "text": "来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周近上。"
        },
        {
          "character": "周近",
          "type": "念",
          "text": "一生素识边夷信，怕是曹公命远行。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "参见丞相。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "一旁坐下。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "谢座。传唤小官，有何吩咐？"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "老夫今日想起一事，想蔡中郎与老夫交好，又无嗣子。闻得其女文姬，流落南 匈奴，为左贤王妃。命你去往胡营，将她赎回国来。老夫准备黄金千两，彩缎 百段，送与那单于。我想此事，定能办到，只是有劳大夫远行了。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "区区远行，何劳之有？待小官收拾起行便了。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "有劳大夫了！"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "想此事表人情一番举动， 准备着行聘礼送到胡中。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "周近",
          "type": "西皮摇板",
          "text": "别丞相此远行亦非劳顿， 表一表朋友情五伦之中。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周近下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "记当日拜桥公过世腹痛，"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "掩门。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下。"
        },
        {
          "character": "曹操",
          "type": "西皮摇板",
          "text": "喜此番赎文姬定庆成功。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹操下。"
        }
      ]
    },
    {
      "scene_id": 6,
      "name": "第六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "侍琴上。"
        },
        {
          "character": "侍琴",
          "type": "西皮摇板",
          "text": "胡中岁月无皇历， 但见草枯又一年。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "我，侍琴。只因我家小姐听我相劝，嫁了左贤王，左贤王倒也十分喜爱。怎奈 我家小姐终日愁眉泪眼，闷闷不乐，想念家乡。唉！这也难怪，就是连我，将 来也不知道如何打算哪？计算起来也有十年了，且喜我家小姐生下二子，我家 小姐的意思，叫我教给二位公子汉朝的文字，将来也好回国。咳！这也是我家 小姐一片痴心妄想。人家的孩子哪能跟你回国呢？咳，看今日天气晴和，不免 带他们两人出去游逛便了。"
        },
        {
          "character": "侍琴",
          "type": "西皮摇板",
          "text": "在胡中衣和食两都不便， 悔不该与小姐误进忠言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侍琴下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周近、四兵丁同上。"
        },
        {
          "character": "周近",
          "type": "西皮摇板",
          "text": "奉朝命不辞劳远行万里， 都只为怜才女赎那文姬。 满目中蔽尘沙已到胡地， 要与那匈奴国说明是非。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "周近。奉曹丞相之命，去到南匈奴，赎回蔡文姬。看看离胡地不远。 左右！"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "周近",
          "type": "西皮摇板",
          "text": "数月间在鞍马程途难定， 又只见半空中雨雪霏迷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周近、四兵丁同下。"
        }
      ]
    },
    {
      "scene_id": 8,
      "name": "第八场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四宫娥引蔡琰、侍琴同上。"
        },
        {
          "character": "蔡琰",
          "type": "西皮原板",
          "text": "荒原寒日嘶胡马， 万里云山归路遐。 蒙头霜霰冬和夏， 满目牛羊风卷沙。 伤心竟把胡人嫁， 忍耻偷生计已差。 月明孤影毡庐下， 何处云飞是妾家？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左贤王上。"
        },
        {
          "character": "左贤王",
          "type": "西皮散板",
          "text": "看贤妻这恩情半真半假， 却缘何每日里泪落如麻？ 我只得进宫院撩她情话，"
        },
        {
          "character": "蔡琰",
          "type": "西皮散板",
          "text": "原来是上早朝走马还家。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "啊，我看妃子面带泪痕，为了何事？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "我并未落泪呀？"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "明明泪痕未干，怎说无有？何必隐瞒于我？"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "对啦，小姐。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "哦！莫非是我胡人粗鲁？还有什么不满意之事么？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "王爷待我恩情甚好，还有什么不满意之处？王爷不要多疑。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "既然如此，我从不见你一开笑口。你我既为夫妻，有话就该言讲，不必隐瞒于 我，也好替妃子你分忧解愁。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "小姐，您有什么话儿，就跟王爷说吧。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "王爷再三询问，妾也不敢隐瞒。自古道：“狐死尚要首丘”，何况我们人类？ 是我每日思念家乡，故而伤心落泪。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "这倒容易得很。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "噢！真个容易？不知几时可以回国？"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "待我养兵数载，夺取汉朝天下，带你回国。那时还要封你做王后，岂不容易得 很？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "王爷，你要取那汉室天下，便是我国仇人。恬颜事仇，妾所不愿。唯有一死而 己！"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "不必如此，你我饮酒取乐。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "陪侍王爷。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "来，酒宴摆上。"
        },
        {
          "character": "四宫娥",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。四宫娥同摆宴。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "妃子请。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "啊！你为何又伤心落泪呀？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "我并未落泪。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "待我与妃子把盏。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "妾实不会饮酒，王爷多吃几杯吧。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "哦，妃子既不愿饮酒，你我去至郊外，行围射猎，消遣一回，你看如何？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "胡人欢喜骑射，妾是不惯的。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "这又不好，那又不好，这倒难了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院上。"
        },
        {
          "character": "家院",
          "type": "白",
          "text": "宫中宣召，速速进宫。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "知道了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "家院下。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "啊，妃子，宽饮几杯，我去去就来。 带马。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "送王爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左贤王下。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "看他这样殷勤，他哪知我的苦心喏！"
        },
        {
          "character": "蔡琰",
          "type": "西皮散板",
          "text": "终日里对胡人笑啼都假， 献殷勤又何必埋怨于他？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡琰下，众人同下。"
        }
      ]
    },
    {
      "scene_id": 9,
      "name": "第九场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "单于、大臣、四侍卫同上。"
        },
        {
          "character": "单于",
          "type": "西皮摇板",
          "text": "满朝争识单于贵，"
        },
        {
          "character": "大臣",
          "type": "白",
          "text": "周大夫到。"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": "大臣",
          "type": "白",
          "text": "有请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖牌子〗。周近、四兵丁同上。"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "啊，大夫请！请坐！不知大夫驾到，孤有失远迎，面前恕罪！"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "周某来得鲁莽，单于海涵！"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "岂敢！大夫到此，有和见教？"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "只因我国有一女子，名叫蔡文姬，乃是通儒蔡中郎之女。我家丞相特命下官前 来赎她回国，单于做主。"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "虽有此女，配与左贤王为妻，在此居住多年。何必叫她回去？"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "只因她父无子，就生此女。我家丞相特备黄金千两，彩缎百段，望求单于笑纳。 来！"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "礼物抬上来。"
        },
        {
          "character": "四兵丁",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵丁同抬彩礼。"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "呜呼呼呀！这些个礼物，孤家安能不收？嗯，我自有道理。 啊，大夫，那左贤王，乃是我国大臣。若将他夫妻拆散，如之奈何？"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "啊，单于，想今日中国，俱都是曹丞相势力之下。破乌桓，斩蹋顿，殆忘异心。 我想为一女子，开罪天朝，未免有些不便吧！"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "大夫所言极是。这礼物焉敢不收？ 来！"
        },
        {
          "character": "四侍卫",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "礼物搭了下去。"
        },
        {
          "character": "大臣",
          "type": "白",
          "text": "搭了下去。"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "大夫暂居馆驿歇息，孤家自有主张。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "周某静听大王好音。暂时别。"
        },
        {
          "character": "单于",
          "type": "白",
          "text": "好，奉送。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周近、四兵丁同下。单于、四侍卫、大臣同下。"
        }
      ]
    },
    {
      "scene_id": 10,
      "name": "第十场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "左贤王上，侍琴上。"
        },
        {
          "character": "左贤王",
          "type": "白",
          "text": "你将这圣旨交与你家小姐，叫她即刻回国便了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左贤王递旨。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "哎，是啦。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "左贤王下。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "啊！这下可好啦！我们小姐要回国了！我给我们小姐送个信儿去。 有请小姐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡琰、二王子同上。"
        },
        {
          "character": "蔡琰",
          "type": "念",
          "text": "极目胡天空咏叹，不知何处是长安。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "小姐，您大喜啦！您瞧瞧这上面都写的是什么？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "待我看来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侍琴呈旨，蔡琰看。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "好了，待我谢天谢地。 侍琴，"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你可晓得几时可以启程？"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "那我也不知道哇！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你去传话周大夫，要急速启程才好。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": "二王子",
          "type": "同白",
          "text": "妈呀！您上哪儿呀？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "无端生此两儿，我一旦回国，他二人岂不成无母之人么？ 侍琴，"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "哎。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你替我想来，如今我倒是去住两难了。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "这叫我也是没有主意呀！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "我一心想念家乡，适逢机会，难道为这两个孽障，就永远葬身此地不成？机缘 错过，后悔难追！还是硬着心肠，回国便了。"
        },
        {
          "character": "二王子",
          "type": "同白",
          "text": "妈呀！您回去带着我吧！您带着我！您带着我！"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "哎，我说小姐，这父母疼子可都是一样的。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "咳！是啊！父母爱子，人有同情。想我父在日，何等疼爱于我。如今三尺孤坟， 连一杯麦饭都无人祭扫。我若是牵连私情，把祖宗丘墓弃之不顾，我怎对得 住先人？又怎对得起那曹丞相啊？也罢！你与我收拾行装，就此启程便了。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "是啦。"
        },
        {
          "character": "二王子",
          "type": "同白",
          "text": "妈！您带着我！带着我！您带着我！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "好好好，你二人不要啼哭，你随着侍琴去换衣服，我们带你回去就是。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "是啦，咱们去换衣服去。"
        },
        {
          "character": "二王子",
          "type": "同白",
          "text": "您带我们去啦？"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "走吧，走吧，走吧，咱们换衣裳去。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "侍琴。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "哎。你们俩先去吧。"
        },
        {
          "character": "二王子",
          "type": "同白",
          "text": "你来，你来，你来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二王子同下。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "小姐，您叫我什么事啊？"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你看他二人如此可爱，叫我怎生舍得？"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "不用说您舍不得，就是连我也舍不得他们哪！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "怎么！你也是舍不得他们？"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "对啦。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "哎呀，这就好了。我本想带你回国，看此情形，只好烦你抚养他们，待成人之 后，我多备金银，赎你回国。你不要推辞，我这里拜托了。"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "我说小姐，事到如今，我也不敢推辞。可是一样，小姐此番回得国去，可不要 忘了我呀！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "侍琴，我焉能忘你的大恩？你去哄住他二人，不要与我见面。免得临别之时， 悲痛难捱也！"
        },
        {
          "character": "侍琴",
          "type": "白",
          "text": "哎！是啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "侍琴下。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "生离不如死别了！"
        },
        {
          "character": "蔡琰",
          "type": "西皮摇板",
          "text": "日日思归归又怨， 不归却又一心悬。 还乡惜别两难遣， 宁弃胡儿归故园。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡琰下。"
        }
      ]
    },
    {
      "scene_id": 11,
      "name": "第十一场",
      "utterances": [
        {
          "character": "李成",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成上。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "我本，"
        },
        {
          "character": "李成",
          "type": "数板",
          "text": "我本是中国人，是也有买卖做。记得那一年，是胡人来打我。胡人来得凶，是 杀人又放火。我是惯爱说大话，是趴到死人堆里头躲一躲。偏偏肚子不争气， 是叽哩咕噜直觉饿。刚刚把头钻出来，胡兵看见把我掳。掳到他国不当人，是 愣要当个牛马做。这样看起来，是国别亡，是家别破。给人家外国当奴隶，是 真叫实难过，实难过。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "在下李成，我也是中国人。只因那年胡人造反，把我掳到他国。还算好，不肯 伤害我的性命。赏我一名老军，让我看守昭君墓，这且不言。听说被俘虏来的 蔡文姬蔡小姐，奉旨要回国了。可惜一样啊，不打我们这儿经过。我打算往上 赶上几站，到了那儿我要求要求，把我带回国去。我们这儿还有一个伙伴哪， 把他叫出来，我们商量商量。 我说伙计，伙计！"
        },
        {
          "character": "张四",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "张四上。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "哎，什么事啊？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "什么事情啊？"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "你知道蔡小姐呀，奉旨要回国啦。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "噢！"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "可惜一样啊。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "不打咱们这儿经过。我打算哪，赶上几站哪，要求把咱们带回国去，你瞧怎么 样啊？"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "是这么个事啊？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "你这儿等着，我去。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "嘿嘿嘿！什么你去呀？你瞧你长相到那儿一说砸了，不带咱们了，那怎么办哪？"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "那怎么那个？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "怎么办？"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "我去。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "你去？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "你这儿等着我。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "噢。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "向例我是会运动啊。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "是啊。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "运动好了，把咱们带回国去，咱们还吹哪。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "吹什么呀？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "咱们就说呀：新近咱们游历外洋回来的。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "哎，这倒不错！"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "听我的信，我去。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "你可别把我忘了！"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "没错！听信儿吧！"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "听信儿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成下，张四下。"
        }
      ]
    },
    {
      "scene_id": 12,
      "name": "第十二场",
      "utterances": [
        {
          "character": "蔡琰",
          "type": "内西皮导板",
          "text": "整归鞭行不尽天山万里，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵丁、周近引蔡琰同上。"
        },
        {
          "character": "蔡琰",
          "type": "西皮慢板",
          "text": "见黄沙和边草一样低迷。 又听得马啸啸悲风动地， 虽然是行路难却幸生归。 悔当日生胡儿不能捐弃， 到如今行一步一步远足重难移。 从此后隔死生，"
        },
        {
          "character": "蔡琰",
          "type": "西皮散板",
          "text": "永无消息，"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "趱行者！"
        },
        {
          "character": "蔡琰",
          "type": "西皮散板",
          "text": "反叫我对穹庐无限依依！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 13,
      "name": "第十三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "周近上。"
        },
        {
          "character": "周近",
          "type": "西皮摇板",
          "text": "望长天观日落光辉暗淡， 倒不如在此处少驻整鞍。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "一路行来，天色将晚，不免在馆驿住宿一宵，明日再行。远远望见小姐来也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵丁引蔡琰同上。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "禀小姐：天色已晚，就在馆驿安宿一宵，特来请示。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "但凭大夫。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "驿馆去者。"
        },
        {
          "character": "四兵丁",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同走圆场。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "大夫鞍马劳乏，请歇息去吧。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周近下。"
        },
        {
          "character": "蔡琰",
          "type": "念",
          "text": "爱胡儿又恨胡乡，旧怨初平新怨长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "号角声。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "看如此荒郊，月光惨淡，朔风四起，孤灯不明，叫我这伤心人如何可以安睡？ 驿亭外胡笳远鸣，声声哀怨，似代我诉说离愁。我蔡文姬柔肠寸断矣！想我在 胡中多年，感胡笳之声，用琴写之。曾制有《胡笳》第十三拍，今夜千愁万恨 并在心头，我不免再制成《胡笳》第十四拍，也好稍抒幽愤。人生到此，怎不 凄凉人也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "号角声。"
        },
        {
          "character": "蔡琰",
          "type": "二黄慢板",
          "text": "身归国兮儿莫知随， 心悬悬兮长如饥。 四时万物兮有盛衰， 唯有愁苦兮不暂移。 山高地阔兮见汝无期， 更深夜阑兮梦汝来斯。 梦中执手兮一喜一悲， 觉后痛吾心兮无休歇时。 十有四拍兮涕泪交垂， 河水东流兮心是思。"
        },
        {
          "character": "侍女",
          "type": "白",
          "text": "天已不早，请小姐登程。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "就此启程。正是："
        },
        {
          "character": "蔡琰",
          "type": "念",
          "text": "星河寥落胡天晓，关塞萧条白日长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 14,
      "name": "第十四场",
      "utterances": [
        {
          "character": "李成",
          "type": "内白",
          "text": "啊哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成上。"
        },
        {
          "character": "李成",
          "type": "念",
          "text": "连日赶路多辛苦，大风如刀削屁股。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "今天蔡小姐奉旨回国了，我不免在这大路旁边等候小姐。看那旁黄尘起处，想 必是小姐的人役来也！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四兵丁、周近引蔡琰同上。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "迎接小姐！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你是什么人？"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "人役列开！"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "是，哦，参见小姐。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你是做什么的？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "小人是看守昭君墓的老军，我也是中国人。听说您要回国了，求您把我带回去 吧。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "啊，周大夫，我想昭君可怜得很，我想前去祭奠一番，你意如何？"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "但凭小姐。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "墓陵离此多远？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "还有一箭多地。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你叫什么名字？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "小人名叫李成。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "李成。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "带路前往。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "是！诸位随我来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 15,
      "name": "第十五场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张四上。李成上，四兵丁、周近引蔡琰同上。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "来此已是。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "可有香火？"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "哦，外国不兴那个。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "待我潦草祭奠一番。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "明妃啊！我与你境遇相同，这伤心一样。我今日到此，祭奠与你，不知你地下 阴灵可能知晓否？"
        },
        {
          "character": "蔡琰",
          "type": "二黄导板",
          "text": "见坟台哭一声明妃细听，"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "席地而坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同坐。"
        },
        {
          "character": "蔡琰",
          "type": "回龙",
          "text": "我文姬来奠酒诉说衷情："
        },
        {
          "character": "蔡琰",
          "type": "反二黄慢板",
          "text": "你本是误丹青毕生饮恨， 我也曾被娥眉累苦此身。"
        },
        {
          "character": "蔡琰",
          "type": "反二黄快三眼",
          "text": "你输我及生前得归乡井， 我输你保骨肉幸免飘零。 问苍天何使我两人共命？ 听琵琶马上曲悲切笳声。 看狼山闻陇水梦魂，"
        },
        {
          "character": "蔡琰",
          "type": "反二黄散板",
          "text": "犹警， 可怜你留青冢独向黄昏。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "参见小姐，我名叫张四，我也是中国人。听说您回国，您把我带回去得啦。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "哎，小姐，他还年轻哪。让他这儿看着，您把我带回去得啦。"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "别介！别介！别介！您把我带回去得啦。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "你二人俱是中原人，可晓得墓中也是中国人哪？烦你们多看守几年，待有机会， 再回国去吧。"
        },
        {
          "character": "李成、张四",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "看赏。"
        },
        {
          "character": "周近",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周近递银。"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "谢小姐。咳！你呀！你净跟着搅吗你！"
        },
        {
          "character": "张四",
          "type": "白",
          "text": "你净跟我吵吗！"
        },
        {
          "character": "李成",
          "type": "白",
          "text": "谁也不带啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李成、张四同下。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "我们启程吧。"
        },
        {
          "character": "蔡琰",
          "type": "反二黄散板",
          "text": "这叫做惜惺惺相怜同命， 她那在九泉下应解伤心。 我只得含悲泪兼程前进， 还望她向天南月夜归魂。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 16,
      "name": "第十六场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "〖吹打〗，四龙套、曹操同上。四兵丁、周近引蔡琰同上。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "大夫歇息去吧。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周近下，四兵丁同下。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "叩见伯父。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "免礼，快快请起。一路劳乏，歇息去吧。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "容侄女回家探视，再来叩府谢恩。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "好，回府歇息去吧。"
        },
        {
          "character": "蔡琰",
          "type": "白",
          "text": "正是："
        },
        {
          "character": "蔡琰",
          "type": "念",
          "text": "我生不辰逢离乱，幸叫生入玉门关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "蔡琰下。"
        },
        {
          "character": "曹操",
          "type": "白",
          "text": "回府！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}