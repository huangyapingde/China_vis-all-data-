          "character": "樊旗牌",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊旗牌向薛旗牌。"
        },
        {
          "character": "樊旗牌",
          "type": "白",
