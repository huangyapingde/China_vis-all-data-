        {
          "character": "柳迎春",
          "type": "白",
          "text": "哎呀呀！使不得！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "婆婆来啦？"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "你们为了何事吵闹起来？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "您听我说。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我先说。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "听我说！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我先说。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "让我说吧！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我先说。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "你们为了何事吵闹起来呀？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀，我先说！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哦——"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "让你说！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "嗯。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我说她，她也说我。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我骂她哪，她也骂我。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "多新鲜哪。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我打她——"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "啊，怎样？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "她还打我来着哪！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哎呀呀，哪有此事！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳迎春向樊梨花。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "媳妇，为了何事，姑嫂争斗起来？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "婆婆哇！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哟，哭啦！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "不要悲伤，慢慢讲来。"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "她骂媳妇是下贱，"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "樊梨花",
          "type": "西皮摇板",
          "text": "怎配为人在世间！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哎，媳妇哇。"
        },
        {
          "character": "柳迎春",
          "type": "西皮摇板",
          "text": "还要看在为婆面，"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哎哟，妈呀！妈呀，您……您干嘛给她跪下啊！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哎你又来了！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "您干嘛给她跪下啊！这成什么礼啊！"
        },
        {
          "character": "柳迎春",
          "type": "西皮摇板",
          "text": "快快发兵救驾还。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "媳妇发兵的才是。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "媳妇发兵就是。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "中军听令！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "在。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "吩咐大小三军：明日午时三刻，校场听点，伺候发兵。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "慢着！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "等等，听信儿。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "啊。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我也能提兵，我也能调将。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "为什么叫她去？我去就好了嘛。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哦你都成啊？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我都成！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "好极了，让你！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嗯。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "来呀！"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "有！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "原令追回。"
        },
        {
          "character": "中军甲",
          "type": "白",
          "text": "哦，原令追回！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "看你的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "中军甲下。"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "唗！大胆丫头，在此打搅！来，你们预备刀子、绳子、剪子，我不活着了！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "我寻死去了！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀，您别死！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "我寻死去了！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀，您别死！"
        },
        {
          "character": "柳迎春",
          "type": "白",
          "text": "哎！我死定了！你气死我也！哼哼哼哼哼！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "妈呀！妈！妈呀，您别死！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "柳迎春下。薛金莲向樊梨花。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哎！哎！你倒是拉着点儿啊！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "待着吧！死呀，叫怹死去，横不是我气的。我看你们谁敢拉着。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "僵啦。说的是哪，我怎么惹这么大的娄子。任凭怎么说，她是个领兵的大元帅， 我是个督粮官儿，怎么斗我也斗不过她呀。糟了，我妈要寻死，这儿也不愿 意，那怎么办哪……诶，有了，我过去，我我、我说几句好话。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲向樊梨花。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嫂子，嫂子，嫂子您干嘛跟我们生气呀嫂子。得了嘿嫂子，嫂子我跟您闹着玩 儿呢，你真跟我僵了是怎么？得了，嫂子，哎，嫂子我这儿给您哪跪……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲欲跪。女官上。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "侯爷请茶。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "咳，不渴。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "少喝点儿。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "一点儿也不喝！"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "喝一点儿吧。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "什么你跟我搅！你再要是搅，我可要杀你我告诉你说！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "什么？你要杀她？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "这个女官是我的。她要杀你啊，把脖子伸长长的，过去叫她杀！瞧她敢杀不敢 杀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女官向薛金莲伸头。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "给你杀，给你杀。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "叫她杀！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "你你、叫我杀，我没有那么大的功夫杀你。"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "我瞧你也不敢。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "诶，嫂子，嫂子我告诉您说呀，我呀本当给您哪跪下，我这磕膝盖儿上我长了 个小疙瘩，不好跪，要……"
        },
        {
          "character": "女官",
          "type": "白",
          "text": "侯爷不要紧，我给你个垫子。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "诶，你滚下去吧你！捣乱！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "女官下。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嫂子！嫂子！哎，嫂嫂哇！"
        },
        {
          "character": "薛金莲",
          "type": "西皮流水板",
          "text": "双膝跌跪泪涟涟， 尊一声嫂嫂听我言： 小妹顽童见识浅， 望求嫂嫂你把恩宽。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嫂子，嫂子。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，这不是薛侯爷吗？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嘿，不是，是金莲儿。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "这么会儿的工夫，怎么矮了半截儿啊？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "什么矮啦，我是给您跪着哪。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "给我跪着哪？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嗯嗯。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，为什么给我跪着呀？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我不是得罪嫂子你了嘛。呃，刚才，你、你不是要发兵……"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "嫂子您跟我一般见识干什么呢。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哟，这是哪儿的话哪。提兵调将你也成，领兵救驾你也能。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "那、那我是吹……"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你都能去，用我们可干什么哪？"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "得了嫂子，我跟您吹着玩儿哪。我哪儿那么大的本事啊。得了好嫂子，您饶……"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "待着吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花推，薛金莲跌坐。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "硬打软揉乎！这就叫扯臊！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "薛金莲",
          "type": "西皮摇板",
          "text": "嫂嫂果然把脸变， 扬着脸儿她不开言。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "薛金莲",
          "type": "西皮摇板",
          "text": "三尺龙泉出了鞘， 不如一死丧黄泉。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲欲自刎。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "我死、我死、我、我死！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "哎哟，妹妹妹妹，别死别死，我发兵啦，发兵啦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "您发兵啦？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "发兵啦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "您不生气啦？"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "我不生气啦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "那我就不死啦。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "你呀，你就没打算死嘛。净顾咱俩闹啦……"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "欸。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "妈那儿还有气哪。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "哟，对啦，妈还生气哪。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "可不是嘛。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "咱们劝劝妈去得了。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "快去呀，快走快走。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊梨花、薛金莲同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}