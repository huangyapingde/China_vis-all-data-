        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "如此你我挽手而行。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛金莲、樊梨花同下，四文堂、女官、樊旗牌、四龙套、薛旗牌同下。"
        }
