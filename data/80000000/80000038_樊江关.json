    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四文堂、女官、樊旗牌、四龙套、薛旗牌、樊梨花、薛金莲同上。"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "妹妹押粮前来，多受风霜之苦。"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "为国勤劳，嫂子您干嘛跟我这么客气呀。"
