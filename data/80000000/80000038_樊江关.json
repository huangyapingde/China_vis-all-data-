        },
        {
          "character": "樊旗牌",
          "type": "白",
          "text": "每人每五两银子。"
        },
        {
          "character": "薛旗牌",
          "type": "白",
          "text": "每人每五两银子？"
        },
        {
          "character": "樊旗牌",
          "type": "白",
          "text": "对啦。"
        },
        {
          "character": "薛旗牌",
