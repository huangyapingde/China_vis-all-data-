        },
        {
          "character": "樊旗牌",
          "type": "白",
          "text": "哈哈！"
        },
        {
          "character": "薛旗牌",
          "type": "白",
          "text": "嘿嘿！"
        },
        {
          "character": "樊旗牌",
          "type": "白",
          "text": "你在一个之内呀。"
        },
        {
          "character": "薛旗牌",
          "type": "白",
          "text": "对啦。"
        },
        {
          "character": "樊旗牌",
          "type": "白",
          "text": "我言语声儿啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "樊旗牌向樊梨花。"
        },
        {
          "character": "樊旗牌",
