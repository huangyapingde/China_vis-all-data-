        {
          "character": "樊梨花",
          "type": "白",
          "text": "别这么胡说啊！"
        },
        {
          "character": "薛金莲",
          "type": "白",
          "text": "樊梨花樊梨花我告诉你说！当初都由你，今儿个有你姑奶奶在此，只怕由得我， 由不得你吧！"
        },
        {
          "character": "樊梨花",
          "type": "白",
          "text": "呀！"
