{
  "script_id": "80000022",
  "title": "辕门斩子",
  "alias": [
    "白虎堂"
  ],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "焦赞",
      "hangdang": "净"
    },
    {
      "name": "孟良",
      "hangdang": "净"
    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "赵德芳",
      "hangdang": "老生"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "穆桂英",
      "hangdang": "武旦"
    },
    {
      "name": "穆瓜",
      "hangdang": "丑"
    }
  ],
  "plot": "宋杨延昭征剿山东穆柯寨，先被穆桂英所败，夜命儿子杨宗保，出营巡哨，为穆桂英擒逼成亲。既而杨宗保\n回营，杨延昭怒其临阵招亲，违犯军法，定欲处斩。焦赞、孟良苦求不下，驰报佘太君出救，杨延昭不听。\n适八贤王赵德芳至，又代杨宗保说情，杨延昭亦不允，甚至反颜怒争，斥赵德芳冲闹白虎法堂，即命部下，\n将赵德芳乘马刖去了足，以示其罪，赵德芳无知之何。正危险间，忽穆桂英至，呈献降龙木，见夫婿绑示辕\n门，即带怒入，硬请赦免。杨延昭始亦不允，既而畏其强，不得已乃允之。",
  "notes": "此戏去杨延昭之须生，最为吃重，颇费力量，须唱做兼工者，演时方有精彩。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "李欣饰孟良，宋小川饰杨宗保，刘习中饰穆瓜；李权操琴，吴有禹司鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套、孟良、焦赞同上，杨延昭上。"
        },
        {
          "character": "杨延昭",
          "type": "念",
          "text": "军前把阵败，怒气满胸怀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭坐帐。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，这里来。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "元帅今日升帐，与往日大不相同。你我要小心伺候哇！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哎，你我大家都要小心。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "大家小心。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "在。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "宗保回营，叫他报门而进！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "喳！ 二哥，"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哎。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你我出营了望了望。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "好，了望了望。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "杨宗保",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎，小本官来了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨宗保上。"
        },
        {
          "character": "杨宗保",
          "type": "念",
          "text": "离了穆柯寨，来此是宋营。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "参见二位叔父。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "罢了！"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "我父帅可曾升帐？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你父帅升帐多时，今日与往日大不相同，你要小心了。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "小心了。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "待我转去。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎！且慢！大丈夫唯有向前，哪有退后之理？ 二哥！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "给他报门去！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "好！ 小本官告进！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "小本官当面。"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "参见父帅！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "下跪儿是宗保？"
        },
        {
          "character": "杨宗保",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "焦、孟二将！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "掌起面来！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "奴才！"
        },
        {
          "character": "杨延昭",
          "type": "西皮散板",
          "text": "怒恼杨延昭， 蠢子听根苗： 命尔去巡哨， 私自把亲招。 枪挑穆天王， 桂英下山巢。 将父擒下马， 这笑哇！笑坏帐下众英豪。 焦孟一声叫，"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "在！"
        },
        {
          "character": "杨延昭",
          "type": "西皮散板",
          "text": "将奴才绑法标定斩不饶！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "孟良、焦赞同绑杨宗保，杨宗保坐。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥这里来。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "小本官犯罪，乃是你我弟兄的引诱，就该进帐与他讲个人情。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "好，讲个人情。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "一同进帐。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "一同进帐。"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "请！ 焦、孟二将与元帅叩头！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "你二人进帐何事？"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "小本官犯罪，理当斩首。念我弟兄二人，鞍前马后有些小功劳，只可以赦，不 可以斩哪！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "莫非与宗保讲情？"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "哎！元帅开恩！元帅开恩！"
        },
        {
          "character": "杨延昭",
          "type": "笑",
          "text": "哈哈……"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "二哥，有门！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "有门！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "唗！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎呀！我的妈呀！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "宗保犯罪，"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "喳！"
        },
        {
          "character": "杨延昭",
          "type": "白",
          "text": "乃是你二人引诱，先斩宗保，再取你二人首级！下堂去吧！"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "喳喳……"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "嘿！我说这个人情讲不下来，你说有你！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你说有你！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "你说有你！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "你说有你！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "呸！招打！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎，二哥，你别打我。看好了小本官，我搬老太太去！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哎！去你的！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞下。焦赞搀佘太君同上。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎！老太太快点走啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君要跌到，焦赞扶。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "哎哟！您慢着点呀！"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "听说是斩宗保把我吓坏， 险些儿一步跌倒尘埃。 又只见小孙儿捆绑在帐外， 因甚事绑辕门要把刀开？"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
          "text": "都只为招亲在穆柯山寨， 因此上绑辕门要把刀开。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "哦！"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "劝孙儿免悲声休要急坏， 待祖母进帐去把情讲来。 叫焦赞你与我前把路带。"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "喳！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "胆大的杨延昭不下位来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君坐。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "太娘到啊！"
        },
        {
          "character": "杨延昭",
          "type": "西皮导板",
          "text": "忽听得老娘亲来到帐外，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "掩门！太娘到哇！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四龙套同下，杨延昭下位。"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "嗨！元帅他知道啦！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "怎么着？他知道啦？"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "哎！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "我原要他知道！"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "杨延昭下位去迎接娘来。 见老娘施一礼躬身下拜，"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "不消！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "嘿！不消！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "问老娘驾到此所为何来？"
        },
        {
          "character": "佘太君",
          "type": "西皮慢板",
          "text": "娘进帐我的儿早已知解， 反把这假言语问娘何来？"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "老娘亲怒冲冲愁眉难解， 莫不是为宗保这不孝的奴才？"
        },
        {
          "character": "佘太君",
          "type": "西皮慢板",
          "text": "小孙儿他犯了何条律戒， 因何故绑辕门要把刀开？"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "儿命他领人马巡查边界， 谁叫他穆柯寨私配裙钗？ 因此上儿将他捆绑帐外， 问老娘儿斩他该是不该？"
        },
        {
          "character": "佘太君",
          "type": "西皮慢板",
          "text": "犯将令理应该斩首帐外，"
        },
        {
          "character": "孟良、焦赞",
          "type": "同白",
          "text": "斩不得！"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "且慢！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "佘太君",
          "type": "西皮慢板",
          "text": "还看他年幼小无知婴孩。"
        },
        {
          "character": "杨延昭",
          "type": "西皮慢板",
          "text": "娘道他年纪小孩童气概，"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "讲几个年幼人娘且听来： 秦甘罗十二岁身为太宰， 石敬瑭十三岁拜将登台； 三国中小周郎名扬四海， 十岁上学道法人称将才。 十二岁掌东吴水军元帅， 他看那曹孟德如同婴孩。 在赤壁用火攻神鬼难解， 烧曹兵八十万无处葬埋。 这也是父母生非神下界， 难道说小奴才是禽兽投胎？"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "嗯！"
        },
        {
          "character": "佘太君",
          "type": "西皮快板",
          "text": "听一言气得我牙根咬坏， 骂一声杨延昭不肖奴才： 我杨家投宋君名扬四海， 弟兄们一个个俱是将才。 到如今剩宗保一条后代， 眼睁睁还要他祭扫坟台。 倘若是小孙儿有个好歹， 那时节我的儿悔不及来！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "昨日里斩八将头挂营外， 老娘亲你不把军令放开。 今日里斩宗保娘把儿怪， 坐帐前哭啼啼珠泪满腮。 叫焦赞——"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "在呀！"
        },
        {
          "character": "杨延昭",
          "type": "西皮快板",
          "text": "将宝剑悬挂帐外，"
        },
        {
          "character": "焦赞",
          "type": "白",
          "text": "喳！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "焦赞挂宝剑。"
        },
        {
          "character": "杨延昭",
          "type": "西皮摇板",
          "text": "老娘亲再讲情儿自刎头来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延昭归坐。"
        },
        {
          "character": "佘太君",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "佘太君",
          "type": "西皮摇板",
          "text": "杨延昭性倔强令人可恼， 他把我年迈人哪放在心梢。 眼睁睁小孙儿性命难保， 孙儿啊！"
        },
        {
          "character": "孟良",
          "type": "白",
          "text": "太娘请至后面。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "佘太君下。赵德芳上。"
        },
        {
          "character": "赵德芳",
          "type": "白",
          "text": "吁！"
        },
        {
          "character": "赵德芳",
          "type": "西皮摇板",
          "text": "赵德芳一马儿来在法标。 御外男把什么军令犯了？ 为什么绑辕门项戴枷着？"
        },
        {
          "character": "杨宗保",
          "type": "西皮摇板",
