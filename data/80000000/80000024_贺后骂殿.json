{
  "script_id": "80000024",
  "title": "贺后骂殿",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "贺后",
      "hangdang": "旦"
    },
    {
      "name": "赵光义",
      "hangdang": "老生"
    },
    {
      "name": "潘洪",
      "hangdang": "净"
    },
    {
      "name": "杨继业",
      "hangdang": "老生"
    }
  ],
  "plot": "宋，赵光义继其兄赵匡胤帝位，贺后因夫赵匡胤死的不明，令长子赵德昭上殿质问。赵光义大怒，欲斩之，\n赵德昭撞死殿上。贺后携次子赵德芳上殿，历数赵光义之过，赵光义谢罪，赐贺后尚方剑，封入养老官，并\n封赵德芳为八贤王。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "text",
          "text": "业；周长华操琴，白登云司鼓。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德芳扶贺后同上。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "老王不幸把命丧， 二主篡位谋家邦。 大皇儿忙把金殿上， 要回社稷自为王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后、赵德芳同下。"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "迈步且把金殿上， 快快还我锦家邦。"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "大皇儿哭得甚惨伤， 口口声声要家邦， 本当下位把国让！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "万岁，江山只有争斗，哪有禅让之理？"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "难学尧舜和商汤。 回头便把皇儿讲， 孤不封你自为王。"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "江山本是小王掌， 何人要你封我王！"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "奴才说话太张狂， 开言就把孤王伤。 殿前潘豹与潘疆， 推出午门一命亡。"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "辩贼不过已赐死， 不如一死丧无常。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德昭碰死。贺后、赵德芳同上。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "一见皇儿把命丧， 怎不叫娘我痛断了肠。 把尸首搭至在白虎堂停放， 随娘到金殿骂昏王。"
        },
        {
          "character": "贺后",
          "type": "叫头",
          "text": "昏王！篡位王！"
        },
        {
          "character": "贺后",
          "type": "二黄导板",
          "text": "有贺后在金殿一声高骂，"
        },
        {
          "character": "贺后",
          "type": "叫头",
          "text": "昏王！篡位王！"
        },
        {
          "character": "贺后",
          "type": "回龙",
          "text": "骂一声无道君细听根芽："
        },
        {
          "character": "贺后",
          "type": "二黄慢板",
          "text": "老王爷为江山足踢拳打， 老王爷为山河奔走天涯。"
        },
        {
          "character": "贺后",
          "type": "二黄快三眼",
          "text": "遭不幸老王爷晏了御驾，⑴ 贼昏王篡了位谋乱邦家。 把一个皇太子逼死殿下， 反道说为嫂我拦阻有差。 贼好比王莽贼称孤道寡， 贼好比曹阿瞒奸雄不差； 贼好比秦赵高指鹿为马， 贼好比司马师搅乱中华。 只骂得贼昏王装聋作哑， 只骂得贼昏王扭转身躯、闭目合睛、羞羞惭惭一语不发； 只骂得贼昏王无言对答， 两旁的文武臣珠泪如麻。 搬一把金交椅娘且坐下， 你叔王不让位我再去骂他。"
        },
        {
          "character": "赵光义",
          "type": "二黄慢板",
          "text": "自盘古立帝邦天子为重， 老皇嫂骂孤王情理难容。 论国法就将你残生断送！"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "谁敢？"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义下位，曹彬、赵普、潘洪、苗宗善同下。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "皇嫂！"
        },
        {
          "character": "赵光义",
          "type": "二黄快三眼",
          "text": "还看在与兄王掌印东宫。 兄王爷晏了驾钟鼓齐动， 满朝中文武臣齐保孤穹。 孤这里施一礼把皇嫂尊重， 崇上徽号容是不容？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义付剑。"
        },
        {
          "character": "贺后",
          "type": "二黄原板",
          "text": "享荣华受富贵要它何用？ 倒不如带皇儿务农耕种，我受的什么荣封？"
        },
        {
          "character": "赵光义",
          "type": "二黄原板",
          "text": "老皇嫂讲什么务农耕种， 普天下俱都是兄王荣封。 享荣华受富贵你母子同共， 亦非是叔为君侄为臣各分西东。 孤赐你尚方剑泰山执重， 掌三宫和六院大小嫔妃若有违背任你施行，王我件件依从。"
        },
        {
          "character": "赵德芳",
          "type": "哭",
          "text": "先王呀！"
        },
        {
          "character": "赵光义",
          "type": "二黄原板",
          "text": "赵德芳我的儿休要悲痛， 近前来听叔王把儿来封： 孤赐你金镶白玉琮， 加封儿一钦王、二良王，三忠四正、五德王、六敬王，上殿不参王，下殿不辞 王，再赐你凹面金锏，上打昏君、下打谗臣，压定了满朝的文武、大小官员， 哪一个不尊，你本是八贤王，代管孤穹。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义付锏。"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "老皇嫂请回宫身体保重， 从今后换笑脸展了愁容。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "辞别二王下殿口，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "潘洪暗上。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "送国太。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "回头只见贼奸谋。 有朝犯在我的手，"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "贼子啊！"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "三尺龙泉不容留！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后、赵德芳同下。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "潘卿。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "孤今登基，心中不爽，是何缘故？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "我主新登大宝，理应修造太庙，春秋二祭，以保社稷永固。圣寿无疆！⑵"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "依卿所奏。退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义、潘洪同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "赵光义",
          "type": "stage",
          "text": "—————————— ⑴原录音有残缺，本句前半部分没有。现根据郑大同等在《程砚秋唱腔集》中的记录补全。 ⑵原录音模糊。现根据《京剧丛刊》第三十四集中程砚秋演出本补全。"
        }
      ]
    }
  ]
}