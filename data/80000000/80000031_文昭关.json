{
  "script_id": "80000031",
  "title": "文昭关",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "伍员",
      "hangdang": "老生"
    },
    {
      "name": "东皋公",
      "hangdang": "老生"
    },
    {
      "name": "皇甫讷",
      "hangdang": "老生"
    },
    {
      "name": "米南适",
      "hangdang": "净"
    }
  ],
  "plot": "伍员行至昭关。这时楚平王已命人画影图形，四处缉拿。伍员被隐士东皋公请至家中，七日七夜，一筹莫展，\n须发尽白。东皋公与好友皇甫讷设计，救伍员混出昭关。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "东皋公上。"
        },
        {
          "character": "东皋公",
          "type": "引子",
          "text": "门外青山绿水，黄花百草风吹。"
        },
        {
          "character": "东皋公",
          "type": "念",
          "text": "昔年周游列国，习就满腹才学。如今看破世事，隐居山林安乐。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "老汉东皋公，曾拜扁鹊先生门下为徒。是我周游列国，看破世事，隐居山林， 倒也逍遥自在。我有一好友，名唤皇甫讷，我二人情义相投，时常一处饮酒弹 琴。这几日是他未到庄中前来，也不知为了何事。看今日天气晴和，不免去到 山前山后，游玩一番便了。"
        },
        {
          "character": "东皋公",
          "type": "西皮原板",
          "text": "闲来无事步从容， 东窗不觉日映红。 万物静观皆自得， 四季看花与人同。"
        },
        {
          "character": "伍员",
          "type": "内白",
          "text": "马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。撞金钟。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "伍员马上怒气冲， 逃出龙潭虎穴中。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺，伍员。可恨平王无道，害我满门。幸喜逃出樊城，要到吴国借兵报仇。行 至此间，四面俱是高山峻岭，不知哪条道路，可通吴国？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "嗯哼！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "那厢有一老丈，下马问来。 啊，老丈请了。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "那旁来的敢是伍子胥？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "这个？老丈！俺不是伍子胥，老丈不要认差了！"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "我乃山中隐士，将军但讲何妨？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "俺便是伍子胥，老丈何以知晓？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "那日老汉路过昭关，见挂有画图，与将军面貌相似，故而冒叫一声，将军莫怪。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "啊，将军，今欲何往？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "我有满腹含冤，要到吴国借兵报仇！行至此间，四面俱是高山峻岭。请问老丈， 哪条道路可通吴国？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "将军你来看，四面俱是高山峻岭，若要去到吴国，必须打从昭关经过。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "可有别路？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "呃，并无别路。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "不好了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "撞金钟。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "听说吴国路不通， 好似狼牙箭穿胸！"
        },
        {
          "character": "伍员",
          "type": "哭头",
          "text": "心猿意马终何用！ 爹娘啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "撞金钟。"
        },
        {
          "character": "伍员",
          "type": "西皮摇板",
          "text": "血海冤仇落了空。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "将军不必如此，此处离寒舍不远，请到寒舍一叙。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "萍水相逢，怎好打搅？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "四海之内皆是朋友。请呐！"
        },
        {
          "character": "东皋公",
          "type": "西皮流水板",
          "text": "山在西来水在东， 山水无处不想逢。 男儿四海皆朋友， 人到何处不相逢！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿上。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "迎接家爷。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "马匹带过。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿拉马下。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "请坐。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "请问老丈尊姓大名？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "老汉东皋公。曾拜扁鹊先生门下为徒。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哦，原来是前辈的老先生，失敬了。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "岂敢。将军为何这等模样？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唉，老丈啊！"
        },
        {
          "character": "伍员",
          "type": "西皮快原板",
          "text": "恨平无无道乱楚宫， 父纳子妻理难容！ 我的父谏奏反把命送， 满门家眷血染红。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "原来如此。啊，将军，老汉这里有一后花园，请将军暂住几日，待我想条妙计， 救你出关就是。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "若得如此，感恩非浅。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "将军请。正是："
        },
        {
          "character": "东皋公",
          "type": "念",
          "text": "忠臣孝子当维护，"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "愧煞男儿不丈夫！"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "将军是大丈夫！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "惭愧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东皋公、伍员同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "西皮流水板",
          "text": "过了一天又一天， 心中好似滚油煎。 腰间枉挂三尺剑， 不能报却父母冤！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "幸遇东皋公，将我隐藏后花园中，一连几日，并无动静。今日又是一天，好不 愁闷人也。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起初更鼓〗。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "唉，爹娘啊！"
        },
        {
          "character": "伍员",
          "type": "二黄慢板",
          "text": "一轮明月照窗前， 愁人心中似箭穿。 实指望到吴国借兵回转， 又谁知昭关又有阻拦。 幸遇那东皋公行方便， 他将我隐藏在后花园。 一连几天我的眉不展， 夜夜何曾得安眠。 俺伍员好一比丧家犬， 满腹含冤我向谁言； 我好比哀哀长空雁， 我好比龙游在浅沙滩； 我好比鱼儿吞了钩线， 我好比波浪中失舵的舟船。 思来想去我的肝肠断， 今夜晚怎能够盼到明天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起二更鼓〗。东皋公上。"
        },
        {
          "character": "东皋公",
          "type": "二黄原板",
          "text": "夤夜漏声催晓箭， 月移花影上栏杆。 熄灭了灯亮窗前站， 且听愁人口内言。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起三更鼓〗。"
        },
        {
          "character": "伍员",
          "type": "二黄原板",
          "text": "心中有事难合眼， 翻来覆去睡不安。 背地里只把东皋公怨， 叫人难解巧机关。 若是真心来救我， 为何几日他不言？ 贪图富贵来害我， 你就该拿我献与昭关。 哭一声爹娘不能相见，不能见！ 爹娘呀！ 要相逢除非是梦里团圆。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "〖起四更鼓〗。"
        },
        {
          "character": "东皋公",
          "type": "二黄原板",
          "text": "听他言来心好惨， 铁石人儿也泪涟。 背地里只把老汉怨， 想条妙计救他出关。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东皋公下。〖起五更鼓〗。"
        },
        {
          "character": "伍员",
          "type": "二黄原板",
          "text": "鸡鸣犬吠五更天， 越思越想越伤惨。 想当初在朝为官宦， 朝臣待漏五更寒。 到如今夜宿在荒村院， 我冷冷清清向谁言！ 我本当拔宝剑自寻短见，寻短见！ 爹娘啊！ 父母冤仇化尘烟。 对天发下宏誓愿， 我不杀平王我的心怎甘。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东皋公上。"
        },
        {
          "character": "东皋公",
          "type": "二黄摇板",
          "text": "鸡鸣五鼓星斗散， 将军开门有话言。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "开门来。"
        },
        {
          "character": "伍员",
          "type": "二黄导板",
          "text": "适才朦胧将合眼！"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "开门来。"
        },
        {
          "character": "伍员",
          "type": "二黄散板",
          "text": "忽听门外有人言。 用手开门来观看，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员开门。"
        },
        {
          "character": "东皋公",
          "type": "二黄散板",
          "text": "将军为何白了髯？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "啊，将军，一夜之间为何须发皓然了？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "我却不信。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "你自己看来。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "伍员",
          "type": "二黄散板",
          "text": "冤仇未报容颜变， 一事无成两鬓斑。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "恭喜将军，贺喜将军！"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "喜从何来？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "将军可以过得昭关了。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "怎见得？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "我有一好友，名唤皇甫讷。待我请他前来，想条妙计救你出关就是。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "但凭老丈。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿暗上。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "来。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "有。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "拿我名帖，请皇甫官人，过庄一叙。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老丈请上，受我一拜。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "也有一拜！"
        },
        {
          "character": "伍员",
          "type": "二黄摇板",
          "text": "但愿过的昭关险， 满斗焚香谢苍天。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东皋公、伍员同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "童儿、皇甫讷同上。"
        },
        {
          "character": "皇甫讷",
          "type": "二黄摇板",
          "text": "皋公请我来相见， 见了他人问根源。"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "前去通禀。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "有请家爷。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "东皋公上。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "何事？"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "皇甫官人到了。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "说我出迎。"
        },
        {
          "character": "童儿",
          "type": "白",
          "text": "家爷出迎。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "皇甫官人在哪里？"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "皋公兄。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "啊，皇甫官人。请到里面。请坐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "童儿暗下。"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "有坐。仁兄相约为了何事？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "伍将军到了，请来一会。"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "哪个伍将军？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "临潼斗宝伍子胥伍将军。"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "此人今在何处？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "现在后面。"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "请来相见。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "候着。"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "有请伍将军。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "伍员上。"
        },
        {
          "character": "伍员",
          "type": "念",
          "text": "父母冤仇恨，常挂一片心。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "老丈何事？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "皇甫官人到了，请来相见。"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "哦，待我向前。 皇甫兄在哪里？"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "伍将军在哪里？"
        },
        {
          "character": "伍员",
          "type": "白",
          "text": "皇甫兄在哪里？"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "啊，将军，这就是皇甫官人。"
        },
        {
          "character": "皇甫讷",
          "type": "白",
          "text": "岂敢。"
        },
        {
          "character": "东皋公",
          "type": "白",
          "text": "皇甫官人，这就是伍将军。"
        },
        {
          "character": "伍员",
