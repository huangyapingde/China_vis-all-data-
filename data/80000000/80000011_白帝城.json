{
  "script_id": "80000011",
  "title": "白帝城",
  "alias": [
    "永安宫"
  ],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "刘备",
      "hangdang": "老生"
    },
    {
      "name": "太监",
      "hangdang": "丑"
    },
    {
      "name": "诸葛亮",
      "hangdang": "老生"
    },
    {
      "name": "刘永",
      "hangdang": "小生"
    },
    {
      "name": "刘理",
      "hangdang": "小生"
    },
    {
      "name": "赵云",
      "hangdang": "老生"
    },
    {
      "name": "马谡",
      "hangdang": "净"
    }
  ],
  "plot": "刘备伐吴，中陆逊火攻之计，兵败白帝城，一病不起。乃派人调诸葛亮前来，托孤于诸葛亮，便死。",
  "notes": "此剧可与《小桃园》、《伐东吴》、《战猇亭》、《连营寨》、《八阵图》连演，总称《吞吴恨》。",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "刘备",
          "type": "内白",
          "text": "搀扶！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "太监扶刘备同上。"
        },
        {
          "character": "刘备",
          "type": "二黄慢板",
          "text": "恨不得把吴狗顷国灭尽， 报弟仇杀孙权方称我的心。 陆逊儿用诡计令人可恨， 多亏了那赵子龙救驾逃生。 烧得孤连营寨七百里整， 烧得孤人和马七十余万片甲无存。 烧得孤在火焰下四处奔命， 烧得孤兵败在白帝城。 为此事不由孤我的珠泪滚滚， 只觉得心神不定我坐卧不宁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，实指望与二弟、三弟报仇，杀得东吴堪堪大败，不想中了陆逊小儿用火之 计，烧孤连营七百余里。因此兵败白帝城，身染重病。这几日，常见二弟、三 弟，在孤面前，不离左右。大料孤不久于人世了！"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "梦魂间一阵阵心神不稳， 见二弟和三弟不离我的身。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，二弟来了！啊，二弟！啊，二弟你来啊……"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启禀主公：我那二千岁不在人世了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "怎么，你那二千岁，他、他、他不在人世了？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "不在人世了！"
        },
        {
          "character": "刘备",
          "type": "哭",
          "text": "二弟呀……"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "你本是大英雄盖世无对，"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，三弟来了！啊，三弟！你来呀……"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "启主公：我那三千岁也不在人世了！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，你那三千岁也不在人世了？"
        },
        {
          "character": "太监",
          "type": "白",
          "text": "不在人世了！"
        },
        {
          "character": "刘备",
          "type": "哭",
          "text": "唉，二弟呀……"
        },
        {
          "character": "刘备",
          "type": "二黄原板",
          "text": "兄弟们要相逢万也不能。 内侍臣勿喧声各归肃静， 扶孤王龙床上我养一养精神。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备睡。诸葛亮、刘永、刘理、马谡同上。"
        },
        {
          "character": "诸葛亮",
          "type": "二黄散板",
          "text": "带领殿下宫院进， 问声主公可安宁？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公醒来！"
        },
        {
          "character": "刘备",
          "type": "二黄散板",
          "text": "耳边厢又听得人声一阵，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "刘备",
          "type": "二黄散板",
          "text": "见先生在一边珠泪淋淋。"
        },
        {
          "character": "刘永、刘理",
          "type": "同哭",
          "text": "父皇……"
        },
        {
          "character": "刘备",
          "type": "二黄散板",
          "text": "二皇儿含悲泪一旁站定， 孤又惭孤又悔孤又伤心。"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公，近日病体如何？"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "唉，悔不听先生之言，有此大败，损兵折将，乃孤王之罪矣！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "军家胜败，古之常理，主公保重要紧！"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "是啊，主公保重要紧！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "哦，参谋言得极是，宫外伺候。"
        },
        {
          "character": "马谡",
          "type": "白",
          "text": "遵旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马谡下。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "啊，先生，"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "主公。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "你看马谡，人才如何？"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "幼常虽然年幼，颇有才能，乃国家栋梁。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "不然哪，不然！孤看马谡，言过其实，终无大用；若为重任，他必有所失。先 生，你要牢牢紧记！"
        },
        {
          "character": "诸葛亮",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "二皇儿，"
        },
        {
          "character": "刘永、刘理",
          "type": "同白",
          "text": "父皇。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "朕亡后，军国大事，全仗先生。汝弟兄，侍先生要侍之若父。向前去，拜过你 相父！"
        },
        {
          "character": "刘永、刘理",
          "type": "同白",
          "text": "儿遵命。"
        },
        {
          "character": "刘永、刘理",
          "type": "同二黄散板",
          "text": "走上前来忙跪定，"
        },
        {
          "character": "诸葛亮",
          "type": "二黄散板",
          "text": "搀起刘氏后代根。"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟在哪里？四弟……"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵云上。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "四弟……"
        },
        {
          "character": "刘备",
          "type": "二黄散板",
          "text": "一把手拉住了子龙手， 我和你患难相从共死生。 长坂坡曾救过阿斗小命， 我死后全仗你照应他们。"
        },
        {
          "character": "赵云",
          "type": "白",
          "text": "主公！"
        },
        {
          "character": "赵云",
          "type": "二黄散板",
          "text": "主公但把心放定， 保孤之事我担承！"
        },
        {
          "character": "刘备",
          "type": "二黄散板",
          "text": "霎时间腹内痛心血上涌"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备吐。"
        },
        {
          "character": "诸葛亮、赵云、刘永、刘理",
          "type": "同白",
          "text": "保重了！"
        },
        {
          "character": "刘备",
          "type": "二黄散板",
          "text": "两弟仇东吴恨化了灰尘！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "刘备死，诸葛亮、赵云、刘永、刘理同哭。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}