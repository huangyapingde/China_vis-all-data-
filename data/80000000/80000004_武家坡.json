{
  "script_id": "80000004",
  "title": "武家坡",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "薛平贵",
      "hangdang": "老生"
    },
    {
      "name": "王宝钏",
      "hangdang": "旦"
    }
  ],
  "plot": "薛平贵归家，遇王宝钏于武家坡前，夫妻相别十八年，王宝钏已不识薛平贵。薛平贵假问路以试其心，王宝\n钏逃回窑，薛平贵赶至，直告己名及别后经历，夫妻相认。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "薛平贵",
          "type": "内西皮导板",
          "text": "一马离了西凉界，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "薛平贵上。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "不由人一阵阵泪洒胸怀。 青是山绿是水花花世界， 薛平贵好一似孤雁归来。 那王允在朝中身为太宰， 哪把我贫穷人放在心怀。 恨魏虎是内亲将我来害， 苦苦的要害我所为何来？ 柳林下栓战马"
        },
        {
          "character": "薛平贵",
          "type": "西皮摇板",
          "text": "武家坡外， 见了这众大嫂借问开怀。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂请了！"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "请了。军爷失迷路途？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我乃是找名问姓的。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "哪一家呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "王丞相之女，薛平贵之妻，王宝钏。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "回转寒窑去了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "烦劳大嫂转达一声：就说他丈夫带来万金家书，叫她前来接取。"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "军爷稍待。 王三姐！"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "做什么？"
        },
        {
          "character": "大嫂",
          "type": "内白",
          "text": "你家丈夫带来万金家书，坡前接取。"
        },
        {
          "character": "王宝钏",
          "type": "内白",
          "text": "有劳了！"
        },
        {
          "character": "王宝钏",
          "type": "内西皮导板",
          "text": "邻居大嫂一声唤，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王宝钏上。"
        },
        {
          "character": "王宝钏",
          "type": "西皮慢板",
          "text": "武家坡来了王氏宝钏。 站立在坡前用目看， 那军爷貌好似我的夫郎。 假意儿在此剜苦菜， 他那里问一声我回答一言。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "这大嫂传话太迟慢， 武家坡"
        },
        {
          "character": "薛平贵",
          "type": "西皮流水板",
          "text": "站得我不耐烦。 站立坡前用目看， 见一位大嫂把菜剜。 前影儿看也看不见， 后影儿好象妻宝钏。 本当向前将妻唤， 错认了民妻"
        },
        {
          "character": "薛平贵",
          "type": "西皮散板",
          "text": "理不端。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂请了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "还礼。军爷敢是失迷路途的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "亦非失迷路途，乃找名问姓的。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有名便知，无名不晓。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "王丞相之女，薛平贵之妻，王宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "王宝钏？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷与她有亲？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "无亲。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有故？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "非故。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你问她做甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我与她丈夫同军吃粮，托我带来家书，故而动问。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军爷请稍站。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哎呀，且住！想我夫妻，分别一十八载，今日才得书信回来。本当向前接取， 怎奈衣衫褴褛。若不向前，书信又不能到手！这？这便怎么处？我自有道理！ 啊，军爷！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呃。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "要见王宝钏，与你打个哑谜，你可晓得？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "略知一二。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "远？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "远在天边，不能相见。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "近？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哦！莫非就是薛大嫂？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不敢，平贵之寒妻。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀呀！来，来，来！重见一礼。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "方才见过礼了。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "有道是：礼多人不怪呀！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "好个“礼多人不怪”。军爷拿书信来。"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "请稍待。 哎呀且住！想我离家一十八载，也不知她的贞洁如何？我不免调戏她一番，她 若守节，上前相认。她若失节，将她杀死，去见代战公主！"
        },
        {
          "character": "薛平贵",
          "type": "西皮流水板",
          "text": "洞宾曾把牡丹戏， 庄子先生三戏妻。 秋胡曾戏过罗氏女， 平贵要戏自己的妻。 弓叉袋内把书取，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "书信呢？"
        },
        {
          "character": "薛平贵",
          "type": "西皮流水板",
          "text": "我把大嫂的书信失。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "书信放在哪里？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "弓叉袋内。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "敢莫是不要紧的所在？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "要紧的所在。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "为何失落了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "想是中途打雁失落。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "打雁做甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "打雁充饥呀。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "想是那雁儿，吃了你的心肝不成么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂，一封书信，能值几何？何得开口骂人呀？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "有道是：为人谋而不忠乎，与朋友交而不信乎。失落人家书信，岂不令人痛乎 呀？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀呀！真不愧大家之女，开口就是文呐！大嫂不必痛哭，书信上面的言语， 我还记得几句。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "哦，是了！想是我丈夫带来安家银子，被你尽心花费。书信拿不出来，可是么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不是的！我那薛大哥，在那里修书，我在一旁打点行李，偷看几句，故而记得！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "如此说来，你是有心失落的了！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呵，我若有心，也不失落你的书信呐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "站远些！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呵呵呵！"
        },
        {
          "character": "薛平贵",
          "type": "西皮导板",
          "text": "八月十五月正明，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了，军营之中，连个灯亮都无有么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "全凭皓月当空。"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "薛大哥在月下修书文。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "我问他好来？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "他倒好，"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "再问他安宁？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "倒也安宁。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "三餐茶饭？"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "有小军造。"
        },
        {
          "character": "王宝钏",
          "type": "西皮原板",
          "text": "衣衫破了，"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "自有人缝。 薛大哥这几年运不通， 他在那征西路上受了苦刑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "受了苦情？敢莫是挨了打了？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不错，正是挨了打了！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "打了多少？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "四十军棍。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "喂呀，我那苦命的夫啊！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "大嫂不必痛哭，这苦么，还在后头呢！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "放老成些！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呵呵呵！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "在营中失落了一骑马，"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "是官马，还是私马？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "自然是官马。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "既是官马，岂不要赔？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哪怕他不赔！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "他哪有许多银钱赔马呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "自然有啊！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "因赔马借了我十两银。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "军营之中吃几份钱粮？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "一份。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我那丈夫呢？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "也是一份。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你二人俱是一样，你哪有银钱借与他用？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我那薛大哥，乃是风流的男子，银钱尽心花费。为军的乃是贫寒出身，故而积 攒得下，借与他用。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "不对了！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "我那薛郎，他也是个贫寒出身，从来不晓得花费银钱的！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "哎呀，薛大哥啊，我今日才知你也是贫寒出身呐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "倒被他取笑了！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "本利算来二十两， 不曾还我半毫分。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你就该问他要！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "他无有也是枉然。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "打骂也该问他要！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "岂不伤了朋友的和气？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "你腰中带的何物？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "防身宝剑。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "着啊！杀了他也该问他要！"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "杀人岂不要偿命呐！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "难道说，你这银子就不要了么？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "呃，有道是善财难舍呀！"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "放老成些！"
        },
        {
          "character": "薛平贵",
          "type": "西皮原板",
          "text": "二次里过营去讨要， 他言道：长安城有一个王氏宝钏。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "住了！王宝钏该你的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "不该。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "欠你的？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "也不欠。"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "提她做甚？"
        },
        {
          "character": "薛平贵",
          "type": "白",
          "text": "我且问你，这父债？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "子还。"
        },
        {
          "character": "薛宝钏",
          "type": "白",
          "text": "夫债呢？"
        },
        {
          "character": "王宝钏",
          "type": "白",
          "text": "妻……"
