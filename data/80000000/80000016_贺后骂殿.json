  "plot": "宋太祖赵匡胤，自陈桥兵变，黄袍加身，俨然为开国皇帝。母后独孤氏，屡见历代幼主受祸，创兄终弟及之\n说，为宋朝家法。太祖不敢违母后之命，亦慨然允许。太祖度量深沉，弟与子毫无歧视，而赵光义（庙号太\n宗）已万分焦虑，有迫不及待之势。烛影摇红，难逃后人史笔，只以官讳边密，当时不敢传播耳。噫！独孤\n氏一言，起萧墙之祸，手足间凶终隙末。竟至于如此，此剧系太祖宴驾之后，赵光义袭位，朝廷大臣，因独\n孤后曾经颁发懿旨，俱无异言，惟太祖之后贺氏，寻思再三，以为孤儿寡妇，若被人欺朦，不免难以存活，\n乘众公卿朝贺之时，率领二子上殿。质问其如何安置。大者一时言语卤莽，恐遭不测之祸，撞死阶前。贺后\n有此机会，啼哭叫骂。竟欲以身殉之。赵光义不愿受逼嫂杀侄之恶名，亲自抚慰，复命众公卿竭力解劝。将\n小者封以王爵，赐宝剑金锏，得以便宜行事，压服群僚。贺后心虽不甘，而面子上只好欣然谢恩，退归府第\n云。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "曹彬、赵普、潘洪、苗宗善同上。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "type": "同白",
          "text": "嗯哼！"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "type": "同点绛唇",
          "text": "静鞭声敲，禁门待诏，立金阙，新主临朝，山河齐戴孝。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "type": "同白",
          "text": "下官，"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "潘洪。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "赵普。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "曹彬。"
        },
        {
          "character": "苗宗善",
          "type": "白",
          "text": "苗宗善。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "列位大人请了。"
        },
        {
          "character": "曹彬、赵普、苗宗善",
          "type": "白",
          "text": "请了。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "今当新主登基，一同上殿朝贺。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "type": "白",
          "text": "看：香烟缭绕，圣驾临朝，分班伺候。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "曹彬、赵普、潘洪、苗宗善同下。〖二黄小开门〗。潘疆、潘豹引赵光义同上。"
        },
        {
          "character": "赵光义",
          "type": "引子",
          "text": "兄亡侄幼，众文武，扶孤登基。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义归坐，曹彬、赵普、潘洪、苗宗善同上。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "type": "同白",
          "text": "臣等见驾，吾皇万岁！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "众卿平身。"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "type": "同白",
          "text": "万万岁！"
        },
        {
          "character": "赵光义",
          "type": "念",
          "text": "兄王晏驾龙归西，全凭争先一着棋。满朝文武来辅助，孤王才得立帝基。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "孤，赵光义。今日登基受贺。众卿，"
        },
        {
          "character": "曹彬、赵普、潘洪、苗宗善",
          "type": "同白",
          "text": "臣。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "孤王登基，不知当降什么国号？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣启万岁：弟继兄位，当用大宋国号。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "依卿所奏。待孤传旨，晓谕天下。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "遵旨！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "潘卿听封！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封你左班丞相。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "赵普听封！"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封你右班丞相。"
        },
        {
          "character": "赵普",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "曹彬听封！"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封你孝义侯之位，代管禁军。"
        },
        {
          "character": "曹彬",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "苗宗善听封！"
        },
        {
          "character": "苗宗善",
          "type": "白",
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封你护国军师，子袭父职。"
        },
        {
          "character": "苗宗善",
          "type": "白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "潘疆、潘豹听封。"
        },
        {
          "character": "潘疆、潘豹",
          "type": "同白",
          "text": "臣！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "封你二人以为镇殿将军。"
        },
        {
          "character": "潘疆、潘豹",
          "type": "同白",
          "text": "谢主龙恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "满朝文武加升三级。大赦天下。有本早奏，无本退班。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣启万岁：今当我主登基，杨继业不来参驾，定有藐视我主之意。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "待孤传旨，宣杨继业上殿。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "领旨。 万岁有旨：杨继业上殿。"
        },
        {
          "character": "杨继业",
          "type": "内白",
          "text": "领旨。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "忽听万岁宣……"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "龙帘卷起。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "呜呼呀！我道幼主登基，原来二主篡位。唉！"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "上殿把驾参。 臣，杨继业见驾，吾皇万岁！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "大胆杨继业，孤王登基，为何不来朝贺？"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "臣参驾来迟，死罪啊，死罪！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "哪里是参驾来迟，分明是藐视寡人。 殿前武士！"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "推出斩了。"
        },
        {
          "character": "四武士",
          "type": "同白",
          "text": "哦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四武士绑杨继业同下。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "刀下留人！"
        },
        {
          "character": "四武士",
          "type": "内同白",
          "text": "啊！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣启万岁：斩了杨继业，倘若他那几个虎子，反进京来，难以抵挡。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "啊？怎么参本是你，保本也是你呀？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "臣乃是为主江山。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "就依卿所奏，将杨继业赦回。"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "将杨继业赦回。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨继业上。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "午门得活命，死而又复生。"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "不是我保本，焉有你命存？"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "我今愿一死，何劳你讲情？"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "好心来救你，反倒不知情。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "忠臣不怕死，怕死岂为忠？"
        },
        {
          "character": "潘洪",
          "type": "念",
          "text": "你既不怕死，随我去面君。"
        },
        {
          "character": "杨继业",
          "type": "念",
          "text": "面君便面君，怕你不成？"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "走！"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "走！"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "请呐。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "杨继业多谢万岁不斩之恩。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "非是孤王不斩于你，念你在朝有十大汗马功劳，今将你削职为民，赐你百亩田 园，下殿去吧。"
        },
        {
          "character": "杨继业",
          "type": "白",
          "text": "谢万岁。"
        },
        {
          "character": "杨继业",
          "type": "二黄散板",
          "text": "先王爷待臣恩义广， 汗马功劳付汪洋。 含悲忍泪下殿往， 万里江山不久长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德昭上。"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "父王不幸归泉壤， 我朝出了篡位王。 请出母后把话讲，"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "有请母后！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后上。"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "快与孩儿作主张。"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "老王不幸把命丧， 二主篡位谋家邦。 大皇儿忙把金殿上， 要回社稷自立为王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "贺后下。"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "遵命。"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "迈步且把金殿上，"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "叔父啊！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "快快还我锦家邦。"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "大皇儿上殿高声嚷， 口口声声要家邦， 本当下位把国让，"
        },
        {
          "character": "潘洪",
          "type": "白",
          "text": "且慢！臣启万岁：太子年幼，社稷为重。"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "难学尧舜和商汤。 回头便对皇侄讲， 孤不封你自立为王。"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "住口！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "你今不把江山让， 篡位的名儿天下扬。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "大胆！"
        },
        {
          "character": "赵光义",
          "type": "二黄散板",
          "text": "奴才说话忒猖狂， 开口便把孤王伤。 吩咐潘豹与潘疆， 快将奴才绑法场。"
        },
        {
          "character": "赵德昭",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵德昭",
          "type": "二黄散板",
          "text": "听一言来怒满腔， 奸王做事狠心肠。 满朝皆是贼奸党， 不如碰死见先王。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵德昭碰死。贺后、赵德芳同上。"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "喂呀！"
        },
        {
          "character": "贺后",
          "type": "二黄散板",
          "text": "一见皇儿把命丧， 怎不叫娘我痛断肠。 将尸首搭至在白虎堂上， 随娘到金殿去骂昏王。"
        },
        {
          "character": "贺后",
          "type": "叫头",
          "text": "昏王！篡位王！无道的昏王啊！"
        },
        {
          "character": "贺后",
          "type": "二黄导板",
          "text": "有贺后在金殿一声高骂，"
        },
        {
          "character": "贺后",
          "type": "叫头",
          "text": "昏王！篡位王！喂呀！"
        },
        {
          "character": "贺后",
          "type": "回龙",
          "text": "骂一声无道君细听根芽："
        },
        {
          "character": "贺后",
          "type": "二黄慢板",
          "text": "老王爷为江山足踢拳打， 老王爷为山河奔走天涯。"
        },
        {
          "character": "贺后",
          "type": "二黄快三眼",
          "text": "遭不幸老王爷晏了御驾， 贼昏王篡了位谋乱邦家。 把一个皇太子逼死殿下， 反道说为嫂我拦阻有差。 贼好比王莽贼称孤道寡， 贼好比曹阿瞒奸雄不差； 贼好比秦赵高指鹿为马， 贼好比司马师搅乱中华。 只骂得贼昏王装聋作哑， 只骂得贼昏王扭转身躯、闭目合睛、羞羞惭惭一语不发； 只骂得贼昏王无言对答， 两旁的文武臣珠泪如麻。 搬一把金交椅娘且坐下， 你叔王不让位我再去骂他。"
        },
        {
          "character": "赵光义",
          "type": "二黄三眼",
          "text": "自盘古立帝邦天子为重， 老皇嫂骂孤王情理难容。 论国法就该把残生断送，"
        },
        {
          "character": "贺后",
          "type": "白",
          "text": "谁敢？"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "退班！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵光义下位，曹彬、赵普、潘洪、苗宗善同下。"
        },
        {
          "character": "赵光义",
          "type": "白",
          "text": "皇嫂！"
        },
        {
          "character": "赵光义",
