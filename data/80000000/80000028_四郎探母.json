    },
    {
      "name": "杨延昭",
      "hangdang": "老生"
    },
    {
      "name": "杨宗保",
      "hangdang": "小生"
    },
    {
      "name": "佘太君",
      "hangdang": "老旦"
    },
    {
      "name": "杨八姐",
      "hangdang": "旦"
    },
    {
      "name": "杨九妹",
      "hangdang": "旦"
    },
    {
      "name": "四夫人",
      "hangdang": "旦"
    },
    {
      "name": "大国舅",
