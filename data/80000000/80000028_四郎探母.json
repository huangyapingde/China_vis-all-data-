    },
    {
      "name": "二国舅",
      "hangdang": "丑"
    }
  ],
  "plot": "杨延辉被擒后，改姓名，与铁镜公主成婚。辽邦萧天佐摆天门阵，佘太君亲征。杨延辉思母，为铁镜公主看\n破，以实告之；铁镜公主计盗令箭，助其出关，私回宋营，母子兄弟相会。杨延辉复回辽邦，被萧后得知，\n欲斩，铁镜公主代为求免。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第十场：过场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "马夫、杨延辉自两边分上，遇，马夫带马，同下。"
        },
        {
          "character": null,
          "type": "text",
          "text": "【第十一场：擒杨】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四辽兵引大国舅、二国舅同上。"
        },
        {
          "character": "大国舅",
          "type": "念",
          "text": "摘去顶带，"
        },
        {
          "character": "二国舅",
          "type": "念",
          "text": "罚俸三载。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "木易混出关去，栅子口等他！"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "马夫引杨延辉同上，杨延辉下马。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "接嘴巴吧！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大国舅打杨延辉嘴巴，二国舅给杨延辉带手桎。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        },
        {
          "character": "二国舅",
          "type": "stage",
          "text": "【第十二场：回令】"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四辽女、四辽兵、四官引萧太后同上。"
        },
        {
          "character": "萧太后",
          "type": "念",
          "text": "散出鹰鹞去，捉拿燕子归。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧太后归大座，众人分侍左右。大国舅捧宝剑、令箭上，进门。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "哎！木易拿到！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "押上来！"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "押上来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二国舅押杨延辉同上。"
        },
        {
          "character": "杨延辉",
          "type": "西皮摇板",
          "text": "探母回来入陷阱，"
        },
        {
          "character": "杨延辉",
          "type": "西皮快板",
          "text": "吓得延辉胆战惊。 迈步且把银安进！"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "走！"
        },
        {
          "character": "杨延辉",
          "type": "西皮摇板",
          "text": "太后饶儿命残生。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延辉跪。"
        },
        {
          "character": "萧太后",
          "type": "西皮快板",
          "text": "一见木易怒气生， 不由本后动无名， 家住哪州并哪郡？ 一一从头你说分明。"
        },
        {
          "character": "杨延辉",
          "type": "西皮快板",
          "text": "家住山后磁州郡， 火塘寨上有家门。 我父令公官一品， 我母佘氏老太君。 若问孩儿的名和姓， 我本是杨……"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "说！快点说实话！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "太后！"
        },
        {
          "character": "杨延辉",
          "type": "西皮摇板",
          "text": "杨四郎就是儿的名！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "呸！"
        },
        {
          "character": "萧太后",
          "type": "西皮摇板",
          "text": "吩咐两旁刀斧手，"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "有！"
        },
        {
          "character": "萧太后",
          "type": "西皮摇板",
          "text": "推出银安问斩刑！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "斩！"
        },
        {
          "character": "杨延辉",
          "type": "西皮快板",
          "text": "早知今日犯将令， 探母不该转回程。 眼望后宫高声"
        },
        {
          "character": "杨延辉",
          "type": "哭头",
          "text": "唤，我的妻呀！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二国舅向大国舅手语示意，出门急下。"
        },
        {
          "character": "杨延辉",
          "type": "西皮摇板",
          "text": "夫妻们要相逢是万不能！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二国舅引铁镜公主同上。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "公主快走吧！晚了就瞧不见啦！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "适才国舅来报信， 倒叫咱家吃一惊。 只见驸马殿下捆， 快快醒来说分明。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "醒醒瞧瞧，谁来啦？"
        },
        {
          "character": "杨延辉",
          "type": "西皮导板",
          "text": "一霎时只觉得昏迷不醒，"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哎呀，公主！"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "哎！公主在那儿呢，我成了母猪了。"
        },
        {
          "character": "杨延辉",
          "type": "西皮流水板",
          "text": "一见公主面前存。 你若念在夫妻义， 忙上银安讲人情； 你若不念夫妻义， 斩了我杨延辉你再穿罗裙！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮流水板",
          "text": "驸马爷暂受一时捆， 咱家上殿讲人情。"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "迈步且把银安进， 问我一言答一声。"
        },
        {
          "character": "萧太后",
          "type": "西皮摇板",
          "text": "我儿不在后宫廷， 来到金殿为何情？"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "额娘！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "驸马犯了何条令， 因何捆绑就问斩刑？"
        },
        {
          "character": "萧太后",
          "type": "西皮摇板",
          "text": "你夫妻定计盗我的令， 佯装不知你问娘亲。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "母后！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "驸马犯罪理当斩， 看在儿面就饶他的身。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "定斩不赦！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮流水板",
          "text": "母后不把人情准， 倒叫咱家无计行。 出得殿来驸马请， 一同哀告，"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "铁镜公主",
          "type": "西皮散板",
          "text": "你我的老娘亲。"
        },
        {
          "character": "杨延辉",
          "type": "叫头",
          "text": "太后！"
        },
        {
          "character": "铁镜公主",
          "type": "叫头",
          "text": "额娘！"
        },
        {
          "character": "杨延辉、铁镜公主",
          "type": "同叫头",
          "text": "（太后）（额娘）！"
        },
        {
          "character": "杨延辉",
          "type": "哭头",
          "text": "吾哭、哭一声老太后！"
        },
        {
          "character": "铁镜公主",
          "type": "哭头",
          "text": "我叫、叫、叫、叫一声老娘亲！"
        },
        {
          "character": "杨延辉",
          "type": "反西皮散板",
          "text": "当初被擒就该斩，"
        },
        {
          "character": "铁镜公主",
          "type": "反西皮散板",
          "text": "不该与儿配为婚。"
        },
        {
          "character": "杨延辉",
          "type": "反西皮散板",
          "text": "斩了孩儿不打紧，"
        },
        {
          "character": "铁镜公主",
          "type": "反西皮散板",
          "text": "儿的终身靠何人？"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "老太后！"
        },
        {
          "character": "铁镜公主",
          "type": "唱",
          "text": "老娘亲！"
        },
        {
          "character": "杨延辉、铁镜公主",
          "type": "同唱",
          "text": "啊！"
        },
        {
          "character": "杨延辉",
          "type": "唱",
          "text": "我的丈母娘啊！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "斩！"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "伙计，别瞧着呀。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "怎么着？"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "太后要杀驸马，咱们得讲个人情啊。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "哦，这人情讲得下来吗？"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "哎，老太后最欢喜就是咱们这个长相。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "来吧来吧。 太后在上，我们哥儿俩给您磕头啦！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "你们俩人儿磕头干什么？"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "驸马犯罪理应问斩，念在我们小哥儿俩鞍前马后的，没有别的，将驸马爷给赦 了吧。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "哦，你们俩人是给驸马讲情吗？"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "不敢！太后开恩吧！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "等等儿，等等儿！"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "我得问问你们。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "是。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "驸马出关的时候，是你们谁把他放出去的？"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "那天他的值日，他放的！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "又是谁把他擒住的呢？"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "擒住？那是我擒的！"
        },
        {
          "character": "萧太后",
          "type": "笑",
          "text": "啊哈哈哈哈。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "乐了！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "得了吧！木易犯罪，皆是你二人的引诱。先杀木易，然后要你们俩人儿的脑袋！"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "又饶俩。"
        },
        {
          "character": "铁镜公主",
          "type": "西皮快板",
          "text": "母后再三不容情， 倒叫咱家怒气生。 当初被擒就该斩！"
        },
        {
          "character": "萧太后",
          "type": "西皮快板",
          "text": "不知他是那姓杨人。"
        },
        {
          "character": "铁镜公主",
          "type": "西皮快板",
          "text": "斩了驸马儿无靠，"
        },
        {
          "character": "萧太后",
          "type": "西皮快板",
          "text": "再与我儿你配为婚。"
        },
        {
          "character": "铁镜公主",
          "type": "西皮快板",
          "text": "好马不把双鞍配，"
        },
        {
          "character": "萧太后",
          "type": "西皮摇板",
          "text": "哪有个长生不老的人！"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "下喀吧！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "出得殿来心暗忖，"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "公主！您呐别打愣神儿啦。到了什么节骨眼啦，趁早想主意救驸马爷。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "哎哟，我说二位国舅呀！"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "公主。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "事到如今呐，我可是连一点儿主意，可也都没有了。二位国舅有何高见呐？"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "您瞧瞧见事则迷呀。我问问您呐，当初儿盗令的时候，打谁的身上所起呀？"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "当初儿盗令的时候？"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "哦，那是打阿哥身上起的。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "打阿哥身上起的？"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "是呀。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "咱们再打阿哥身上把他找补回来呀！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "怎么办呐？"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "啊？"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "不要紧，我来给您呐出个主意！"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "他有好主意。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "您把阿哥，往太后怀里这么一扔。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "您就撒泼打滚，拿起宝剑来，假装寻死，您还得念着点儿，“哟！这要把木易 杀了，你叫我怎么办？我们不活着啦……”老太后一欢喜外孙子，也许把驸马 爷给赦了。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "好主意。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "怎么着？把阿哥往太后身上一扔。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "我么？就撒泼打滚，要死的是吧？"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "是啊。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "那可使不得。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "怎么？"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "那要是吓着孩子可怎么好呢？我呀，可舍不得我的儿子。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "哟，您呐别死心眼呀，您呐要是舍不了小的可救不了老的！"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "是呀，您要有了老的，那后来有多少小的啊！"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "是呀！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "使得？"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "使得！豁出去了！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "阿哥摔与老娘亲！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "我可不活着了，我可死了吧！"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "哟！哎哟，公主，公主！别寻死了！ 赦了、赦了、赦了！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "赦啦？"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "赦了！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "那么着我就不死啦。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "根儿底没打算死！ 哎呀，赶紧着。解下来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二国舅欲解杨延辉。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "哎！少巴结差使啦。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "得，我们又巴结差使了。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "铁镜公主解下杨延辉。杨延辉下。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "哎，得了，一天云雾散，完喽！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "国舅。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "公主。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "我母后虽然把驸马爷给赦了。"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "是呀。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "但是她那儿抱着阿哥还有气呐！"
        },
        {
          "character": "大国舅、二国舅",
          "type": "同白",
          "text": "哟，可不是嘛！别害怕。不要紧啊。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "有办法吗？"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "娘儿俩没有多大怨恨，您呐过去，赔个礼，请个安。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "马马乎乎把阿哥结过来就完啦。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "对了，来吧来吧。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "我说，母后，额娘！您呐真生气了？方才本来是驸马的不是，得罪了您啦，孩 儿我们这儿给您呐赔礼啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧太后扭脸不理。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "哎哟，反丝吊面——不理。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "把脸调到那边去了。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "调到那边儿去啦？我告诉您，那边儿啊，不好。这边的风水好，您这儿再来一 蹲儿。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "哎，对了对了。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "阿娘，您是恼了孩儿我了吗？得了，您别生气啦……得罪了您啦，我们这儿可 又给您呐请安啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧太后扭脸不理。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "骆驼打哈嚏——扭过脖去了。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "哎，哎哟呵呵，这还是不行啊。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "这还是不行啊。"
        },
        {
          "character": "大国舅",
          "type": "白",
          "text": "哎，公主，这样儿吧，您给老人家赔礼，您也要笑着点儿，您别绷脸啊，您这 么一笑，逗得老太后这么一笑，他们众位一笑，就明儿见啦。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "别胡支使我。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "哎，来吧！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "额娘，您呐干嘛跟我们小孩子一般见识啊？女儿我再也不敢啦，您把阿哥赏给 孩儿我吧，我们这儿又给您呐赔礼啦！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "萧太后笑。"
        },
        {
          "character": "二国舅",
          "type": "白",
          "text": "哎！乐了！乐了！乐了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "铁镜公主接过喜神。杨延辉上。"
        },
        {
          "character": "杨延辉",
          "type": "西皮快板",
          "text": "千层浪里得活命， 不斩延辉准人情。 未谢太后先谢你！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "啊，公主，适才犯罪，多蒙公主讲情，我这里当面谢过了！"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "哪的话呀！"
        },
        {
          "character": "杨延辉",
          "type": "西皮摇板",
          "text": "我母道你是贤德的人！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "母后得罪咱赔礼。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "驸马，母后得罪你啦！没有说的！我这儿给你请安啦！赔礼啦！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "岂敢！"
        },
        {
          "character": "铁镜公主",
          "type": "西皮摇板",
          "text": "千万莫要记在心。"
        },
        {
          "character": "杨延辉",
          "type": "西皮摇板",
          "text": "双双银安进， 叩过不斩恩。"
        },
        {
          "character": "萧太后",
          "type": "白",
          "text": "给你一支将令，把守北天门，好好儿的当差吧，再要是私自出营，我要你的脑 袋！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "大国舅、二国舅、四辽女、四官、萧太后自两边分下。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "驸马！"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "你听见了没有？"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "我母后命你到北天门把守。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "呃。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "你此番前去要好好儿的当差吧。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "是是是。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "你可别过营去探母啦。"
        },
        {
          "character": "杨延辉",
          "type": "白",
          "text": "哦。"
        },
        {
          "character": "铁镜公主",
          "type": "白",
          "text": "你再要是过营去探母啊，想着准带回令啊！"
        },
        {
          "character": "杨延辉",
          "type": "笑",
          "text": "哦，哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "杨延辉、铁镜公主同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        },
        {
          "character": "杨延辉",
          "type": "stage",
          "text": "—————————— ⑴原录音有残缺，缺“未开言不由”。"
        }
      ]
    }
