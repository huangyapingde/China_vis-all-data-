      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、张飞自下场门同上，二旗牌、刘备同上。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊，大哥！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟！"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "大哥不必下马，请请。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "二旗牌、刘备同下。四龙套、赵云同上，见张飞。张飞转背不睬。赵云、四龙套同下。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "嘿！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "四军士、张飞同下。"
        }
      ]
    },
    {
      "scene_id": 7,
      "name": "第七场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "四军士、二旗牌、刘备、张飞、赵云同上，刘备、张飞、赵云同入座。〖吹打止〗。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "啊，大哥！"
        },
        {
          "character": "刘备",
          "type": "白",
          "text": "三弟。"
        },
        {
          "character": "张飞",
          "type": "白",
          "text": "一路搬兵，多有辛苦。"
        },
        {
