{
  "script_id": "80000010",
  "title": "梅龙镇",
  "alias": [
    "游龙戏凤；一名：下江南"
  ],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "正德帝",
      "hangdang": "老生"
    },
    {
      "name": "李凤姐",
      "hangdang": "旦"
    }
  ],
  "plot": "明武宗私游大同，过李龙酒店，见李龙之妹李凤姐美，乃加调戏。后实告以皇帝身份，封李凤姐为妃。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "正德帝上。"
        },
        {
          "character": "正德帝",
          "type": "引子",
          "text": "离金阙暗藏国宝，观风华访察民情。"
        },
        {
          "character": "正德帝",
          "type": "念",
          "text": "大明一统锦山河，龙车凤辇多快乐，孤王离了燕京地，闻得大同景致多。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "孤，大明天子正德在位。是孤离了太平城，来在这大同地面梅龙镇上，住在李 龙的店中，是他言道：要茶要酒将木马一响，有人送来。今晚夜宿梅龙镇上， 好不闷煞人也。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "有为王坐在梅龙镇， 想起朝中大事情。 将玉玺付于龙国太， 朝中大事有公卿， 孤忙将木马一声震， 唤出提壶送酒的人，啊，饮杯巡。"
        },
        {
          "character": "李凤姐",
          "type": "内白",
          "text": "来了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐上。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "自幼儿生长在梅龙镇， 兄妹二人度光阴。 我大哥临行对我论， 他言道前厅有一位军人。 将茶饭与他来奉敬，"
        },
        {
          "character": "正德帝",
          "type": "笑",
          "text": "哈哈！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啐，"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "急忙回转绣房门，啊，前去拈针。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝下。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "好花儿出在僻乡村， 并无贤臣奏寡人。 孤忙将木马二声震，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐上。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "来了提茶送酒人。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒保。酒保！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "酒保无有，倒有个酒大姐在此。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "啊？这个丫头自称酒大姐，本当叫她一声，怕她消受不起，也罢！以酒为名， 我就叫她一声。 酒大姐。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "方才那个梢长大汉，他是何人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他是我家哥哥。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪里去了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "巡更守夜去了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "他叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他叫李龙。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐你呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我哇？我是无有名字的。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎。人生天地之间，哪有没有名字的道理？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "名字倒有，说出来怕军爷你叫。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军我不叫就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此，我姓李呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我晓得你姓李，你叫什么名字？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我叫……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "李凤姐。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好一个李凤姐！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "拿名字来还我！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "话出如风怎样还你？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "方才说不叫，如今怎么又叫起来了？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我就叫这一次。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "下次不可。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "下次不叫就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "唤我何事？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我且问你，这梅龙镇上是这样的酒饭不成？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我们这里酒饭有三等。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪三等？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "上中下三等。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这上等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "来往官员所用。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "中等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "买卖客商。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "下等的呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "下等的吗……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为何不讲？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "怕军爷着恼。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的不恼就是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "就是你们吃粮当军之人所用。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "噢！吃粮当军之人有这样的苦处，寡人此番回朝发饷银十万犒赏他们。 酒大姐，把这上等的酒饭摆上一席，为军的一用。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷要用上等的酒吃吗？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你要？你可知晓？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你且讲来。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "坐船？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "船钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "住店？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "店钱。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "吃酒的呢？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "酒后！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "呀啐！连个酒钱都不会说，什么叫作酒后。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "听你之言，敢是要钱？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我倒不要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哪个要钱？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哥哥回来问我要钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你哥哥要钱就好讲话了，将帘卷起。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "是！"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "在身上取出银一锭， 交于大姐算酒钱。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "拿去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "放下。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "放在哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "放在桌儿之上。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为何放在桌儿之上？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有道是男女授受不亲呐！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "桌儿是滑的，银子是光的，滚在地下那还了得。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "滚在地下有我去捡。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你怕什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕伤了大姐你的腰哇。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "伤了我的腰与你有什么相干？放下！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "拿去。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷敢是舍不得？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我倒舍得，只怕大姐你舍不得呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哎呀，且住！看这军爷有些不老成，待我来哄他一哄。 军爷，你方才进店之时，可曾看见一幅古画吗？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不曾看见，在哪里呀？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在那里。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "在哪里？"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐拿银。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "在这里呀。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "被她见笑了。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "李凤姐取过一锭银， 问声军爷几个人？"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "为军的一人一骑马，"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "一人用不了许多银。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "银子多了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "送于大姐买花儿戴。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "多谢军爷，军爷请了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "请到哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "请到客堂。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "正要到你的卧房。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "唉！客堂哦！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "噢，客堂呵！哈哈！大姐这是哪个的卧房？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这是我哥哥的卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "肮脏的很呐。大姐，这又是哪个的卧房？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "这是我的卧房，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我正要到你卧房走走。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷，你可晓得男女有别呀？"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "龙行虎步客堂进，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐！这梅龙镇上好紧的门户哇！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "遇见你们这样的人，这门户不得不紧。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐你好紧呐，哈哈！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "啐！"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "回手带上两扇门，啊，掸一掸灰尘。 我这里将酒来摆定， 再把军爷请一声。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷，请出来吃酒哇！请出来吃酒！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "这梅龙镇上好高的房子呵！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "房子，房子，我打你娘的一盘子。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么打起来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你这个人进得店来，上也瞧瞧，下也看看，我们女儿家有什么好看的不成？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "大姐长得好看，为军的爱看。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "军爷爱看？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "爱看。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此你就看看。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "真大方呵，待我看来，好！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "再看看！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "好，我就再看看。好！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "再看看，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "不看了。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "为何不看？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "看够了哇！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我若不念你是我店中的客官，我定要骂你。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "怎么骂起来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不但骂你，我还要打你！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "为军的出世以来，并无人来打我，大姐要打你打上几下。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "如此我就打！打！打！啐。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "李凤姐下。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "好一个聪明李凤姐， 她与为军戏耍玩。 孤忙家木马连声响，"
        },
