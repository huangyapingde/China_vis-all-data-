          "character": "正德帝",
          "type": "白",
          "text": "慢来，哎呀，且住！丫头若是喊叫起来，惊动乡邻地保出诸当官，君臣见面成 何体统？有了，她若有福，封她一宫；她若无福，打马就走。 大姐你可认识我哇？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "早认识你了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "认识我是哪一个？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你是大户长的兄弟，三户长的哥哥，你是二混帐，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我乃当今正德天子。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "起来，起来！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "做什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你可认识我？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我认识你是个卖酒的丫头。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我乃当今正德皇帝……"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "他的娘哟！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "哎呀，岂不折煞你这丫头。自古龙行有宝！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "有宝献宝。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "无宝呢？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "献你的现世宝。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "凤姐观宝。"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "在头上摘下沾毡罩， 身上现出滚龙袍。 叫一声凤姐来看宝，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你可晓得男女授受不亲呐？哈哈！"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "哪有个庶民敢穿龙袍？啊，五爪的金龙！"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "怪不得昨夜得一梦， 五爪金龙卧房中。 我这里上前忙跪定， 望求万岁将我封。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "下跪何人？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "李凤姐，"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "跪在我的面前作甚？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "前来讨封。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "你骂我是你哥哥的大舅子，我是不能封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你封了我，哥哥岂不是你的大舅子了么！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "越发的不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "当真不封？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "当真不封。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "不封就不封。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "慢来！我若不封岂不羞煞你这丫头？凤姐听封！"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "孤三宫六院俱封尽， 封你闲游戏耍宫。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "叩罢了头来龙恩重，"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "用手搀起爱梓童。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "低声问万岁，因何无侍从？"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "孤王打马奔大同。"
        },
        {
          "character": "李凤姐",
          "type": "四平调",
          "text": "就在这店中寻一梦，"
        },
        {
          "character": "正德帝",
          "type": "四平调",
          "text": "一双金杯落封龙。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "万岁请！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "请到哪里？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "请到卧房。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕呀！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "你怕什么？"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "我怕你哥哥回来。"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "哥哥此时不回来，就不回来了。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "此时不回来，就不回来了？"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "如此，凤姐！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "万岁！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "梓童！"
        },
        {
          "character": "李凤姐",
          "type": "白",
          "text": "我主！"
        },
        {
          "character": "正德帝",
          "type": "白",
          "text": "随我来呀！哈哈哈哈！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "正德帝、李凤姐同下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}