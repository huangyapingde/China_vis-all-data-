{
  "script_id": "80000032",
  "title": "千里送京娘",
  "alias": [],
  "source": "录音、唱片本",
  "characters": [
    {
      "name": "赵匡胤",
      "hangdang": "红净"
    },
    {
      "name": "赵京娘",
      "hangdang": "旦"
    }
  ],
  "plot": "赵匡胤路经古寺，救出为山寇张广、周进所劫掳之少女赵京娘，结为兄妹，以避嫌疑。赵匡胤又亲身护送赵\n京娘回家。赵京娘之父欲以赵京娘许婚，赵匡胤拒之而行。赵京娘思赵匡胤自尽，魂送之。",
  "notes": "",
  "scenes": [
    {
      "scene_id": 1,
      "name": "第一场",
      "utterances": [
        {
          "character": "赵匡胤",
          "type": "内白",
          "text": "走！马来！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上，趟马。"
        },
        {
          "character": "赵匡胤",
          "type": "粉蝶儿",
          "text": "野旷天高，极目处，野旷天高。 叹中原，干戈纷扰。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "丹心一片淩云霄，可畏风霜义气豪。扫尽人间不平事，全仗蟠龙棍一条。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "俺，赵匡胤。只因在汴梁城内，抱打不平，杀死土豪，闯下大祸，只得逃往关 西一带，创立基业。"
        },
        {
          "character": "赵匡胤",
          "type": "粉蝶儿",
          "text": "大丈夫创基业，志气豪。 争得个，地动山摇。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤加鞭，走圆场。赵京娘内哭。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵匡胤",
          "type": "粉蝶儿",
          "text": "却只听，哭啼啼，悲惨惨，一阵阵送耳稍。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤望门。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "“清幽观”。 啊呀且住！这古庙之中，为何有女子啼哭之声？嗯，倒要看个明白。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下马，持棍进庙，四下张望，闻哭声，回身凝望。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "唔呼呀！这哭声，原来在这青石板下。"
        },
        {
          "character": "赵匡胤",
          "type": "粉蝶儿",
          "text": "蟠龙棍挑起那青石板，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤自下场门救赵京娘上。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哎呀！大王爷饶命！饶命！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊！"
        },
        {
          "character": "赵匡胤",
          "type": "粉蝶儿",
          "text": "这女子，战兢兢，呼大王，好生蹊跷。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "大王爷饶命，饶命。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "俺乃行路之人，哪里是什么大王爷？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "原来是好汉爷爷！好汉爷爷救命哪，救命！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这一女子，为何藏在青石板下，快快讲来。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "赵京娘",
          "type": "山坡羊",
          "text": "赵京娘，战兢兢，忙拭泪眼， 悲切切，哽哽难言。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "家住哪里？姓甚名谁？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "我名赵京娘，家住华荣县。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "因何至此？起来讲。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "是。"
        },
        {
          "character": "赵京娘",
          "type": "山坡羊",
          "text": "清明扫墓祖坟前， 蓦地里，强徒骤至劫我婵娟。 孤哀哀被捆在这野寺荒山， 京娘誓死不遂贼愿。 怕只怕，那二贼归，我就命难全。 望求好汉搭救我， 搭救我弱女脱难。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "好恼！清平世界，朗朗乾坤，抢夺人家女子，这还了得！哼！二贼现在哪里？ 待我除却此害。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤持棍欲去，赵京娘挽留。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "且慢！不知他们往哪里抢劫去了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "既然如此，你逃命去吧！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "多谢壮士。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘欲行又止。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "壮士呀！想华荣县离此路途遥远，我又不认路径，这旷野荒郊，倘若再遇强盗…… 哎呀，我命休也。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵匡胤",
          "type": "雁儿落",
          "text": "弱女遭难，苦情堪怜， 怎奈我玄郎也在急难间。 见义勇为，方显得英雄汉，"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "罢！"
        },
        {
          "character": "赵匡胤",
          "type": "雁儿落",
          "text": "哪管他自身危与安，且救人于倒悬。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，京娘，不必如此，待我送你回去。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "此话当真？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哪有假意。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "多谢壮士！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "不必谢了。你我出庙一同赶路。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、赵京娘同出。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哎呀，壮士，想你我男女同行，行至关津渡口，倘若有人盘问，岂不连累于你？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这个……说得倒也是。嗯，我自有道理。 啊，京娘，你我俱都姓赵，我有意与你结拜仁义兄妹，你意如何？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "身蒙救命之恩，岂有不愿之理？兄长请上，受小妹一拜。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "愚兄也有一拜。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、赵京娘同拜。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "待愚兄与你带马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤出门，带马。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹请来上马。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "路途遥远，怎能累兄长步行？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "愚兄体壮，量也无妨。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "如此，小妹不恭了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "快快上马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘上马。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哎呀兄长！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "扶上。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤扶赵京娘上马，圆场，同下。"
        }
      ]
    },
    {
      "scene_id": 2,
      "name": "第二场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "张广、周进引众喽兵同上。"
        },
        {
          "character": "张广",
          "type": "念",
          "text": "要除心头恨，"
        },
        {
          "character": "周进",
          "type": "念",
          "text": "钢刀杀仇人。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "贤弟。"
        },
        {
          "character": "周进",
          "type": "白",
          "text": "大哥。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "愚兄费尽心机抢来一个绝色的女子，不想又被红脸大汉抢去，真真气煞我也。"
        },
        {
          "character": "周进",
          "type": "白",
          "text": "大哥，咱们还是追呀。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "嗯，正合我意。 众喽兵！"
        },
        {
          "character": "众喽兵",
          "type": "同白",
          "text": "有。"
        },
        {
          "character": "张广",
          "type": "白",
          "text": "紧紧追赶！"
        },
        {
          "character": "众喽兵",
          "type": "同白",
          "text": "啊。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "众人同下。"
        }
      ]
    },
    {
      "scene_id": 3,
      "name": "第三场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘骑马上，赵匡胤上。"
        },
        {
          "character": "赵京娘",
          "type": "泣颜回",
          "text": "望断孤云泪涟涟，"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长快走。"
        },
        {
          "character": "赵京娘",
          "type": "泣颜回",
          "text": "我吁吁气喘， 挽丝缰，跨玉鞍。 看兄长虎步龙行， 我京娘有福得识英雄。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "内擂鼓。赵京娘惊望。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哎呀，兄长！听后面人声呐喊，想是那强盗，他、他、他又追来了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹不必惊慌。愚兄这条蟠龙棍，打遍天下，怕他何来！"
        },
        {
          "character": "赵匡胤",
          "type": "雁儿落",
          "text": "气腾腾直贯云霄，"
        },
        {
          "character": "张广、周进",
          "type": "内同白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘骑马下。张广、周进引喽兵人同上，小开打。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哪里走！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、张广、周进开打。张广、周进败下，赵匡胤追下。"
        }
      ]
    },
    {
      "scene_id": 4,
      "name": "第四场",
      "utterances": [
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘牵马上，张望。"
        },
        {
          "character": "赵京娘",
          "type": "楚江吟",
          "text": "遥望凝眸， 今日得识英雄喜悠悠。 他为我千里奔走， 他为我与群贼厮斗。 他真是磊落胸怀义搏千秋，"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "我京娘呵，"
        },
        {
          "character": "赵京娘",
          "type": "楚江吟",
          "text": "脉脉衷情系心头，却难出口。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤上。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹，"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长，那伙强盗怎么样了？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "被愚兄杀得打败而逃，贤妹受惊了。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "无妨，兄长你真乃盖世英雄。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹夸奖。啊，贤妹，此地不可久站，待愚兄与你带马。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "且慢，穿好衣服，也好赶路。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "多谢贤妹。"
        },
        {
          "character": "赵匡胤",
          "type": "梁州第七",
          "text": "且上骅骝， 何惧那龙潭虎口。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "赵玄郎，"
        },
        {
          "character": "赵匡胤",
          "type": "梁州第七",
          "text": "历尽艰险眉不皱， 侠肝义胆，志在解民忧。 看青山笑我， 壮志未酬。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘勒马凝望，若有所思。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长请看此处，景色秀丽，实堪玩赏。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "锦绣河山，果然壮丽。阿，正乃天色不早，你我赶路。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "天时尚早。啊，兄长，请看那万树丛中，独有一树高入云端。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "此乃是千年苍松。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "苍松之上，还开着点点紫花。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "嗳，苍松哪有开花之理？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "噢！苍松是不开花的？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "依小妹看来，那苍松虽好，只是有些美中不足。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哪些不足？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长！"
        },
        {
          "character": "赵京娘",
          "type": "滚绣球",
          "text": "莫道它蔚蔚入云霞， 却少些儿艳丽三春花。 妹羡那紫藤花挂满枝杈， 花树相伴，堪称潇洒，美满无涯，"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长，"
        },
        {
          "character": "赵京娘",
          "type": "滚绣球",
          "text": "再莫要种松种柏不种花。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，贤妹，你看，道路崎岖，待愚兄与你牵马。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤、赵京娘同走圆场。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "啊，兄长，请留步……"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，讲说什么？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "你来看。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "吕梁山，山山不断。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "这近呢？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "青石涧，涧水长流。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "那水面之上？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，片片落花。"
        },
        {
          "character": "赵京娘",
          "type": "念",
          "text": "落花有意随流水。"
        },
        {
          "character": "赵匡胤",
          "type": "念",
          "text": "流水无心恋落花。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "却是为何？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "只因他有奔投沧海之志。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哦！原来如此。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "你我赶路。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "是。 兄长，有座小桥。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "桥窄水急，贤妹，快快下马，待愚兄牵了过去。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "多谢兄长。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤牵马过场，赵京娘后随。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，贤妹，快快过桥来。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "是。 啊，兄长，这桥窄水急，小妹心中有些害怕。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "无妨，快快过桥来。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘过桥。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "啊，兄长！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤扶赵京娘。鸳鸯声。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长，那是什么鸟？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "一对鸳鸯。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "鸳鸯鸟，比翼双飞，朝夕相聚，永不分离，甚是可羡！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "是啊！鸳鸯比翼甚是可羡；怎奈它朝夕相聚，沉缅闲情，终难遂鸿鹄之志！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "噢！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹，快快下桥来！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "是。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下桥。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹。"
        },
        {
          "character": "赵京娘",
          "type": "赏花时",
          "text": "杨花点点满汀洲， 柳丝袅娜垂岸头。 春光洋溢春溪水， 春意阑珊更惹春愁。 水中鸳鸯并翅而游， 岸边兄妹并肩而走。 却为何有缘邂逅， 难谐凤鸾俦？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹！"
        },
        {
          "character": "赵匡胤",
          "type": "逍遥乐",
          "text": "杨花点点满汀洲， 柳丝袅娜垂岸头。 春光点缀山河旧， 春意阑珊更惹国愁。 云际鸿鹄，展翅翱游， 天下英豪，四海奔走。 大丈夫，满腔热血与世共忧！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹，恐怕天色有变，你我急急赶路！"
        },
        {
          "character": "赵匡胤",
          "type": "货郎儿五转",
          "text": "阴云起，晴光收，"
        },
        {
          "character": "赵京娘",
          "type": "货郎儿五转",
          "text": "看双双晚燕归南楼。"
        },
        {
          "character": "赵匡胤",
          "type": "货郎儿五转",
          "text": "忙加鞭，山雨骤，"
        },
        {
          "character": "赵京娘",
          "type": "货郎儿五转",
          "text": "对对鸳鸯，对对鸳鸯各自投。"
        },
        {
          "character": "赵匡胤",
          "type": "货郎儿五转",
          "text": "莫管它莺友燕友，"
        },
        {
          "character": "赵京娘",
          "type": "货郎儿五转",
          "text": "妹羡它情稠意稠。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "哎呀！"
        },
        {
          "character": "赵匡胤",
          "type": "货郎儿五转",
          "text": "要提防路滑山径陡。"
        },
        {
          "character": "赵京娘",
          "type": "货郎儿五转",
          "text": "形影相随千里送，"
        },
        {
          "character": "赵匡胤",
          "type": "货郎儿五转",
          "text": "娇莺鸿鹄紧相从。 此情此景添惶恐，"
        },
        {
          "character": "赵京娘",
          "type": "货郎儿五转",
          "text": "莫道它无情却有情。"
        },
        {
          "character": "赵匡胤",
          "type": "货郎儿五转",
          "text": "走一程，"
        },
        {
          "character": "赵京娘",
          "type": "货郎儿五转",
          "text": "又一程， 雨洗山光一片青。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "呀！"
        },
        {
          "character": "赵京娘",
          "type": "货郎儿五转",
          "text": "家乡将近意未尽， 无限离愁未了情。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘下马。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹为何不走？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "前面村庄就是小妹家乡了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "哦！怎么，前面就是贤妹家乡了？"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "赶快回去，免得双亲挂念。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "请兄长至家中面见爹娘。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "愚兄还有要事在身。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "我与兄长既为仁义兄妹，怎好不至家中一见爹娘？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "这个……我实对你说了吧！只因在汴梁城内，抱打不平，闯下大祸，俺今进得 庄去，恐怕连累你家爹娘，有些不便。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "嗳，这有何妨？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "愚兄决然不去了。你我就此分别了吧！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "怎么，你我就此分别了么？"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "正是。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "唉，也罢，兄长千里相送，恩情未尽。小妹送你一程。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "有道是：送君千里，终须一别。不送也罢！"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "小妹一定要送！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "如此，有劳贤妹！"
        },
        {
          "character": "赵京娘",
          "type": "煞尾",
          "text": "只恨千里途程短， 也是别离太匆匆。 万里鹏程多珍重，"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长啊！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘饮泣跪拜。"
        },
        {
          "character": "赵京娘",
          "type": "煞尾",
          "text": "切莫忘，关西有人悬望中！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹请起。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵京娘起。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，贤妹，请回去吧！愚兄告辞了！ 请回去吧，愚兄告辞了。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "啊，贤妹，你我后会有期。"
        },
        {
          "character": "赵京娘",
          "type": "白",
          "text": "兄长！"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "后会有期。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤拉马，上马。"
        },
        {
          "character": "赵匡胤",
          "type": "白",
          "text": "贤妹，你要保重了！"
        },
        {
          "character": null,
          "type": "stage",
          "text": "赵匡胤下，赵京娘望，退下。"
        },
        {
          "character": null,
          "type": "stage",
          "text": "完"
        }
      ]
    }
  ]
}