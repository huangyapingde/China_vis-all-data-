        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "他跑了。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你怎么样呢？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我打算要从良。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "粮米挺贵的存什么粮？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我是从良过日子。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你打算跟谁呀？"
        },
        {
          "character": "周腊梅",
