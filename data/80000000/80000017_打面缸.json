        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "没有事咱们退堂。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷不要退堂，有打官司的。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "在哪儿呢？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "在那里跪着呐。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "原来是位堂客。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "是的。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "我说你是谁？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "老爷你连我都不认识吗？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷你连她都不认识了？"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "我不认识你认识？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "我也不认识。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "耍什么骨头，你是谁呀？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我就是行院中的周腊梅。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷她就是行院中的周腊梅，周腊梅就是她，腊八周就是她。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "得了，什么时侯喝腊八粥？你是行院中的周腊梅，不在行院中挨饥……"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "什么？"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "受饿，跪我这儿干什么来了？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我上你这儿冤来了。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "带多少钱上我这儿冤来了？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我是伸冤告状。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你告谁呀，你拿来呀？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "要什么？"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "拿状子来。"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我交给王先生了。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "王先生，把状子交给你了吗？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "什么状子啊？"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "挺长的四方的那个。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "长的方的那是状子，于你如何是无钞票。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你是财迷意则是。我说王先生你看看去。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷看看我再看。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "还是王先生你先看。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷看了我好办公事。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你实气死人，老爷我不认识字呵。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "什么，不认识字就出来做官。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "马马虎虎。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "这幸亏有我。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "若没你，我不绝后了嘛。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "什么绝了。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "没有你我不栽了跟斗了。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "哪里的事情，马马虎虎做了官，我看看老爷，这头一个字念什么？"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "得了，薰了我半天你也不认识。"
