        {
          "character": "王书吏",
          "type": "白",
          "text": "就是头一个绕笔不认识。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "不认识咱们撕去往下念。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "往下念我来看看，老爷哈……你把它都撕掉了罢。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "一个认识的也没有。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "好得得好，我们都不认识字，你上法院告去吧。"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "老爷我跟你打个哑谜吧。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "什么哑谜？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "山中的老虎吃豆腐。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷，山中老虎吃豆腐，你问问她是酱豆腐、臭豆腐、五香的豆腐干。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "得了，你卖臭豆腐哪儿的事情。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你说山中老虎吃豆腐，此话怎讲呢？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我们口述。"
        },
        {
          "character": "大老爷",
