          "text": "老爷我不要她。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "怎么？"
        },
        {
          "character": "张才",
          "type": "白",
          "text": "她们行院中的人好吃嘴懒做活。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "人家说你们了，你们行院中的人好吃嘴懒做活，见了那个往前拿来罢。喳喳喳。"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "我说老爷，好吃的我们也不吃了，好喝的我们也不喝了，好揍你那……"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "什么呀？"
        },
        {
          "character": "周腊梅",
          "type": "白",
          "text": "那个活我们也会做呀。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "也会做活，我说王先生。"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "老爷。"
        },
        {
          "character": "大老爷",
          "type": "白",
          "text": "你不开过裁缝铺吗？"
        },
        {
          "character": "王书吏",
          "type": "白",
          "text": "开过。"
        },
