        },
        {
          "character": null,
          "type": "stage",
          "text": "四衙役同上，王书吏上，大老爷上。"
        },
        {
          "character": "大老爷",
          "type": "唢呐腔",
          "text": "众衙役列两旁。 枷棍板拶当堂放，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "周腊梅上。"
        },
        {
          "character": "周腊梅",
          "type": "吹腔",
          "text": "手拿状子朝前走， 大老爷作主张。 小女不在烟花巷，"
        },
        {
          "character": null,
          "type": "stage",
          "text": "王书吏接状子。"
        },
        {
          "character": "王书吏",
          "type": "吹腔",
          "text": "王书吏看端详。"
